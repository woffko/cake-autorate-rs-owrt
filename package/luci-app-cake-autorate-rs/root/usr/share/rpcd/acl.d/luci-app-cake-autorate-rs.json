{
	"luci-app-cake-autorate-rs": {
		"description": "Grant access to CAKE Autorate RS LuCI app",
		"read": {
			"cgi-io": [ "exec" ],
			"file": {
				"/var/run/sqm/available_qdiscs": [ "list" ],
				"/usr/lib/sqm/*.qos.help": [ "read" ],
				"/var/run/cake-autorate/*/status.json": [ "read" ],
				"/etc/init.d/cake-autorate status": [ "exec" ],
				"/etc/init.d/sqm status": [ "exec" ],
				"/usr/libexec/cake-autorate-rs/log-bundle *": [ "exec" ]
			},
			"ubus": {
				"file": [ "read", "list" ],
				"luci": [ "getInitList" ]
			},
			"uci": [ "cake-autorate", "sqm" ]
		},
		"write": {
			"cgi-io": [ "exec" ],
			"file": {
				"/etc/init.d/cake-autorate enable": [ "exec" ],
				"/etc/init.d/cake-autorate disable": [ "exec" ],
				"/etc/init.d/cake-autorate start": [ "exec" ],
				"/etc/init.d/cake-autorate stop": [ "exec" ],
				"/etc/init.d/cake-autorate restart": [ "exec" ],
				"/etc/init.d/cake-autorate reload": [ "exec" ],
				"/etc/init.d/cake-autorate-mqtt enable": [ "exec" ],
				"/etc/init.d/cake-autorate-mqtt disable": [ "exec" ],
				"/etc/init.d/cake-autorate-mqtt start": [ "exec" ],
				"/etc/init.d/cake-autorate-mqtt stop": [ "exec" ],
				"/etc/init.d/cake-autorate-mqtt restart": [ "exec" ],
				"/etc/init.d/cake-autorate-mqtt reload": [ "exec" ],
				"/etc/init.d/sqm enable": [ "exec" ],
				"/etc/init.d/sqm start": [ "exec" ],
				"/etc/init.d/sqm restart": [ "exec" ],
				"/usr/libexec/cake-autorate-rs/speedtest *": [ "exec" ],
				"/usr/libexec/cake-autorate-rs/pinger-plan *": [ "exec" ],
				"/usr/libexec/cake-autorate-rs/log-bundle *": [ "exec" ],
				"/usr/libexec/cake-autorate-rs/mqtt-status *": [ "exec" ]
			},
			"ubus": {
				"luci": [ "setInitAction" ]
			},
			"uci": [ "cake-autorate", "sqm" ]
		}
	}
}
