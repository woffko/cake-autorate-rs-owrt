#!/bin/sh

section="$1"
target_if_override="$2"
mode="$3"
backend_override="$4"
job_key_override="$5"
route_mode_override="$6"
mwan3_member_override="$7"
direction_override="${8:-}"
runtime_lock_lib="${CAKE_AUTORATE_RUNTIME_LOCK_LIB:-/usr/libexec/cake-autorate-rs/runtime-lock}"
speedtest_self="${CAKE_AUTORATE_SPEEDTEST_SELF:-$0}"

# A job-start caller launches the worker stopped, records its exact PID and
# /proc start time while holding the per-job flock, then resumes it.  This
# closes the check/launch/pid-publication race between simultaneous LuCI RPCs.
if [ "${CAKE_AUTORATE_SPEEDTEST_JOB_START_STOPPED:-0}" = 1 ]; then
	kill -STOP "$$" 2>/dev/null || exit 1
	unset CAKE_AUTORATE_SPEEDTEST_JOB_START_STOPPED
fi

# Full Auto-Tune can request a launch handshake for a separately supervised
# process group.  Stop before backend discovery, route probing, SQM changes, or
# network traffic; the parent records PID/starttime in its RAM recovery journal
# and sends CONT only after that obligation is durable.
if [ "${CAKE_AUTORATE_SPEEDTEST_START_STOPPED:-0}" = 1 ]; then
	# The first process is deliberately still in the Auto-Tune owner's process
	# group. If the owner dies before journalling this PID, owner-group recovery
	# removes it. After CONT, exec(setsid) keeps the same PID/starttime while
	# making that pre-journalled PID the independently supervised PGID/SID.
	setsid_reexec="${CAKE_AUTORATE_SPEEDTEST_SETSID:-$(command -v setsid 2>/dev/null)}"
	[ -n "$setsid_reexec" ] || exit 1
	kill -STOP "$$" 2>/dev/null || exit 1
	unset CAKE_AUTORATE_SPEEDTEST_START_STOPPED
	exec "$setsid_reexec" "$0" "$@"
fi

if [ -r "$runtime_lock_lib" ]; then
	# shellcheck source=/usr/libexec/cake-autorate-rs/runtime-lock
	. "$runtime_lock_lib"
fi

case "$direction_override" in
	''|both|download|upload) ;;
	*) direction_override="" ;;
esac

if [ "$section" = "--status" ] || [ "$section" = "status" ]; then
	section=""
	target_if_override=""
	mode="status"
fi

if [ "$target_if_override" = "--status" ] || [ "$target_if_override" = "status" ]; then
	target_if_override=""
	mode="status"
fi

if [ "$mode" != "status" ] && [ "$mode" != "route-status" ] &&
   [ -n "$mode" ] && [ -z "$backend_override" ]; then
	backend_override="$mode"
	mode=""
fi

download_bytes_default="25000000"
upload_bytes_default="4000000"
upload_retry_bytes_default="1000000 262144"
timeout_default="45"
duration_default="15"
route_probe_default="1.1.1.1"
sqm_run_bin="${CAKE_AUTORATE_SQM_RUN:-/usr/lib/sqm/run.sh}"
sqm_recover_bin="${CAKE_AUTORATE_SQM_RECOVER:-/usr/libexec/cake-autorate-rs/sqm-recover}"
sqm_config_file="${CAKE_AUTORATE_SQM_CONFIG_FILE:-/etc/config/sqm}"

uci_get() {
	[ -n "$section" ] || return 0
	uci -q get "cake-autorate.$section.$1" 2>/dev/null
}

uci_raw_get() {
	uci -q get "$1" 2>/dev/null
}

json_escape() {
	printf '%s' "$1" | tr '\n\r\t' '   ' | sed 's/\\/\\\\/g; s/"/\\"/g'
}

json_error() {
	printf '{"error":"%s"}\n' "$(json_escape "$1")"
	exit 1
}

append_warning() {
	[ -n "$1" ] || return 0

	if [ -n "$warning" ]; then
		warning="$warning $1"
	else
		warning="$1"
	fi
}

now_s() {
	awk '{ print $1 }' /proc/uptime
}

elapsed_s() {
	awk -v start="$1" -v stop="$2" 'BEGIN { delta = stop - start; if (delta < 0.01) delta = 0.01; printf "%.2f", delta }'
}

kbps_for() {
	awk -v bytes="$1" -v elapsed="$2" 'BEGIN { printf "%.0f", bytes * 8 / elapsed / 1000 }'
}

bits_to_kbps() {
	awk -v value="$1" 'BEGIN { if (value + 0 > 0) printf "%.0f", value / 1000 }'
}

bytes_per_second_to_kbps() {
	awk -v value="$1" 'BEGIN { if (value + 0 > 0) printf "%.0f", value * 8 / 1000 }'
}

upload_exceeds_download_sanity_ratio() {
	awk -v download="$1" -v upload="$2" 'BEGIN { exit !(download > 0 && upload > download * 1.5) }'
}

mbps_to_kbps() {
	awk -v value="$1" 'BEGIN { if (value + 0 > 0) printf "%.0f", value * 1000 }'
}

is_uint() {
	case "$1" in
		''|*[!0-9]*)
			return 1
			;;
	esac

	[ "$1" -ge 0 ] 2>/dev/null
}

is_positive_uint() {
	is_uint "$1" && [ "$1" -gt 0 ] 2>/dev/null
}

num_or_default() {
	if is_uint "$1"; then
		printf '%s' "$1"
	else
		printf '%s' "$2"
	fi
}

positive_num_or_default() {
	if is_positive_uint "$1"; then
		printf '%s' "$1"
	else
		printf '%s' "$2"
	fi
}

bool_enabled() {
	case "$1" in
		1|on|true|yes|enabled)
			return 0
			;;
	esac

	return 1
}

command_path() {
	command -v "$1" 2>/dev/null || true
}

# Some OpenWrt BusyBox builds reject fractional `sleep` arguments. Keep the
# recovery/poll loops bounded without spinning: use fractional sleep when the
# installed applet accepts it, fall back to `usleep`, and finally one second.
speedtest_brief_sleep_mode=""
speedtest_usleep_bin=""
brief_sleep() {
	local duration="${1:-0.05}" usec

	case "$duration" in
		0.05) usec=50000 ;;
		0.10|0.1) usec=100000 ;;
		*) return 1 ;;
	esac
	case "$speedtest_brief_sleep_mode" in
		fractional) sleep "$duration" ;;
		usleep) "$speedtest_usleep_bin" "$usec" ;;
		whole) sleep 1 ;;
		'')
			if sleep "$duration" 2>/dev/null; then
				speedtest_brief_sleep_mode=fractional
				return 0
			fi
			speedtest_usleep_bin="$(command_path usleep)"
			if [ -n "$speedtest_usleep_bin" ] &&
			   "$speedtest_usleep_bin" "$usec" 2>/dev/null; then
				speedtest_brief_sleep_mode=usleep
				return 0
			fi
			speedtest_brief_sleep_mode=whole
			sleep 1
			;;
		*) return 1 ;;
	esac
}

resolve_interface_device() {
	local name="$1"
	local status dev

	[ -n "$name" ] || return 1

	if [ -e "/sys/class/net/$name" ]; then
		printf '%s\n' "$name"
		return 0
	fi

	status="$(ubus call network.interface."$name" status 2>/dev/null)"
	if [ -n "$status" ] && [ -n "$jsonfilter_bin" ]; then
		dev="$(printf '%s\n' "$status" | "$jsonfilter_bin" -e '@.l3_device' 2>/dev/null)"
		[ -n "$dev" ] || dev="$(printf '%s\n' "$status" | "$jsonfilter_bin" -e '@.device' 2>/dev/null)"

		if [ -n "$dev" ] && [ -e "/sys/class/net/$dev" ]; then
			printf '%s\n' "$dev"
			return 0
		fi
	fi

	printf '%s\n' "$name"
}

route_device_for() {
	local probe="$1"
	local source_ip="$2"

	if [ -n "$source_ip" ]; then
		ip route get "$probe" from "$source_ip" 2>/dev/null | sed -n 's/.* dev \([^ ]*\).*/\1/p' | head -n 1
	else
		ip route get "$probe" 2>/dev/null | sed -n 's/.* dev \([^ ]*\).*/\1/p' | head -n 1
	fi
}

source_ip_for_interface() {
	[ -n "$1" ] || return 1
	ip -4 -o addr show dev "$1" scope global 2>/dev/null | awk '{ split($4, a, "/"); print a[1]; exit }'
}

selected_target_interface() {
	local iface

	iface="$target_if_override"
	[ -n "$iface" ] || iface="$(uci_get wan_if)"
	[ -n "$iface" ] || iface="$(uci_get sqm_interface)"
	[ -n "$iface" ] || iface="$(uci_get ul_if)"
	resolve_interface_device "$iface"
}

safe_uci_name() {
	case "$1" in
		''|*[!A-Za-z0-9_]*)
			return 1
			;;
	esac

	return 0
}

safe_route_name() {
	case "$1" in
		''|*[!A-Za-z0-9_.:@-]*)
			return 1
			;;
	esac

	return 0
}

valid_ipv4() {
	case "$1" in ''|*[!0-9.]*) return 1 ;; esac
	printf '%s\n' "$1" | awk -F. '
		NF != 4 { exit 1 }
		{
			for (i = 1; i <= 4; i++)
				if ($i !~ /^[0-9]+$/ || $i < 0 || $i > 255) exit 1
		}
	'
}

effective_route_mode() {
	case "$route_mode_configured" in
		main)
			printf '%s' main
			;;
		mwan3)
			printf '%s' mwan3
			;;
		auto|'')
			if [ -n "$mwan3_member" ]; then
				printf '%s' mwan3
			else
				printf '%s' main
			fi
			;;
		*)
			return 1
			;;
	esac
}

route_exec() {
	if [ "$route_mode" = "mwan3" ]; then
		mwan3 use "$mwan3_member" exec "$@"
	else
		"$@"
	fi
}

# nft-mwan3 routes dynamically linked programs by injecting an SO_MARK wrapper
# through LD_PRELOAD. speedtest-go is a static Go binary, so its bulk sockets do
# not pass through that wrapper. Run only that backend under a package-owned,
# unprivileged uid and override mwan3's output mark for that uid in a temporary
# route-hook chain. The lock is global because two different member marks for
# the same uid would be ambiguous.
speedtest_route_pin_lock="${CAKE_AUTORATE_SPEEDTEST_ROUTE_PIN_LOCK:-/tmp/cake-autorate-speedtest-route-pin.lock}"
speedtest_route_pin_active=0
speedtest_route_pin_table=""
speedtest_route_pin_uid=""
speedtest_route_pin_gid=""
speedtest_route_pin_owner_start=""
speedtest_route_proof_error=""

speedtest_route_pin_lock_safe() {
	[ -d "$speedtest_route_pin_lock" ] && [ ! -L "$speedtest_route_pin_lock" ] || return 1
	command -v runtime_lock_path_owned_by_euid >/dev/null 2>&1 || return 1
	runtime_lock_path_owned_by_euid "$speedtest_route_pin_lock"
}

release_speedtest_route_pin() {
	local owner_pid owner_start owner_table

	[ "${speedtest_route_pin_active:-0}" = 1 ] || return 0
	speedtest_route_pin_lock_safe || return 1
	owner_pid="$(sed -n '1p' "$speedtest_route_pin_lock/owner" 2>/dev/null)"
	owner_start="$(sed -n '2p' "$speedtest_route_pin_lock/owner" 2>/dev/null)"
	owner_table="$(sed -n '3p' "$speedtest_route_pin_lock/owner" 2>/dev/null)"
	[ "$owner_pid" = "$$" ] && [ "$owner_start" = "$speedtest_route_pin_owner_start" ] &&
		[ "$owner_table" = "$speedtest_route_pin_table" ] || return 1
	case "$owner_table" in cake_st_[0-9]*) ;; *) return 1 ;; esac
	nft delete table inet "$owner_table" >/dev/null 2>&1 || return 1
	rm -f "$speedtest_route_pin_lock/owner" || return 1
	rmdir "$speedtest_route_pin_lock" || return 1
	speedtest_route_pin_active=0
	speedtest_route_pin_table=""
	return 0
}

recover_stale_speedtest_route_pin() {
	local owner_pid owner_start owner_table

	[ -e "$speedtest_route_pin_lock" ] || return 0
	speedtest_route_pin_lock_safe || return 1
	[ -f "$speedtest_route_pin_lock/owner" ] && [ ! -L "$speedtest_route_pin_lock/owner" ] || return 1
	runtime_lock_path_owned_by_euid "$speedtest_route_pin_lock/owner" || return 1
	owner_pid="$(sed -n '1p' "$speedtest_route_pin_lock/owner" 2>/dev/null)"
	owner_start="$(sed -n '2p' "$speedtest_route_pin_lock/owner" 2>/dev/null)"
	owner_table="$(sed -n '3p' "$speedtest_route_pin_lock/owner" 2>/dev/null)"
	if speedtest_process_identity_matches "$owner_pid" "$owner_start"; then
		return 75
	fi
	case "$owner_table" in cake_st_[0-9]*) ;; *) return 1 ;; esac
	nft delete table inet "$owner_table" >/dev/null 2>&1 || return 1
	rm -f "$speedtest_route_pin_lock/owner" || return 1
	rmdir "$speedtest_route_pin_lock" || return 1
}

acquire_speedtest_route_pin() {
	local pin_user="cake-speedtest" route_mark_clear_mask lock_rc

	[ "$route_mode" = mwan3 ] || return 0
	[ "${speedtest_route_pin_active:-0}" = 1 ] && return 0
	command -v nft >/dev/null 2>&1 || {
		speedtest_route_proof_error="nft is required to pin static speedtest-go sockets to an mwan3 member"
		return 1
	}
	command -v start-stop-daemon >/dev/null 2>&1 || {
		speedtest_route_proof_error="start-stop-daemon is required for isolated speedtest-go routing"
		return 1
	}
	speedtest_route_pin_uid="$(id -u "$pin_user" 2>/dev/null)"
	speedtest_route_pin_gid="$(id -g "$pin_user" 2>/dev/null)"
	is_uint "$speedtest_route_pin_uid" && is_uint "$speedtest_route_pin_gid" || {
		speedtest_route_proof_error="the package-owned cake-speedtest user is unavailable"
		return 1
	}
	case "$route_fwmark:$route_mark_mask" in
		0x[0-9A-Fa-f]*:0x[0-9A-Fa-f]*) ;;
		*) speedtest_route_proof_error="mwan3 returned an invalid member mark or mask"; return 1 ;;
	esac
	case "$route_table" in ''|*[!0-9]*) speedtest_route_proof_error="mwan3 returned an invalid routing table"; return 1 ;; esac

	recover_stale_speedtest_route_pin
	lock_rc="$?"
	case "$lock_rc" in
		0) ;;
		75) speedtest_route_proof_error="another pinned speedtest-go calibration is already running"; return 1 ;;
		*) speedtest_route_proof_error="a stale speedtest-go route pin could not be recovered safely"; return 1 ;;
	esac
	umask 077
	mkdir "$speedtest_route_pin_lock" 2>/dev/null || {
		speedtest_route_proof_error="another pinned speedtest-go calibration started concurrently"
		return 1
	}
	speedtest_route_pin_table="cake_st_$$"
	speedtest_route_pin_owner_start="$(speedtest_process_starttime "$$" 2>/dev/null)"
	is_positive_uint "$speedtest_route_pin_owner_start" || {
		rmdir "$speedtest_route_pin_lock" 2>/dev/null || true
		speedtest_route_proof_error="unable to bind the speedtest-go route pin to its owner"
		return 1
	}
	printf '%s\n%s\n%s\n' "$$" "$speedtest_route_pin_owner_start" "$speedtest_route_pin_table" \
		> "$speedtest_route_pin_lock/owner" || {
		rmdir "$speedtest_route_pin_lock" 2>/dev/null || true
		speedtest_route_proof_error="unable to record the speedtest-go route pin owner"
		return 1
	}
	chmod 600 "$speedtest_route_pin_lock/owner" || {
		rm -f "$speedtest_route_pin_lock/owner"
		rmdir "$speedtest_route_pin_lock" 2>/dev/null || true
		return 1
	}
	route_mark_clear_mask="$(printf '0x%08x' "$((0xffffffff ^ route_mark_mask))" 2>/dev/null)"
	case "$route_mark_clear_mask" in
		0x[0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f]) ;;
		*)
			rm -f "$speedtest_route_pin_lock/owner"
			rmdir "$speedtest_route_pin_lock" 2>/dev/null || true
			return 1
			;;
	esac
	nft add table inet "$speedtest_route_pin_table" >/dev/null 2>&1 &&
		nft "add chain inet $speedtest_route_pin_table output { type route hook output priority mangle + 2; policy accept; }" >/dev/null 2>&1 &&
		nft "add rule inet $speedtest_route_pin_table output meta skuid $speedtest_route_pin_uid meta mark set meta mark & $route_mark_clear_mask | $route_fwmark" >/dev/null 2>&1 || {
		nft delete table inet "$speedtest_route_pin_table" >/dev/null 2>&1 || true
		rm -f "$speedtest_route_pin_lock/owner"
		rmdir "$speedtest_route_pin_lock" 2>/dev/null || true
		speedtest_route_proof_error="unable to install the isolated speedtest-go mwan3 route pin"
		return 1
	}
	speedtest_route_pin_active=1
	return 0
}

run_speedtest_go_command() {
	local binary="$1"
	shift
	if [ "$route_mode" = mwan3 ]; then
		[ "${speedtest_route_pin_active:-0}" = 1 ] || {
			speedtest_route_proof_error="the isolated speedtest-go route pin was not initialized by its parent"
			return 1
		}
		HOME=/tmp start-stop-daemon -S -c "$speedtest_route_pin_uid:$speedtest_route_pin_gid" \
			-d /tmp -x "$binary" -- "$@"
	else
		route_exec "$binary" "$@"
	fi
}

interface_byte_counter() {
	local device="$1" direction="$2" file
	case "$direction" in rx|tx) ;; *) return 1 ;; esac
	case "$device" in ''|*[!A-Za-z0-9_.:@-]*) return 1 ;; esac
	file="/sys/class/net/$device/statistics/${direction}_bytes"
	[ -r "$file" ] || return 1
	sed -n '1p' "$file"
}

minimum_proof_bytes() {
	awk -v kbps="$1" -v elapsed="$2" 'BEGIN {
		value = kbps * elapsed * 1000 / 8 * 0.10;
		if (value < 1048576) value = 1048576;
		printf "%.0f", value
	}'
}

verify_speedtest_go_route_bytes() {
	local rx_after tx_after

	rx_after="$(interface_byte_counter "$route_device" rx)" || return 1
	tx_after="$(interface_byte_counter "$route_device" tx)" || return 1
	is_uint "$speedtest_route_rx_before" && is_uint "$speedtest_route_tx_before" &&
		is_uint "$rx_after" && is_uint "$tx_after" || return 1
	[ "$rx_after" -ge "$speedtest_route_rx_before" ] && [ "$tx_after" -ge "$speedtest_route_tx_before" ] || return 1
	speedtest_route_rx_delta=$((rx_after - speedtest_route_rx_before))
	speedtest_route_tx_delta=$((tx_after - speedtest_route_tx_before))
	speedtest_route_rx_required=0
	speedtest_route_tx_required=0
	if is_positive_uint "$download_kbps"; then
		speedtest_route_rx_required="$(minimum_proof_bytes "$download_kbps" "$download_elapsed")"
		[ "$speedtest_route_rx_delta" -ge "$speedtest_route_rx_required" ] || return 1
	fi
	if is_positive_uint "$upload_kbps"; then
		speedtest_route_tx_required="$(minimum_proof_bytes "$upload_kbps" "$upload_elapsed")"
		[ "$speedtest_route_tx_delta" -ge "$speedtest_route_tx_required" ] || return 1
	fi
	speedtest_route_traffic_proved=true
	return 0
}

route_rule_for_device() {
	local device="$1" rules table mark

	[ -n "$device" ] || return 0
	rules="$(ip -4 rule show 2>/dev/null)"
	table="$(printf '%s\n' "$rules" | awk -v device="$device" '
		{ for (i = 1; i <= NF; i++) if ($i == "iif" && $(i + 1) == device)
			for (j = 1; j <= NF; j++) if ($j == "lookup") { print $(j + 1); exit } }')"
	[ -n "$table" ] || return 0
	mark="$(printf '%s\n' "$rules" | awk -v table="$table" '
		{ found = 0; for (i = 1; i <= NF; i++) if ($i == "lookup" && $(i + 1) == table) found = 1;
		  if (found) for (i = 1; i <= NF; i++) if ($i == "fwmark") { split($(i + 1), value, "/"); print value[1]; exit } }')"
	printf '%s|%s\n' "$mark" "$table"
}

inspect_selected_route() {
	local status network_status environment default_if member_enabled member_running member_up network_up network_device env_device route_rule

	route_device=""
	route_source_ip=""
	route_fwmark=""
	route_mark_mask=""
	route_table=""
	route_member_status="unknown"
	route_active="false"
	route_error=""

	if [ "$route_mode" = "mwan3" ]; then
		command -v mwan3 >/dev/null 2>&1 || { route_error="mwan3 is not installed"; return 1; }
		command -v nft >/dev/null 2>&1 && nft list table inet mwan3 >/dev/null 2>&1 || { route_error="nftables table inet mwan3 is unavailable"; return 1; }
		[ -n "$jsonfilter_bin" ] || { route_error="jsonfilter is required for mwan3 route validation"; return 1; }
		safe_route_name "$mwan3_member" || { route_error="invalid mwan3 member"; return 1; }

		status="$(ubus call mwan3 status "{\"interface\":\"$mwan3_member\"}" 2>/dev/null)" || {
			route_error="mwan3 member $mwan3_member was not found"
			return 1
		}
		route_member_status="$(printf '%s\n' "$status" | "$jsonfilter_bin" -e '@.interfaces.*.status' 2>/dev/null | sed -n '1p')"
		member_enabled="$(printf '%s\n' "$status" | "$jsonfilter_bin" -e '@.interfaces.*.enabled' 2>/dev/null | sed -n '1p')"
		member_running="$(printf '%s\n' "$status" | "$jsonfilter_bin" -e '@.interfaces.*.running' 2>/dev/null | sed -n '1p')"
		member_up="$(printf '%s\n' "$status" | "$jsonfilter_bin" -e '@.interfaces.*.up' 2>/dev/null | sed -n '1p')"

		network_status="$(ubus call "network.interface.$mwan3_member" status 2>/dev/null)" || {
			route_error="network interface $mwan3_member was not found"
			return 1
		}
		network_up="$(printf '%s\n' "$network_status" | "$jsonfilter_bin" -e '@.up' 2>/dev/null)"
		network_device="$(printf '%s\n' "$network_status" | "$jsonfilter_bin" -e '@.l3_device' 2>/dev/null)"
		[ -n "$network_device" ] || network_device="$(printf '%s\n' "$network_status" | "$jsonfilter_bin" -e '@.device' 2>/dev/null)"

		environment="$(mwan3 use "$mwan3_member" exec env 2>/dev/null)" || {
			route_error="mwan3 could not resolve member $mwan3_member"
			return 1
		}
		env_device="$(printf '%s\n' "$environment" | sed -n 's/^DEVICE=//p' | sed -n '1p')"
		route_device="${env_device:-$network_device}"
		route_source_ip="$(printf '%s\n' "$environment" | sed -n 's/^SRCIP=//p' | sed -n '1p')"
		route_mark_mask="$(printf '%s\n' "$environment" | sed -n 's/^FWMARK=//p' | sed -n '1p')"
		route_fwmark="$route_mark_mask"
		route_rule="$(route_rule_for_device "$route_device")"
		if [ -n "$route_rule" ]; then
			route_fwmark="${route_rule%%|*}"
			route_table="${route_rule#*|}"
		fi

		if [ "$route_device" != "$target_if" ]; then
			route_error="route mismatch: mwan3 member $mwan3_member uses $route_device, expected $target_if"
			return 1
		fi
		if [ "$member_enabled" != "true" ] || [ "$member_running" != "true" ] ||
		   [ "$member_up" != "true" ] || [ "$network_up" != "true" ] ||
		   [ "$route_member_status" != "online" ]; then
			route_error="mwan3 member $mwan3_member is ${route_member_status:-offline}"
			return 1
		fi
	else
		route_device="$route_if"
		route_source_ip="$target_source_ip"
		route_table="main"
		route_member_status="online"
		if [ "$route_device" != "$target_if" ]; then
			route_error="main route uses ${route_device:-no device}, expected $target_if"
			return 1
		fi
	fi

	default_if="$(route_device_for "$route_probe" "")"
	[ "$default_if" = "$route_device" ] && route_active="true"
	route_identity="$route_mode|$mwan3_member|$route_device|$route_source_ip|$route_fwmark|$route_table"
	return 0
}

fetch_external_ip() {
	local output candidate

	if [ -n "$fallback_fetch" ]; then
		output="$(route_exec "$fallback_fetch" -q -4 -O - --timeout="$timeout_s" "$external_ip_url" 2>/dev/null)" || output=""
	elif [ -n "$curl_fetch" ]; then
		output="$(route_exec "$curl_fetch" -4 -fsS --max-time "$timeout_s" "$external_ip_url" 2>/dev/null)" || output=""
	fi
	# Accept exactly one dotted-quad payload. Selecting only the first line would
	# let a backend append attacker-controlled or malformed data while still
	# passing route attestation.
	candidate="$(printf '%s' "$output" | tr -d '\r')"
	valid_ipv4 "$candidate" || return 1
	printf '%s\n' "$candidate"
}

route_status_json() {
	local route_status_external_ip

	if ! inspect_selected_route; then
		json_error "${route_error:-selected route is unavailable}"
	fi
	valid_ipv4 "$route_source_ip" || json_error "Selected route has no valid IPv4 source address."
	route_status_external_ip="$(fetch_external_ip)"
	[ -n "$route_status_external_ip" ] ||
		json_error "Unable to determine the external IPv4 address through the selected route."
	printf '{"state":"ready","schema_version":1,"target_interface":"%s","resolved_interface":"%s","route_interface":"%s","route_mode":"%s","mwan3_member":"%s","source_ip":"%s","external_ip":"%s","route_fwmark":"%s","route_table":"%s","route_identity":"%s","route_active":%s,"member_status":"%s"}\n' \
		"$(json_escape "$target_if_override")" \
		"$(json_escape "$target_if")" \
		"$(json_escape "$route_device")" \
		"$(json_escape "$route_mode")" \
		"$(json_escape "$mwan3_member")" \
		"$(json_escape "$route_source_ip")" \
		"$(json_escape "$route_status_external_ip")" \
		"$(json_escape "$route_fwmark")" \
		"$(json_escape "$route_table")" \
		"$(json_escape "$route_identity")" \
		"$route_active" \
		"$(json_escape "$route_member_status")"
}

speedtest_unshaped_enabled() {
	local value

	# Internal Full Auto-Tune validation mode. The fifth argument is otherwise
	# only used as the worker key for job-run, so normal/manual invocations keep
	# their existing unshaped calibration behavior.
	if [ "$mode" = "run" ] && [ "$job_key_override" = "shaped" ]; then
		return 1
	fi

	value="$(uci_get speedtest_unshaped)"
	[ -n "$value" ] || value="1"
	bool_enabled "$value"
}

sqm_state_dir() {
	local dir

	dir="$(
		if [ -r /etc/sqm/sqm.conf ]; then
			. /etc/sqm/sqm.conf 2>/dev/null
		fi
		printf '%s' "${SQM_STATE_DIR:-/var/run/sqm}"
	)"
	[ -n "$dir" ] || dir="/var/run/sqm"
	printf '%s' "$dir"
}

sqm_active_for_device() {
	local dir

	[ -n "$1" ] || return 1
	dir="$(sqm_state_dir)"
	[ -f "$dir/$1.state" ]
}

target_is_verifiably_unshaped() {
	local qdisc_state root_kind has_ingress=false

	command -v tc >/dev/null 2>&1 || return 1
	qdisc_state="$(tc qdisc show dev "$target_if" 2>/dev/null)" || return 1
	root_kind="$(printf '%s\n' "$qdisc_state" | awk '$4 == "root" { print $2; exit }')"
	printf '%s\n' "$qdisc_state" | grep -Eq ' ingress | clsact ' && has_ingress=true
	case "$root_kind" in ''|noqueue|mq) ;; *) return 1 ;; esac
	[ "$has_ingress" = false ] || return 1
	! sqm_active_for_device "$target_if"
}

capture_managed_sqm_recovery_snapshot() {
	local manage_sqm sqm_enabled owner enabled configured_target snapshot tmp

	calibration_sqm_managed=0
	calibration_sqm_section=""
	calibration_sqm_target="$target_if"
	calibration_sqm_ul_if=""
	calibration_sqm_dl_if=""
	calibration_sqm_config_fingerprint=""
	# standalone_recovery_arm publishes the planned path before this copy. If
	# SIGKILL lands while the snapshot is being prepared, its supervisor can
	# therefore remove both the unpublished temporary and final path safely.
	if [ -n "${calibration_sqm_config_snapshot:-}" ]; then
		snapshot="$calibration_sqm_config_snapshot"
	else
		snapshot="$runtime_lock_root/sqm-snapshot.${section}-$$-${runtime_interface_lock_token}"
		calibration_sqm_config_snapshot="$snapshot"
	fi
	managed_sqm_snapshot_path_valid "$snapshot" 0 || return 1
	[ ! -e "$snapshot" ] || return 1
	manage_sqm="$(uci_get manage_sqm)"
	[ -n "$manage_sqm" ] || manage_sqm=1
	# A standalone unshaped test may mutate only a queue whose complete managed
	# identity can be journalled and checked by sqm-recover. An unmanaged active
	# queue is left untouched instead of relying on a state-file-only restart.
	bool_enabled "$manage_sqm" || return 1
	sqm_enabled="$(uci_get sqm_enabled)"
	bool_enabled "$sqm_enabled" || return 1
	calibration_sqm_section="$(uci_get sqm_section)"
	[ -n "$calibration_sqm_section" ] || calibration_sqm_section="cake_$section"
	calibration_sqm_ul_if="$(uci_get ul_if)"
	[ -n "$calibration_sqm_ul_if" ] || calibration_sqm_ul_if="$target_if"
	calibration_sqm_dl_if="$(uci_get dl_if)"
	[ -n "$calibration_sqm_dl_if" ] || calibration_sqm_dl_if="ifb4$target_if"
	safe_uci_name "$calibration_sqm_section" &&
		safe_route_name "$calibration_sqm_target" &&
		safe_route_name "$calibration_sqm_ul_if" &&
		safe_route_name "$calibration_sqm_dl_if" || return 1
	owner="$(uci_raw_get "sqm.$calibration_sqm_section._cake_autorate_managed")"
	enabled="$(uci_raw_get "sqm.$calibration_sqm_section.enabled")"
	configured_target="$(uci_raw_get "sqm.$calibration_sqm_section.interface")"
	[ "$owner" = "$section" ] && [ "$enabled" = 1 ] &&
		[ "$configured_target" = "$target_if" ] || return 1
	[ -f "$sqm_config_file" ] && [ ! -L "$sqm_config_file" ] || return 1
	runtime_lock_path_owned_by_euid "$sqm_config_file" || return 1
	tmp="$snapshot.tmp"
	[ ! -e "$tmp" ] && [ ! -L "$tmp" ] || return 1
	if ! cp "$sqm_config_file" "$tmp" || ! chmod 600 "$tmp" 2>/dev/null ||
	   ! runtime_lock_path_owned_by_euid "$tmp" || ! mv "$tmp" "$snapshot"; then
		rm -f "$tmp" 2>/dev/null || true
		return 1
	fi
	managed_sqm_snapshot_path_valid "$snapshot" 1 || {
		remove_managed_sqm_snapshot >/dev/null 2>&1 || true
		return 1
	}
	calibration_sqm_config_fingerprint="$(managed_sqm_snapshot_fingerprint \
		"$calibration_sqm_section" "$snapshot")" || {
		remove_managed_sqm_snapshot >/dev/null 2>&1 || true
		return 1
	}
	[ "$(managed_sqm_config_fingerprint "$calibration_sqm_section")" = \
	  "$calibration_sqm_config_fingerprint" ] || {
		remove_managed_sqm_snapshot >/dev/null 2>&1 || true
		return 1
	}
	# Bind the identity reads and the full-section digest to one stable snapshot.
	# A raw UCI writer which ignores the runtime lock is still detected before
	# the first SQM mutation below.
	owner="$(uci_raw_get "sqm.$calibration_sqm_section._cake_autorate_managed")"
	enabled="$(uci_raw_get "sqm.$calibration_sqm_section.enabled")"
	configured_target="$(uci_raw_get "sqm.$calibration_sqm_section.interface")"
	if [ "$owner" != "$section" ] || [ "$enabled" != 1 ] ||
	   [ "$configured_target" != "$target_if" ]; then
		remove_managed_sqm_snapshot >/dev/null 2>&1 || true
		return 1
	fi
	calibration_sqm_managed=1
}

managed_sqm_config_fingerprint() {
	local sqm_config_section="$1" config_dir="${2:-}" raw sorted digest

	safe_uci_name "$sqm_config_section" || return 1
	command -v sha256sum >/dev/null 2>&1 || return 1
	command -v sort >/dev/null 2>&1 || return 1
	command -v runtime_lock_ram_path >/dev/null 2>&1 || return 1
	runtime_lock_ram_path "$speedtest_job_dir" || return 1
	[ ! -L "$speedtest_job_dir" ] || return 1
	mkdir -p "$speedtest_job_dir" || return 1
	[ -d "$speedtest_job_dir" ] && [ ! -L "$speedtest_job_dir" ] || return 1
	command -v runtime_lock_path_owned_by_euid >/dev/null 2>&1 || return 1
	runtime_lock_path_owned_by_euid "$speedtest_job_dir" || return 1
	chmod 700 "$speedtest_job_dir" 2>/dev/null || return 1
	raw="$(mktemp "$speedtest_job_dir/.sqm-config.XXXXXX")" || return 1
	sorted="$(mktemp "$speedtest_job_dir/.sqm-config-sorted.XXXXXX")" || {
		rm -f "$raw"
		return 1
	}
	if [ -n "$config_dir" ]; then
		case "$config_dir" in "$runtime_lock_root"/sqm-snapshot-check-*) ;; *)
			rm -f "$raw" "$sorted"
			return 1
		;; esac
		uci -q -c "$config_dir" show "sqm.$sqm_config_section" > "$raw" || {
			rm -f "$raw" "$sorted"
			return 1
		}
	else
		uci -q show "sqm.$sqm_config_section" > "$raw" || {
			rm -f "$raw" "$sorted"
			return 1
		}
	fi
	if [ ! -s "$raw" ] ||
	   ! LC_ALL=C sort "$raw" > "$sorted"; then
		rm -f "$raw" "$sorted"
		return 1
	fi
	digest="$(sha256sum "$sorted" 2>/dev/null | awk 'NR == 1 { print $1; exit }')"
	rm -f "$raw" "$sorted"
	[ "${#digest}" -eq 64 ] 2>/dev/null || return 1
	case "$digest" in *[!0-9a-f]*) return 1 ;; esac
	printf 'sha256:%s\n' "$digest"
}

managed_sqm_snapshot_path_valid() {
	local snapshot="$1" require_file="${2:-1}" name mode

	[ -n "$snapshot" ] || return 1
	runtime_lock_ram_path "$snapshot" || return 1
	case "$snapshot" in "$runtime_lock_root"/sqm-snapshot.*) ;; *) return 1 ;; esac
	name="${snapshot#"$runtime_lock_root"/sqm-snapshot.}"
	case "$name" in ''|*/*|*[!A-Za-z0-9_-]*) return 1 ;; esac
	[ ! -L "$snapshot" ] || return 1
	if [ "$require_file" = 0 ] && [ ! -e "$snapshot" ]; then
		return 0
	fi
	[ -f "$snapshot" ] || return 1
	runtime_lock_path_owned_by_euid "$snapshot" || return 1
	mode="$(LC_ALL=C ls -ldn "$snapshot" 2>/dev/null |
		awk 'NR == 1 { print substr($1, 1, 10); exit }')"
	[ "$mode" = "-rw-------" ]
}

managed_sqm_snapshot_fingerprint() {
	local sqm_config_section="$1" snapshot="$2" check_dir fingerprint rc=0

	managed_sqm_snapshot_path_valid "$snapshot" 1 || return 1
	check_dir="$runtime_lock_root/sqm-snapshot-check-$$-${runtime_interface_lock_token}"
	case "$check_dir" in "$runtime_lock_root"/sqm-snapshot-check-*) ;; *) return 1 ;; esac
	[ ! -e "$check_dir" ] && [ ! -L "$check_dir" ] || return 1
	mkdir "$check_dir" || return 1
	chmod 700 "$check_dir" 2>/dev/null || rc=1
	runtime_lock_path_owned_by_euid "$check_dir" || rc=1
	if [ "$rc" -eq 0 ]; then
		cp "$snapshot" "$check_dir/sqm" || rc=1
	fi
	if [ "$rc" -eq 0 ]; then
		chmod 600 "$check_dir/sqm" 2>/dev/null || rc=1
	fi
	if [ "$rc" -eq 0 ]; then
		fingerprint="$(managed_sqm_config_fingerprint "$sqm_config_section" "$check_dir")" || rc=1
	fi
	rm -f "$check_dir/sqm" 2>/dev/null || rc=1
	rmdir "$check_dir" 2>/dev/null || rc=1
	[ "$rc" -eq 0 ] || return 1
	printf '%s\n' "$fingerprint"
}

remove_managed_sqm_snapshot() {
	local snapshot="${calibration_sqm_config_snapshot:-}" tmp

	[ -n "$snapshot" ] || return 0
	managed_sqm_snapshot_path_valid "$snapshot" 0 || return 1
	tmp="$snapshot.tmp"
	if [ -e "$tmp" ] || [ -L "$tmp" ]; then
		[ -f "$tmp" ] && [ ! -L "$tmp" ] || return 1
		runtime_lock_path_owned_by_euid "$tmp" || return 1
		rm -f "$tmp" || return 1
	fi
	if [ -e "$snapshot" ]; then
		managed_sqm_snapshot_path_valid "$snapshot" 1 || return 1
		rm -f "$snapshot" || return 1
	fi
	[ ! -e "$snapshot" ] && [ ! -L "$snapshot" ]
}

autorate_instance_running() {
	[ -n "$(autorate_instance_pid)" ]
}

autorate_instance_pid() {
	safe_uci_name "$section" || return 1
	pgrep -f "^/usr/sbin/cake-autorated --instance $section\$" 2>/dev/null | sed -n '1p'
}

speedtest_process_starttime() {
	local pid="$1"

	if command -v runtime_lock_process_starttime >/dev/null 2>&1; then
		runtime_lock_process_starttime "$pid"
		return $?
	fi
	[ -r "/proc/$pid/stat" ] || return 1
	sed 's/^.*) //' "/proc/$pid/stat" 2>/dev/null | awk 'NF >= 20 { print $20; exit }'
}

speedtest_process_identity_matches() {
	local pid="$1" expected_start="$2" actual_start

	is_positive_uint "$pid" && is_positive_uint "$expected_start" || return 1
	actual_start="$(speedtest_process_starttime "$pid" 2>/dev/null)"
	[ "$actual_start" = "$expected_start" ]
}

process_is_stopped() {
	[ -n "$1" ] || return 1
	grep -q '^State:[[:space:]]*[Tt]' "/proc/$1/status" 2>/dev/null
}

wait_for_process_state() {
	local pid="$1" expected_start="$2" wanted="$3" attempts="${4:-40}" i=0

	while [ "$i" -lt "$attempts" ]; do
		speedtest_process_identity_matches "$pid" "$expected_start" || return 2
		if [ "$wanted" = stopped ]; then
			process_is_stopped "$pid" && return 0
		else
			process_is_stopped "$pid" || return 0
		fi
		i=$((i + 1))
		brief_sleep 0.05
	done
	return 1
}

wait_for_sqm_state() {
	local wanted="$1" attempts="${2:-40}" i=0

	while [ "$i" -lt "$attempts" ]; do
		if [ "$wanted" = active ]; then
			sqm_active_for_device "$target_if" && return 0
		else
			sqm_active_for_device "$target_if" || return 0
		fi
		i=$((i + 1))
		brief_sleep 0.05
	done
	return 1
}

standalone_recovery_write() {
	local tmp journal_version

	[ -n "${standalone_recovery_journal:-}" ] || return 0
	command -v runtime_lock_ram_path >/dev/null 2>&1 || return 1
	runtime_lock_ram_path "$standalone_recovery_journal" || return 1
	journal_version="${standalone_recovery_version:-4}"
	[ "$journal_version" = 4 ] || return 1
	tmp="$standalone_recovery_journal.tmp.$$"
	if {
		printf 'version=%s\n' "$journal_version"
		printf 'owner_pid=%s\n' "$standalone_recovery_owner_pid"
		printf 'owner_start=%s\n' "$standalone_recovery_owner_start"
		printf 'target_if=%s\n' "$target_if"
		printf 'section=%s\n' "$section"
		printf 'lock_token=%s\n' "$standalone_recovery_lock_token"
		printf 'autorate_pid=%s\n' "${calibration_autorate_pid:-}"
		printf 'autorate_start=%s\n' "${calibration_autorate_start:-}"
		printf 'autorate_restore_required=%s\n' "${calibration_autorate_was_running:-0}"
		printf 'sqm_restore_required=%s\n' "${calibration_sqm_was_running:-0}"
		printf 'sqm_managed=%s\n' "${calibration_sqm_managed:-0}"
		printf 'sqm_section=%s\n' "${calibration_sqm_section:-}"
		printf 'sqm_target=%s\n' "${calibration_sqm_target:-}"
		printf 'sqm_ul_if=%s\n' "${calibration_sqm_ul_if:-}"
		printf 'sqm_dl_if=%s\n' "${calibration_sqm_dl_if:-}"
		printf 'sqm_config_fingerprint=%s\n' "${calibration_sqm_config_fingerprint:-}"
		printf 'sqm_config_snapshot=%s\n' "${calibration_sqm_config_snapshot:-}"
		printf 'phase=%s\n' "${standalone_recovery_phase:-armed}"
	} > "$tmp" && mv "$tmp" "$standalone_recovery_journal"; then
		return 0
	fi
	rm -f "$tmp" 2>/dev/null || true
	return 1
}

standalone_recovery_load() {
	local file="$1" line key value seen="" required expected_snapshot

	command -v runtime_lock_ram_path >/dev/null 2>&1 || return 1
	runtime_lock_ram_path "$file" || return 1
	[ -f "$file" ] && [ ! -L "$file" ] || return 1
	recovery_version=""
	recovery_owner_pid=""
	recovery_owner_start=""
	recovery_target_if=""
	recovery_section=""
	recovery_lock_token=""
	recovery_autorate_pid=""
	recovery_autorate_start=""
	recovery_autorate_required=""
	recovery_sqm_required=""
	recovery_sqm_managed=""
	recovery_sqm_section=""
	recovery_sqm_target=""
	recovery_sqm_ul_if=""
	recovery_sqm_dl_if=""
	recovery_sqm_config_fingerprint=""
	recovery_sqm_config_snapshot=""
	recovery_phase=""
	while IFS= read -r line || [ -n "$line" ]; do
		case "$line" in *=*) ;; *) return 1 ;; esac
		key="${line%%=*}"
		value="${line#*=}"
		case " $seen " in *" $key "*) return 1 ;; esac
		case "$key" in
			version) recovery_version="$value" ;;
			owner_pid) recovery_owner_pid="$value" ;;
			owner_start) recovery_owner_start="$value" ;;
			target_if) recovery_target_if="$value" ;;
			section) recovery_section="$value" ;;
			lock_token) recovery_lock_token="$value" ;;
			autorate_pid) recovery_autorate_pid="$value" ;;
			autorate_start) recovery_autorate_start="$value" ;;
			autorate_restore_required) recovery_autorate_required="$value" ;;
			sqm_restore_required) recovery_sqm_required="$value" ;;
			sqm_managed) recovery_sqm_managed="$value" ;;
			sqm_section) recovery_sqm_section="$value" ;;
			sqm_target) recovery_sqm_target="$value" ;;
			sqm_ul_if) recovery_sqm_ul_if="$value" ;;
			sqm_dl_if) recovery_sqm_dl_if="$value" ;;
			sqm_config_fingerprint) recovery_sqm_config_fingerprint="$value" ;;
			sqm_config_snapshot) recovery_sqm_config_snapshot="$value" ;;
			phase) recovery_phase="$value" ;;
			*) return 1 ;;
		esac
		seen="${seen}${seen:+ }$key"
	done < "$file"
	for required in version owner_pid owner_start target_if section lock_token \
		autorate_pid autorate_start autorate_restore_required sqm_restore_required \
		sqm_managed sqm_section sqm_target sqm_ul_if sqm_dl_if \
		sqm_config_fingerprint sqm_config_snapshot phase; do
		case " $seen " in *" $required "*) ;; *) return 1 ;; esac
	done
	[ "$recovery_version" = 4 ] || return 1
	is_positive_uint "$recovery_owner_pid" && is_positive_uint "$recovery_owner_start" || return 1
	safe_route_name "$recovery_target_if" && safe_uci_name "$recovery_section" || return 1
	case "$recovery_lock_token" in ''|*[!A-Za-z0-9_-]*) return 1 ;; esac
	case "$recovery_autorate_required:$recovery_sqm_required" in
		0:0|0:1|1:0|1:1) ;;
		*) return 1 ;;
	esac
	if [ "$recovery_autorate_required" = 1 ]; then
		is_positive_uint "$recovery_autorate_pid" && is_positive_uint "$recovery_autorate_start" || return 1
	else
		[ -z "$recovery_autorate_pid$recovery_autorate_start" ] || return 1
	fi
	case "$recovery_sqm_managed" in 0|1) ;; *) return 1 ;; esac
	[ "$recovery_sqm_required" != 1 ] || [ "$recovery_sqm_managed" = 1 ] || return 1
	if [ "$recovery_sqm_managed" = 1 ]; then
		safe_uci_name "$recovery_sqm_section" &&
			safe_route_name "$recovery_sqm_target" &&
			safe_route_name "$recovery_sqm_ul_if" &&
			safe_route_name "$recovery_sqm_dl_if" || return 1
		[ "$recovery_sqm_target" = "$recovery_target_if" ] || return 1
		case "$recovery_sqm_config_fingerprint" in
			sha256:????????????????????????????????????????????????????????????????) ;;
			*) return 1 ;;
		esac
		case "${recovery_sqm_config_fingerprint#sha256:}" in *[!0-9a-f]*) return 1 ;; esac
	elif [ -n "$recovery_sqm_config_fingerprint" ]; then
		return 1
	fi
	managed_sqm_snapshot_path_valid "$recovery_sqm_config_snapshot" 0 || return 1
	expected_snapshot="$runtime_lock_root/sqm-snapshot.${recovery_section}-${recovery_owner_pid}-${recovery_lock_token}"
	[ "$recovery_sqm_config_snapshot" = "$expected_snapshot" ] || return 1
	if [ "$recovery_sqm_required" = 1 ]; then
		managed_sqm_snapshot_path_valid "$recovery_sqm_config_snapshot" 1 || return 1
	fi
	case "$recovery_phase" in armed|restored) ;;
		*) return 1 ;;
	esac
	if [ "$recovery_phase" = restored ]; then
		[ "$recovery_autorate_required" = 0 ] && [ "$recovery_sqm_required" = 0 ] || return 1
	fi
}

standalone_recovery_ready_matches() {
	local file="$1" pid start owner_pid owner_start token extra

	[ -f "$file" ] && [ ! -L "$file" ] || return 1
	pid="$(sed -n '1s/^pid=//p' "$file")"
	start="$(sed -n '2s/^start=//p' "$file")"
	owner_pid="$(sed -n '3s/^owner_pid=//p' "$file")"
	owner_start="$(sed -n '4s/^owner_start=//p' "$file")"
	token="$(sed -n '5s/^token=//p' "$file")"
	extra="$(sed -n '6p' "$file")"
	[ -z "$extra" ] || return 1
	is_positive_uint "$pid" && is_positive_uint "$start" || return 1
	[ "$owner_pid" = "$standalone_recovery_owner_pid" ] &&
		[ "$owner_start" = "$standalone_recovery_owner_start" ] &&
		[ "$token" = "$standalone_recovery_lock_token" ] || return 1
	speedtest_process_identity_matches "$pid" "$start" || return 1
	standalone_recovery_supervisor_pid="$pid"
	standalone_recovery_supervisor_start="$start"
}

standalone_recovery_supervisor_alive() {
	speedtest_process_identity_matches "$standalone_recovery_supervisor_pid" \
		"$standalone_recovery_supervisor_start"
}

standalone_recovery_arm() {
	local lock_name setsid_bin ready i=0

	[ "${interface_lock_shared:-0}" != 1 ] || return 0
	[ "${standalone_recovery_armed:-0}" != 1 ] || return 0
	setsid_bin="$(command_path setsid)"
	[ -n "$setsid_bin" ] || return 1
	command -v runtime_lock_write_record >/dev/null 2>&1 || return 1
	safe_uci_name "$section" && safe_route_name "$target_if" || return 1
	lock_name="$(printf '%s' "$target_if" | tr ':@.' '___')"
	runtime_lock_ram_path "$speedtest_job_dir" || return 1
	[ ! -L "$speedtest_job_dir" ] || return 1
	mkdir -p "$speedtest_job_dir" || return 1
	[ -d "$speedtest_job_dir" ] && [ ! -L "$speedtest_job_dir" ] || return 1
	runtime_lock_path_owned_by_euid "$speedtest_job_dir" || return 1
	chmod 700 "$speedtest_job_dir" 2>/dev/null || return 1
	standalone_recovery_journal="$speedtest_job_dir/recovery-$section-$lock_name-$$.journal"
	ready="$standalone_recovery_journal.ready"
	standalone_recovery_owner_pid="$$"
	standalone_recovery_owner_start="$runtime_interface_lock_starttime"
	standalone_recovery_lock_token="$runtime_interface_lock_token"
	standalone_recovery_phase=armed
	standalone_recovery_version=4
	calibration_autorate_was_running=0
	calibration_autorate_pid=""
	calibration_autorate_start=""
	calibration_sqm_was_running=0
	calibration_sqm_managed=0
	calibration_sqm_section=""
	calibration_sqm_target="$target_if"
	calibration_sqm_ul_if=""
	calibration_sqm_dl_if=""
	calibration_sqm_config_fingerprint=""
	calibration_sqm_config_snapshot="$runtime_lock_root/sqm-snapshot.${section}-$$-${runtime_interface_lock_token}"
	managed_sqm_snapshot_path_valid "$calibration_sqm_config_snapshot" 0 || return 1
	[ ! -e "$calibration_sqm_config_snapshot" ] || return 1
	rm -f "$standalone_recovery_journal" "$ready"
	standalone_recovery_write || return 1

	"$setsid_bin" "$speedtest_self" --standalone-recover "$standalone_recovery_journal" \
		</dev/null >/dev/null 2>&1 &
	standalone_recovery_supervisor_pid="$!"
	standalone_recovery_supervisor_start="$(speedtest_process_starttime "$standalone_recovery_supervisor_pid" 2>/dev/null)"
	while [ "$i" -lt 100 ]; do
		if standalone_recovery_ready_matches "$ready"; then
			break
		fi
		kill -0 "$standalone_recovery_supervisor_pid" 2>/dev/null || break
		i=$((i + 1))
		brief_sleep 0.05
	done
	if ! standalone_recovery_ready_matches "$ready"; then
		if speedtest_process_identity_matches "$standalone_recovery_supervisor_pid" \
		   "$standalone_recovery_supervisor_start"; then
			kill "$standalone_recovery_supervisor_pid" 2>/dev/null || true
		fi
		wait "$standalone_recovery_supervisor_pid" 2>/dev/null || true
		rm -f "$standalone_recovery_journal" "$ready"
		standalone_recovery_journal=""
		return 1
	fi

	# Link the already-live supervisor into the authoritative interface record
	# before the first STOP or SQM command.  Before this rewrite a crash has no
	# paused state to restore and the stale record is safely replaceable.
	if ! runtime_lock_write_record "$runtime_interface_lock_record" "$$" \
	   "$runtime_interface_lock_starttime" speedtest "$runtime_interface_lock_token" \
	   "$standalone_recovery_journal"; then
		if standalone_recovery_supervisor_alive; then
			kill "$standalone_recovery_supervisor_pid" 2>/dev/null || true
		fi
		wait "$standalone_recovery_supervisor_pid" 2>/dev/null || true
		rm -f "$standalone_recovery_journal" "$ready"
		standalone_recovery_journal=""
		return 1
	fi
	export CAKE_AUTORATE_INTERFACE_LOCK_RECOVERY_JOURNAL="$standalone_recovery_journal"
	standalone_recovery_ready_file="$ready"
	standalone_recovery_armed=1
}

standalone_recovery_mark_restored() {
	[ "${standalone_recovery_armed:-0}" = 1 ] || return 0
	standalone_recovery_phase=restored
	standalone_recovery_write
}

prepare_speedtest_calibration() {
	local autorate_pid autorate_start sqm_preflight_active=0
	[ -n "$section" ] || return 0
	[ -n "$target_if" ] || return 0
	speedtest_unshaped_enabled || return 0

	if [ "${interface_lock_shared:-0}" != 1 ]; then
		standalone_recovery_arm || {
			append_warning "Unshaped speed test was refused because crash recovery could not be armed."
			return 1
		}
	fi

	if [ -x "$sqm_run_bin" ] && sqm_active_for_device "$target_if"; then
		capture_managed_sqm_recovery_snapshot || {
			append_warning "Active SQM has no immutable managed recovery identity; the unshaped test was refused before pausing autorate or SQM."
			standalone_recovery_mark_restored || true
			return 1
		}
		sqm_preflight_active=1
	fi

	if autorate_instance_running; then
		autorate_pid="$(autorate_instance_pid)"
		autorate_start="$(speedtest_process_starttime "$autorate_pid" 2>/dev/null)"
		is_positive_uint "$autorate_pid" && is_positive_uint "$autorate_start" || {
			append_warning "Autorate instance $section changed identity before it could be paused."
			standalone_recovery_mark_restored || true
			return 1
		}
		if is_positive_uint "$autorate_pid" && process_is_stopped "$autorate_pid"; then
			if [ "${interface_lock_shared:-0}" = 1 ]; then
				append_warning "Autorate instance $section was already paused by its owning maintenance job."
			else
				append_warning "Autorate instance $section was unexpectedly already paused; refusing an unowned mutation."
				standalone_recovery_mark_restored || true
				return 1
			fi
		else
			calibration_autorate_pid="$autorate_pid"
			calibration_autorate_start="$autorate_start"
			calibration_autorate_was_running=1
			[ "${standalone_recovery_armed:-0}" != 1 ] || {
				standalone_recovery_supervisor_alive || return 1
				standalone_recovery_write || return 1
			}
			if ! kill -STOP "$autorate_pid" 2>/dev/null ||
			   ! wait_for_process_state "$autorate_pid" "$autorate_start" stopped; then
				# A STOP which was delivered but not observed is conservatively
				# undone.  SQM has not been touched at this point.
				if speedtest_process_identity_matches "$autorate_pid" "$autorate_start"; then
					kill -CONT "$autorate_pid" 2>/dev/null || true
					wait_for_process_state "$autorate_pid" "$autorate_start" running 20 >/dev/null 2>&1 || true
				fi
				calibration_autorate_was_running=0
				calibration_autorate_pid=""
				calibration_autorate_start=""
				[ "${standalone_recovery_armed:-0}" != 1 ] || standalone_recovery_write || true
				append_warning "Autorate instance $section could not be verifiably paused; SQM was left unchanged."
				standalone_recovery_mark_restored || true
				return 1
			fi
			calibration_autorate_paused="true"
			append_warning "Paused autorate instance $section during unshaped speed test."
		fi
	fi

	if [ "$sqm_preflight_active" = 1 ]; then
		current_sqm_fingerprint="$(managed_sqm_config_fingerprint \
			"$calibration_sqm_section" 2>/dev/null)" || current_sqm_fingerprint=""
		if [ "$current_sqm_fingerprint" != "$calibration_sqm_config_fingerprint" ]; then
			append_warning "Managed SQM configuration changed after recovery preflight; the unshaped test was cancelled."
			restore_speedtest_calibration >/dev/null 2>&1 || true
			return 1
		fi
		if ! sqm_active_for_device "$target_if"; then
			append_warning "SQM state changed after recovery preflight; the unshaped test was cancelled."
			restore_speedtest_calibration >/dev/null 2>&1 || true
			return 1
		fi
		calibration_sqm_was_running=1
		[ "${standalone_recovery_armed:-0}" != 1 ] || {
			standalone_recovery_supervisor_alive || {
				restore_speedtest_calibration >/dev/null 2>&1 || true
				return 1
			}
			standalone_recovery_write || {
				restore_speedtest_calibration >/dev/null 2>&1 || true
				return 1
			}
		}
		if ! "$sqm_run_bin" stop "$target_if" >/dev/null 2>&1 ||
		   ! wait_for_sqm_state inactive; then
			append_warning "SQM on $target_if could not be verifiably stopped; the unshaped test was cancelled."
			restore_speedtest_calibration >/dev/null 2>&1 || true
			return 1
		fi
		calibration_sqm_paused="true"
		calibration_sqm_bypass_mode="paused-managed"
		append_warning "Temporarily disabled SQM on $target_if during unshaped speed test."
	elif [ -x "$sqm_run_bin" ] && sqm_active_for_device "$target_if"; then
		append_warning "SQM appeared after recovery preflight; the unshaped test was cancelled."
		restore_speedtest_calibration >/dev/null 2>&1 || true
		return 1
	fi
	if [ "$calibration_sqm_paused" != true ]; then
		target_is_verifiably_unshaped || {
			append_warning "The target did not have managed SQM to pause and its qdisc state was not verifiably unshaped."
			restore_speedtest_calibration >/dev/null 2>&1 || true
			return 1
		}
		calibration_sqm_bypass_mode="already-unshaped"
	fi

	calibration_shaper_bypassed="true"
}

restore_speedtest_calibration() {
	local rc=0

	if [ "$calibration_sqm_was_running" = "1" ]; then
		# The immutable recovery helper is the sole SQM mutation path. It
		# revalidates owner/enablement/target under the inherited kernel locks,
		# repairs CAKE/IFB/redirect if necessary, and verifies exact health.
		# Starting run.sh first would mutate from a stale snapshot before that
		# validation and could route traffic through the wrong queue.
		if [ "${calibration_sqm_managed:-0}" = 1 ] && [ -x "$sqm_recover_bin" ] &&
		   "$sqm_recover_bin" "$section" "$calibration_sqm_section" \
			"$calibration_sqm_target" "$calibration_sqm_ul_if" \
			"$calibration_sqm_dl_if" "$calibration_sqm_config_fingerprint" \
			"$calibration_sqm_config_snapshot" >/dev/null 2>&1; then
			calibration_sqm_was_running=0
			if [ "${standalone_recovery_armed:-0}" = 1 ] && ! standalone_recovery_write; then
				# The snapshot is still present. Keep the old obligation durable
				# so the supervisor can safely repeat the idempotent exact restore.
				calibration_sqm_was_running=1
				rc=1
			else
				# Only the caller may unlink its snapshot, and only after the
				# journal durably says SQM no longer requires restoration.
				# Keep the now-absent path in the version-4 journal: the recovery
				# supervisor validates that exact path and can distinguish a
				# completed unlink from a malformed/missing journal field.
				remove_managed_sqm_snapshot || true
			fi
		else
			rc=1
		fi
	fi
	if [ "$rc" -ne 0 ]; then
		# Keep the exact autorate process stopped while its managed SQM backing
		# is absent or unverified. Resuming it here would let the controller
		# operate without the queue it owns and would hide a recovery obligation.
		[ "${standalone_recovery_armed:-0}" != 1 ] || standalone_recovery_write || true
		return 1
	fi

	if [ "$calibration_autorate_was_running" = "1" ]; then
		if ! speedtest_process_identity_matches "$calibration_autorate_pid" "$calibration_autorate_start"; then
			# The exact process which was stopped no longer exists; never signal a
			# recycled PID.  There is consequently no paused process left to resume.
			calibration_autorate_was_running=0
			calibration_autorate_pid=""
			calibration_autorate_start=""
		elif kill -CONT "$calibration_autorate_pid" >/dev/null 2>&1 &&
		     wait_for_process_state "$calibration_autorate_pid" "$calibration_autorate_start" running; then
			calibration_autorate_was_running=0
			calibration_autorate_pid=""
			calibration_autorate_start=""
		else
			rc=1
		fi
		[ "${standalone_recovery_armed:-0}" != 1 ] || standalone_recovery_write || rc=1
	fi

	if [ "$rc" -eq 0 ]; then
		standalone_recovery_mark_restored || rc=1
	fi
	return "$rc"
}

standalone_recovery_main() {
	local journal="$1" ready tmp supervisor_start record_owned=0 settled_record_owned=0

	standalone_recovery_load "$journal" || exit 1
	standalone_recovery_journal="$journal"
	ready="$journal.ready"
	[ "${CAKE_AUTORATE_INTERFACE_LOCK_FD:-}" = 9 ] || exit 1
	[ "${CAKE_AUTORATE_RUNTIME_GLOBAL_LOCK_FD:-}" = 8 ] || exit 1
	[ "${CAKE_AUTORATE_INTERFACE_LOCK_TOKEN:-}" = "$recovery_lock_token" ] || exit 1
	runtime_lock_interface_paths "$recovery_target_if" || exit 1
	runtime_lock_verify_inherited 9 "$runtime_interface_lock_guard" exclusive || exit 1
	runtime_lock_verify_inherited 8 "$runtime_lock_root/runtime.guard" shared || exit 1
	runtime_lock_load_record "$runtime_interface_lock_record" || exit 1
	[ "$runtime_record_pid" = "$recovery_owner_pid" ] &&
		[ "$runtime_record_starttime" = "$recovery_owner_start" ] &&
		[ "$runtime_record_role" = speedtest ] &&
		[ "$runtime_record_token" = "$recovery_lock_token" ] &&
		{ [ -z "$runtime_record_journal" ] || [ "$runtime_record_journal" = "$journal" ]; } || exit 1

	supervisor_start="$(speedtest_process_starttime "$$")" || exit 1
	tmp="$ready.tmp.$$"
	if {
		printf 'pid=%s\n' "$$"
		printf 'start=%s\n' "$supervisor_start"
		printf 'owner_pid=%s\n' "$recovery_owner_pid"
		printf 'owner_start=%s\n' "$recovery_owner_start"
		printf 'token=%s\n' "$recovery_lock_token"
	} > "$tmp" && mv "$tmp" "$ready"; then
		:
	else
		rm -f "$tmp" 2>/dev/null || true
		exit 1
	fi

	while speedtest_process_identity_matches "$recovery_owner_pid" "$recovery_owner_start"; do
		brief_sleep 0.10
	done

	# Reload the last atomically published obligation only after the exact owner
	# is gone.  The inherited kernel descriptors keep service/SQM mutations out
	# throughout recovery.
	standalone_recovery_load "$journal" || exit 1
	standalone_recovery_journal="$journal"
	standalone_recovery_owner_pid="$recovery_owner_pid"
	standalone_recovery_owner_start="$recovery_owner_start"
	standalone_recovery_lock_token="$recovery_lock_token"
	standalone_recovery_phase="$recovery_phase"
	standalone_recovery_version="$recovery_version"
	target_if="$recovery_target_if"
	section="$recovery_section"
	calibration_autorate_pid="$recovery_autorate_pid"
	calibration_autorate_start="$recovery_autorate_start"
	calibration_autorate_was_running="$recovery_autorate_required"
	calibration_sqm_was_running="$recovery_sqm_required"
	calibration_sqm_managed="$recovery_sqm_managed"
	calibration_sqm_section="$recovery_sqm_section"
	calibration_sqm_target="$recovery_sqm_target"
	calibration_sqm_ul_if="$recovery_sqm_ul_if"
	calibration_sqm_dl_if="$recovery_sqm_dl_if"
	calibration_sqm_config_fingerprint="$recovery_sqm_config_fingerprint"
	calibration_sqm_config_snapshot="$recovery_sqm_config_snapshot"
	standalone_recovery_armed=1

	# The normal owner marks the obligation restored before releasing its locks.
	# A new operation may already own this interface by the time the supervisor
	# is scheduled. Never recreate or overwrite ownership in the settled case;
	# remove only the exact record left by the old owner.
	if [ "$recovery_phase" = restored ]; then
		settled_record_owned=0
		if [ -e "$runtime_interface_lock_record" ]; then
			runtime_lock_load_record "$runtime_interface_lock_record" || exit 1
			if [ "$runtime_record_pid" = "$recovery_owner_pid" ] &&
			   [ "$runtime_record_starttime" = "$recovery_owner_start" ] &&
			   [ "$runtime_record_role" = speedtest ] &&
			   [ "$runtime_record_token" = "$recovery_lock_token" ] &&
			   [ "$runtime_record_journal" = "$journal" ]; then
				settled_record_owned=1
			fi
		fi
		remove_managed_sqm_snapshot || exit 1
		if [ "$settled_record_owned" -eq 1 ]; then
			rm -f "$runtime_interface_lock_record" || exit 1
		fi
		rm -f "$ready" "$journal"
		exec 9>&-
		exec 8>&-
		exit 0
	fi

	# The owner died with a live obligation. Reassert the inherited locks after
	# its death. If a foreign holder won either lock, fail closed without touching
	# SQM or autorate state.
	runtime_lock_verify_inherited 9 "$runtime_interface_lock_guard" exclusive || exit 1
	runtime_lock_verify_inherited 8 "$runtime_lock_root/runtime.guard" shared || exit 1

	if [ -e "$runtime_interface_lock_record" ]; then
		runtime_lock_load_record "$runtime_interface_lock_record" || exit 1
		if [ "$runtime_record_pid" = "$recovery_owner_pid" ] &&
		   [ "$runtime_record_starttime" = "$recovery_owner_start" ] &&
		   [ "$runtime_record_role" = speedtest ] &&
		   [ "$runtime_record_token" = "$recovery_lock_token" ] &&
		   { [ -z "$runtime_record_journal" ] || [ "$runtime_record_journal" = "$journal" ]; }; then
			runtime_interface_lock_starttime="$supervisor_start"
			runtime_interface_lock_owner_pid="$$"
			runtime_interface_lock_token="$recovery_lock_token"
			runtime_lock_write_record "$runtime_interface_lock_record" "$$" \
				"$supervisor_start" recovery "$recovery_lock_token" "$journal" || exit 1
			runtime_interface_lock_held=1
			record_owned=1
		else
			# A new or corrupt ownership record is never safe to overwrite.
			exit 1
		fi
	else
		# Missing metadata can be rebuilt only after both inherited kernel locks
		# have been reasserted above.
		runtime_interface_lock_starttime="$supervisor_start"
		runtime_interface_lock_owner_pid="$$"
		runtime_interface_lock_token="$recovery_lock_token"
		runtime_lock_write_record "$runtime_interface_lock_record" "$$" \
			"$supervisor_start" recovery "$recovery_lock_token" "$journal" || exit 1
		runtime_interface_lock_held=1
		record_owned=1
	fi
	[ "$record_owned" -eq 1 ] || exit 1
	export CAKE_AUTORATE_INTERFACE_LOCK_OWNER="$$"
	export CAKE_AUTORATE_INTERFACE_LOCK_STARTTIME="$supervisor_start"
	export CAKE_AUTORATE_INTERFACE_LOCK_TOKEN="$recovery_lock_token"
	export CAKE_AUTORATE_INTERFACE_LOCK_RECOVERY_JOURNAL="$journal"
	export CAKE_AUTORATE_INTERFACE_LOCK_FD=9

	while ! restore_speedtest_calibration; do
		logger -t cake-autorate-speedtest "retrying crash recovery for $section on $target_if" 2>/dev/null || true
		sleep 1
	done
	remove_managed_sqm_snapshot || exit 1
	rm -f "$ready" "$journal"
	runtime_lock_release_interface || exit 1
	runtime_global_lock_mode=shared
	runtime_global_lock_inherited=0
	runtime_lock_release_global || exit 1
	exit 0
}

json_first_file() {
	local file="$1"
	local expr value

	shift
	[ -n "$jsonfilter_bin" ] || return 1

	for expr in "$@"; do
		value="$("$jsonfilter_bin" -i "$file" -e "$expr" 2>/dev/null | sed -n '/./{p;q;}')"
		if [ -n "$value" ]; then
			printf '%s\n' "$value"
			return 0
		fi
	done

	return 1
}

backend_title() {
	case "$1" in
		auto)
			printf '%s' "Auto"
			;;
		librespeed-cli)
			printf '%s' "LibreSpeed CLI"
			;;
		speedtest-go)
			printf '%s' "speedtest-go"
			;;
		iperf3)
			printf '%s' "configured iperf3"
			;;
		builtin-http)
			printf '%s' "built-in HTTP"
			;;
		*)
			printf '%s' "$1"
			;;
	esac
}

valid_backend() {
	case "$1" in
		auto|librespeed-cli|speedtest-go|iperf3|builtin-http)
			return 0
			;;
	esac

	return 1
}

backend_available() {
	case "$1" in
		librespeed-cli)
			[ -n "$librespeed_bin" ] && [ -n "$jsonfilter_bin" ]
			;;
		speedtest-go)
			[ -n "$speedtest_go_bin" ] && [ -n "$jsonfilter_bin" ]
			;;
		iperf3)
			[ -n "$iperf3_bin" ] && [ -n "$iperf3_server" ] && [ -n "$jsonfilter_bin" ]
			;;
		builtin-http)
			[ -n "$curl_fetch" ] || [ -n "$fallback_fetch" ]
			;;
		*)
			return 1
			;;
	esac
}

backend_install_hint() {
	case "$1" in
		librespeed-cli)
			printf '%s' "apk add librespeed-cli"
			;;
		speedtest-go)
			printf '%s' "apk add speedtest-go"
			;;
		iperf3)
			printf '%s' "apk add iperf3; set iperf3 server below"
			;;
		builtin-http)
			printf '%s' "built in; no extra package"
			;;
	esac
}

backend_package() {
	case "$1" in
		librespeed-cli)
			printf '%s' "librespeed-cli"
			;;
		speedtest-go)
			printf '%s' "speedtest-go"
			;;
		iperf3)
			printf '%s' "iperf3"
			;;
	esac
}

backend_reason() {
	case "$1" in
		librespeed-cli)
			[ -n "$librespeed_bin" ] || { printf '%s' "not installed"; return; }
			[ -n "$jsonfilter_bin" ] || { printf '%s' "jsonfilter is required"; return; }
			printf '%s' "available"
			;;
		speedtest-go)
			[ -n "$speedtest_go_bin" ] || { printf '%s' "not installed"; return; }
			[ -n "$jsonfilter_bin" ] || { printf '%s' "jsonfilter is required"; return; }
			printf '%s' "available"
			;;
		iperf3)
			[ -n "$iperf3_server" ] || { printf '%s' "server not configured"; return; }
			[ -n "$iperf3_bin" ] || { printf '%s' "not installed"; return; }
			[ -n "$jsonfilter_bin" ] || { printf '%s' "jsonfilter is required"; return; }
			printf '%s' "available"
			;;
		builtin-http)
			if [ -n "$curl_fetch" ] || [ -n "$fallback_fetch" ]; then
				printf '%s' "available"
			else
				printf '%s' "curl, uclient-fetch, or wget is required"
			fi
			;;
		*)
			printf '%s' "unknown backend"
			;;
	esac
}

first_available_backend() {
	local backend

	for backend in librespeed-cli speedtest-go iperf3 builtin-http; do
		if backend_available "$backend"; then
			printf '%s' "$backend"
			return 0
		fi
	done

	return 1
}

selected_status_backend() {
	if [ "$preferred_backend" != "auto" ]; then
		printf '%s' "$preferred_backend"
		return 0
	fi

	first_available_backend
}

backend_status_json() {
	local selected backend first available selected_bool

	selected="$(selected_status_backend)"
	first="1"

	if [ -n "$selected" ] && backend_available "$selected"; then
		available="true"
	else
		available="false"
	fi

	printf '{"available":%s,"preferred_backend":"%s","preferred_title":"%s","selected_backend":"%s","selected_title":"%s","backends":[' \
		"$available" \
		"$(json_escape "$preferred_backend")" \
		"$(json_escape "$(backend_title "$preferred_backend")")" \
		"$(json_escape "$selected")" \
		"$(json_escape "$(backend_title "$selected")")"

	for backend in librespeed-cli speedtest-go iperf3 builtin-http; do
		[ "$first" = "1" ] || printf ','
		first="0"

		if backend_available "$backend"; then
			available="true"
		else
			available="false"
		fi

		if [ "$backend" = "$selected" ]; then
			selected_bool="true"
		else
			selected_bool="false"
		fi

		printf '{"name":"%s","title":"%s","available":%s,"selected":%s,"reason":"%s","install_hint":"%s"}' \
			"$(json_escape "$backend")" \
			"$(json_escape "$(backend_title "$backend")")" \
			"$available" \
			"$selected_bool" \
			"$(json_escape "$(backend_reason "$backend")")" \
			"$(json_escape "$(backend_install_hint "$backend")")"
	done

	printf '],"warning":"%s"}\n' "$(json_escape "$warning")"
}

refresh_backend_bins() {
	jsonfilter_bin="$(command_path jsonfilter)"
	librespeed_bin="$(command_path librespeed-cli)"
	speedtest_go_bin="$(command_path speedtest-go)"
	iperf3_bin="$(command_path iperf3)"
}

backend_install_json() {
	local selected="$1"
	local package packages output available

	valid_backend "$selected" || json_error "Unknown speed test backend: $selected"

	case "$selected" in
		auto)
			json_error "Select LibreSpeed CLI, speedtest-go, or configured iperf3 before installing an optional backend."
			;;
		builtin-http)
			printf '{"backend":"builtin-http","backend_title":"%s","package":"","installed":true,"available":%s,"reason":"%s"}\n' \
				"$(json_escape "$(backend_title builtin-http)")" \
				"$(backend_available builtin-http && printf true || printf false)" \
				"$(json_escape "$(backend_reason builtin-http)")"
			exit 0
			;;
	esac

	package="$(backend_package "$selected")"
	[ -n "$package" ] || json_error "$(backend_title "$selected") cannot be installed automatically."

	if backend_available "$selected"; then
		printf '{"backend":"%s","backend_title":"%s","package":"%s","installed":true,"available":true,"reason":"%s"}\n' \
			"$(json_escape "$selected")" \
			"$(json_escape "$(backend_title "$selected")")" \
			"$(json_escape "$package")" \
			"$(json_escape "$(backend_reason "$selected")")"
		exit 0
	fi

	command -v apk >/dev/null 2>&1 || json_error "apk was not found on this router."

	packages="$package jsonfilter"
	output="$(apk add $packages 2>&1)"
	if [ "$?" -ne 0 ]; then
		json_error "Failed to install $packages: $output"
	fi

	refresh_backend_bins

	if backend_available "$selected"; then
		available="true"
	else
		available="false"
	fi

	printf '{"backend":"%s","backend_title":"%s","package":"%s","installed":true,"available":%s,"reason":"%s"}\n' \
		"$(json_escape "$selected")" \
		"$(json_escape "$(backend_title "$selected")")" \
		"$(json_escape "$package")" \
		"$available" \
		"$(json_escape "$(backend_reason "$selected")")"
}

reset_result() {
	download_kbps="null"
	upload_kbps="null"
	download_size="0"
	upload_size="0"
	download_elapsed="0.00"
	upload_elapsed="0.00"
	source=""
	backend=""
	test_server_id=""
	test_server_name=""
	test_server_sponsor=""
	bind_mode="none"
}

direction_result_available() {
	case "$direction_override" in
		download) is_positive_uint "$download_kbps" ;;
		upload) is_positive_uint "$upload_kbps" ;;
		*) is_positive_uint "$download_kbps" ;;
	esac
}

fetch_download() {
	if [ "$fetch_kind" = "curl" ]; then
		if [ -n "$bind_interface" ]; then
			route_exec "$fetch" ${force_ipv4_arg:+-4} -f -L -sS --max-time "$timeout_s" --interface "$bind_interface" -o "$tmp_download" "$download_url"
		else
			route_exec "$fetch" ${force_ipv4_arg:+-4} -f -L -sS --max-time "$timeout_s" -o "$tmp_download" "$download_url"
		fi
	else
		route_exec "$fetch" -q ${force_ipv4_arg:+-4} -O "$tmp_download" --timeout="$timeout_s" "$download_url"
	fi
}

fetch_upload() {
	if [ "$fetch_kind" = "curl" ]; then
		if [ -n "$bind_interface" ]; then
			route_exec "$fetch" ${force_ipv4_arg:+-4} -f -L -sS --max-time "$timeout_s" --interface "$bind_interface" --request POST --data-binary "@$tmp_upload" -o "$tmp_response" "$upload_url"
		else
			route_exec "$fetch" ${force_ipv4_arg:+-4} -f -L -sS --max-time "$timeout_s" --request POST --data-binary "@$tmp_upload" -o "$tmp_response" "$upload_url"
		fi
	else
		route_exec "$fetch" -q ${force_ipv4_arg:+-4} -O "$tmp_response" --timeout="$timeout_s" --post-file="$tmp_upload" "$upload_url"
	fi
}

run_builtin_http() {
	local download_start download_stop upload_done upload_last_try upload_try upload_blocks upload_start upload_stop

	reset_result
	backend="builtin-http"

	if bool_enabled "$bind_interface_enabled" && [ -n "$target_if" ] && [ -n "$curl_fetch" ]; then
		fetch="$curl_fetch"
		fetch_kind="curl"
		bind_interface="$target_if"
		bind_mode="curl-interface"
	else
		fetch="$fallback_fetch"
		fetch_kind="uclient-fetch"

		if [ -n "$fetch" ]; then
			fetch_kind="$(basename "$fetch")"
		fi

		if bool_enabled "$bind_interface_enabled" && [ -n "$target_if" ]; then
			if [ "$route_mode" = mwan3 ]; then
				bind_mode="mwan3-member"
			else
				bind_mode="route-check"
			fi

			if [ "$route_mode" != mwan3 ] && [ -n "$route_if" ] && [ "$route_if" != "$target_if" ]; then
				append_warning "Speed test could not bind to $target_if because curl is not installed; route probe uses $route_if."
			fi
		fi
	fi

	[ -n "$fetch" ] || return 1
	source="$fetch_kind"

	if [ "$direction_override" != upload ]; then
		download_start="$(now_s)"
		if ! fetch_download >/dev/null 2>&1; then
			return 1
		fi
		download_stop="$(now_s)"
		download_elapsed="$(elapsed_s "$download_start" "$download_stop")"
		download_size="$(wc -c < "$tmp_download" | tr -d ' ')"
		download_kbps="$(kbps_for "$download_size" "$download_elapsed")"
	fi

	if [ "$direction_override" != download ] && is_uint "$upload_bytes" && [ "$upload_bytes" -gt 0 ] && [ -n "$upload_url" ]; then
		upload_done="0"
		upload_last_try=""

		for upload_try in "$upload_bytes" $upload_retry_bytes; do
			is_positive_uint "$upload_try" || continue
			[ "$upload_try" = "$upload_last_try" ] && continue

			upload_last_try="$upload_try"
			upload_blocks="$(( (upload_try + 1023) / 1024 ))"
			rm -f "$tmp_upload" "$tmp_response"

			if ! dd if=/dev/zero of="$tmp_upload" bs=1024 count="$upload_blocks" >/dev/null 2>&1; then
				continue
			fi

			upload_size="$(wc -c < "$tmp_upload" | tr -d ' ')"
			upload_start="$(now_s)"
			if fetch_upload >/dev/null 2>&1; then
				upload_stop="$(now_s)"
				upload_elapsed="$(elapsed_s "$upload_start" "$upload_stop")"
				upload_kbps="$(kbps_for "$upload_size" "$upload_elapsed")"
				upload_done="1"

				if [ "$upload_try" != "$upload_bytes" ]; then
					append_warning "Upload test used a smaller retry payload."
				fi

				break
			fi
		done

		if [ "$upload_done" != "1" ]; then
			upload_size="0"
			append_warning "Upload test failed; upload rate was left unchanged."
		fi
	fi

	direction_result_available
}

run_librespeed_cli() {
	local start stop dl_mbps ul_mbps download_arg upload_arg upload_kib ipv4_arg interface_arg value

	backend_available "librespeed-cli" || return 1
	reset_result
	backend="librespeed-cli"
	source="librespeed-cli"

	ipv4_arg=""
	interface_arg=""
	if bool_enabled "$force_ipv4_enabled"; then
		ipv4_arg="--ipv4"
	fi

	if bool_enabled "$bind_interface_enabled" && [ -n "$target_if" ]; then
		interface_arg="--interface $target_if"
		bind_mode="librespeed-interface"
	fi

	upload_arg=""
	download_arg=""
	if [ "$direction_override" = upload ]; then
		download_arg="--no-download"
	fi
	if [ "$direction_override" = download ] || { is_uint "$upload_bytes" && [ "$upload_bytes" -eq 0 ]; }; then
		upload_arg="--no-upload"
	elif is_positive_uint "$upload_bytes"; then
		upload_kib="$(( (upload_bytes + 1023) / 1024 ))"
		upload_arg="--upload-size $upload_kib --no-pre-allocate"
	fi

	rm -f "$tmp_response"
	start="$(now_s)"
	if ! route_exec "$librespeed_bin" --json --timeout "$timeout_s" --duration "$duration_s" $ipv4_arg $interface_arg $download_arg $upload_arg > "$tmp_response" 2>/dev/null; then
		return 1
	fi
	stop="$(now_s)"

	download_elapsed="$(elapsed_s "$start" "$stop")"
	upload_elapsed="$download_elapsed"
	dl_mbps="$(json_first_file "$tmp_response" '@[0].download' '@.download' '@.result.download' '@.servers[0].download')"
	ul_mbps="$(json_first_file "$tmp_response" '@[0].upload' '@.upload' '@.result.upload' '@.servers[0].upload')"

	value="$(mbps_to_kbps "$dl_mbps")"
	[ -n "$value" ] && download_kbps="$value"
	if [ -n "$ul_mbps" ]; then
		value="$(mbps_to_kbps "$ul_mbps")"
		[ -n "$value" ] && upload_kbps="$value"
	fi

	download_size="$(json_first_file "$tmp_response" '@[0].bytes_received' '@.bytes_received' '@.result.bytes_received' '@.servers[0].bytes_received')"
	upload_size="$(json_first_file "$tmp_response" '@[0].bytes_sent' '@.bytes_sent' '@.result.bytes_sent' '@.servers[0].bytes_sent')"
	[ -n "$download_size" ] || download_size="0"
	[ -n "$upload_size" ] || upload_size="0"

	direction_result_available
}

speedtest_go_cache_file() {
	[ -n "$section" ] && safe_uci_name "$section" || return 1
	printf '%s/%s.speedtest-go-server\n' "$speedtest_job_dir" "$section"
}

speedtest_go_cached_server() {
	local cache_file cached_server

	cache_file="$(speedtest_go_cache_file)" || return 0
	cached_server="$(sed -n '1p' "$cache_file" 2>/dev/null)"
	is_positive_uint "$cached_server" && printf '%s\n' "$cached_server"
}

speedtest_go_cache_server() {
	local server_id="$1" cache_file

	is_positive_uint "$server_id" || return 0
	cache_file="$(speedtest_go_cache_file)" || return 0
	mkdir -p "$speedtest_job_dir" 2>/dev/null || return 0
	chmod 700 "$speedtest_job_dir" 2>/dev/null || true
	printf '%s\n' "$server_id" > "$cache_file"
}

speedtest_go_clear_cached_server() {
	local cache_file

	cache_file="$(speedtest_go_cache_file)" || return 0
	rm -f "$cache_file"
}

speedtest_go_result_is_plausible() {
	direction_result_available || return 1

	if [ "$direction_override" != download ] && [ "$direction_override" != upload ] && is_positive_uint "$upload_kbps" &&
		upload_exceeds_download_sanity_ratio "$download_kbps" "$upload_kbps"; then
		return 1
	fi

	return 0
}

speedtest_go_save_bad_result() {
	speedtest_go_bad_download_kbps="$download_kbps"
	speedtest_go_bad_upload_kbps="$upload_kbps"
	speedtest_go_bad_download_elapsed="$download_elapsed"
	speedtest_go_bad_upload_elapsed="$upload_elapsed"
	speedtest_go_bad_server_id="$test_server_id"
	speedtest_go_bad_server_name="$test_server_name"
	speedtest_go_bad_server_sponsor="$test_server_sponsor"
}

speedtest_go_restore_bad_result() {
	download_kbps="$speedtest_go_bad_download_kbps"
	upload_kbps="$speedtest_go_bad_upload_kbps"
	download_elapsed="$speedtest_go_bad_download_elapsed"
	upload_elapsed="$speedtest_go_bad_upload_elapsed"
	test_server_id="$speedtest_go_bad_server_id"
	test_server_name="$speedtest_go_bad_server_name"
	test_server_sponsor="$speedtest_go_bad_server_sponsor"
	download_size="0"
	upload_size="0"
}

speedtest_go_candidate_ids() {
	local list_file source_ip

	list_file="/tmp/cake-autorate-speedtest-go-servers.$$"
	set -- "$speedtest_go_bin" --list --ping-mode http

	if bool_enabled "$bind_interface_enabled" && [ -n "$target_if" ]; then
		source_ip="${route_source_ip:-$(source_ip_for_interface "$target_if")}"
		[ -n "$source_ip" ] && set -- "$@" --source "$source_ip" --dns-bind-source
	fi

	if ! run_speedtest_go_command "$@" > "$list_file" 2>/dev/null; then
		rm -f "$list_file"
		return 1
	fi

	sed -n 's/^\[[[:space:]]*\([0-9][0-9]*\)\][[:space:]]*[0-9.][0-9.]*km[[:space:]]*\([0-9][0-9]*\)ms.*/\2 \1/p' "$list_file" |
		sort -n | awk '{ print $2 }'
	rm -f "$list_file"
}

run_speedtest_go_once() {
	local server_id="$1" start stop dl_bytes_per_s ul_bytes_per_s source_ip value

	reset_result
	backend="speedtest-go"
	source="speedtest-go"

	set -- "$speedtest_go_bin" --json --ping-mode http
	if is_positive_uint "$server_id"; then
		set -- "$@" --server "$server_id"
	fi

	if [ "$direction_override" = upload ]; then
		set -- "$@" --no-download
	fi
	if [ "$direction_override" = download ] || { is_uint "$upload_bytes" && [ "$upload_bytes" -eq 0 ]; }; then
		set -- "$@" --no-upload
	fi

	if bool_enabled "$bind_interface_enabled" && [ -n "$target_if" ]; then
		source_ip="${route_source_ip:-$(source_ip_for_interface "$target_if")}"
		if [ -n "$source_ip" ]; then
			set -- "$@" --source "$source_ip" --dns-bind-source
			bind_mode="source-ip"
		else
			bind_mode="route-check"
			if [ -n "$route_if" ] && [ "$route_if" != "$target_if" ]; then
				append_warning "speedtest-go could not bind to $target_if because no IPv4 source address was found; route probe uses $route_if."
			fi
		fi
	fi

	rm -f "$tmp_response"
	speedtest_route_traffic_proved=false
	speedtest_route_rx_delta=0
	speedtest_route_tx_delta=0
	speedtest_route_rx_required=0
	speedtest_route_tx_required=0
	speedtest_route_rx_before="$(interface_byte_counter "$route_device" rx)" || return 1
	speedtest_route_tx_before="$(interface_byte_counter "$route_device" tx)" || return 1
	start="$(now_s)"
	if ! run_speedtest_go_command "$@" > "$tmp_response" 2>/dev/null; then
		return 1
	fi
	stop="$(now_s)"

	download_elapsed="$(elapsed_s "$start" "$stop")"
	upload_elapsed="$download_elapsed"
	dl_bytes_per_s="$(json_first_file "$tmp_response" '@.servers[0].dl_speed' '@.servers[*].dl_speed' '@.server.dl_speed' '@.dl_speed')"
	ul_bytes_per_s="$(json_first_file "$tmp_response" '@.servers[0].ul_speed' '@.servers[*].ul_speed' '@.server.ul_speed' '@.ul_speed')"
	test_server_id="$(json_first_file "$tmp_response" '@.servers[0].id' '@.server.id')"
	test_server_name="$(json_first_file "$tmp_response" '@.servers[0].name' '@.server.name')"
	test_server_sponsor="$(json_first_file "$tmp_response" '@.servers[0].sponsor' '@.server.sponsor')"

	value="$(bytes_per_second_to_kbps "$dl_bytes_per_s")"
	[ -n "$value" ] && download_kbps="$value"
	if [ -n "$ul_bytes_per_s" ]; then
		value="$(bytes_per_second_to_kbps "$ul_bytes_per_s")"
		[ -n "$value" ] && upload_kbps="$value"
	fi

	download_size="0"
	upload_size="0"

	direction_result_available || return 1
	if ! verify_speedtest_go_route_bytes; then
		speedtest_route_proof_error="speedtest-go traffic did not traverse the selected interface $route_device"
		return 1
	fi
	return 0
}

run_speedtest_go() {
	local cached_server candidate_ids candidate_id attempts rejected_server max_attempts

	backend_available "speedtest-go" || return 1
	# Acquire in the top-level backend process. Candidate discovery runs in a
	# command substitution; creating the lock there would strand subshell state
	# while $$ still names the live parent shell on BusyBox ash.
	if [ "$route_mode" = mwan3 ]; then
		acquire_speedtest_route_pin || return 1
	fi

	if is_positive_uint "$speedtest_go_server_id"; then
		run_speedtest_go_once "$speedtest_go_server_id"
		return $?
	fi

	speedtest_go_bad_download_kbps=""
	speedtest_go_bad_upload_kbps=""
	speedtest_go_bad_download_elapsed=""
	speedtest_go_bad_upload_elapsed=""
	speedtest_go_bad_server_id=""
	speedtest_go_bad_server_name=""
	speedtest_go_bad_server_sponsor=""
	max_attempts=3
	cached_server="$(speedtest_go_cached_server)"

	if is_positive_uint "$cached_server"; then
		if run_speedtest_go_once "$cached_server" && speedtest_go_result_is_plausible; then
			return 0
		fi
		[ -z "$speedtest_route_proof_error" ] || return 1

		append_warning "speedtest-go cached server ID $cached_server failed validation; automatic selection will retry."
		speedtest_go_clear_cached_server
	fi

	candidate_ids="$(speedtest_go_candidate_ids)"
	[ -z "$speedtest_route_proof_error" ] || return 1
	if [ -z "$candidate_ids" ]; then
		append_warning "speedtest-go could not list nearby servers; using its default automatic selection."
		if run_speedtest_go_once ""; then
			if speedtest_go_result_is_plausible; then
				speedtest_go_cache_server "$test_server_id"
				return 0
			fi
			speedtest_go_save_bad_result
		fi
		[ -z "$speedtest_route_proof_error" ] || return 1
	else
		attempts=0
		for candidate_id in $candidate_ids; do
			[ "$attempts" -lt "$max_attempts" ] || break
			[ "$candidate_id" = "$cached_server" ] && continue
			attempts=$((attempts + 1))

			if ! run_speedtest_go_once "$candidate_id"; then
				[ -z "$speedtest_route_proof_error" ] || return 1
				continue
			fi

			if speedtest_go_result_is_plausible; then
				speedtest_go_cache_server "$test_server_id"
				if [ -n "$rejected_server" ]; then
					append_warning "speedtest-go rejected automatic server $rejected_server after an implausible upload result and selected ${test_server_sponsor:-server} (ID ${test_server_id:-$candidate_id}); this server will be reused while it validates."
				fi
				return 0
			fi

			rejected_server="${test_server_sponsor:-server} (ID ${test_server_id:-$candidate_id})"
			speedtest_go_save_bad_result
		done
	fi

	if is_positive_uint "$speedtest_go_bad_download_kbps"; then
		speedtest_go_restore_bad_result
		upload_kbps="null"
		append_warning "speedtest-go automatic server selection reported upload more than 150% of download; upload rate was left unchanged. Pin a server ID if this persists."
		return 0
	fi

	return 1
}

run_iperf3_one() {
	local reverse="$1"
	local output="$2"
	local source_ip

	set -- "$iperf3_bin" -J -t "$duration_s" -c "$iperf3_server"

	if [ "$reverse" = "1" ]; then
		set -- "$@" -R
	fi

	if is_positive_uint "$iperf3_port"; then
		set -- "$@" -p "$iperf3_port"
	fi

	if bool_enabled "$bind_interface_enabled" && [ -n "$target_if" ]; then
		source_ip="${route_source_ip:-$(source_ip_for_interface "$target_if")}"
		if [ -n "$source_ip" ]; then
			set -- "$@" -B "$source_ip"
			bind_mode="source-ip"
		else
			bind_mode="route-check"
			if [ -n "$route_if" ] && [ "$route_if" != "$target_if" ]; then
				append_warning "iperf3 could not bind to $target_if because no IPv4 source address was found; route probe uses $route_if."
			fi
		fi
	fi

	route_exec "$@" > "$output" 2>/dev/null
}

run_iperf3() {
	local start stop dl_bits ul_bits value

	backend_available "iperf3" || return 1
	reset_result
	backend="iperf3"
	source="iperf3"

	rm -f "$tmp_download" "$tmp_upload"
	if [ "$direction_override" != upload ]; then
		start="$(now_s)"
		if ! run_iperf3_one 1 "$tmp_download"; then
			return 1
		fi
		stop="$(now_s)"

		download_elapsed="$(elapsed_s "$start" "$stop")"
		dl_bits="$(json_first_file "$tmp_download" '@.end.sum_received.bits_per_second' '@.end.sum.bits_per_second')"
		download_size="$(json_first_file "$tmp_download" '@.end.sum_received.bytes' '@.end.sum.bytes')"
		value="$(bits_to_kbps "$dl_bits")"
		[ -n "$value" ] && download_kbps="$value"
		[ -n "$download_size" ] || download_size="0"
	fi

	if [ "$direction_override" != download ] && is_uint "$upload_bytes" && [ "$upload_bytes" -gt 0 ]; then
		start="$(now_s)"
		if run_iperf3_one 0 "$tmp_upload"; then
			stop="$(now_s)"
			upload_elapsed="$(elapsed_s "$start" "$stop")"
			ul_bits="$(json_first_file "$tmp_upload" '@.end.sum_sent.bits_per_second' '@.end.sum.bits_per_second')"
			upload_size="$(json_first_file "$tmp_upload" '@.end.sum_sent.bytes' '@.end.sum.bytes')"
			value="$(bits_to_kbps "$ul_bits")"
			[ -n "$value" ] && upload_kbps="$value"
			[ -n "$upload_size" ] || upload_size="0"
		else
			append_warning "iperf3 upload test failed; upload rate was left unchanged."
		fi
	fi

	direction_result_available
}

emit_result() {
	case "$backend:$direction_override" in
		speedtest-go:download) backend_direction_flag=--no-upload ;;
		speedtest-go:upload) backend_direction_flag=--no-download ;;
		speedtest-go:*|*:both|*:) backend_direction_flag=both ;;
		*:download) backend_direction_flag=download-only ;;
		*:upload) backend_direction_flag=upload-only ;;
	esac
	printf '{"download_kbps":%s,"upload_kbps":%s,"download_bytes":%s,"upload_bytes":%s,"download_elapsed_s":%s,"upload_elapsed_s":%s,"test_direction":"%s","backend_direction_flag":"%s","source":"%s","backend":"%s","backend_title":"%s","server_id":"%s","server_name":"%s","server_sponsor":"%s","bind_mode":"%s","target_interface":"%s","route_interface":"%s","route_mode":"%s","mwan3_member":"%s","route_source_ip":"%s","route_fwmark":"%s","route_table":"%s","route_traffic_proof":{"available":%s,"passed":%s,"rx_bytes":%s,"tx_bytes":%s,"required_rx_bytes":%s,"required_tx_bytes":%s},"external_ip_before":"%s","external_ip_after":"%s","shaper_bypassed":%s,"autorate_paused":%s,"sqm_paused":%s,"sqm_bypass_mode":"%s","warning":"%s"}\n' \
		"$download_kbps" \
		"$upload_kbps" \
		"$download_size" \
		"$upload_size" \
		"$download_elapsed" \
		"$upload_elapsed" \
		"$(json_escape "${direction_override:-both}")" \
		"$(json_escape "$backend_direction_flag")" \
		"$(json_escape "$source")" \
		"$(json_escape "$backend")" \
		"$(json_escape "$(backend_title "$backend")")" \
		"$(json_escape "$test_server_id")" \
		"$(json_escape "$test_server_name")" \
		"$(json_escape "$test_server_sponsor")" \
		"$(json_escape "$bind_mode")" \
		"$(json_escape "$target_if")" \
		"$(json_escape "$route_device")" \
		"$(json_escape "$route_mode")" \
		"$(json_escape "$mwan3_member")" \
		"$(json_escape "$route_source_ip")" \
		"$(json_escape "$route_fwmark")" \
		"$(json_escape "$route_table")" \
		"$([ "$backend" = speedtest-go ] && printf true || printf false)" \
		"${speedtest_route_traffic_proved:-false}" \
		"${speedtest_route_rx_delta:-0}" \
		"${speedtest_route_tx_delta:-0}" \
		"${speedtest_route_rx_required:-0}" \
		"${speedtest_route_tx_required:-0}" \
		"$(json_escape "$external_ip_before")" \
		"$(json_escape "$external_ip_after")" \
		"$calibration_shaper_bypassed" \
		"$calibration_autorate_paused" \
		"$calibration_sqm_paused" \
		"$(json_escape "${calibration_sqm_bypass_mode:-none}")" \
		"$(json_escape "$warning")"
}

run_available_backends() {
	local candidate

	for candidate in librespeed-cli speedtest-go iperf3 builtin-http; do
		backend_available "$candidate" || continue

		case "$candidate" in
			librespeed-cli)
				run_librespeed_cli && return 0
				;;
			speedtest-go)
				run_speedtest_go && return 0
				;;
			iperf3)
				run_iperf3 && return 0
				;;
			builtin-http)
				run_builtin_http && return 0
				;;
		esac
		[ -z "$speedtest_route_proof_error" ] || return 1

		append_warning "$(backend_title "$candidate") backend failed; trying next backend."
	done

	return 1
}

run_backend() {
	case "$1" in
		librespeed-cli)
			run_librespeed_cli
			;;
		speedtest-go)
			run_speedtest_go
			;;
		iperf3)
			run_iperf3
			;;
		builtin-http)
			run_builtin_http
			;;
		*)
			return 1
			;;
	esac
}

run_preferred_backend() {
	if [ "$preferred_backend" = "auto" ]; then
		run_available_backends
		return $?
	fi

	if ! backend_available "$preferred_backend"; then
		json_error "$(backend_title "$preferred_backend") backend is not available: $(backend_reason "$preferred_backend"). $(backend_install_hint "$preferred_backend")"
	fi

	if run_backend "$preferred_backend"; then
		return 0
	fi
	[ -z "$speedtest_route_proof_error" ] || json_error "$speedtest_route_proof_error"

	json_error "$(backend_title "$preferred_backend") backend failed"
}

speedtest_job_dir="${CAKE_AUTORATE_SPEEDTEST_JOB_DIR:-/tmp/cake-autorate-speedtest}"

acquire_interface_lock() {
	local requested_owner requested_start requested_token requested_journal lock_rc

	safe_route_name "$target_if" || json_error "Invalid target interface for speed test lock."
	command -v runtime_lock_acquire_interface >/dev/null 2>&1 ||
		json_error "The shared CAKE/SQM runtime-lock helper is unavailable."
	requested_owner="${CAKE_AUTORATE_INTERFACE_LOCK_OWNER:-}"
	requested_start="${CAKE_AUTORATE_INTERFACE_LOCK_STARTTIME:-}"
	requested_token="${CAKE_AUTORATE_INTERFACE_LOCK_TOKEN:-}"
	requested_journal="${CAKE_AUTORATE_INTERFACE_LOCK_RECOVERY_JOURNAL:-}"
	if [ -n "$requested_owner$requested_start$requested_token$requested_journal" ]; then
		is_positive_uint "$requested_owner" && is_positive_uint "$requested_start" &&
			[ -n "$requested_token" ] ||
			json_error "Parent interface-lock identity is incomplete."
		[ "${CAKE_AUTORATE_RUNTIME_GLOBAL_LOCK_FD:-}" = 8 ] ||
			json_error "Parent global runtime-lock identity is incomplete."
		if ! runtime_lock_ensure_global_shared; then
			json_error "Parent global runtime lock does not match its inherited descriptor."
		fi
		if runtime_lock_borrow_interface "$target_if" "$requested_owner" "$requested_start" \
		   "$requested_token" "$requested_journal"; then
			interface_lock_shared=1
			interface_lock_dir="$runtime_interface_lock_record"
			return 0
		fi
		json_error "Parent interface-lock identity or inherited kernel lock does not match."
	fi
	runtime_lock_acquire_global_shared || {
		lock_rc="$?"
		[ "$lock_rc" -eq 75 ] && json_error "CAKE/SQM service mutation is already in progress."
		json_error "Unable to acquire the global CAKE/SQM runtime lock."
	}
	runtime_lock_acquire_interface "$target_if" speedtest "" || {
		lock_rc="$?"
		runtime_lock_release_global >/dev/null 2>&1 || true
		case "$lock_rc" in
			75) json_error "Another heavy speed test is already using $target_if." ;;
			76) json_error "Full Auto-Tune recovery is pending for $target_if." ;;
			*) json_error "Unable to establish an atomic speed-test interface lock." ;;
		esac
	}
	interface_lock_dir="$runtime_interface_lock_record"
}

release_interface_lock() {
	[ -n "$interface_lock_dir" ] || return 0
	[ "${interface_lock_shared:-0}" = 1 ] && return 0
	if [ "${standalone_recovery_armed:-0}" = 1 ] &&
	   [ "${standalone_recovery_phase:-armed}" != restored ]; then
		return 1
	fi
	if [ "${standalone_recovery_armed:-0}" = 1 ] &&
	   ! standalone_recovery_supervisor_alive; then
		# Restoration is complete, so a supervisor which died before garbage
		# collection no longer represents an obligation. Remove its tmpfs-only
		# metadata while the owner still holds both authoritative locks.
		remove_managed_sqm_snapshot || return 1
		rm -f "$standalone_recovery_journal" "${standalone_recovery_ready_file:-}" || return 1
		standalone_recovery_armed=0
	fi
	runtime_lock_release_interface || return 1
	runtime_lock_release_global || return 1
	interface_lock_dir=""
	interface_lock_shared=0
}

speedtest_job_paths() {
	job_key="$1"
	job_mutex_file="$speedtest_job_dir/$job_key.start.lock"
	job_pid_file="$speedtest_job_dir/$job_key.pid"
	job_result_file="$speedtest_job_dir/$job_key.result"
	job_error_file="$speedtest_job_dir/$job_key.error"
	job_work_file="$speedtest_job_dir/$job_key.work"
	job_stderr_file="$speedtest_job_dir/$job_key.stderr"
	job_log_file="$speedtest_job_dir/$job_key.log"
}

speedtest_job_record_load() {
	local file="$1" line key value seen=""

	[ -f "$file" ] && [ ! -L "$file" ] || return 1
	job_record_version=""
	job_record_pid=""
	job_record_start=""
	job_record_key=""
	while IFS= read -r line || [ -n "$line" ]; do
		case "$line" in *=*) ;; *) return 1 ;; esac
		key="${line%%=*}"
		value="${line#*=}"
		case " $seen " in *" $key "*) return 1 ;; esac
		case "$key" in
			version) job_record_version="$value" ;;
			pid) job_record_pid="$value" ;;
			start) job_record_start="$value" ;;
			job_key) job_record_key="$value" ;;
			*) return 1 ;;
		esac
		seen="${seen}${seen:+ }$key"
	done < "$file"
	[ "$job_record_version" = 1 ] && is_positive_uint "$job_record_pid" &&
		is_positive_uint "$job_record_start" && [ "$job_record_key" = "$job_key" ]
}

speedtest_job_cmdline_matches() {
	local pid="$1"

	[ -r "/proc/$pid/cmdline" ] || return 1
	tr '\000' '\n' < "/proc/$pid/cmdline" | awk \
		-v self="$speedtest_self" -v section="$section" -v target="$target_if_override" \
		-v backend="$preferred_backend" -v key="$job_key" '
		$0 == self { state = 1; next }
		state == 1 && $0 == section { state = 2; next }
		state == 2 && $0 == target { state = 3; next }
		state == 3 && $0 == "job-run" { state = 4; next }
		state == 4 && $0 == backend { state = 5; next }
		state == 5 && $0 == key { state = 6; exit }
		END { exit !(state == 6) }'
}

speedtest_job_record_matches_process() {
	local pid="$1" start="$2"

	speedtest_process_identity_matches "$pid" "$start" &&
		speedtest_job_cmdline_matches "$pid"
}

speedtest_job_record_write() {
	local pid="$1" start="$2" tmp="$job_pid_file.tmp.$$"

	if {
		printf 'version=1\n'
		printf 'pid=%s\n' "$pid"
		printf 'start=%s\n' "$start"
		printf 'job_key=%s\n' "$job_key"
	} > "$tmp" && mv "$tmp" "$job_pid_file"; then
		return 0
	fi
	rm -f "$tmp" 2>/dev/null || true
	return 1
}

speedtest_job_record_matches_self() {
	speedtest_job_record_load "$job_pid_file" &&
		[ "$job_record_pid" = "$$" ] &&
		speedtest_process_identity_matches "$$" "$job_record_start" &&
		speedtest_job_cmdline_matches "$$"
}

speedtest_job_start() {
	local setsid_bin flock_bin job_pid job_start i=0

	job_key="$section"
	safe_uci_name "$job_key" || json_error "Invalid speed test job name."
	setsid_bin="$(command_path setsid)"
	[ -n "$setsid_bin" ] || json_error "The setsid command is required to run speed tests safely."
	mkdir -p "$speedtest_job_dir" || json_error "Unable to create speed test job directory."
	[ -d "$speedtest_job_dir" ] && [ ! -L "$speedtest_job_dir" ] ||
		json_error "Speed test job directory is unsafe."
	chmod 700 "$speedtest_job_dir" 2>/dev/null || true
	speedtest_job_paths "$job_key"
	flock_bin="${CAKE_AUTORATE_RUNTIME_FLOCK:-flock}"
	command -v "$flock_bin" >/dev/null 2>&1 || json_error "The flock command is required for speed test jobs."
	exec 6>>"$job_mutex_file" || json_error "Unable to open the speed test start lock."
	"$flock_bin" -x 6 || json_error "Unable to serialize speed test startup."

	if speedtest_job_record_load "$job_pid_file"; then
		if speedtest_job_record_matches_process "$job_record_pid" "$job_record_start"; then
			printf '{"state":"running","job_id":"%s"}\n' "$(json_escape "$job_key")"
			"$flock_bin" -u 6
			exec 6>&-
			return 0
		fi
	fi

	rm -f "$job_pid_file" "$job_result_file" "$job_error_file" "$job_work_file" "$job_stderr_file" "$job_log_file"
	CAKE_AUTORATE_SPEEDTEST_JOB_START_STOPPED=1 \
		"$setsid_bin" "$speedtest_self" "$section" "$target_if_override" job-run "$preferred_backend" "$job_key" "$route_mode_override" "$mwan3_member_override" \
		6>&- </dev/null >"$job_log_file" 2>&1 &
	job_pid="$!"
	while [ "$i" -lt 100 ]; do
		job_start="$(speedtest_process_starttime "$job_pid" 2>/dev/null)"
		if is_positive_uint "$job_start" && process_is_stopped "$job_pid" &&
		   speedtest_job_cmdline_matches "$job_pid"; then
			break
		fi
		kill -0 "$job_pid" 2>/dev/null || break
		i=$((i + 1))
		brief_sleep 0.05
	done
	if ! is_positive_uint "${job_start:-}" || ! process_is_stopped "$job_pid" ||
	   ! speedtest_job_cmdline_matches "$job_pid"; then
		kill -KILL "$job_pid" 2>/dev/null || true
		wait "$job_pid" 2>/dev/null || true
		"$flock_bin" -u 6
		exec 6>&-
		json_error "Speed test worker could not complete its verified launch handshake."
	fi
	if ! speedtest_job_record_write "$job_pid" "$job_start"; then
		kill -KILL "$job_pid" 2>/dev/null || true
		wait "$job_pid" 2>/dev/null || true
		"$flock_bin" -u 6
		exec 6>&-
		json_error "Unable to publish the verified speed test worker identity."
	fi
	if ! kill -CONT "$job_pid" 2>/dev/null; then
		if speedtest_job_record_load "$job_pid_file" &&
		   [ "$job_record_pid" = "$job_pid" ] && [ "$job_record_start" = "$job_start" ]; then
			rm -f "$job_pid_file"
		fi
		kill -KILL "$job_pid" 2>/dev/null || true
		wait "$job_pid" 2>/dev/null || true
		"$flock_bin" -u 6
		exec 6>&-
		json_error "Verified speed test worker could not be resumed."
	fi
	printf '{"state":"running","job_id":"%s"}\n' "$(json_escape "$job_key")"
	"$flock_bin" -u 6
	exec 6>&-
}

speedtest_job_run() {
	job_key="$1"
	safe_uci_name "$job_key" || exit 1
	mkdir -p "$speedtest_job_dir" || exit 1
	speedtest_job_paths "$job_key"
	speedtest_job_record_matches_self || exit 1

	"$0" "$section" "$target_if_override" run "$preferred_backend" "" "$route_mode_override" "$mwan3_member_override" >"$job_work_file" 2>"$job_stderr_file"
	job_rc="$?"

	if [ "$job_rc" -eq 0 ] && [ -s "$job_work_file" ]; then
		mv "$job_work_file" "$job_result_file"
		rm -f "$job_stderr_file"
	else
		if [ -s "$job_work_file" ]; then
			mv "$job_work_file" "$job_error_file"
		elif [ -s "$job_stderr_file" ]; then
			printf '{"error":"%s"}\n' "$(json_escape "$(sed -n '1p' "$job_stderr_file")")" > "$job_error_file"
		else
			printf '{"error":"Speed test job failed."}\n' > "$job_error_file"
		fi
		rm -f "$job_work_file"
	fi

	if speedtest_job_record_matches_self; then
		rm -f "$job_pid_file"
	fi
}

speedtest_job_status() {
	job_key="$section"
	safe_uci_name "$job_key" || json_error "Invalid speed test job name."
	speedtest_job_paths "$job_key"

	if [ -s "$job_result_file" ]; then
		cat "$job_result_file"
		return 0
	fi

	if [ -s "$job_error_file" ]; then
		cat "$job_error_file"
		return 0
	fi

	if speedtest_job_record_load "$job_pid_file"; then
		if speedtest_job_record_matches_process "$job_record_pid" "$job_record_start"; then
			printf '{"state":"running","job_id":"%s"}\n' "$(json_escape "$job_key")"
			return 0
		fi
	fi

	printf '{"error":"Speed test job is not running."}\n'
}

