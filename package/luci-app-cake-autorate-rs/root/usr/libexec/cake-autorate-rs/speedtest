[ -n "$mwan3_member_override" ] && mwan3_member="$mwan3_member_override"
[ -n "$external_ip_url" ] || external_ip_url="https://api.ipify.org"
[ -n "$backend_override" ] && preferred_backend="$backend_override"
valid_backend "$preferred_backend" || preferred_backend="auto"

