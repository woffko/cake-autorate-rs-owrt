	restore_speedtest_calibration
	if ! inspect_selected_route; then
		json_error "Selected route failed after speed test: ${route_error:-unavailable}."
	fi
	if [ "$route_identity" != "$route_identity_before" ]; then
		json_error "Selected route identity changed during speed test."
	fi
	external_ip_after="$(fetch_external_ip)"
	if [ -z "$external_ip_after" ] || [ "$external_ip_after" != "$external_ip_before" ]; then
		json_error "External IP changed or could not be verified after speed test."
	fi
	emit_result
	exit 0
fi

