download_url="$(uci_get speedtest_download_url)"
upload_url="$(uci_get speedtest_upload_url)"
bind_interface_enabled="$(uci_get speedtest_bind_interface)"
force_ipv4_enabled="$(uci_get speedtest_force_ipv4)"
