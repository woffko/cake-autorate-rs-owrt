#!/bin/sh

state_root="${CAKE_AUTOTUNE_SCHEDULER_STATE_ROOT:-/var/run/cake-autorate-autotune-scheduler}"
helper="${CAKE_AUTOTUNE_HELPER:-/usr/libexec/cake-autorate-rs/autotune}"
service="${CAKE_AUTOTUNE_SERVICE:-/etc/init.d/cake-autorate}"
route_helper="${CAKE_AUTOTUNE_ROUTE_HELPER:-/usr/libexec/cake-autorate-rs/speedtest}"
sqm_health_helper="${CAKE_AUTOTUNE_SQM_HEALTH_HELPER:-/usr/libexec/cake-autorate-rs/sqm-recover}"
daemon_bin="${CAKE_AUTOTUNE_DAEMON:-/usr/sbin/cake-autorated}"
proc_root="${CAKE_AUTOTUNE_PROC_ROOT:-/proc}"
runtime_lock_lib="${CAKE_AUTORATE_RUNTIME_LOCK_LIB:-/usr/libexec/cake-autorate-rs/runtime-lock}"
runtime_lock_available=0
sleep_s=60
retry_delay_s="${CAKE_AUTOTUNE_SCHEDULER_RETRY_DELAY_S:-900}"
poll_interval_s="${CAKE_AUTOTUNE_SCHEDULER_POLL_INTERVAL_S:-5}"
job_timeout_s="${CAKE_AUTOTUNE_SCHEDULER_JOB_TIMEOUT_S:-1800}"
recovery_root="$state_root/recovery"
autotune_result_producer="cake-autorate-rs-autotune"
absent_candidate_marker="__CAKE_AUTOTUNE_OPTION_ABSENT__"

mkdir -p "$state_root"

case "$retry_delay_s" in ''|*[!0-9]*) retry_delay_s=900 ;; esac
case "$poll_interval_s" in ''|*[!0-9]*) poll_interval_s=5 ;; esac
case "$job_timeout_s" in ''|*[!0-9]*) job_timeout_s=1800 ;; esac
[ "$retry_delay_s" -ge 60 ] 2>/dev/null || retry_delay_s=60
[ "$poll_interval_s" -ge 1 ] 2>/dev/null || poll_interval_s=1
[ "$poll_interval_s" -le 60 ] 2>/dev/null || poll_interval_s=60
[ "$job_timeout_s" -ge 60 ] 2>/dev/null || job_timeout_s=60

if [ -r "$runtime_lock_lib" ]; then
	# shellcheck source=/usr/libexec/cake-autorate-rs/runtime-lock
	. "$runtime_lock_lib"
	runtime_lock_available=1
fi

json_escape() {
	printf '%s' "$1" | tr '\n\r\t' '   ' | sed 's/\\/\\\\/g; s/"/\\"/g'
}

write_state() {
	section="$1"
	state="$2"
	message="$3"
	state_tmp="$state_root/$section.json.$$"
	printf '{"state":"%s","message":"%s","updated_at":%s}\n' \
		"$(json_escape "$state")" "$(json_escape "$message")" "$(date +%s)" > "$state_tmp" &&
		mv "$state_tmp" "$state_root/$section.json"
}

get_uint() {
	value="$(uci -q get "cake-autorate.$1.$2" 2>/dev/null)"
	case "$value" in ''|*[!0-9]*) value="$3" ;; esac
	printf '%s' "$value"
}

within_window() {
	start="$1"
	end="$2"
	hour="$(date +%H)"
	hour="${hour#0}"
	[ -n "$hour" ] || hour=0
	if [ "$start" -eq "$end" ]; then
		return 0
	elif [ "$start" -lt "$end" ]; then
		[ "$hour" -ge "$start" ] && [ "$hour" -lt "$end" ]
	else
		[ "$hour" -ge "$start" ] || [ "$hour" -lt "$end" ]
	fi
}

interface_bytes() {
	interface="$1"
	rx="$(sed -n '1p' "/sys/class/net/$interface/statistics/rx_bytes" 2>/dev/null)"
	tx="$(sed -n '1p' "/sys/class/net/$interface/statistics/tx_bytes" 2>/dev/null)"
	case "$rx:$tx" in *[!0-9:]*) return 1 ;; esac
	printf '%s' "$((rx + tx))"
}

resolve_interface() {
	name="$1"
	if [ -e "/sys/class/net/$name" ]; then
		printf '%s' "$name"
		return 0
	fi
	status="$(ubus call "network.interface.$name" status 2>/dev/null)"
	device="$(printf '%s' "$status" | jsonfilter -e '@.l3_device' 2>/dev/null)"
	[ -n "$device" ] || device="$(printf '%s' "$status" | jsonfilter -e '@.device' 2>/dev/null)"
	[ -e "/sys/class/net/$device" ] || return 1
	printf '%s' "$device"
}

idle_ready() {
	section="$1"
	interface="$2"
	now="$3"
	bytes="$4"
	window="$(get_uint "$section" scheduled_autotune_idle_window_s 60)"
	threshold="$(get_uint "$section" connection_active_thr_kbps 2000)"
	sample="$state_root/$section.idle"
	if [ ! -s "$sample" ]; then
		printf '%s %s\n' "$now" "$bytes" > "$sample"
		return 1
	fi
	read -r previous_at previous_bytes < "$sample"
	case "$previous_at:$previous_bytes" in *[!0-9:]*) previous_at=0; previous_bytes="$bytes" ;; esac
	elapsed="$((now - previous_at))"
	[ "$elapsed" -ge "$window" ] || return 1
	printf '%s %s\n' "$now" "$bytes" > "$sample"
	[ "$bytes" -ge "$previous_bytes" ] || return 1
	rate_kbps="$(((bytes - previous_bytes) * 8 / elapsed / 1000))"
	[ "$rate_kbps" -le "$threshold" ]
}

budget_ready() {
	section="$1"
	limit_mb="$(get_uint "$section" scheduled_autotune_max_traffic_mb_day 4096)"
	day="$(date +%Y%m%d)"
	file="$state_root/$section.budget"
	used=0
	if [ -s "$file" ]; then
		read -r saved_day used < "$file"
		[ "$saved_day" = "$day" ] || used=0
	fi
	case "$used" in ''|*[!0-9]*) used=0 ;; esac
	[ "$used" -lt "$((limit_mb * 1024 * 1024))" ]
}

record_budget() {
	section="$1"
	consumed="$2"
	day="$(date +%Y%m%d)"
	file="$state_root/$section.budget"
	used=0
	if [ -s "$file" ]; then
		read -r saved_day used < "$file"
		[ "$saved_day" = "$day" ] || used=0
	fi
	case "$used:$consumed" in *[!0-9:]*) return ;; esac
	printf '%s %s\n' "$day" "$((used + consumed))" > "$file"
}

extract() {
	jsonfilter -s "$1" -e "$2" 2>/dev/null
}

safe_uci_section() {
	case "$1" in
		''|*[!A-Za-z0-9_]*) return 1 ;;
	esac
}

valid_ipv4() {
	case "$1" in ''|*[!0-9.]*) return 1 ;; esac
	printf '%s\n' "$1" | awk -F. '
		NF != 4 { exit 1 }
		{
			for (i = 1; i <= 4; i++)
				if ($i !~ /^[0-9]+$/ || $i < 0 || $i > 255) exit 1
		}
	'
}

configuration_has_pending_changes() {
	[ -z "$(uci -q changes cake-autorate 2>/dev/null)" ] &&
		[ -z "$(uci -q changes sqm 2>/dev/null)" ]
}

# Hash the exact committed/runtime-visible UCI input that determines one
# autorate instance and the SQM queue it owns.  The Auto-Tune helper emits this
# same fingerprint in its terminal result; the scheduler compares it with the
# pre-run snapshot and recomputes it immediately before commit.
configuration_fingerprint() {
	fingerprint_section="$1"
	safe_uci_section "$fingerprint_section" || return 1
	[ "$(uci -q get "cake-autorate.$fingerprint_section" 2>/dev/null)" = cake_autorate ] || return 1
	fingerprint_sqm_section="$(uci -q get "cake-autorate.$fingerprint_section.sqm_section" 2>/dev/null)"
	[ -n "$fingerprint_sqm_section" ] || fingerprint_sqm_section="cake_$fingerprint_section"
	safe_uci_section "$fingerprint_sqm_section" || return 1
	[ "$(uci -q get "sqm.$fingerprint_sqm_section._cake_autorate_managed" 2>/dev/null)" = "$fingerprint_section" ] || return 1
	command -v sha256sum >/dev/null 2>&1 || return 1

	fingerprint_cake_raw="$(mktemp "$state_root/.fingerprint-cake.XXXXXX")" || return 1
	fingerprint_cake_sorted="$(mktemp "$state_root/.fingerprint-cake-sorted.XXXXXX")" || {
		rm -f "$fingerprint_cake_raw"
		return 1
	}
	fingerprint_sqm_raw="$(mktemp "$state_root/.fingerprint-sqm.XXXXXX")" || {
		rm -f "$fingerprint_cake_raw" "$fingerprint_cake_sorted"
		return 1
	}
	fingerprint_sqm_sorted="$(mktemp "$state_root/.fingerprint-sqm-sorted.XXXXXX")" || {
		rm -f "$fingerprint_cake_raw" "$fingerprint_cake_sorted" "$fingerprint_sqm_raw"
		return 1
	}
	if ! uci -q show "cake-autorate.$fingerprint_section" > "$fingerprint_cake_raw" ||
	   ! LC_ALL=C sort "$fingerprint_cake_raw" > "$fingerprint_cake_sorted" ||
	   ! uci -q show "sqm.$fingerprint_sqm_section" > "$fingerprint_sqm_raw" ||
	   ! LC_ALL=C sort "$fingerprint_sqm_raw" > "$fingerprint_sqm_sorted"; then
		rm -f "$fingerprint_cake_raw" "$fingerprint_cake_sorted" "$fingerprint_sqm_raw" "$fingerprint_sqm_sorted"
		return 1
	fi
	fingerprint_digest="$({
		printf 'cake-autorate:%s\n' "$fingerprint_section"
		cat "$fingerprint_cake_sorted"
		printf 'sqm:%s\n' "$fingerprint_sqm_section"
		cat "$fingerprint_sqm_sorted"
	} | sha256sum 2>/dev/null | awk 'NR == 1 { print $1 }')"
	rm -f "$fingerprint_cake_raw" "$fingerprint_cake_sorted" "$fingerprint_sqm_raw" "$fingerprint_sqm_sorted"
	[ "${#fingerprint_digest}" -eq 64 ] 2>/dev/null || return 1
	case "$fingerprint_digest" in *[!0-9a-f]*) return 1 ;; esac
	printf 'sha256:%s\n' "$fingerprint_digest"
}

is_uint_between() {
	value="$1"
	minimum="$2"
	maximum="$3"
	case "$value" in ''|*[!0-9]*) return 1 ;; esac
	[ "$value" -ge "$minimum" ] 2>/dev/null && [ "$value" -le "$maximum" ] 2>/dev/null
}

is_decimal_between() {
	value="$1"
	minimum="$2"
	maximum="$3"
	case "$value" in
		''|*[!0-9.]*|.*|*..*|*.) return 1 ;;
	esac
	awk -v value="$value" -v minimum="$minimum" -v maximum="$maximum" \
		'BEGIN { exit !(value >= minimum && value <= maximum) }'
}

numbers_equal() {
	is_decimal_between "$1" 0 100000000 || return 1
	is_decimal_between "$2" 0 100000000 || return 1
	awk -v first="$1" -v second="$2" 'BEGIN {
		delta = (first + 0) - (second + 0)
		if (delta < 0) delta = -delta
		exit(delta > 0.000001)
	}'
}

result_has_exact_passing_gates() (
	gate_json="$1"
	gate_codes="$(extract "$gate_json" '@.validation.gates[*].code')" || return 1
	gate_required="$(extract "$gate_json" '@.validation.gates[*].required')" || return 1
	gate_passes="$(extract "$gate_json" '@.validation.gates[*].pass')" || return 1
	gate_actuals="$(extract "$gate_json" '@.validation.gates[*].actual')" || return 1
	gate_limits="$(extract "$gate_json" '@.validation.gates[*].limit')" || return 1
	gate_comparisons="$(extract "$gate_json" '@.validation.gates[*].comparison')" || return 1
	expected_realization_min="$(extract "$gate_json" '@.validation_thresholds.candidate_realization_min_percent')" || return 1
	expected_realization_max="$(extract "$gate_json" '@.validation_thresholds.candidate_realization_max_percent')" || return 1
	expected_retention="$(extract "$gate_json" '@.validation_thresholds.capacity_retention_min_percent')" || return 1
	expected_delay="$(extract "$gate_json" '@.validation_thresholds.delay_max_ms')" || return 1
	expected_loss="$(extract "$gate_json" '@.validation_thresholds.loss_max_percent')" || return 1
	expected_cpu="$(extract "$gate_json" '@.validation_thresholds.cpu_max_percent')" || return 1
	gate_profile="$(extract "$gate_json" '@.profile')" || return 1
	case "$gate_profile" in
		gaming|best_overall) expected_quality_required=true ;;
		fair) expected_quality_required=false ;;
		*) return 1 ;;
	esac
	for expected_gate_limit in "$expected_realization_min" "$expected_realization_max" \
		"$expected_retention" "$expected_delay" "$expected_loss" "$expected_cpu"
	do
		is_decimal_between "$expected_gate_limit" 0.001 100000000 || return 1
	done
	# jsonfilter emits a whitespace-separated vector. Disable pathname expansion
	# inside this subshell before every deliberate tokenization so a hostile gate
	# token can never expand against files in the scheduler working directory.
	set -f
	set -- $gate_codes
	[ "$#" -eq 14 ] || return 1
	gate_seen=" "
	for gate_code in "$@"; do
		case "$gate_code" in
			download-candidate-realization|upload-candidate-realization|\
			download-candidate-realization-maximum|upload-candidate-realization-maximum|\
			download-capacity-retention|upload-capacity-retention|\
			download-icmp-latency|download-transport-latency|\
			download-packet-loss|download-cpu|\
			upload-icmp-latency|upload-transport-latency|\
			upload-packet-loss|upload-cpu) ;;
			*) return 1 ;;
		esac
		case "$gate_seen" in *" $gate_code "*) return 1 ;; esac
		gate_seen="$gate_seen$gate_code "
	done
	for required_gate in \
		download-candidate-realization upload-candidate-realization \
		download-candidate-realization-maximum upload-candidate-realization-maximum \
		download-capacity-retention upload-capacity-retention \
		download-icmp-latency download-transport-latency \
		download-packet-loss download-cpu \
		upload-icmp-latency upload-transport-latency \
		upload-packet-loss upload-cpu
	do
		case "$gate_seen" in *" $required_gate "*) ;; *) return 1 ;; esac
	done
	set -- $gate_passes
	[ "$#" -eq 14 ] || return 1
	for gate_pass in "$@"; do [ "$gate_pass" = true ] || return 1; done
	set -- $gate_required
	[ "$#" -eq 14 ] || return 1
	for required_flag in "$@"; do
		case "$required_flag" in true|false) ;; *) return 1 ;; esac
	done
	set -- $gate_actuals
	[ "$#" -eq 14 ] || return 1
	for gate_actual in "$@"; do is_decimal_between "$gate_actual" 0 100000000 || return 1; done
	set -- $gate_limits
	[ "$#" -eq 14 ] || return 1
	for gate_limit in "$@"; do is_decimal_between "$gate_limit" 0.001 100000000 || return 1; done
	set -- $gate_comparisons
	[ "$#" -eq 14 ] || return 1
	for gate_comparison in "$@"; do
		case "$gate_comparison" in minimum|maximum) ;; *) return 1 ;; esac
	done

	# `pass:true` is not an attestation by itself. Recompute each gate from its
	# actual/limit pair and require the comparison kind dictated by its code.
	awk -v codes="$gate_codes" -v requireds="$gate_required" -v passes="$gate_passes" \
		-v actuals="$gate_actuals" -v limits="$gate_limits" \
		-v comparisons="$gate_comparisons" \
		-v realization_min="$expected_realization_min" \
		-v realization_max="$expected_realization_max" \
		-v retention="$expected_retention" -v delay="$expected_delay" \
		-v loss="$expected_loss" -v cpu="$expected_cpu" \
		-v quality_required="$expected_quality_required" 'BEGIN {
		n = split(codes, code, " ")
		if (split(requireds, required, " ") != n || split(passes, pass, " ") != n ||
		    split(actuals, actual, " ") != n ||
		    split(limits, limit, " ") != n || split(comparisons, comparison, " ") != n)
			exit 1
		for (i = 1; i <= n; i++) {
			expected = (code[i] == "download-candidate-realization" ||
			            code[i] == "upload-candidate-realization" ||
			            code[i] == "download-capacity-retention" ||
			            code[i] == "upload-capacity-retention") ? "minimum" : "maximum"
			is_latency = (code[i] == "download-icmp-latency" ||
			              code[i] == "download-transport-latency" ||
			              code[i] == "upload-icmp-latency" ||
			              code[i] == "upload-transport-latency")
			expected_required = is_latency ? quality_required : "true"
			if (required[i] != expected_required)
				exit 1
			if (pass[i] != "true" || comparison[i] != expected)
				exit 1
			if (code[i] == "download-candidate-realization" ||
			    code[i] == "upload-candidate-realization")
				expected_limit = realization_min
			else if (code[i] == "download-candidate-realization-maximum" ||
			         code[i] == "upload-candidate-realization-maximum")
				expected_limit = realization_max
			else if (code[i] == "download-capacity-retention" ||
			         code[i] == "upload-capacity-retention")
				expected_limit = retention
			else if (code[i] == "download-icmp-latency" ||
			         code[i] == "download-transport-latency" ||
			         code[i] == "upload-icmp-latency" ||
			         code[i] == "upload-transport-latency")
				expected_limit = delay
			else if (code[i] == "download-packet-loss" ||
			         code[i] == "upload-packet-loss")
				expected_limit = loss
			else
				expected_limit = cpu
			delta = (limit[i] + 0) - (expected_limit + 0)
			if (delta < 0) delta = -delta
			if (delta > 0.000001)
				exit 1
			if (expected == "minimum" && actual[i] + 0 < limit[i] + 0)
				exit 1
			if (expected == "maximum" && actual[i] + 0 > limit[i] + 0)
				exit 1
		}
		exit 0
	}'
)

result_proposal_is_safe() {
	proposal_json="$1"
	result_profile="$(extract "$proposal_json" '@.profile')"
	proposal_schema="$(extract "$proposal_json" '@.proposal.schema_version')"
	proposal_profile="$(extract "$proposal_json" '@.proposal.profile')"
	proposal_target_grade="$(extract "$proposal_json" '@.proposal.target_grade')"
	proposal_quality_required="$(extract "$proposal_json" '@.proposal.quality_target_required')"
	proposal_throughput_priority="$(extract "$proposal_json" '@.proposal.throughput_priority')"
	[ "$proposal_schema" = 3 ] && [ "$result_profile" = "$proposal_profile" ] || return 1
	case "$result_profile" in gaming|best_overall|fair) ;; *) return 1 ;; esac
	dl_min="$(extract "$proposal_json" '@.proposal.download.minimum_kbps')"
	dl_base="$(extract "$proposal_json" '@.proposal.download.base_kbps')"
	dl_max="$(extract "$proposal_json" '@.proposal.download.maximum_kbps')"
	dl_cap="$(extract "$proposal_json" '@.proposal.download.absolute_cap_kbps')"
	dl_low="$(extract "$proposal_json" '@.proposal.download.observed_low_kbps')"
	dl_median="$(extract "$proposal_json" '@.proposal.download.observed_median_kbps')"
	dl_high="$(extract "$proposal_json" '@.proposal.download.observed_high_kbps')"
	ul_min="$(extract "$proposal_json" '@.proposal.upload.minimum_kbps')"
	ul_base="$(extract "$proposal_json" '@.proposal.upload.base_kbps')"
	ul_max="$(extract "$proposal_json" '@.proposal.upload.maximum_kbps')"
	ul_cap="$(extract "$proposal_json" '@.proposal.upload.absolute_cap_kbps')"
	ul_low="$(extract "$proposal_json" '@.proposal.upload.observed_low_kbps')"
	ul_median="$(extract "$proposal_json" '@.proposal.upload.observed_median_kbps')"
	ul_high="$(extract "$proposal_json" '@.proposal.upload.observed_high_kbps')"
	active_threshold="$(extract "$proposal_json" '@.proposal.active_threshold_kbps')"
	adjust_up="$(extract "$proposal_json" '@.proposal.thresholds_ms.adjust_up')"
	delay_threshold="$(extract "$proposal_json" '@.proposal.thresholds_ms.delay')"
	adjust_down="$(extract "$proposal_json" '@.proposal.thresholds_ms.adjust_down')"
	adaptive_hold="$(extract "$proposal_json" '@.proposal.adaptive_ceiling.hold_s')"
	adaptive_growth="$(extract "$proposal_json" '@.proposal.adaptive_ceiling.growth_percent')"
	adaptive_probe="$(extract "$proposal_json" '@.proposal.adaptive_ceiling.probe_s')"
	adaptive_cooldown="$(extract "$proposal_json" '@.proposal.adaptive_ceiling.cooldown_s')"
	adaptive_ttl="$(extract "$proposal_json" '@.proposal.adaptive_ceiling.failed_bound_ttl_s')"
	link_overhead="$(extract "$proposal_json" '@.proposal.link.overhead')"
	link_mpu="$(extract "$proposal_json" '@.proposal.link.mpu')"
	link_layer="$(extract "$proposal_json" '@.proposal.link.layer')"
	proposal_confidence="$(extract "$proposal_json" '@.proposal.confidence')"
	validation_realization_min="$(extract "$proposal_json" '@.proposal.validation.candidate_realization_min_percent')"
	validation_realization_max="$(extract "$proposal_json" '@.proposal.validation.candidate_realization_max_percent')"
	validation_retention="$(extract "$proposal_json" '@.proposal.validation.capacity_retention_min_percent')"
	validation_icmp="$(extract "$proposal_json" '@.proposal.validation.icmp_delta_max_ms')"
	validation_transport="$(extract "$proposal_json" '@.proposal.validation.transport_delta_max_ms')"
	validation_loss="$(extract "$proposal_json" '@.proposal.validation.loss_max_percent')"
	validation_cpu="$(extract "$proposal_json" '@.proposal.validation.cpu_max_percent')"
	result_validation_realization_min="$(extract "$proposal_json" '@.validation_thresholds.candidate_realization_min_percent')"
	result_validation_realization_max="$(extract "$proposal_json" '@.validation_thresholds.candidate_realization_max_percent')"
	result_validation_retention="$(extract "$proposal_json" '@.validation_thresholds.capacity_retention_min_percent')"
	result_validation_delay="$(extract "$proposal_json" '@.validation_thresholds.delay_max_ms')"
	result_validation_loss="$(extract "$proposal_json" '@.validation_thresholds.loss_max_percent')"
	result_validation_cpu="$(extract "$proposal_json" '@.validation_thresholds.cpu_max_percent')"
	sqm_qdisc="$(extract "$proposal_json" '@.proposal.sqm.qdisc')"
	sqm_script="$(extract "$proposal_json" '@.proposal.sqm.script')"
	sqm_classification="$(extract "$proposal_json" '@.proposal.sqm.classification')"
	sqm_squash_dscp="$(extract "$proposal_json" '@.proposal.sqm.squash_dscp')"
	sqm_squash_ingress="$(extract "$proposal_json" '@.proposal.sqm.squash_ingress')"
	sqm_ingress_ecn="$(extract "$proposal_json" '@.proposal.sqm.ingress_ecn')"
	sqm_egress_ecn="$(extract "$proposal_json" '@.proposal.sqm.egress_ecn')"
	sqm_iqdisc_opts="$(extract "$proposal_json" '@.proposal.sqm.iqdisc_opts')"
	sqm_eqdisc_opts="$(extract "$proposal_json" '@.proposal.sqm.eqdisc_opts')"

	for rate_value in "$dl_min" "$dl_base" "$dl_max" "$dl_cap" "$dl_low" "$dl_median" "$dl_high" \
		"$ul_min" "$ul_base" "$ul_max" "$ul_cap" "$ul_low" "$ul_median" "$ul_high"
	do
		is_uint_between "$rate_value" 100 100000000 || return 1
	done
	[ "$dl_min" -le "$dl_base" ] && [ "$dl_base" -le "$dl_max" ] && [ "$dl_max" -le "$dl_cap" ] || return 1
	[ "$ul_min" -le "$ul_base" ] && [ "$ul_base" -le "$ul_max" ] && [ "$ul_max" -le "$ul_cap" ] || return 1
	[ "$dl_low" -le "$dl_median" ] && [ "$dl_median" -le "$dl_high" ] && [ "$dl_high" -le "$dl_cap" ] || return 1
	[ "$ul_low" -le "$ul_median" ] && [ "$ul_median" -le "$ul_high" ] && [ "$ul_high" -le "$ul_cap" ] || return 1
	is_uint_between "$active_threshold" 1 20000 || return 1
	[ "$active_threshold" -le "$dl_min" ] && [ "$active_threshold" -le "$ul_min" ] || return 1
	is_uint_between "$adjust_up" 1 200 || return 1
	is_uint_between "$delay_threshold" 1 1000 || return 1
	is_uint_between "$adjust_down" 1 5000 || return 1
	[ "$adjust_up" -le "$delay_threshold" ] && [ "$delay_threshold" -le "$adjust_down" ] || return 1
	is_uint_between "$adaptive_hold" 1 86400 || return 1
	is_decimal_between "$adaptive_growth" 0.1 10 || return 1
	is_uint_between "$adaptive_probe" 1 3600 || return 1
	is_uint_between "$adaptive_cooldown" 0 86400 || return 1
	is_uint_between "$adaptive_ttl" 1 604800 || return 1
	is_uint_between "$link_overhead" 0 1500 || return 1
	is_uint_between "$link_mpu" 0 65535 || return 1
	is_uint_between "$proposal_confidence" 1 100 || return 1
	case "$link_layer" in none|ethernet|atm) ;; *) return 1 ;; esac
	numbers_equal "$validation_realization_min" 80 || return 1
	numbers_equal "$validation_realization_max" 110 || return 1
	numbers_equal "$validation_cpu" 85 || return 1
	numbers_equal "$result_validation_realization_min" "$validation_realization_min" || return 1
	numbers_equal "$result_validation_realization_max" "$validation_realization_max" || return 1
	numbers_equal "$result_validation_retention" "$validation_retention" || return 1
	numbers_equal "$result_validation_delay" "$validation_transport" || return 1
	numbers_equal "$result_validation_loss" "$validation_loss" || return 1
	numbers_equal "$result_validation_cpu" "$validation_cpu" || return 1
	numbers_equal "$validation_icmp" "$validation_transport" || return 1
	[ "$sqm_qdisc" = cake ] && [ "$sqm_ingress_ecn" = ECN ] &&
		[ "$sqm_egress_ecn" = NOECN ] || return 1
	case "$result_profile" in
		gaming)
			[ "$proposal_target_grade" = A+ ] &&
				[ "$proposal_quality_required" = true ] &&
				[ "$proposal_throughput_priority" = false ] &&
				numbers_equal "$validation_retention" 70 &&
				numbers_equal "$validation_transport" 5 &&
				numbers_equal "$validation_loss" 1 &&
				[ "$sqm_script" = layer_cake.qos ] &&
				[ "$sqm_classification" = diffserv4 ] &&
				[ "$sqm_squash_dscp" = false ] &&
				[ "$sqm_squash_ingress" = false ] &&
				[ "$sqm_iqdisc_opts" = diffserv4 ] &&
				[ "$sqm_eqdisc_opts" = diffserv4 ] || return 1
			;;
		best_overall)
			[ "$proposal_target_grade" = A ] &&
				[ "$proposal_quality_required" = true ] &&
				[ "$proposal_throughput_priority" = false ] &&
				numbers_equal "$validation_retention" 80 &&
				numbers_equal "$validation_transport" 30 &&
				numbers_equal "$validation_loss" 3 || return 1
			;;
		fair)
			[ "$proposal_target_grade" = C ] &&
				[ "$proposal_quality_required" = false ] &&
				[ "$proposal_throughput_priority" = true ] &&
				numbers_equal "$validation_retention" 90 &&
				numbers_equal "$validation_transport" 200 &&
				numbers_equal "$validation_loss" 5 || return 1
			;;
	esac
	case "$result_profile" in
		best_overall|fair)
			[ "$sqm_script" = piece_of_cake.qos ] &&
				[ "$sqm_classification" = besteffort ] &&
				[ "$sqm_squash_dscp" = true ] &&
				[ "$sqm_squash_ingress" = true ] &&
				[ -z "$sqm_iqdisc_opts" ] &&
				[ -z "$sqm_eqdisc_opts" ] || return 1
			;;
	esac
}

route_attestation_matches_result() {
	attestation_section="$1"
	attestation_interface="$2"
	attestation_result="$3"
	[ -x "$route_helper" ] || return 1
	attestation_json="$(CAKE_AUTORATE_ROUTE_STATUS_TIMEOUT_S=5 \
		"$route_helper" "$attestation_section" "$attestation_interface" route-status auto 2>/dev/null)" || return 1
	[ "$(extract "$attestation_json" '@.state')" = ready ] || return 1
	[ "$(extract "$attestation_json" '@.schema_version')" = 1 ] || return 1
	for attestation_field in target_interface resolved_interface route_interface route_mode mwan3_member source_ip external_ip route_identity; do
		attestation_value="$(extract "$attestation_json" "@.$attestation_field")"
		case "$attestation_field" in source_ip|external_ip) valid_ipv4 "$attestation_value" || return 1 ;; esac
		case "$attestation_field" in
			target_interface) result_value="$(extract "$attestation_result" '@.target_interface')" ;;
			resolved_interface) result_value="$(extract "$attestation_result" '@.resolved_interface')" ;;
			route_interface) result_value="$(extract "$attestation_result" '@.route_interface')" ;;
			route_mode) result_value="$(extract "$attestation_result" '@.route_mode')" ;;
			mwan3_member) result_value="$(extract "$attestation_result" '@.mwan3_member')" ;;
			source_ip) result_value="$(extract "$attestation_result" '@.source_ip')" ;;
			external_ip) result_value="$(extract "$attestation_result" '@.external_ip')" ;;
			route_identity) result_value="$(extract "$attestation_result" '@.route_identity')" ;;
		esac
		[ "$attestation_value" = "$result_value" ] || return 1
	done
}

daemon_identity_healthy() {
	health_section="$1"
	daemon_expected="$(uci -q get "cake-autorate.$health_section.enabled" 2>/dev/null)"
	[ -x "$daemon_bin" ] || return 1
	daemon_real="$(readlink -f "$daemon_bin" 2>/dev/null)" || return 1
	[ -n "$daemon_real" ] || return 1
	daemon_matches=0
	for daemon_proc in "$proc_root"/[0-9]*; do
		[ -d "$daemon_proc" ] || continue
		[ "$(readlink -f "$daemon_proc/exe" 2>/dev/null)" = "$daemon_real" ] || continue
		[ -r "$daemon_proc/cmdline" ] || continue
		daemon_argv="$(tr '\000' '\n' < "$daemon_proc/cmdline" 2>/dev/null)"
		[ "$daemon_argv" = "$(printf '%s\n--instance\n%s' "$daemon_bin" "$health_section")" ] || continue
		daemon_matches=$((daemon_matches + 1))
	done
	if [ "$daemon_expected" = 1 ]; then
		[ "$daemon_matches" -eq 1 ]
	else
		[ "$daemon_matches" -eq 0 ]
	fi
}

managed_sqm_healthy() {
	health_section="$1"
	[ "$(uci -q get "cake-autorate.$health_section.manage_sqm" 2>/dev/null)" = 1 ] || return 1
	[ "$(uci -q get "cake-autorate.$health_section.sqm_enabled" 2>/dev/null)" = 1 ] || return 1
	[ -x "$sqm_health_helper" ] || return 1
	CAKE_AUTORATE_RUNTIME_GLOBAL_LOCK_BORROW=1 \
		"$sqm_health_helper" "$health_section" >/dev/null 2>&1
}

runtime_health_exact() {
	health_section="$1"
	daemon_identity_healthy "$health_section" && managed_sqm_healthy "$health_section"
}

result_is_auto_apply_eligible() {
	gate_result="$1"
	gate_state="$(extract "$gate_result" '@.state')"
	gate_schema_version="$(extract "$gate_result" '@.schema_version')"
	gate_producer="$(extract "$gate_result" '@.producer')"
	gate_profile="$(extract "$gate_result" '@.profile')"
	gate_validation_profile="$(extract "$gate_result" '@.validation.profile')"
	gate_run_id="$(extract "$gate_result" '@.run_id')"
	gate_validation_pass="$(extract "$gate_result" '@.validation.pass')"
	gate_validation_hard_pass="$(extract "$gate_result" '@.validation.hard_pass')"
	gate_quality_target_met="$(extract "$gate_result" '@.validation.quality_target_met')"
	gate_auto_apply_eligible="$(extract "$gate_result" '@.auto_apply_eligible')"
	gate_manual_apply_eligible="$(extract "$gate_result" '@.manual_apply_eligible')"
	gate_confidence_mode="$(extract "$gate_result" '@.confidence_mode')"
	gate_validation_contaminated="$(extract "$gate_result" '@.validation.contaminated')"
	gate_phase_evidence_complete="$(extract "$gate_result" '@.phase_evidence_complete')"
	gate_phase_contamination_seen="$(extract "$gate_result" '@.phase_contamination_seen')"
	gate_runtime_restored="$(extract "$gate_result" '@.runtime_restored')"
	gate_recovery_pending="$(extract "$gate_result" '@.recovery_pending')"
	gate_configuration_written="$(extract "$gate_result" '@.configuration_written')"
	gate_correction_action="$(extract "$gate_result" '@.validation.correction.action')"
	gate_correction_feasible="$(extract "$gate_result" '@.validation.correction.feasible')"

	# Every field is deliberately mandatory. Missing, malformed, legacy, low-
	# confidence, contaminated, or otherwise unknown evidence must never become
	# a configuration change merely because the helper reported "complete".
	[ "$gate_state" = complete ] || return 1
	[ "$gate_schema_version" = 5 ] || return 1
	[ "$gate_producer" = "$autotune_result_producer" ] || return 1
	[ "$gate_validation_profile" = "$gate_profile" ] || return 1
	case "$gate_run_id" in ''|*[!A-Za-z0-9_-]*) return 1 ;; esac
	[ "${#gate_run_id}" -le 128 ] || return 1
	[ "$gate_validation_pass" = true ] || return 1
	[ "$gate_validation_hard_pass" = true ] || return 1
	[ "$gate_quality_target_met" = true ] || return 1
	[ "$gate_auto_apply_eligible" = true ] || return 1
	[ "$gate_manual_apply_eligible" = true ] || return 1
	[ "$gate_confidence_mode" = normal ] || return 1
	[ "$gate_validation_contaminated" = false ] || return 1
	[ "$gate_phase_evidence_complete" = true ] || return 1
	[ "$gate_phase_contamination_seen" = false ] || return 1
	[ "$gate_runtime_restored" = true ] || return 1
	[ "$gate_recovery_pending" = false ] || return 1
	[ "$gate_configuration_written" = false ] || return 1
	[ "$gate_correction_action" = none ] || return 1
	[ "$gate_correction_feasible" = true ] || return 1
	result_has_exact_passing_gates "$gate_result" || return 1
	result_proposal_is_safe "$gate_result" || return 1
}

result_matches_apply_context() {
	context_section="$1"
	context_interface="$2"
	context_expected_fingerprint="$3"
	context_result="$4"

	result_fingerprint="$(extract "$context_result" '@.config_fingerprint')"
	[ -n "$context_expected_fingerprint" ] && [ "$result_fingerprint" = "$context_expected_fingerprint" ] || return 1
	case "$result_fingerprint" in sha256:*) ;; *) return 1 ;; esac
	result_fingerprint_hex="${result_fingerprint#sha256:}"
	[ "${#result_fingerprint_hex}" -eq 64 ] 2>/dev/null || return 1
	case "$result_fingerprint_hex" in *[!0-9a-f]*) return 1 ;; esac
	[ "$(configuration_fingerprint "$context_section")" = "$context_expected_fingerprint" ] || return 1

	[ "$(extract "$context_result" '@.job_id')" = "$context_section" ] || return 1
	[ "$(extract "$context_result" '@.target_interface')" = "$context_interface" ] || return 1
	[ "$(extract "$context_result" '@.resolved_interface')" = "$context_interface" ] || return 1
	[ "$(extract "$context_result" '@.route_interface')" = "$context_interface" ] || return 1
	result_source_ip="$(extract "$context_result" '@.source_ip')"
	result_external_ip="$(extract "$context_result" '@.external_ip')"
	valid_ipv4 "$result_source_ip" && valid_ipv4 "$result_external_ip" || return 1

	configured_route_mode="$(uci -q get "cake-autorate.$context_section.route_mode" 2>/dev/null)"
	configured_member="$(uci -q get "cake-autorate.$context_section.mwan3_member" 2>/dev/null)"
	[ -n "$configured_route_mode" ] || configured_route_mode=auto
	case "$configured_route_mode" in
		main) expected_route_mode=main; expected_member="" ;;
		mwan3) expected_route_mode=mwan3; expected_member="$configured_member" ;;
		auto)
			if [ -n "$configured_member" ]; then
				expected_route_mode=mwan3
				expected_member="$configured_member"
			else
				expected_route_mode=main
				expected_member=""
			fi
			;;
		*) return 1 ;;
	esac
	[ "$(extract "$context_result" '@.route_mode')" = "$expected_route_mode" ] || return 1
	[ "$(extract "$context_result" '@.mwan3_member')" = "$expected_member" ] || return 1
	result_route_identity="$(extract "$context_result" '@.route_identity')"
	case "$expected_route_mode" in
		main)
			[ "$result_route_identity" = "main||$context_interface|$result_source_ip||main" ] || return 1
			;;
		mwan3)
			route_identity_prefix="mwan3|$expected_member|$context_interface|$result_source_ip|"
			case "$result_route_identity" in "$route_identity_prefix"*) ;; *) return 1 ;; esac
			route_identity_tail="${result_route_identity#"$route_identity_prefix"}"
			case "$route_identity_tail" in *'|'?*) ;; *) return 1 ;; esac
			;;
	esac
}

stage_candidate_option() {
	stage_option="$1"
	stage_value="$2"
	case "$stage_option" in ''|*[!A-Za-z0-9_]*) return 1 ;; esac
	case "$stage_value" in *'|'*|*'
'*) return 1 ;; esac
	[ "$stage_value" != "$absent_candidate_marker" ] || return 1
	if stage_previous="$(uci -q get "cake-autorate.$section.$stage_option" 2>/dev/null)"; then
		stage_present=1
		case "$stage_previous" in *'|'*|*'
'*) return 1 ;; esac
		[ "$stage_previous" != "$absent_candidate_marker" ] || return 1
	else
		stage_present=0
		stage_previous=""
	fi
	printf '%s|%s|%s|%s\n' "$stage_option" "$stage_present" "$stage_previous" "$stage_value" >> "$ownership_journal"
	uci -q -P "$transaction_savedir" set "cake-autorate.$section.$stage_option=$stage_value" || return 1
}

stage_candidate_absent_option() {
	stage_option="$1"
	case "$stage_option" in ''|*[!A-Za-z0-9_]*) return 1 ;; esac
	if stage_previous="$(uci -q get "cake-autorate.$section.$stage_option" 2>/dev/null)"; then
		stage_present=1
		case "$stage_previous" in *'|'*|*'
'*) return 1 ;; esac
		[ "$stage_previous" != "$absent_candidate_marker" ] || return 1
	else
		return 0
	fi
	printf '%s|%s|%s|%s\n' "$stage_option" "$stage_present" "$stage_previous" \
		"$absent_candidate_marker" >> "$ownership_journal"
	uci -q -P "$transaction_savedir" delete "cake-autorate.$section.$stage_option" || return 1
}

prepare_recovery_root() {
	case "$recovery_root" in /tmp/*|/run/*|/var/run/*) ;; *) return 1 ;; esac
	case "$recovery_root" in *'/../'*|*'/..'|*'//'*) return 1 ;; esac
	[ ! -L "$recovery_root" ] || return 1
	mkdir -p "$recovery_root" || return 1
	[ -d "$recovery_root" ] && [ ! -L "$recovery_root" ] || return 1
	chmod 700 "$recovery_root" 2>/dev/null || true
}

safe_transaction_dir() {
	case "$1" in "$recovery_root"/apply-*) ;; *) return 1 ;; esac
	[ -d "$1" ] && [ ! -L "$1" ]
}

write_transaction_meta() {
	meta_dir="$1"
	meta_section="$2"
	meta_interface="$3"
	meta_phase="$4"
	safe_transaction_dir "$meta_dir" || return 1
	safe_uci_section "$meta_section" || return 1
	case "$meta_interface" in ''|*[!A-Za-z0-9_.:@-]*) return 1 ;; esac
	case "$meta_phase" in prepared|commit-intent|candidate-committed|applied|restored) ;; *) return 1 ;; esac
	meta_tmp="$meta_dir/meta.tmp.$$"
	{
		printf 'version=1\n'
		printf 'section=%s\n' "$meta_section"
		printf 'interface=%s\n' "$meta_interface"
		printf 'phase=%s\n' "$meta_phase"
	} > "$meta_tmp" && mv "$meta_tmp" "$meta_dir/meta"
}

load_transaction_meta() {
	load_dir="$1"
	safe_transaction_dir "$load_dir" || return 1
	[ -f "$load_dir/meta" ] && [ ! -L "$load_dir/meta" ] || return 1
	recovery_version=""
	recovery_section=""
	recovery_interface=""
	recovery_phase=""
	recovery_seen=" "
	while IFS= read -r recovery_line || [ -n "$recovery_line" ]; do
		case "$recovery_line" in *=*) ;; *) return 1 ;; esac
		recovery_key="${recovery_line%%=*}"
		recovery_value="${recovery_line#*=}"
		case "$recovery_seen" in *" $recovery_key "*) return 1 ;; esac
		case "$recovery_key" in
			version) recovery_version="$recovery_value" ;;
			section) recovery_section="$recovery_value" ;;
			interface) recovery_interface="$recovery_value" ;;
			phase) recovery_phase="$recovery_value" ;;
			*) return 1 ;;
		esac
		recovery_seen="$recovery_seen$recovery_key "
	done < "$load_dir/meta"
	[ "$recovery_version" = 1 ] || return 1
	safe_uci_section "$recovery_section" || return 1
	case "$recovery_interface" in ''|*[!A-Za-z0-9_.:@-]*) return 1 ;; esac
	case "$recovery_phase" in prepared|commit-intent|candidate-committed|applied|restored) ;; *) return 1 ;; esac
}

remove_transaction_dir() {
	remove_dir="$1"
	safe_transaction_dir "$remove_dir" || return 1
	rm -rf "$remove_dir"
}

restart_service_locked() {
	CAKE_AUTORATE_RUNTIME_GLOBAL_LOCK_BORROW=1 "$service" restart >/dev/null 2>&1
}

recover_apply_transaction_locked() {
	recover_dir="$1"
	load_transaction_meta "$recover_dir" || return 1
	case "$recovery_phase" in
		prepared|applied|restored)
			remove_transaction_dir "$recover_dir"
			return $?
			;;
	esac
	ownership_file="$recover_dir/owned-options"
	[ -s "$ownership_file" ] && [ ! -L "$ownership_file" ] || return 1
	rollback_savedir="$recover_dir/rollback-uci"
	[ ! -e "$rollback_savedir" ] || rm -rf "$rollback_savedir" || return 1
	mkdir -p "$rollback_savedir" || return 1
	rollback_count=0
	rollback_seen=" "
	while IFS='|' read -r rollback_option rollback_present rollback_previous rollback_candidate rollback_extra; do
		[ -z "$rollback_extra" ] || return 1
		case "$rollback_option" in ''|*[!A-Za-z0-9_]*) return 1 ;; esac
		case "$rollback_seen" in *" $rollback_option "*) return 1 ;; esac
		rollback_seen="$rollback_seen$rollback_option "
		case "$rollback_present" in 0|1) ;; *) return 1 ;; esac
		case "$rollback_previous:$rollback_candidate" in *'|'*|*'
'*) return 1 ;; esac
		[ -n "$rollback_candidate" ] || return 1
		[ "$rollback_previous" != "$absent_candidate_marker" ] || return 1
		if rollback_current="$(uci -q get "cake-autorate.$recovery_section.$rollback_option" 2>/dev/null)"; then
			rollback_current_present=1
		else
			rollback_current_present=0
			rollback_current=""
		fi
		if { [ "$rollback_candidate" = "$absent_candidate_marker" ] &&
		     [ "$rollback_current_present" -eq 0 ]; } ||
		   { [ "$rollback_candidate" != "$absent_candidate_marker" ] &&
		     [ "$rollback_current_present" -eq 1 ] &&
		     [ "$rollback_current" = "$rollback_candidate" ]; }; then
			if [ "$rollback_present" -eq 1 ]; then
				uci -q -P "$rollback_savedir" set "cake-autorate.$recovery_section.$rollback_option=$rollback_previous" || return 1
			else
				uci -q -P "$rollback_savedir" delete "cake-autorate.$recovery_section.$rollback_option" || return 1
			fi
			rollback_count=$((rollback_count + 1))
		elif [ "$rollback_present" -eq 1 ] && [ "$rollback_current_present" -eq 1 ] &&
		     [ "$rollback_current" = "$rollback_previous" ]; then
			:
		elif [ "$rollback_present" -eq 0 ] && [ "$rollback_current_present" -eq 0 ]; then
			:
		else
			write_state "$recovery_section" recovery-pending "Automatic apply recovery found a foreign value; no owned setting was overwritten"
			return 1
		fi
	done < "$ownership_file"
	[ "$rollback_seen" != " " ] || return 1
	if [ "$rollback_count" -gt 0 ]; then
		uci -q -P "$rollback_savedir" commit cake-autorate >/dev/null 2>&1 || {
			write_state "$recovery_section" recovery-pending "Unable to commit the scheduler-owned rollback"
			return 1
		}
	fi
	if ! restart_service_locked; then
		write_state "$recovery_section" recovery-pending "Rollback values are restored, but CAKE Autorate restart failed"
		return 1
	fi
	if ! runtime_health_exact "$recovery_section"; then
		write_state "$recovery_section" recovery-pending "Rollback runtime health could not be verified"
		return 1
	fi
	write_transaction_meta "$recover_dir" "$recovery_section" "$recovery_interface" restored || return 1
	remove_transaction_dir "$recover_dir" || return 1
	write_state "$recovery_section" recovered "Interrupted automatic apply was rolled back and runtime health was verified"
}

recovery_transactions_pending() {
	prepare_recovery_root || return 0
	for pending_dir in "$recovery_root"/apply-*; do
		[ -e "$pending_dir" ] && return 0
	done
	return 1
}

recover_pending_transactions() {
	prepare_recovery_root || return 1
	recovery_failed=0
	for pending_dir in "$recovery_root"/apply-*; do
		[ -e "$pending_dir" ] || continue
		if [ "$runtime_lock_available" -ne 1 ]; then
			recovery_failed=1
			continue
		fi
		if ! runtime_lock_acquire_global_exclusive; then
			recovery_failed=1
			continue
		fi
		if ! recover_apply_transaction_locked "$pending_dir"; then
			recovery_failed=1
		fi
		runtime_lock_release_global || recovery_failed=1
	done
	[ "$recovery_failed" -eq 0 ] && ! recovery_transactions_pending
}

apply_result() (
	section="$1"
	result="$2"
	expected_fingerprint="${3:-}"
	expected_interface="${4:-}"
	transaction_dir=""
	transaction_savedir=""
	ownership_journal=""
	apply_lock_held=0
	apply_succeeded=0
	apply_cleanup() {
		apply_cleanup_rc=$?
		if [ "$apply_succeeded" -ne 1 ] && [ -n "$transaction_dir" ] &&
		   [ -d "$transaction_dir" ] && [ "$apply_lock_held" -eq 1 ]; then
			if ! recover_apply_transaction_locked "$transaction_dir"; then
				apply_cleanup_rc=1
			fi
		fi
		if [ "$apply_lock_held" -eq 1 ]; then
			runtime_lock_release_global || apply_cleanup_rc=1
		fi
		trap - EXIT INT TERM
		exit "$apply_cleanup_rc"
	}
	trap apply_cleanup EXIT
	trap 'exit 1' INT TERM

	safe_uci_section "$section" || exit 1
	case "$expected_interface" in ''|*[!A-Za-z0-9_.:@-]*) exit 1 ;; esac
	[ "$runtime_lock_available" -eq 1 ] || exit 1
	result_is_auto_apply_eligible "$result" || exit 1
	runtime_lock_acquire_global_exclusive || exit 1
	apply_lock_held=1
	configuration_has_pending_changes || exit 1
	result_matches_apply_context "$section" "$expected_interface" "$expected_fingerprint" "$result" || exit 1
	route_attestation_matches_result "$section" "$expected_interface" "$result" || exit 1

	prepare_recovery_root || exit 1
	transaction_dir="$(mktemp -d "$recovery_root/apply-$section.XXXXXX")" || exit 1
	transaction_savedir="$transaction_dir/uci"
	mkdir -p "$transaction_savedir" || exit 1
	ownership_journal="$transaction_dir/owned-options"
	: > "$ownership_journal" || exit 1
	write_transaction_meta "$transaction_dir" "$section" "$expected_interface" prepared || exit 1
	dl_min="$(extract "$result" '@.proposal.download.minimum_kbps')"
	dl_base="$(extract "$result" '@.proposal.download.base_kbps')"
	dl_max="$(extract "$result" '@.proposal.download.maximum_kbps')"
	dl_cap="$(extract "$result" '@.proposal.download.absolute_cap_kbps')"
	dl_low="$(extract "$result" '@.proposal.download.observed_low_kbps')"
	dl_median="$(extract "$result" '@.proposal.download.observed_median_kbps')"
	ul_min="$(extract "$result" '@.proposal.upload.minimum_kbps')"
	ul_base="$(extract "$result" '@.proposal.upload.base_kbps')"
	ul_max="$(extract "$result" '@.proposal.upload.maximum_kbps')"
	ul_cap="$(extract "$result" '@.proposal.upload.absolute_cap_kbps')"
	ul_low="$(extract "$result" '@.proposal.upload.observed_low_kbps')"
	ul_median="$(extract "$result" '@.proposal.upload.observed_median_kbps')"
	profile="$(extract "$result" '@.profile')"
	retention="$(extract "$result" '@.proposal.validation.capacity_retention_min_percent')"
	target_delay="$(extract "$result" '@.proposal.validation.transport_delta_max_ms')"
	sqm_qdisc="$(extract "$result" '@.proposal.sqm.qdisc')"
	sqm_script="$(extract "$result" '@.proposal.sqm.script')"
	sqm_squash_dscp="$(extract "$result" '@.proposal.sqm.squash_dscp')"
	sqm_squash_ingress="$(extract "$result" '@.proposal.sqm.squash_ingress')"
	sqm_ingress_ecn="$(extract "$result" '@.proposal.sqm.ingress_ecn')"
	sqm_egress_ecn="$(extract "$result" '@.proposal.sqm.egress_ecn')"
	sqm_iqdisc_opts="$(extract "$result" '@.proposal.sqm.iqdisc_opts')"
	sqm_eqdisc_opts="$(extract "$result" '@.proposal.sqm.eqdisc_opts')"
	result_is_auto_apply_eligible "$result" || exit 1
	configuration_has_pending_changes || exit 1
	result_matches_apply_context "$section" "$expected_interface" "$expected_fingerprint" "$result" || exit 1
	stage_candidate_option min_dl_shaper_rate_kbps "$dl_min" || exit 1
	stage_candidate_option base_dl_shaper_rate_kbps "$dl_base" || exit 1
	stage_candidate_option max_dl_shaper_rate_kbps "$dl_max" || exit 1
	stage_candidate_option min_ul_shaper_rate_kbps "$ul_min" || exit 1
	stage_candidate_option base_ul_shaper_rate_kbps "$ul_base" || exit 1
	stage_candidate_option max_ul_shaper_rate_kbps "$ul_max" || exit 1
	stage_candidate_option sqm_download "$dl_base" || exit 1
	stage_candidate_option sqm_upload "$ul_base" || exit 1
	stage_candidate_option adaptive_ceiling_dl_cap_kbps "$dl_cap" || exit 1
	stage_candidate_option adaptive_ceiling_ul_cap_kbps "$ul_cap" || exit 1
	stage_candidate_option transport_latency_enabled 1 || exit 1
	stage_candidate_option throughput_guard_enabled 1 || exit 1
	stage_candidate_option autotune_profile "$profile" || exit 1
	stage_candidate_option throughput_guard_retention_percent "$retention" || exit 1
	stage_candidate_option quality_target_delay_ms "$target_delay" || exit 1
	stage_candidate_option throughput_reference_dl_p20_kbps "$dl_low" || exit 1
	stage_candidate_option throughput_reference_dl_p50_kbps "$dl_median" || exit 1
	stage_candidate_option throughput_reference_ul_p20_kbps "$ul_low" || exit 1
	stage_candidate_option throughput_reference_ul_p50_kbps "$ul_median" || exit 1

	for pair in \
		"connection_active_thr_kbps @.proposal.active_threshold_kbps" \
		"dl_avg_owd_delta_max_adjust_up_thr_ms @.proposal.thresholds_ms.adjust_up" \
		"ul_avg_owd_delta_max_adjust_up_thr_ms @.proposal.thresholds_ms.adjust_up" \
		"dl_owd_delta_delay_thr_ms @.proposal.thresholds_ms.delay" \
		"ul_owd_delta_delay_thr_ms @.proposal.thresholds_ms.delay" \
		"dl_avg_owd_delta_max_adjust_down_thr_ms @.proposal.thresholds_ms.adjust_down" \
		"ul_avg_owd_delta_max_adjust_down_thr_ms @.proposal.thresholds_ms.adjust_down" \
		"adaptive_ceiling_hold_time_s @.proposal.adaptive_ceiling.hold_s" \
		"adaptive_ceiling_growth_percent @.proposal.adaptive_ceiling.growth_percent" \
		"adaptive_ceiling_probe_duration_s @.proposal.adaptive_ceiling.probe_s" \
		"adaptive_ceiling_cooldown_s @.proposal.adaptive_ceiling.cooldown_s" \
		"adaptive_ceiling_failed_bound_ttl_s @.proposal.adaptive_ceiling.failed_bound_ttl_s" \
		"sqm_overhead @.proposal.link.overhead" \
		"sqm_tcMPU @.proposal.link.mpu"
	do
		set -- $pair
		value="$(extract "$result" "$2")"
		case "$value" in
			''|*[!0-9.]*) exit 1 ;;
		esac
		stage_candidate_option "$1" "$value" || exit 1
	done

	link_layer="$(extract "$result" '@.proposal.link.layer')"
	case "$link_layer" in none|ethernet|atm) ;; *) exit 1 ;; esac
	stage_candidate_option sqm_linklayer "$link_layer" || exit 1
	stage_candidate_option sqm_qdisc "$sqm_qdisc" || exit 1
	stage_candidate_option sqm_script "$sqm_script" || exit 1
	stage_candidate_option sqm_squash_dscp \
		"$([ "$sqm_squash_dscp" = true ] && printf 1 || printf 0)" || exit 1
	stage_candidate_option sqm_squash_ingress \
		"$([ "$sqm_squash_ingress" = true ] && printf 1 || printf 0)" || exit 1
	stage_candidate_option sqm_ingress_ecn "$sqm_ingress_ecn" || exit 1
	stage_candidate_option sqm_egress_ecn "$sqm_egress_ecn" || exit 1
	if [ "$profile" = gaming ]; then
		stage_candidate_option sqm_qdisc_advanced 1 || exit 1
		stage_candidate_option sqm_qdisc_really_really_advanced 1 || exit 1
		stage_candidate_option sqm_iqdisc_opts "$sqm_iqdisc_opts" || exit 1
		stage_candidate_option sqm_eqdisc_opts "$sqm_eqdisc_opts" || exit 1
	else
		stage_candidate_option sqm_qdisc_advanced 0 || exit 1
		stage_candidate_option sqm_qdisc_really_really_advanced 0 || exit 1
		stage_candidate_absent_option sqm_iqdisc_opts || exit 1
		stage_candidate_absent_option sqm_eqdisc_opts || exit 1
	fi

	# The proposal may have spent many seconds in extraction/staging.  Repeat
	# every trust check at the last possible point before the private UCI delta
	# becomes committed state.
	result_is_auto_apply_eligible "$result" || exit 1
	configuration_has_pending_changes || exit 1
	result_matches_apply_context "$section" "$expected_interface" "$expected_fingerprint" "$result" || exit 1
	route_attestation_matches_result "$section" "$expected_interface" "$result" || exit 1
	write_transaction_meta "$transaction_dir" "$section" "$expected_interface" commit-intent || exit 1
	uci -q -P "$transaction_savedir" commit cake-autorate || exit 1
	write_transaction_meta "$transaction_dir" "$section" "$expected_interface" candidate-committed || exit 1

	# The init child explicitly borrows fd 8.  It neither reacquires nor releases
	# the scheduler-owned exclusive lock, so stage/commit/restart is one
	# continuous transaction and cannot deadlock on itself.
	restart_service_locked || exit 1
	runtime_health_exact "$section" || exit 1
	route_attestation_matches_result "$section" "$expected_interface" "$result" || exit 1
	write_transaction_meta "$transaction_dir" "$section" "$expected_interface" applied || exit 1
	apply_succeeded=1
	if ! remove_transaction_dir "$transaction_dir"; then
		# The applied marker is authoritative: commit, restart, exact SQM/daemon
		# health, and route attestation all succeeded. A tmpfs cleanup error must not
		# report the already-live candidate as failed; startup safely removes an
		# applied-phase journal without rolling it back.
		write_state "$section" applied "Validated proposal was applied; stale RAM transaction cleanup is deferred" || true
	fi
	exit 0
)

finish_attempt_accounting() {
	attempt_section="$1"
	attempt_interface="$2"
	attempt_bytes_before="$3"
	attempt_finished_at="$(date +%s)"
	attempt_bytes_after="$(interface_bytes "$attempt_interface" 2>/dev/null || printf '%s' "$attempt_bytes_before")"
	if [ "$attempt_bytes_after" -ge "$attempt_bytes_before" ] 2>/dev/null; then
		record_budget "$attempt_section" "$((attempt_bytes_after - attempt_bytes_before))"
	fi
	attempt_tmp="$state_root/$attempt_section.last-attempt.$$"
	printf '%s\n' "$attempt_finished_at" > "$attempt_tmp" &&
		mv "$attempt_tmp" "$state_root/$attempt_section.last-attempt"
}

run_section() {
	section="$1"
	interface="$2"
	now="$3"
	bytes_before="$4"
	expected_fingerprint="$5"
	backend="$(uci -q get "cake-autorate.$section.speedtest_backend" 2>/dev/null)"
	[ -n "$backend" ] || backend=auto
	profile="$(uci -q get "cake-autorate.$section.autotune_profile" 2>/dev/null)"
	case "$profile" in
		gaming|fair) ;;
		best_overall|best-overall|balanced|'') profile=best_overall ;;
		*)
			write_state "$section" deferred "Scheduled Full Auto-Tune profile is invalid"
			return
			;;
	esac
	configuration_has_pending_changes &&
		[ "$(configuration_fingerprint "$section")" = "$expected_fingerprint" ] || {
			write_state "$section" deferred "Configuration changed before scheduled Full Auto-Tune could start"
			return
		}
	write_state "$section" running "Scheduled Full Auto-Tune is running"
	"$helper" "$section" "$interface" start "$backend" "" "" "$profile" 0 >/dev/null 2>&1 || {
		finish_attempt_accounting "$section" "$interface" "$bytes_before"
		write_state "$section" failed "Unable to start scheduled Full Auto-Tune"
		return
	}

	deadline="$((now + job_timeout_s))"
	state=running
	while [ "$(date +%s)" -lt "$deadline" ]; do
		if ! result="$("$helper" "$section" "$interface" status "$backend" "" "" "$profile" 0 2>/dev/null)"; then
			finish_attempt_accounting "$section" "$interface" "$bytes_before"
			write_state "$section" failed "Scheduled Full Auto-Tune status could not be read; no result was trusted"
			return
		fi
		state="$(extract "$result" '@.state')"
		case "$state" in
			complete) break ;;
			running|recovery-pending)
				sleep "$poll_interval_s"
				continue
				;;
			inconclusive|background-blocked)
				finish_attempt_accounting "$section" "$interface" "$bytes_before"
				reason="$(extract "$result" '@.reason' 2>/dev/null || true)"
				[ -n "$reason" ] || reason="$state"
				write_state "$section" deferred "Scheduled Full Auto-Tune was inconclusive ($reason); it will retry after the safety delay"
				return
				;;
			failed|cancelled|idle)
				finish_attempt_accounting "$section" "$interface" "$bytes_before"
				write_state "$section" failed "Scheduled Full Auto-Tune failed; no configuration was written"
				return
				;;
			*)
				finish_attempt_accounting "$section" "$interface" "$bytes_before"
				write_state "$section" failed "Scheduled Full Auto-Tune returned an unknown state; no result was trusted"
				return
				;;
		esac
	done
	[ "$state" = complete ] || {
		if [ "$state" = recovery-pending ]; then
			write_state "$section" recovery-pending "Full Auto-Tune runtime recovery is still pending; the scheduler will retry only after it settles"
		else
			if ! "$helper" "$section" "$interface" cancel "$backend" "" "" "$profile" 0 >/dev/null 2>&1; then
				write_state "$section" failed "Scheduled Full Auto-Tune timed out and cancellation could not be confirmed"
			else
				write_state "$section" failed "Scheduled Full Auto-Tune timed out"
			fi
		fi
		finish_attempt_accounting "$section" "$interface" "$bytes_before"
		return
	}

	if [ "$(extract "$result" '@.profile' 2>/dev/null)" != "$profile" ]; then
		finish_attempt_accounting "$section" "$interface" "$bytes_before"
		write_state "$section" failed "Scheduled Full Auto-Tune returned a different calibration profile; no result was trusted"
		return
	fi
	finish_attempt_accounting "$section" "$interface" "$bytes_before"
	printf '%s\n' "$(date +%s)" > "$state_root/$section.last"
	if [ "$(uci -q get "cake-autorate.$section.scheduled_autotune_auto_apply" 2>/dev/null)" = 1 ]; then
		if ! result_is_auto_apply_eligible "$result"; then
			write_state "$section" proposal_ready "Full Auto-Tune completed, but its evidence is not eligible for automatic apply; manual review is required"
			return
		fi
		if apply_result "$section" "$result" "$expected_fingerprint" "$interface"; then
			write_state "$section" applied "Validated Full Auto-Tune proposal was applied"
		else
			write_state "$section" failed "Validated result could not be applied because configuration, route, recovery, or runtime state changed"
		fi
	elif result_is_auto_apply_eligible "$result"; then
		write_state "$section" proposal_ready "Validated proposal is ready for manual review"
	else
		write_state "$section" proposal_ready "Proposal is ready for manual review, but is not eligible for automatic apply"
	fi
}

check_section() {
	section="$1"
	[ "$(uci -q get "cake-autorate.$section.scheduled_autotune_enabled" 2>/dev/null)" = 1 ] || return 0
	if recovery_transactions_pending; then
		write_state "$section" recovery-pending "An interrupted automatic apply must be recovered before another calibration"
		return
	fi
	configuration_has_pending_changes || {
		write_state "$section" deferred "Uncommitted CAKE Autorate or managed SQM settings are pending"
		return
	}
	interval_h="$(get_uint "$section" scheduled_autotune_interval_hours 24)"
	start_h="$(get_uint "$section" scheduled_autotune_window_start_hour 2)"
	end_h="$(get_uint "$section" scheduled_autotune_window_end_hour 5)"
	within_window "$start_h" "$end_h" || return 0
	now="$(date +%s)"
	last=0
	[ -s "$state_root/$section.last" ] && last="$(sed -n '1p' "$state_root/$section.last")"
	case "$last" in ''|*[!0-9]*) last=0 ;; esac
	[ "$((now - last))" -ge "$((interval_h * 3600))" ] || return 0
	last_attempt=0
	[ -s "$state_root/$section.last-attempt" ] && last_attempt="$(sed -n '1p' "$state_root/$section.last-attempt")"
	case "$last_attempt" in ''|*[!0-9]*) last_attempt=0 ;; esac
	[ "$((now - last_attempt))" -ge "$retry_delay_s" ] || return 0
	budget_ready "$section" || {
		write_state "$section" deferred "Daily traffic budget reached"
		return
	}
	interface="$(uci -q get "cake-autorate.$section.wan_if" 2>/dev/null)"
	[ -n "$interface" ] || interface="$(uci -q get "cake-autorate.$section.sqm_interface" 2>/dev/null)"
	interface="$(resolve_interface "$interface")" || return 0
	bytes="$(interface_bytes "$interface")" || return 0
	idle_ready "$section" "$interface" "$now" "$bytes" || return 0
	fingerprint="$(configuration_fingerprint "$section")" || {
		write_state "$section" deferred "Unable to fingerprint the instance and its owned SQM queue"
		return
	}
	run_section "$section" "$interface" "$now" "$bytes" "$fingerprint"
}

run_loop() {
	while true; do
		if ! recover_pending_transactions; then
			sleep "$sleep_s"
			continue
		fi
		sections="$(uci -q show cake-autorate 2>/dev/null | sed -n 's/^cake-autorate\.\([^.=]*\)=cake_autorate$/\1/p')"
		for section in $sections; do
			check_section "$section"
		done
		sleep "$sleep_s"
	done
}

[ "${CAKE_AUTOTUNE_SCHEDULER_SOURCE_ONLY:-0}" = 1 ] && return 0 2>/dev/null

case "${1:-run}" in
	run) run_loop ;;
	check)
		recover_pending_transactions || {
			[ -z "${2:-}" ] || write_state "$2" recovery-pending "Interrupted automatic apply recovery is incomplete"
			exit 1
		}
		check_section "$2"
		;;
	*) printf 'usage: %s [run|check INSTANCE]\n' "$0" >&2; exit 2 ;;
esac
