#!/bin/sh

section="$1"
mode="$2"
install_backend="$3"

if [ "$section" = "--status" ] || [ "$section" = "status" ]; then
	section="primary"
	mode="status"
fi

if [ -z "$section" ]; then
	section="primary"
fi

if [ -z "$mode" ]; then
	mode="status"
fi

case "$mode" in
	status|scan|install)
		;;
	*)
		printf '{"error":"unsupported mode"}\n'
		exit 1
		;;
esac

json_escape() {
	printf '%s' "$1" | tr '\n\r\t' '   ' | sed 's/\\/\\\\/g; s/"/\\"/g'
}

json_bool() {
	if [ "$1" = "1" ]; then
		printf 'true'
	else
		printf 'false'
	fi
}

json_error() {
	printf '{"error":"%s"}\n' "$(json_escape "$1")"
	exit 1
}

command_path() {
	command -v "$1" 2>/dev/null || true
}

uci_get() {
	uci -q get "cake-autorate.$section.$1" 2>/dev/null
}

valid_reflector() {
	case "$1" in
		''|*[!0-9A-Za-z:._-]*)
			return 1
			;;
	esac

	return 0
}

num_or_default() {
	case "$1" in
		''|*[!0-9]*)
			printf '%s' "$2"
			;;
		*)
			if [ "$1" -gt 0 ] 2>/dev/null; then
				printf '%s' "$1"
			else
				printf '%s' "$2"
			fi
			;;
	esac
}

append_warning() {
	[ -n "$1" ] || return 0
	warnings="${warnings}${warnings:+
}$1"
}

append_line_var() {
	case "$1" in
		active)
			active="${active}${active:+
}$2"
			;;
		spare)
			spare="${spare}${spare:+
}$2"
			;;
		bad)
			bad="${bad}${bad:+
}$2"
			;;
		scan_rows)
			scan_rows="${scan_rows}${scan_rows:+
}$2"
			;;
		scan_candidates)
			scan_candidates="${scan_candidates}${scan_candidates:+
}$2"
			;;
	esac
}

append_candidate() {
	local candidate="$1"
	local existing

	[ -n "$candidate" ] || return 0

	for existing in $reflectors; do
		[ "$existing" = "$candidate" ] && return 0
	done

	reflectors="${reflectors}${reflectors:+ }$candidate"
}

probe_fping_batch() {
	local targets="$1"
	local extra="$2"
	local output

	if [ -z "$fping_bin" ] || [ -z "$targets" ]; then
		return 1
	fi

	output="$("$fping_bin" $extra -c 1 -t 1000 $targets 2>&1)"

	printf '%s\n' "$output" | awk '
		/: xmt\/rcv\/%loss = / && /min\/avg\/max =/ {
			host = $0
			sub(/[[:space:]]*: xmt\/rcv\/%loss = .*/, "", host)
			sub(/[[:space:]]+$/, "", host)
			avg = $0
			sub(/^.*min\/avg\/max = [^\/]*\//, "", avg)
			sub(/\/.*$/, "", avg)
			if (host != "" && avg ~ /^[0-9.]+$/)
				print host "|" avg
		}
	'
}

lookup_probe_result() {
	local results="$1"
	local host="$2"

	printf '%s\n' "$results" | awk -F '|' -v host="$host" '$1 == host { print $2; exit }'
}

probe_tsping_batch() {
	local targets="$1"
	local tmp pid

	if [ -z "$tsping_bin" ] || [ -z "$targets" ]; then
		return 1
	fi

	tmp="${TMPDIR:-/tmp}/cake-autorate-rs-tsping-scan.$$"
	rm -f "$tmp"
	"$tsping_bin" --print-timestamps --machine-readable=, --sleep-time 0 --target-spacing 50 $targets >"$tmp" 2>/dev/null &
	pid="$!"
	sleep 4
	kill "$pid" 2>/dev/null || true
	wait "$pid" 2>/dev/null || true

	awk -F ',' '
		NF == 10 {
			host = $2
			gsub(/^[[:space:]]+|[[:space:]]+$/, "", host)
			dl = $9
			ul = $10
			gsub(/^[[:space:]]+|[[:space:]]+$/, "", dl)
			gsub(/^[[:space:]]+|[[:space:]]+$/, "", ul)
			if (host != "" && dl ~ /^[0-9.]+$/ && ul ~ /^[0-9.]+$/ && !(host in seen)) {
				seen[host] = 1
				print host "|" (dl + ul)
			}
		}
	' "$tmp"
	rm -f "$tmp"
}

pinger_title() {
	case "$1" in
		fping)
			printf '%s' "fping"
			;;
		fping-ts)
			printf '%s' "fping-ts"
			;;
		tsping)
			printf '%s' "tsping"
			;;
		irtt)
			printf '%s' "irtt"
			;;
		ping)
			printf '%s' "ping fallback"
			;;
		*)
			printf '%s' "$1"
			;;
	esac
}

pinger_delay_type() {
	case "$1" in
		fping|ping)
			printf '%s' "RTT"
			;;
		fping-ts|tsping|irtt)
			printf '%s' "OWD"
			;;
	esac
}

pinger_target_mode() {
	case "$1" in
		fping|fping-ts|tsping)
			printf '%s' "round-robin"
			;;
		ping|irtt)
			printf '%s' "individual"
			;;
	esac
}

pinger_supported() {
	case "$1" in
		fping|fping-ts|tsping|ping)
			return 0
			;;
	esac

	return 1
}

pinger_available() {
	case "$1" in
		fping)
			[ -n "$fping_bin" ]
			;;
		fping-ts)
			[ "$fping_ts_supported" = "1" ]
			;;
		tsping)
			[ -n "$tsping_bin" ]
			;;
		irtt)
			[ -n "$irtt_bin" ]
			;;
		ping)
			[ -n "$ping_bin" ]
			;;
		*)
			return 1
			;;
	esac
}

pinger_reason() {
	case "$1" in
		fping)
			[ -n "$fping_bin" ] && printf '%s' "available" || printf '%s' "not installed"
			;;
		fping-ts)
			[ "$fping_ts_supported" = "1" ] && printf '%s' "available" || printf '%s' "requires fping with --icmp-timestamp"
			;;
		tsping)
			[ -n "$tsping_bin" ] && printf '%s' "available" || printf '%s' "not installed"
			;;
		irtt)
			[ -n "$irtt_bin" ] && printf '%s' "installed; daemon support pending" || printf '%s' "not installed; daemon support pending"
			;;
		ping)
			[ -n "$ping_bin" ] && printf '%s' "available" || printf '%s' "not installed"
			;;
		*)
			printf '%s' "unknown pinger"
			;;
	esac
}

pinger_install_hint() {
	case "$1" in
		fping|fping-ts)
			printf '%s' "apk add fping"
			;;
		tsping)
			printf '%s' "install a compatible tsping binary manually"
			;;
		irtt)
			printf '%s' "daemon support pending; will require irtt server configuration"
			;;
		ping)
			printf '%s' "provided by the base system"
			;;
	esac
}

pinger_package() {
	case "$1" in
		fping|fping-ts)
			printf '%s' "fping"
			;;
	esac
}

pinger_installable() {
	case "$1" in
		fping|fping-ts)
			return 0
			;;
	esac

	return 1
}

refresh_pinger_bins() {
	fping_bin="$(command_path fping)"
	ping_bin="$(command_path ping)"
	tsping_bin="$(command_path tsping)"
	irtt_bin="$(command_path irtt)"
	fping_ts_supported=0

	if [ -n "$fping_bin" ] && "$fping_bin" --help 2>&1 | grep -q -- '--icmp-timestamp'; then
		fping_ts_supported=1
	fi
}

backend_json() {
	local name="$1"
	local available supported installable package
	local quality="${2:-0}"
	local recommended=0
	local configured=0

	pinger_available "$name" && available=1 || available=0
	pinger_supported "$name" && supported=1 || supported=0
	pinger_installable "$name" && installable=1 || installable=0
	package="$(pinger_package "$name")"
	[ "$name" = "$recommended_method" ] && recommended=1
	[ "$name" = "$configured_method" ] && configured=1

	printf '{"name":"%s","title":"%s","delay_type":"%s","target_mode":"%s","available":%s,"supported":%s,"installable":%s,"package":"%s","quality":%s,"recommended":%s,"configured":%s,"reason":"%s","install_hint":"%s"}' \
		"$(json_escape "$name")" \
		"$(json_escape "$(pinger_title "$name")")" \
		"$(json_escape "$(pinger_delay_type "$name")")" \
		"$(json_escape "$(pinger_target_mode "$name")")" \
		"$(json_bool "$available")" \
		"$(json_bool "$supported")" \
		"$(json_bool "$installable")" \
		"$(json_escape "$package")" \
		"$quality" \
		"$(json_bool "$recommended")" \
		"$(json_bool "$configured")" \
		"$(json_escape "$(pinger_reason "$name")")" \
		"$(json_escape "$(pinger_install_hint "$name")")"
}

valid_pinger_backend() {
	case "$1" in
		fping|fping-ts|tsping|irtt|ping)
			return 0
			;;
	esac

	return 1
}

pinger_install_json() {
	local selected="$1"
	local package output available

	[ -n "$selected" ] || selected="$configured_method"
	valid_pinger_backend "$selected" || json_error "Unknown pinger backend: $selected"

	if ! pinger_supported "$selected"; then
		json_error "$(pinger_title "$selected") is visible for upstream parity, but daemon support is pending."
	fi

	if ! pinger_installable "$selected"; then
		if pinger_available "$selected"; then
			printf '{"backend":"%s","backend_title":"%s","package":"","installed":true,"available":true,"supported":true,"reason":"%s"}\n' \
				"$(json_escape "$selected")" \
				"$(json_escape "$(pinger_title "$selected")")" \
				"$(json_escape "$(pinger_reason "$selected")")"
			exit 0
		fi

		json_error "$(pinger_title "$selected") cannot be installed automatically: $(pinger_install_hint "$selected")."
	fi

	package="$(pinger_package "$selected")"
	[ -n "$package" ] || json_error "$(pinger_title "$selected") cannot be installed automatically."

	if pinger_available "$selected"; then
		printf '{"backend":"%s","backend_title":"%s","package":"%s","installed":true,"available":true,"supported":true,"reason":"%s"}\n' \
			"$(json_escape "$selected")" \
			"$(json_escape "$(pinger_title "$selected")")" \
			"$(json_escape "$package")" \
			"$(json_escape "$(pinger_reason "$selected")")"
		exit 0
	fi

	command -v apk >/dev/null 2>&1 || json_error "apk was not found on this router."

	output="$(apk add "$package" 2>&1)"
	if [ "$?" -ne 0 ]; then
		json_error "Failed to install $package: $output"
	fi

	refresh_pinger_bins
	pinger_available "$selected" && available=true || available=false

	printf '{"backend":"%s","backend_title":"%s","package":"%s","installed":true,"available":%s,"supported":true,"reason":"%s"}\n' \
		"$(json_escape "$selected")" \
		"$(json_escape "$(pinger_title "$selected")")" \
		"$(json_escape "$package")" \
		"$available" \
		"$(json_escape "$(pinger_reason "$selected")")"
}

print_string_array() {
	local values="$1"
	local first=1
	local value

	printf '['
	printf '%s\n' "$values" | while IFS= read -r value; do
		[ -n "$value" ] || continue
		if [ "$first" = "1" ]; then
			first=0
		else
			printf ','
		fi
		printf '"%s"' "$(json_escape "$value")"
	done
	printf ']'
}

print_warnings_array() {
	print_string_array "$warnings"
}

UPSTREAM_DEFAULT_REFLECTORS="1.1.1.1 1.0.0.1 8.8.8.8 8.8.4.4 9.9.9.9 9.9.9.10 9.9.9.11 94.140.14.15 94.140.14.140 94.140.14.141 94.140.15.15 94.140.15.16 64.6.65.6 156.154.70.1 156.154.70.2 156.154.70.3 156.154.70.4 156.154.70.5 156.154.71.1 156.154.71.2 156.154.71.3 156.154.71.4 156.154.71.5 208.67.220.2 208.67.220.123 208.67.220.220 208.67.222.2 208.67.222.123 185.228.168.9 185.228.168.10"
default_pool_count=0
for reflector in $UPSTREAM_DEFAULT_REFLECTORS; do
	default_pool_count=$((default_pool_count + 1))
done

configured_method="$(uci_get pinger_method)"
[ -n "$configured_method" ] || configured_method="fping"
configured_no_pingers="$(num_or_default "$(uci_get no_pingers)" 6)"
reflector_ping_interval_s="$(uci_get reflector_ping_interval_s)"
[ -n "$reflector_ping_interval_s" ] || reflector_ping_interval_s="0.3"

configured_reflectors="$(uci_get reflector)"
reflectors=""
candidate_source="configured"

if [ -n "$configured_reflectors" ]; then
	for reflector in $configured_reflectors; do
		append_candidate "$reflector"
	done
else
	candidate_source="upstream-default"
fi

if [ -z "$configured_reflectors" ] || [ "$mode" = "scan" ]; then
	if [ -n "$configured_reflectors" ]; then
		candidate_source="configured-plus-upstream-default"
	fi

	for reflector in $UPSTREAM_DEFAULT_REFLECTORS; do
		append_candidate "$reflector"
	done
fi

refresh_pinger_bins

[ -n "$fping_bin" ] || append_warning "fping is not installed; concurrent RTT probing is unavailable."
[ "$fping_ts_supported" = "1" ] || append_warning "Installed fping does not expose --icmp-timestamp; fping-ts is unavailable."
[ -n "$tsping_bin" ] || append_warning "tsping binary is not installed; tsping remains a manual optional backend."
[ -n "$irtt_bin" ] || append_warning "irtt package is not installed. irtt daemon support is pending and will also require configured IRTT servers."
if [ -n "$irtt_bin" ]; then
	append_warning "irtt binary is installed, but this daemon build does not support pinger_method=irtt yet."
fi

if [ "$mode" = "install" ]; then
	pinger_install_json "$install_backend"
fi

candidate_count=0
valid_count=0
rtt_ok_count=0
timestamp_ok_count=0
timestamp_probe_backend=""
scan_rows=""
scan_candidates=""
active=""
spare=""
bad=""

for reflector in $reflectors; do
	candidate_count=$((candidate_count + 1))

	if ! valid_reflector "$reflector"; then
		append_line_var bad "$reflector"
		append_warning "Ignoring invalid reflector candidate: $reflector"
		continue
	fi

	valid_count=$((valid_count + 1))
	append_line_var scan_candidates "$reflector"

	if [ "$mode" != "scan" ]; then
		append_line_var scan_rows "$reflector|0|0||"
	fi
done

if [ "$mode" = "scan" ]; then
	rtt_results="$(probe_fping_batch "$scan_candidates" "")"
	if [ "$fping_ts_supported" = "1" ]; then
		ts_results="$(probe_fping_batch "$scan_candidates" "--icmp-timestamp")"
		timestamp_probe_backend="fping-ts"
	elif [ -n "$tsping_bin" ]; then
		ts_results="$(probe_tsping_batch "$scan_candidates")"
		timestamp_probe_backend="tsping"
	else
		ts_results=""
	fi

	if [ -z "$ts_results" ] && [ -n "$tsping_bin" ] && [ "$timestamp_probe_backend" != "tsping" ]; then
		tsping_results="$(probe_tsping_batch "$scan_candidates")"
		if [ -n "$tsping_results" ]; then
			ts_results="$tsping_results"
			timestamp_probe_backend="tsping"
		fi
	fi

	OLDIFS="$IFS"
	IFS='
'
	for reflector in $scan_candidates; do
		rtt_ms="$(lookup_probe_result "$rtt_results" "$reflector")"
		ts_ms="$(lookup_probe_result "$ts_results" "$reflector")"
		rtt_ok=0
		ts_ok=0

		if [ -n "$rtt_ms" ]; then
			rtt_ok=1
			rtt_ok_count=$((rtt_ok_count + 1))
		fi

		if [ -n "$ts_ms" ]; then
			ts_ok=1
			timestamp_ok_count=$((timestamp_ok_count + 1))
		fi

		append_line_var scan_rows "$reflector|$rtt_ok|$ts_ok|$rtt_ms|$ts_ms"
	done
	IFS="$OLDIFS"
fi

target_pingers="$configured_no_pingers"
if [ "$target_pingers" -gt 6 ] 2>/dev/null; then
	target_pingers=6
fi
if [ "$target_pingers" -gt "$valid_count" ] 2>/dev/null; then
	target_pingers="$valid_count"
fi
if [ "$target_pingers" -lt 1 ] 2>/dev/null; then
	target_pingers=1
fi

recommended_method="fping"
recommended_reason="fping is the upstream default and the most reliable concurrent RTT backend."

if [ "$mode" = "scan" ]; then
	if [ "$fping_ts_supported" = "1" ] && [ "$timestamp_ok_count" -ge "$target_pingers" ] 2>/dev/null; then
		recommended_method="fping-ts"
		recommended_reason="Enough reflectors answered ICMP timestamp probes; fping-ts can provide directional OWD."
	elif [ -n "$tsping_bin" ] && [ "$timestamp_ok_count" -ge "$target_pingers" ] 2>/dev/null; then
		recommended_method="tsping"
		recommended_reason="Enough reflectors answered ICMP timestamp probes; tsping can provide directional OWD."
	elif [ -n "$fping_bin" ] && [ "$rtt_ok_count" -ge 1 ] 2>/dev/null; then
		recommended_method="fping"
		recommended_reason="Timestamp-capable reflectors were insufficient; use concurrent RTT probing."
	elif [ -n "$ping_bin" ]; then
		recommended_method="ping"
		recommended_reason="fping probing did not find usable reflectors; ping is an emergency single-reflector fallback."
		target_pingers=1
	else
		recommended_reason="No usable pinger backend is available."
	fi
else
	if [ "$configured_method" = "ping" ]; then
		recommended_method="ping"
		recommended_reason="Current configuration uses the single-reflector ping fallback; run a scan before changing it."
	elif [ "$configured_method" = "fping-ts" ] || [ "$configured_method" = "tsping" ]; then
		recommended_method="$configured_method"
		recommended_reason="Current configuration requests a timestamp-aware backend; run a scan to verify reflector support."
	fi
fi

active=""
spare=""
selected_count=0
OLDIFS="$IFS"
IFS='
'
for row in $scan_rows; do
	IFS='|'
	set -- $row
	IFS='
'
	reflector="$1"
	rtt_ok="$2"
	ts_ok="$3"
	[ -n "$reflector" ] || continue
	ok=0
	case "$recommended_method" in
		fping-ts|tsping)
			[ "$mode" = "scan" ] && [ "$ts_ok" = "1" ] && ok=1
			;;
		fping)
			if [ "$mode" = "scan" ]; then
				[ "$rtt_ok" = "1" ] && ok=1
			else
				ok=1
			fi
			;;
		ping)
			if [ "$mode" = "scan" ]; then
				[ "$rtt_ok" = "1" ] && ok=1
			else
				ok=1
			fi
			;;
	esac
	if [ "$ok" = "1" ]; then
		if [ "$selected_count" -lt "$target_pingers" ] 2>/dev/null; then
			append_line_var active "$reflector"
			selected_count=$((selected_count + 1))
		else
			append_line_var spare "$reflector"
		fi
	elif [ "$mode" = "scan" ]; then
		append_line_var bad "$reflector"
	fi
done
IFS="$OLDIFS"

if [ "$mode" = "scan" ] && [ "$selected_count" -lt "$target_pingers" ] 2>/dev/null; then
	append_warning "Fewer usable reflectors than desired active pingers; reduce Pingers or add better reflectors."
fi

printf '{'
printf '"section":"%s",' "$(json_escape "$section")"
printf '"mode":"%s",' "$(json_escape "$mode")"
printf '"configured_method":"%s",' "$(json_escape "$configured_method")"
printf '"configured_no_pingers":%s,' "$configured_no_pingers"
printf '"reflector_ping_interval_s":"%s",' "$(json_escape "$reflector_ping_interval_s")"
printf '"candidate_source":"%s",' "$(json_escape "$candidate_source")"
printf '"default_pool_count":%s,' "$default_pool_count"
printf '"candidate_count":%s,' "$candidate_count"
printf '"valid_count":%s,' "$valid_count"
printf '"rtt_ok_count":%s,' "$rtt_ok_count"
printf '"timestamp_ok_count":%s,' "$timestamp_ok_count"
printf '"timestamp_probe_backend":"%s",' "$(json_escape "$timestamp_probe_backend")"
printf '"recommended_method":"%s",' "$(json_escape "$recommended_method")"
printf '"recommended_no_pingers":%s,' "$target_pingers"
printf '"recommended_reason":"%s",' "$(json_escape "$recommended_reason")"
printf '"backends":['
backend_json "fping" 70
printf ','
backend_json "fping-ts" 90
printf ','
backend_json "tsping" 90
printf ','
backend_json "irtt" 100
printf ','
backend_json "ping" 30
printf '],'
printf '"active":'
print_string_array "$active"
printf ',"spare":'
print_string_array "$spare"
printf ',"recommended_reflectors":'
print_string_array "${active}${active:+
}$spare"
printf ',"bad":'
print_string_array "$bad"
printf ',"warnings":'
print_warnings_array

if [ "$mode" = "scan" ]; then
	printf ',"reflectors":['
	first=1
	OLDIFS="$IFS"
	IFS='
'
	for row in $scan_rows; do
		IFS='|'
		set -- $row
		IFS='
'
		reflector="$1"
		rtt_ok="$2"
		ts_ok="$3"
		rtt_ms="$4"
		ts_ms="$5"
		[ -n "$reflector" ] || continue
		if [ "$first" = 1 ]; then
			first=0
		else
			printf ','
		fi
		printf '{"host":"%s","rtt_ok":%s,"timestamp_ok":%s,"rtt_ms":%s,"timestamp_rtt_ms":%s}' \
			"$(json_escape "$reflector")" \
			"$(json_bool "$rtt_ok")" \
			"$(json_bool "$ts_ok")" \
			"${rtt_ms:-null}" \
			"${ts_ms:-null}"
	done
	IFS="$OLDIFS"
	printf ']'
fi

printf '}\n'
