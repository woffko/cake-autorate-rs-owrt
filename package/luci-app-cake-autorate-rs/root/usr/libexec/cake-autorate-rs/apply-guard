		_autotune_apply_enabled _autotune_apply_disable_adaptive _autotune_apply_action _autotune_apply_token \
		_autotune_apply_expires _autotune_apply_boot_id; do
		if uci_at "$token_dir/expected-final" -q get "cake-autorate.$job.$final_option" >/dev/null 2>&1; then
