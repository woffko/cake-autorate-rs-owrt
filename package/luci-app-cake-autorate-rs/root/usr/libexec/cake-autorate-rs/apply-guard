	done
	uci_at "$token_dir/expected-final" -q delete "sqm.$sqm_guard" || return 1
	uci_at "$token_dir/expected-final" -q commit cake-autorate || return 1
	uci_at "$token_dir/expected-final" -q commit sqm || return 1
}

attest_route() {
	job="$1"
	target="$2"
	backend="$3"
	route_mode="$4"
	member="$5"
	expected_fingerprint="$6"
	attestation="$token_dir/attestation.json"
	"$autotune_bin" "$job" "$target" attest "$backend" "$route_mode" "$member" > "$attestation" 2>/dev/null ||
		die "Live Full Auto-Tune route/configuration attestation failed."
	owned_regular "$attestation" && chmod 600 "$attestation" || die "The attestation file is unsafe."
	[ "$(json_get "$attestation" '@.state')" = ready ] || die "The live Full Auto-Tune attestation is not ready."
	[ "$(json_get "$attestation" '@.schema_version')" = 1 ] || die "The live Full Auto-Tune attestation schema is invalid."
	[ "$(json_get "$attestation" '@.config_fingerprint')" = "$expected_fingerprint" ] || die "The calibrated configuration changed before apply."
	for field in target_interface resolved_interface route_interface route_mode mwan3_member source_ip external_ip route_identity; do
		[ "$(json_get "$attestation" "@.$field")" = "$(json_get "$result_copy" "@.$field")" ] ||
			die "The calibrated route identity changed before apply."
	done
}

result_action_allowed() {
	allowed_action="$1"
	json_get "$result_copy" '@.fair_outcome.allowed_actions[*]' 2>/dev/null |
		grep -F -x -- "$allowed_action" >/dev/null 2>&1
}

safe_run_id() {
	case "$1" in
		''|*[!A-Za-z0-9_-]*) return 1 ;;
	esac
	[ "${#1}" -le 128 ]
}

quality_grade_rank() {
	case "$1" in
		A+) printf '0\n' ;;
		A) printf '1\n' ;;
		B) printf '2\n' ;;
		C) printf '3\n' ;;
		D) printf '4\n' ;;
		F) printf '5\n' ;;
		*) return 1 ;;
	esac
}

validate_profile_search_contract() {
	search_direction="$1"
	search_allow_unsafe="${2:-false}"
	case "$search_direction" in
		download) search_rate_path=download ;;
		upload) search_rate_path=upload ;;
		*) return 1 ;;
	esac
	search_root="@.profile_search.$search_direction"
	require_result_flag "$search_root.schema_version" 1 "The profile-search schema is invalid."
	require_result_flag "$search_root.profile" "$profile" "The profile-search profile changed."
	require_result_flag "$search_root.direction" "$search_direction" "The profile-search direction changed."
	search_action="$(require_result_value "$search_root.action")" ||
		die "The profile-search terminal action is missing."
	case "$search_action" in complete|fallback) ;; *) die "The profile search still has a pending or inconclusive action." ;; esac
	search_selected_safety="$(require_result_value "$search_root.selected.safety_pass")" ||
		die "The selected direction safety state is missing."
	case "$search_selected_safety" in
		true) ;;
		false)
			[ "$search_allow_unsafe" = true ] && [ "$search_action" = fallback ] ||
				die "The selected direction did not preserve its safety floor."
			search_reason="$(require_result_value "$search_root.reason")" ||
				die "The unsafe profile-search reason is missing."
			case "$search_reason" in
				repeatable-compute-ceiling-below-capacity-floor|repeatable-shaper-ceiling-below-capacity-floor) ;;
				*) die "The unsafe profile-search result has no proven repeatable ceiling." ;;
			esac
			profile_unsafe_direction_count=$((profile_unsafe_direction_count + 1))
			;;
		*) die "The selected direction safety state is invalid." ;;
	esac
	selected_rate="$(require_result_value "$search_root.selected.candidate_kbps")" ||
		die "The selected profile-search rate is missing."
	proposal_selected_rate="$(require_result_value "@.proposal.$search_rate_path.base_kbps")" ||
		die "The proposal base rate is missing."
	validation_selected_rate="$(require_result_value "@.validation.candidate_base.${search_direction}_kbps")" ||
		die "The confirmed validation rate is missing."
	is_positive_rate "$selected_rate" &&
		numbers_equal "$selected_rate" "$proposal_selected_rate" &&
		numbers_equal "$selected_rate" "$validation_selected_rate" ||
		die "The selected, proposed, and confirmed direction rates differ."
}

arm_guard() {
	job="${1:-}"
	target="${2:-}"
	backend="${3:-}"
	route_mode="${4:-}"
	member="${5:-}"
	enabled="${6:-}"
	disable_adaptive="${7:-}"
	action="${8:-}"
	fingerprint="${9:-}"

	safe_job "$job" || die "Unsafe Full Auto-Tune instance name."
	safe_interface "$target" || die "Unsafe Full Auto-Tune target interface."
	safe_backend "$backend" || die "Unsupported Full Auto-Tune apply backend."
	case "$route_mode" in main) [ -z "$member" ] || die "Main routing cannot name an mwan3 member." ;; mwan3) safe_interface "$member" || die "Unsafe mwan3 member." ;; *) die "Unsupported Full Auto-Tune route mode." ;; esac
	case "$enabled:$disable_adaptive" in 0:0|0:1|1:0|1:1) ;; *) die "Invalid Full Auto-Tune review decisions." ;; esac
	case "$action:$enabled" in
		apply_sqm:1|disable_sqm:0) ;;
		*) die "The Full Auto-Tune review action and enabled state are inconsistent." ;;
	esac
	safe_fingerprint "$fingerprint" || die "Invalid Full Auto-Tune result fingerprint."
	is_uint "$token_ttl_s" && [ "$token_ttl_s" -ge 30 ] && [ "$token_ttl_s" -le 900 ] || die "Invalid apply-guard TTL."
	is_uint "$rollback_timeout_s" && [ "$rollback_timeout_s" -ge 10 ] && [ "$rollback_timeout_s" -le 120 ] ||
		die "Invalid apply rollback timeout."
	is_uint "$orphan_age_s" && [ "$orphan_age_s" -ge 60 ] && [ "$orphan_age_s" -le 86400 ] || die "Invalid abandoned-token GC age."
	prepare_root
	guard_capacity_check || die "Too many unsafe or abandoned Full Auto-Tune apply tokens exist."
	sqm_guard="$(sqm_guard_section "$job")" || die "The SQM rollback marker identity is unsafe."
	if uci -q get "sqm.$sqm_guard" >/dev/null 2>&1; then
		die "The reserved SQM rollback section already exists; reconcile or remove it before applying."
	fi
	if uci -q show cake-autorate 2>/dev/null | grep -q '\._autotune_apply_'; then
		die "A persistent Full Auto-Tune apply marker already exists; reconcile it before applying another proposal."
	fi

	result="$autotune_root/$job/result.json"
	bounded_regular_file "$result" 1048576 || die "The validated Full Auto-Tune result is missing, unsafe, or too large."
	if command -v hexdump >/dev/null 2>&1; then
		token="$(hexdump -vn32 -e '32/1 "%02x"' /dev/urandom 2>/dev/null)"
	else
		token="$(od -An -N32 -tx1 /dev/urandom 2>/dev/null | tr -d ' \n')"
	fi
	safe_token "$token" || die "Unable to create a secure Full Auto-Tune apply token."
	token_dir="$guard_root/$token"
	[ ! -e "$token_dir" ] && [ ! -L "$token_dir" ] || die "The Full Auto-Tune apply token already exists."
	mkdir "$token_dir" && chmod 700 "$token_dir" || die "Unable to create the Full Auto-Tune apply token."
	arm_cleanup_dir="$token_dir"
	cp "$result" "$token_dir/result.json" || die "Unable to bind the Full Auto-Tune result to its apply token."
	chmod 600 "$token_dir/result.json" || die "Unable to protect the Full Auto-Tune result copy."
	result_copy="$token_dir/result.json"
	owned_regular "$result_copy" || die "The Full Auto-Tune result copy is unsafe."

	require_result_flag '@.state' complete "Only a complete Full Auto-Tune result can be applied."
	require_result_flag '@.schema_version' 6 "Only the fail-closed Full Auto-Tune schema can be applied."
	require_result_flag '@.producer' "$autotune_result_producer" "The Full Auto-Tune result producer is invalid."
	require_result_flag '@.manual_apply_eligible' true "This Full Auto-Tune result is not eligible for explicit review and apply."
	require_result_flag '@.phase_evidence_complete' true "This Full Auto-Tune result has incomplete phase evidence."
	require_result_flag '@.phase_contamination_seen' false "A contaminated Full Auto-Tune result cannot be applied."
	require_result_flag '@.runtime_restored' true "Full Auto-Tune runtime recovery is incomplete."
	require_result_flag '@.recovery_pending' false "Full Auto-Tune recovery is still pending."
	require_result_flag '@.configuration_written' false "The Full Auto-Tune result has unexpected write state."
	require_result_flag '@.conservative' false "A conservative Full Auto-Tune result cannot be auto-applied."
	require_result_flag '@.confidence_mode' normal "Only normal-confidence Full Auto-Tune output can be applied."
	require_result_flag '@.validation.contaminated' false "Full Auto-Tune validation was contaminated."
	run_id="$(require_result_value '@.run_id')" || die "The Full Auto-Tune run identity is missing."
	safe_run_id "$run_id" || die "The Full Auto-Tune run identity is unsafe."
	load_profile_contract
	require_result_flag '@.validation.profile' "$profile" "The terminal validation profile differs from the proposal."
	profile_outcome_mode="$(require_result_value '@.profile_outcome.mode')" ||
		die "The profile outcome mode is missing."
	profile_floor_infeasible=false
	if [ "$profile_outcome_mode" = capacity-floor-infeasible ]; then
		[ "$profile" = fair ] && [ "$action" = disable_sqm ] ||
			die "An infeasible capacity floor may only support an explicit Fair SQM-disable review."
		profile_floor_infeasible=true
		require_result_flag '@.validation.safety_pass' false "The capacity-floor fallback unexpectedly claims to be safe."
		require_result_flag '@.profile_outcome.capacity_floor_met' false "The capacity-floor fallback state changed."
		require_result_flag '@.profile_outcome.manual_only' true "The capacity-floor fallback must be manual-only."
		require_result_flag '@.auto_apply_eligible' false "A capacity-floor fallback must never auto-apply."
		profile_infeasible_reason="$(require_result_value '@.profile_outcome.infeasible_reason')" ||
			die "The capacity-floor fallback reason is missing."
	else
		require_result_flag '@.validation.safety_pass' true "The selected candidate failed a safety gate."
		require_result_flag '@.profile_outcome.capacity_floor_met' true "The selected candidate did not prove its capacity floor."
	fi
	require_result_flag '@.profile_outcome.target_grade' "$target_grade" "The profile outcome target changed."
	profile_outcome_floor="$(require_result_value '@.profile_outcome.capacity_floor_percent')" ||
		die "The profile outcome capacity floor is missing."
	numbers_equal "$profile_outcome_floor" "$validation_retention" ||
		die "The profile outcome and proposal capacity floors differ."
	profile_target_met="$(require_result_value '@.profile_outcome.target_met')" ||
		die "The profile outcome target state is missing."
	[ "$profile_target_met" = "$(json_get "$result_copy" '@.validation.quality_target_met')" ] ||
		die "The profile outcome and final validation target state differ."
	profile_unsafe_direction_count=0
	validate_profile_search_contract download "$profile_floor_infeasible"
	validate_profile_search_contract upload "$profile_floor_infeasible"
	if [ "$profile_floor_infeasible" = true ] && [ "$profile_unsafe_direction_count" -lt 1 ]; then
		die "The capacity-floor fallback contains no direction with a proven repeatable ceiling."
	fi
	case "$action" in
		apply_sqm)
			if [ "$profile_target_met" = true ]; then
				require_result_flag '@.auto_apply_eligible' true "A fully passing proposal unexpectedly requires manual-only apply."
				require_result_flag '@.profile_outcome.manual_only' false "A target-meeting outcome was marked manual-only."
			else
				require_result_flag '@.auto_apply_eligible' false "A profile fallback must never be auto-applied."
				require_result_flag '@.profile_outcome.manual_only' true "A below-target fallback was not marked manual-only."
				profile_outcome_mode="$(require_result_value '@.profile_outcome.mode')" ||
					die "The profile fallback outcome is missing."
				case "$profile:$profile_outcome_mode" in
					gaming:best-attainable-quality-fallback|best_overall:balanced-fallback) ;;
					fair:throughput-optimum-quality-fallback)
						fair_mode="$(json_get "$result_copy" '@.fair_outcome.mode')"
						case "$fair_mode" in throughput-fallback|sqm-disable-recommended) ;;
							*) die "The Fair throughput fallback is missing its typed outcome." ;;
						esac
						result_action_allowed apply_sqm ||
							die "The Fair outcome does not allow applying its best safe SQM candidate."
						;;
					*) die "The below-target result has no recognized typed fallback." ;;
				esac
			fi
			;;
		disable_sqm)
			[ "$profile" = fair ] || die "Only a Fair comparison may recommend disabling SQM."
			require_result_flag '@.auto_apply_eligible' false "Disabling SQM must never be an automatic action."
			if [ "$profile_floor_infeasible" = true ]; then
				require_result_flag '@.validation.hard_pass' false "The infeasible Fair result unexpectedly passed all hard gates."
				require_result_flag '@.fair_outcome.capacity_floor_met' false "The Fair outcome lost its infeasible-floor state."
				require_result_flag '@.fair_outcome.apply_sqm_available' false "The unsafe shaped candidate must not be applyable."
			else
				require_result_flag '@.validation.hard_pass' true "The Fair comparison has no safe shaped reference candidate."
				require_result_flag '@.validation.quality_target_met' false "SQM disable is not available when the Fair quality target was met."
				require_result_flag '@.fair_outcome.capacity_floor_met' true "The Fair comparison did not preserve its throughput floor."
				require_result_flag '@.fair_outcome.apply_sqm_available' true "The safe shaped comparison candidate disappeared."
			fi
			require_result_flag '@.fair_outcome.mode' sqm-disable-recommended "The Fair result did not recommend disabling SQM."
			require_result_flag '@.fair_outcome.target_grade' C "The Fair comparison target changed."
			require_result_flag '@.fair_outcome.target_delta_ms' 200 "The Fair comparison delay target changed."
			require_result_flag '@.fair_outcome.capacity_floor_percent' 90 "The Fair comparison throughput floor changed."
			require_result_flag '@.fair_outcome.recommended_action' disable_sqm "The Fair recommendation changed."
			require_result_flag '@.fair_outcome.disable_sqm_available' true "The no-SQM choice is not supported by complete evidence."
			require_result_flag '@.fair_outcome.comparison_reason' no-material-latency-benefit-with-throughput-cost "The Fair comparison reason changed."
			require_result_flag '@.fair_outcome.no_sqm_control.available' true "The no-SQM control is unavailable."
			require_result_flag '@.fair_outcome.no_sqm_control.measurement_evidence.valid' true "The no-SQM control evidence is invalid."
			require_result_flag '@.fair_outcome.no_sqm_control.measurement_evidence.test_direction' both "The no-SQM control was not bidirectional."
			require_result_flag '@.fair_outcome.no_sqm_control.measurement_evidence.shaper_bypassed' true "The control did not prove that shaping was bypassed."
			require_result_flag '@.fair_outcome.no_sqm_control.measurement_evidence.sqm_paused' true "The control did not prove that SQM was paused."
			require_result_flag '@.fair_outcome.no_sqm_control.forwarded_background.available' true "The no-SQM control has no forwarded-traffic evidence."
			require_result_flag '@.fair_outcome.no_sqm_control.forwarded_background.contaminated' false "Background traffic contaminated the no-SQM control."
			fair_background_dl="$(require_result_value '@.fair_outcome.no_sqm_control.forwarded_background.download_kbps')" ||
				die "The no-SQM background download measurement is missing."
			fair_background_ul="$(require_result_value '@.fair_outcome.no_sqm_control.forwarded_background.upload_kbps')" ||
				die "The no-SQM background upload measurement is missing."
			fair_background_dl_limit="$(require_result_value '@.fair_outcome.no_sqm_control.forwarded_background.download_limit_kbps')" ||
				die "The no-SQM background download limit is missing."
			fair_background_ul_limit="$(require_result_value '@.fair_outcome.no_sqm_control.forwarded_background.upload_limit_kbps')" ||
				die "The no-SQM background upload limit is missing."
			is_decimal "$fair_background_dl" && is_decimal "$fair_background_ul" &&
				is_decimal "$fair_background_dl_limit" && is_decimal "$fair_background_ul_limit" &&
				awk -v dl="$fair_background_dl" -v ul="$fair_background_ul" \
					-v dl_limit="$fair_background_dl_limit" -v ul_limit="$fair_background_ul_limit" \
					'BEGIN { exit(dl > dl_limit || ul > ul_limit) }' ||
				die "The no-SQM control exceeded its forwarded-traffic limits."
			result_action_allowed disable_sqm ||
				die "The Fair outcome does not allow disabling SQM."
			fair_shaped_grade="$(require_result_value '@.validation.actual_grade')" ||
				die "The shaped Fair grade is missing."
			fair_control_grade="$(require_result_value '@.fair_outcome.no_sqm_control.grade')" ||
				die "The no-SQM grade is missing."
			require_result_flag '@.fair_outcome.actual_grade' "$fair_shaped_grade" "The Fair outcome grade differs from validation."
			fair_shaped_rank="$(quality_grade_rank "$fair_shaped_grade")" ||
				die "The shaped Fair grade is invalid."
			fair_control_rank="$(quality_grade_rank "$fair_control_grade")" ||
				die "The no-SQM grade is invalid."
			[ "$fair_control_rank" -le "$fair_shaped_rank" ] ||
				die "The no-SQM control grade is worse than the shaped candidate."
			fair_shaped_delta="$(require_result_value '@.validation.effective_delta_ms')" ||
				die "The shaped Fair delay is missing."
			fair_control_delta="$(require_result_value '@.fair_outcome.no_sqm_control.effective_delta_ms')" ||
				die "The no-SQM delay is missing."
			fair_outcome_delta="$(require_result_value '@.fair_outcome.actual_effective_delta_ms')" ||
				die "The Fair outcome delay is missing."
			is_decimal "$fair_shaped_delta" && is_decimal "$fair_control_delta" &&
				is_decimal "$fair_outcome_delta" &&
				numbers_equal "$fair_outcome_delta" "$fair_shaped_delta" &&
				awk -v control="$fair_control_delta" -v shaped="$fair_shaped_delta" \
					'BEGIN { exit(control > shaped + 10) }' ||
				die "The no-SQM delay is materially worse than the shaped candidate."
			fair_control_dl="$(require_result_value '@.fair_outcome.no_sqm_control.throughput.download_kbps')" ||
				die "The no-SQM download measurement is missing."
			fair_control_ul="$(require_result_value '@.fair_outcome.no_sqm_control.throughput.upload_kbps')" ||
				die "The no-SQM upload measurement is missing."
			is_positive_rate "$fair_control_dl" && is_positive_rate "$fair_control_ul" ||
				die "The no-SQM throughput measurements are invalid."
			fair_dl_gain="$(require_result_value '@.fair_outcome.throughput_gain_without_sqm.download_percent')" ||
				die "The no-SQM download comparison is missing."
			fair_ul_gain="$(require_result_value '@.fair_outcome.throughput_gain_without_sqm.upload_percent')" ||
				die "The no-SQM upload comparison is missing."
			is_decimal "$fair_dl_gain" && is_decimal "$fair_ul_gain" &&
				awk -v dl="$fair_dl_gain" -v ul="$fair_ul_gain" 'BEGIN { exit(dl < 2 || ul < 2) }' ||
				die "The no-SQM throughput benefit is below the explicit recommendation threshold."
			;;
	esac
	[ "$(json_get "$result_copy" '@.job_id')" = "$job" ] || die "The Full Auto-Tune result belongs to a different instance."
	[ "$(json_get "$result_copy" '@.target_interface')" = "$target" ] || die "The Full Auto-Tune result targets a different interface."
	[ "$(json_get "$result_copy" '@.route_mode')" = "$route_mode" ] || die "The Full Auto-Tune result uses a different route mode."
	[ "$(json_get "$result_copy" '@.mwan3_member')" = "$member" ] || die "The Full Auto-Tune result uses a different mwan3 member."
	[ "$(json_get "$result_copy" '@.config_fingerprint')" = "$fingerprint" ] || die "The Full Auto-Tune result fingerprint changed."

	snapshot_configs || die "Unable to snapshot the pre-apply configuration into tmpfs."
	attest_route "$job" "$target" "$backend" "$route_mode" "$member" "$fingerprint"
	now="$(date +%s)"
	is_uint "$now" || die "Unable to establish the apply-token clock."
	expires=$((now + token_ttl_s))
	boot_id="$(current_boot_id)" || die "Unable to establish the current boot identity."
	original_daemon_identity="$(daemon_identity "$job")" || die "Unable to snapshot the pre-apply daemon generation."
	build_expected_manifest "$job" "$target" "$route_mode" "$member" "$enabled" "$disable_adaptive" "$action" "$fingerprint" "$token" "$expires" "$boot_id" ||
		die "Unable to build the exact Full Auto-Tune apply manifest."
	build_expected_final_manifest || die "Unable to build the marker-free Full Auto-Tune terminal manifest."
	expected_cake_fingerprint="$(snapshot_fingerprint "$token_dir/expected" cake-autorate)" || die "Unable to hash the expected CAKE manifest."
	expected_pre_sqm_fingerprint="$(snapshot_fingerprint "$token_dir/expected-pre" sqm)" || die "Unable to hash the pre-init SQM manifest."
	expected_sqm_fingerprint="$(snapshot_fingerprint "$token_dir/expected" sqm)" || die "Unable to hash the expected SQM manifest."
	expected_final_cake_fingerprint="$(snapshot_fingerprint "$token_dir/expected-final" cake-autorate)" || die "Unable to hash the terminal CAKE manifest."
	expected_final_sqm_fingerprint="$(snapshot_fingerprint "$token_dir/expected-final" sqm)" || die "Unable to hash the terminal SQM manifest."
	original_cake_fingerprint="$(snapshot_fingerprint "$token_dir/original" cake-autorate)" || die "Unable to hash the original CAKE snapshot."
	original_sqm_fingerprint="$(snapshot_fingerprint "$token_dir/original" sqm)" || die "Unable to hash the original SQM snapshot."
	{
		printf 'version=2\n'
		printf 'job=%s\n' "$job"
		printf 'target=%s\n' "$target"
		printf 'backend=%s\n' "$backend"
		printf 'route_mode=%s\n' "$route_mode"
		printf 'mwan3_member=%s\n' "$member"
		printf 'enabled=%s\n' "$enabled"
		printf 'disable_adaptive=%s\n' "$disable_adaptive"
		printf 'action=%s\n' "$action"
		printf 'run_id=%s\n' "$run_id"
		printf 'result_fingerprint=%s\n' "$fingerprint"
		printf 'expected_cake_fingerprint=%s\n' "$expected_cake_fingerprint"
		printf 'expected_pre_sqm_fingerprint=%s\n' "$expected_pre_sqm_fingerprint"
		printf 'expected_sqm_fingerprint=%s\n' "$expected_sqm_fingerprint"
		printf 'expected_final_cake_fingerprint=%s\n' "$expected_final_cake_fingerprint"
		printf 'expected_final_sqm_fingerprint=%s\n' "$expected_final_sqm_fingerprint"
		printf 'original_cake_fingerprint=%s\n' "$original_cake_fingerprint"
		printf 'original_sqm_fingerprint=%s\n' "$original_sqm_fingerprint"
		printf 'original_daemon_identity=%s\n' "$original_daemon_identity"
		printf 'source_ip=%s\n' "$(json_get "$result_copy" '@.source_ip')"
		printf 'external_ip=%s\n' "$(json_get "$result_copy" '@.external_ip')"
		printf 'route_identity=%s\n' "$(json_get "$result_copy" '@.route_identity')"
		printf 'expires_epoch=%s\n' "$expires"
		printf 'boot_id=%s\n' "$boot_id"
		printf 'rollback_timeout_s=%s\n' "$rollback_timeout_s"
	} > "$token_dir/meta" || die "Unable to write the Full Auto-Tune token metadata."
	chmod 600 "$token_dir/meta" || die "Unable to protect the Full Auto-Tune token metadata."
	owned_regular "$token_dir/meta" || die "The Full Auto-Tune token metadata is unsafe."
	arm_cleanup_dir=""
	printf '{"state":"armed","schema_version":1,"token":"%s","expires_epoch":%s,"boot_id":"%s"}\n' "$token" "$expires" "$boot_id"
}

load_token() {
	token="$1"
	safe_token "$token" || die "Invalid Full Auto-Tune apply token."
	prepare_root
	token_dir="$guard_root/$token"
	require_secure_directory "$token_dir" || die "The Full Auto-Tune apply token is missing, foreign-owned, or unsafe."
	token_version="$(meta_get version "$token_dir")"
	case "$token_version" in 1|2) ;; *) die "Unsupported Full Auto-Tune apply-token schema." ;; esac
	job="$(meta_get job "$token_dir")"
	target="$(meta_get target "$token_dir")"
	backend="$(meta_get backend "$token_dir")"
	route_mode="$(meta_get route_mode "$token_dir")"
	member="$(meta_get mwan3_member "$token_dir")"
	enabled="$(meta_get enabled "$token_dir")"
	disable_adaptive="$(meta_get disable_adaptive "$token_dir")"
	action="$(meta_get action "$token_dir")"
	run_id="$(meta_get run_id "$token_dir")"
	expires="$(meta_get expires_epoch "$token_dir")"
	token_boot_id="$(meta_get boot_id "$token_dir" 2>/dev/null || true)"
	safe_job "$job" && safe_interface "$target" && safe_backend "$backend" && is_uint "$expires" ||
		die "The Full Auto-Tune token metadata is invalid."
	case "$route_mode" in main) [ -z "$member" ] || die "The Full Auto-Tune token route is invalid." ;; mwan3) safe_interface "$member" || die "The Full Auto-Tune token member is invalid." ;; *) die "The Full Auto-Tune token route mode is invalid." ;; esac
	case "$enabled:$disable_adaptive:$action" in
		1:0:apply_sqm|1:1:apply_sqm|0:0:disable_sqm|0:1:disable_sqm) ;;
		*) die "The Full Auto-Tune token action metadata is invalid." ;;
	esac
	safe_run_id "$run_id" || die "The Full Auto-Tune token run identity is invalid."
	if [ "$token_version" = 2 ]; then
		safe_boot_id "$token_boot_id" || die "The Full Auto-Tune token boot identity is invalid."
		[ "$token_boot_id" = "$(current_boot_id)" ] ||
			die "The Full Auto-Tune token belongs to a previous boot."
	fi
	now="$(date +%s)"
	is_uint "$now" || die "Unable to establish the apply-token clock."
	if [ "$now" -le "$expires" ]; then token_expired=0; else token_expired=1; fi
	result_copy="$token_dir/result.json"
	owned_regular "$result_copy" || die "The token-bound Full Auto-Tune result is unsafe."
	require_secure_directory "$token_dir/original" && require_secure_directory "$token_dir/expected-pre" &&
		require_secure_directory "$token_dir/expected" && require_secure_directory "$token_dir/expected-final" ||
		die "The token-bound configuration snapshots are unsafe."
	owned_regular "$token_dir/sqm-section" || die "The token-bound SQM identity is unsafe."
	result_fingerprint="$(meta_get result_fingerprint "$token_dir")"
	safe_fingerprint "$result_fingerprint" &&
		[ "$(json_get "$result_copy" '@.config_fingerprint')" = "$result_fingerprint" ] ||
		die "The token-bound Full Auto-Tune result fingerprint is inconsistent."
	[ "$(json_get "$result_copy" '@.run_id')" = "$run_id" ] ||
		die "The token-bound Full Auto-Tune run identity is inconsistent."
	for fingerprint_spec in \
		"expected_cake_fingerprint:$token_dir/expected:cake-autorate" \
		"expected_pre_sqm_fingerprint:$token_dir/expected-pre:sqm" \
		"expected_sqm_fingerprint:$token_dir/expected:sqm" \
		"expected_final_cake_fingerprint:$token_dir/expected-final:cake-autorate" \
		"expected_final_sqm_fingerprint:$token_dir/expected-final:sqm" \
		"original_cake_fingerprint:$token_dir/original:cake-autorate" \
		"original_sqm_fingerprint:$token_dir/original:sqm"; do
		fingerprint_key="${fingerprint_spec%%:*}"
		fingerprint_rest="${fingerprint_spec#*:}"
		fingerprint_directory="${fingerprint_rest%:*}"
		fingerprint_config="${fingerprint_rest##*:}"
		stored_fingerprint="$(meta_get "$fingerprint_key" "$token_dir")"
		safe_fingerprint "$stored_fingerprint" || die "A token-bound manifest fingerprint is invalid."
		[ "$(snapshot_fingerprint "$fingerprint_directory" "$fingerprint_config")" = "$stored_fingerprint" ] ||
			die "A token-bound Full Auto-Tune snapshot changed."
	done
}

require_token_unexpired() {
	[ "${token_expired:-1}" -eq 0 ] || die "The Full Auto-Tune apply token expired. Run Auto-Tune again."
}

verify_marker() {
	marker_job="$1"
	marker_stage="${2:-pre}"
	marker_allow_expired="${3:-0}"
	marker_token="$(uci -q get "cake-autorate.$marker_job._autotune_apply_token" 2>/dev/null)"
	load_token "$marker_token"
	[ "$marker_allow_expired" = 1 ] || require_token_unexpired
	[ "$job" = "$marker_job" ] || die "The Full Auto-Tune marker/token instance does not match."
	[ "$(uci -q get "cake-autorate.$job._autotune_apply_guard" 2>/dev/null)" = 1 ] || die "The Full Auto-Tune apply marker is malformed."
	[ "$(uci -q get "cake-autorate.$job._autotune_apply_fingerprint" 2>/dev/null)" = "$(meta_get result_fingerprint "$token_dir")" ] || die "The Full Auto-Tune marker fingerprint does not match its token."
	[ "$(uci -q get "cake-autorate.$job._autotune_apply_target" 2>/dev/null)" = "$target" ] || die "The Full Auto-Tune marker target does not match its token."
	[ "$(uci -q get "cake-autorate.$job._autotune_apply_backend" 2>/dev/null)" = "$backend" ] || die "The Full Auto-Tune marker backend does not match its token."
	[ "$(uci -q get "cake-autorate.$job._autotune_apply_route_mode" 2>/dev/null)" = "$route_mode" ] || die "The Full Auto-Tune marker route mode does not match its token."
	if [ "$route_mode" = mwan3 ]; then
		[ "$(uci -q get "cake-autorate.$job._autotune_apply_mwan3_member" 2>/dev/null)" = "$member" ] ||
			die "The Full Auto-Tune marker member does not match its token."
	elif uci -q get "cake-autorate.$job._autotune_apply_mwan3_member" >/dev/null 2>&1; then
		die "A main-route Full Auto-Tune marker unexpectedly names an mwan3 member."
	fi
	[ "$(uci -q get "cake-autorate.$job._autotune_apply_enabled" 2>/dev/null)" = "$enabled" ] || die "The Full Auto-Tune marker enabled state does not match its token."
	[ "$(uci -q get "cake-autorate.$job._autotune_apply_disable_adaptive" 2>/dev/null)" = "$disable_adaptive" ] || die "The Full Auto-Tune marker adaptive decision does not match its token."
	[ "$(uci -q get "cake-autorate.$job._autotune_apply_action" 2>/dev/null)" = "$action" ] || die "The Full Auto-Tune marker action does not match its token."
	[ "$(uci -q get "cake-autorate.$job._autotune_apply_expires" 2>/dev/null)" = "$expires" ] || die "The Full Auto-Tune marker expiry does not match its token."
	if [ "$token_version" = 2 ]; then
		[ "$(uci -q get "cake-autorate.$job._autotune_apply_boot_id" 2>/dev/null)" = "$token_boot_id" ] ||
			die "The Full Auto-Tune marker boot identity does not match its token."
	fi
	sqm_guard="$(sqm_guard_section "$job")" || die "The SQM rollback marker identity is unsafe."
	[ "$(uci -q get "sqm.$sqm_guard" 2>/dev/null)" = cake_autorate_apply_guard ] ||
		die "The SQM rollback marker has an unexpected section type."
	[ "$(uci -q get "sqm.$sqm_guard._autotune_apply_guard" 2>/dev/null)" = 1 ] ||
		die "The SQM package is not enrolled in the rollback transaction."
	[ "$(uci -q get "sqm.$sqm_guard._autotune_apply_job" 2>/dev/null)" = "$job" ] ||
		die "The SQM rollback marker belongs to a different instance."
	[ "$(uci -q get "sqm.$sqm_guard._autotune_apply_token" 2>/dev/null)" = "$marker_token" ] ||
		die "The SQM rollback marker does not match the apply token."

	expected_cake="$token_dir/check-expected-cake.$$"
	live_cake="$token_dir/check-live-cake.$$"
	canonical_package "$token_dir/expected" cake-autorate "$expected_cake"
	canonical_live_package cake-autorate "$live_cake"
	if ! same_files "$expected_cake" "$live_cake"; then
		rm -f "$expected_cake" "$live_cake"
		die "The applied CAKE Autorate package differs from the exact validated proposal manifest."
	fi
	rm -f "$expected_cake" "$live_cake"

	if [ "$marker_stage" = pre ]; then
		# A config.change reload can run before the explicit guarded restart.
		# Therefore the protected queue may be either the exact arm-time value
		# or the exact manifest already materialized by that first reload. No
		# third/intermediate state is accepted.
		expected_pre_sqm="$token_dir/check-expected-pre-sqm.$$"
		expected_sqm="$token_dir/check-expected-sqm.$$"
		live_sqm="$token_dir/check-live-sqm.$$"
		canonical_package "$token_dir/expected-pre" sqm "$expected_pre_sqm"
		canonical_package "$token_dir/expected" sqm "$expected_sqm"
		canonical_live_package sqm "$live_sqm"
		if ! same_files "$expected_pre_sqm" "$live_sqm" &&
		   ! same_files "$expected_sqm" "$live_sqm"; then
			rm -f "$expected_pre_sqm" "$expected_sqm" "$live_sqm"
			die "The protected SQM package changed outside the validated proposal transaction."
		fi
		rm -f "$expected_pre_sqm" "$expected_sqm" "$live_sqm"
	fi

	verify_live_route
}

verify_live_route() {
	route_json="$token_dir/route-check.$$"
	"$speedtest_bin" "$job" "$target" route-status "$backend" "" "$route_mode" "$member" > "$route_json" 2>/dev/null ||
		die "Unable to attest the selected route during Full Auto-Tune apply."
	owned_regular "$route_json" && chmod 600 "$route_json" || die "The route attestation output is unsafe."
	[ "$(json_get "$route_json" '@.state')" = ready ] || die "The selected Full Auto-Tune route is no longer ready."
	[ "$(json_get "$route_json" '@.source_ip')" = "$(meta_get source_ip "$token_dir")" ] || die "The selected uplink source address changed during apply."
	[ "$(json_get "$route_json" '@.external_ip')" = "$(meta_get external_ip "$token_dir")" ] || die "The selected uplink external address changed during apply."
	[ "$(json_get "$route_json" '@.route_identity')" = "$(meta_get route_identity "$token_dir")" ] || die "The selected uplink route identity changed during apply."
	rm -f "$route_json"
}

guarded_jobs() {
	uci -q show cake-autorate 2>/dev/null |
		sed -n "s/^cake-autorate\.\([A-Za-z0-9_]*\)\._autotune_apply_[A-Za-z0-9_]*=.*/\1/p" |
		LC_ALL=C sort -u
}

guarded_sqm_jobs() {
	uci -q show sqm 2>/dev/null |
		sed -n "s/^sqm\.cake_autorate_apply_[A-Za-z0-9_]*\._autotune_apply_job='\([A-Za-z0-9_]*\)'$/\1/p" |
		LC_ALL=C sort -u
}

any_apply_marker_lines() {
	uci -q show cake-autorate 2>/dev/null | grep -q '\._autotune_apply_' && return 0
	uci -q show sqm 2>/dev/null | grep -q '\._autotune_apply_'
}

verify_init() {
	prepare_root
	jobs="$(guarded_jobs)"
	sqm_jobs="$(guarded_sqm_jobs)"
	if [ -z "$jobs$sqm_jobs" ]; then
		any_apply_marker_lines && die "An incomplete Full Auto-Tune apply marker exists."
		printf '{"state":"clear","schema_version":1}\n'
		return 0
	fi
	[ -n "$jobs" ] && [ -n "$sqm_jobs" ] && [ "$jobs" = "$sqm_jobs" ] ||
		die "The CAKE and SQM apply markers are not an exact pair."
	[ "$(printf '%s\n' $jobs | wc -l)" -eq 1 ] ||
		die "Only one Full Auto-Tune apply marker may be active in a transaction."
	count=0
	for marker_job in $jobs; do
		safe_job "$marker_job" || die "An unsafe Full Auto-Tune marker section exists."
		verify_marker "$marker_job" pre
		count=$((count + 1))
	done
	apply_started_file="$token_dir/apply-started"
	if [ ! -e "$apply_started_file" ]; then
		apply_started_tmp="$token_dir/apply-started.$$"
		date +%s > "$apply_started_tmp" || die "Unable to timestamp the guarded UCI apply."
		chmod 600 "$apply_started_tmp" || die "Unable to protect the guarded UCI apply timestamp."
		owned_regular "$apply_started_tmp" || die "The guarded UCI apply timestamp is unsafe."
		mv "$apply_started_tmp" "$apply_started_file" || die "Unable to publish the guarded UCI apply timestamp."
	fi
	owned_regular "$apply_started_file" || die "The guarded UCI apply timestamp is unsafe."
	printf '{"state":"verified","schema_version":1,"markers":%s,"token":"%s"}\n' "$count" "$marker_token"
}

persistent_uci() {
	[ -n "${recovery_cleanup_dir:-}" ] || return 1
	uci -c "$config_dir" -t "$recovery_cleanup_dir" -p "$recovery_cleanup_dir" "$@"
}

persistent_guarded_jobs() {
	persistent_uci -q show cake-autorate 2>/dev/null |
		sed -n "s/^cake-autorate\.\([A-Za-z0-9_]*\)\._autotune_apply_[A-Za-z0-9_]*=.*/\1/p" |
		LC_ALL=C sort -u
}

persistent_guarded_sqm_jobs() {
	persistent_uci -q show sqm 2>/dev/null |
		sed -n "s/^sqm\.cake_autorate_apply_[A-Za-z0-9_]*\._autotune_apply_job='\([A-Za-z0-9_]*\)'$/\1/p" |
		LC_ALL=C sort -u
}

persistent_marker_lines() {
	persistent_uci -q show cake-autorate 2>/dev/null | grep -q '\._autotune_apply_' && return 0
	persistent_uci -q show sqm 2>/dev/null | grep -q '\._autotune_apply_'
}

cleanup_recovery_dir() {
	[ -n "${recovery_cleanup_dir:-}" ] || return 0
	find "$recovery_cleanup_dir" -type f -exec rm -f {} \; 2>/dev/null || return 1
	find "$recovery_cleanup_dir" -depth -type d -exec rmdir {} \; 2>/dev/null || return 1
	recovery_cleanup_dir=""
}

recover_stale() {
	prepare_root
	recovery_cleanup_dir="$guard_root/recovery.$$"
	[ ! -e "$recovery_cleanup_dir" ] && mkdir "$recovery_cleanup_dir" &&
		chmod 700 "$recovery_cleanup_dir" ||
		die "Unable to create a private stale-marker recovery transaction."
	runtime_lock_path_owned_by_euid "$recovery_cleanup_dir" ||
		die "The stale-marker recovery transaction is not root-owned."

	recovery_jobs="$(persistent_guarded_jobs)"
	recovery_sqm_jobs="$(persistent_guarded_sqm_jobs)"
	if [ -z "$recovery_jobs$recovery_sqm_jobs" ]; then
		persistent_marker_lines && die "An incomplete persistent Full Auto-Tune marker exists."
		cleanup_recovery_dir || die "Unable to clean the stale-marker recovery transaction."
		printf '{"state":"clear","schema_version":1}\n'
		return 0
	fi
	[ -n "$recovery_jobs" ] && [ "$recovery_jobs" = "$recovery_sqm_jobs" ] ||
		die "The persistent CAKE and SQM markers are not an exact pair."
	[ "$(printf '%s\n' $recovery_jobs | wc -l)" -eq 1 ] ||
		die "Only one persistent Full Auto-Tune marker may be recovered at a time."
	recovery_job="$recovery_jobs"
	safe_job "$recovery_job" || die "The persistent Full Auto-Tune marker has an unsafe instance name."
	recovery_guard="$(sqm_guard_section "$recovery_job")" ||
		die "The persistent SQM marker identity is unsafe."
	recovery_token="$(persistent_uci -q get "cake-autorate.$recovery_job._autotune_apply_token" 2>/dev/null)"
	safe_token "$recovery_token" || die "The persistent Full Auto-Tune marker has an invalid token."
	[ "$(persistent_uci -q get "cake-autorate.$recovery_job._autotune_apply_guard" 2>/dev/null)" = 1 ] ||
		die "The persistent Full Auto-Tune marker is malformed."
	recovery_fingerprint="$(persistent_uci -q get "cake-autorate.$recovery_job._autotune_apply_fingerprint" 2>/dev/null)"
	safe_fingerprint "$recovery_fingerprint" || die "The persistent Full Auto-Tune marker fingerprint is invalid."
	safe_interface "$(persistent_uci -q get "cake-autorate.$recovery_job._autotune_apply_target" 2>/dev/null)" ||
		die "The persistent Full Auto-Tune marker target is invalid."
	safe_backend "$(persistent_uci -q get "cake-autorate.$recovery_job._autotune_apply_backend" 2>/dev/null)" ||
		die "The persistent Full Auto-Tune marker backend is invalid."
	recovery_route_mode="$(persistent_uci -q get "cake-autorate.$recovery_job._autotune_apply_route_mode" 2>/dev/null)"
	case "$recovery_route_mode" in
		main)
			persistent_uci -q get "cake-autorate.$recovery_job._autotune_apply_mwan3_member" >/dev/null 2>&1 &&
				die "A persistent main-route marker unexpectedly names an mwan3 member."
			;;
		mwan3)
			safe_interface "$(persistent_uci -q get "cake-autorate.$recovery_job._autotune_apply_mwan3_member" 2>/dev/null)" ||
				die "The persistent Full Auto-Tune mwan3 member is invalid."
			;;
		*) die "The persistent Full Auto-Tune route mode is invalid." ;;
	esac
	recovery_enabled="$(persistent_uci -q get "cake-autorate.$recovery_job._autotune_apply_enabled" 2>/dev/null)"
	recovery_disable_adaptive="$(persistent_uci -q get "cake-autorate.$recovery_job._autotune_apply_disable_adaptive" 2>/dev/null)"
	recovery_action="$(persistent_uci -q get "cake-autorate.$recovery_job._autotune_apply_action" 2>/dev/null)"
	case "$recovery_enabled:$recovery_disable_adaptive:$recovery_action" in
		1:0:apply_sqm|1:1:apply_sqm|0:0:disable_sqm|0:1:disable_sqm) ;;
		*) die "The persistent Full Auto-Tune marker action is inconsistent." ;;
	esac
	recovery_expires="$(persistent_uci -q get "cake-autorate.$recovery_job._autotune_apply_expires" 2>/dev/null)"
	is_uint "$recovery_expires" || die "The persistent Full Auto-Tune marker expiry is invalid."
	[ "$(persistent_uci -q get "sqm.$recovery_guard" 2>/dev/null)" = cake_autorate_apply_guard ] ||
		die "The persistent SQM marker has an unexpected section type."
	[ "$(persistent_uci -q get "sqm.$recovery_guard._autotune_apply_guard" 2>/dev/null)" = 1 ] &&
		[ "$(persistent_uci -q get "sqm.$recovery_guard._autotune_apply_job" 2>/dev/null)" = "$recovery_job" ] &&
		[ "$(persistent_uci -q get "sqm.$recovery_guard._autotune_apply_fingerprint" 2>/dev/null)" = "$recovery_fingerprint" ] &&
		[ "$(persistent_uci -q get "sqm.$recovery_guard._autotune_apply_token" 2>/dev/null)" = "$recovery_token" ] ||
		die "The persistent SQM marker does not exactly match the CAKE marker."

	recovery_token_dir="$guard_root/$recovery_token"
	if [ -e "$recovery_token_dir" ] || [ -L "$recovery_token_dir" ]; then
		die "A persistent Full Auto-Tune marker still has runtime proof and is not stale."
	fi
	recovery_boot_id="$(persistent_uci -q get "cake-autorate.$recovery_job._autotune_apply_boot_id" 2>/dev/null || true)"
	if [ -z "$recovery_boot_id" ]; then
		recovery_reason=legacy-token-missing
	else
		safe_boot_id "$recovery_boot_id" || die "The persistent Full Auto-Tune marker boot identity is invalid."
		current_recovery_boot_id="$(current_boot_id)" ||
			die "Unable to establish the current boot identity during marker recovery."
		if [ "$recovery_boot_id" != "$current_recovery_boot_id" ]; then
			recovery_reason=boot-changed
		else
			recovery_now="$(date +%s)"
			is_uint "$recovery_now" || die "Unable to establish the stale-marker recovery clock."
			[ "$recovery_now" -gt "$recovery_expires" ] ||
				die "The tokenless Full Auto-Tune marker may still belong to an active same-boot transaction."
			recovery_reason=expired
		fi
	fi

	persistent_uci -q delete "sqm.$recovery_guard" ||
		die "Unable to remove the stale SQM transaction marker."
	persistent_uci -q commit sqm || die "Unable to commit stale SQM marker cleanup."
	for recovery_option in _autotune_apply_guard _autotune_apply_fingerprint _autotune_apply_target \
		_autotune_apply_backend _autotune_apply_route_mode _autotune_apply_mwan3_member \
		_autotune_apply_enabled _autotune_apply_disable_adaptive _autotune_apply_action \
		_autotune_apply_token _autotune_apply_expires _autotune_apply_boot_id; do
		if persistent_uci -q get "cake-autorate.$recovery_job.$recovery_option" >/dev/null 2>&1; then
			persistent_uci -q delete "cake-autorate.$recovery_job.$recovery_option" ||
				die "Unable to remove stale CAKE transaction metadata."
		fi
	done
	persistent_uci -q commit cake-autorate || die "Unable to commit stale CAKE marker cleanup."
	persistent_marker_lines && die "Persistent Full Auto-Tune metadata survived stale-marker recovery."
	cleanup_recovery_dir || die "Unable to clean the stale-marker recovery transaction."
	printf '{"state":"recovered","schema_version":1,"job":"%s","reason":"%s"}\n' \
		"$recovery_job" "$recovery_reason"
}

snapshot_state_matches() {
	state_directory="$1"
	state_cake="$token_dir/check-state-cake.$$"
	state_live_cake="$token_dir/check-state-live-cake.$$"
	state_sqm="$token_dir/check-state-sqm.$$"
	state_live_sqm="$token_dir/check-state-live-sqm.$$"
	state_match_rc=1
	if canonical_package "$state_directory" cake-autorate "$state_cake" &&
	   canonical_live_package cake-autorate "$state_live_cake" &&
	   canonical_package "$state_directory" sqm "$state_sqm" &&
	   canonical_live_package sqm "$state_live_sqm" &&
	   same_files "$state_cake" "$state_live_cake" &&
	   same_files "$state_sqm" "$state_live_sqm"; then
		state_match_rc=0
	fi
	rm -f "$state_cake" "$state_live_cake" "$state_sqm" "$state_live_sqm"
	return "$state_match_rc"
}

verify_rollback() {
	load_token "${1:-}"
	original_cake="$token_dir/check-rollback-original-cake.$$"
	live_cake="$token_dir/check-rollback-live-cake.$$"
	original_sqm="$token_dir/check-rollback-original-sqm.$$"
	live_sqm="$token_dir/check-rollback-live-sqm.$$"
	canonical_package "$token_dir/original" cake-autorate "$original_cake"
	canonical_live_package cake-autorate "$live_cake"
	canonical_package "$token_dir/original" sqm "$original_sqm"
	canonical_live_package sqm "$live_sqm"
	if ! same_files "$original_cake" "$live_cake" ||
	   ! same_files "$original_sqm" "$live_sqm"; then
		rm -f "$original_cake" "$live_cake" "$original_sqm" "$live_sqm"
		die "The rollback timer did not restore the exact pre-apply CAKE/SQM state."
	fi
	rm -f "$original_cake" "$live_cake" "$original_sqm" "$live_sqm"
	sqm_guard="$(sqm_guard_section "$job")" || die "The SQM rollback marker identity is unsafe."
	if uci -q get "sqm.$sqm_guard" >/dev/null 2>&1; then
		die "The SQM rollback marker survived the UCI rollback."
	fi
	printf '{"state":"rolled-back","schema_version":1,"token":"%s"}\n' "$token"
}

disabled_runtime_is_clean() {
	disabled_target="$1"
	disabled_ifb="$2"

	pgrep -f "^$daemon_bin --instance $job\$" >/dev/null 2>&1 && return 1
	disabled_target_qdisc="$("$tc_bin" qdisc show dev "$disabled_target" 2>/dev/null || true)"
	printf '%s\n' "$disabled_target_qdisc" | grep -Eq '(^|[[:space:]])qdisc[[:space:]]+cake([[:space:]]|$)' &&
		return 1
	printf '%s\n' "$disabled_target_qdisc" | grep -Eq '(^|[[:space:]])qdisc[[:space:]]+(ingress|clsact)([[:space:]]|$)' &&
		return 1
	if [ -e "$sys_class_net/$disabled_ifb" ]; then
		disabled_ifb_qdisc="$("$tc_bin" qdisc show dev "$disabled_ifb" 2>/dev/null || true)"
		printf '%s\n' "$disabled_ifb_qdisc" | grep -Eq '(^|[[:space:]])qdisc[[:space:]]+cake([[:space:]]|$)' &&
			return 1
		return 1
	fi
	disabled_filter_state="$(
		"$tc_bin" filter show dev "$disabled_target" parent ffff: 2>/dev/null || true
		"$tc_bin" filter show dev "$disabled_target" ingress 2>/dev/null || true
	)"
	printf '%s\n' "$disabled_filter_state" | grep -Ei '(mirred|redirect)' >/dev/null &&
		return 1
	return 0
}

postcheck() {
	is_uint "$postcheck_wait_s" && [ "$postcheck_wait_s" -ge 1 ] && [ "$postcheck_wait_s" -le 30 ] ||
		die "Invalid Full Auto-Tune postcheck wait bound."
	requested_token="${1:-}"
	load_token "$requested_token"
	require_token_unexpired
	[ "$(uci -q get "cake-autorate.$job._autotune_apply_token" 2>/dev/null)" = "$requested_token" ] ||
		die "The requested postcheck token is not the live Full Auto-Tune token."
	verify_marker "$job" post
	expected_sqm="$token_dir/check-expected-sqm.$$"
	live_sqm="$token_dir/check-live-sqm.$$"
	canonical_package "$token_dir/expected" sqm "$expected_sqm"
	sqm_attempt=0
	while :; do
		canonical_live_package sqm "$live_sqm"
		same_files "$expected_sqm" "$live_sqm" && break
		sqm_attempt=$((sqm_attempt + 1))
		[ "$sqm_attempt" -lt "$postcheck_wait_s" ] || break
		sleep 1
	done
	if ! same_files "$expected_sqm" "$live_sqm"; then
		rm -f "$expected_sqm" "$live_sqm"
		die "The managed SQM package differs from the exact Full Auto-Tune manifest."
	fi
	rm -f "$expected_sqm" "$live_sqm"
	if [ "$enabled" = 1 ]; then
		runtime_attempt=0
		while ! pgrep -f "^$daemon_bin --instance $job\$" >/dev/null 2>&1; do
			runtime_attempt=$((runtime_attempt + 1))
			[ "$runtime_attempt" -lt 5 ] || die "The validated autorate instance did not start."
			sleep 1
		done
		resolved="$(json_get "$result_copy" '@.resolved_interface')"
		dl_if="$(uci -q get "cake-autorate.$job.dl_if" 2>/dev/null)"
		safe_interface "$resolved" && safe_interface "$dl_if" || die "The validated SQM runtime interfaces are invalid."
		[ -n "$tc_bin" ] && [ -x "$tc_bin" ] || die "tc is unavailable for the managed SQM runtime check."
		[ -d "$sys_class_net/$resolved" ] && [ -d "$sys_class_net/$dl_if" ] ||
			die "The validated SQM interfaces are not present after restart."
		"$tc_bin" qdisc show dev "$resolved" 2>/dev/null | grep -Eq '^qdisc cake | qdisc cake ' ||
			die "The validated upload CAKE qdisc is not active after restart."
		"$tc_bin" qdisc show dev "$dl_if" 2>/dev/null | grep -Eq '^qdisc cake | qdisc cake ' ||
			die "The validated download CAKE qdisc is not active after restart."
		expected_ul="$(json_get "$result_copy" '@.proposal.upload.base_kbps')"
		expected_dl="$(json_get "$result_copy" '@.proposal.download.base_kbps')"
		[ "$(cake_root_bandwidth_kbps "$resolved")" = "$expected_ul" ] ||
			die "The active upload CAKE bandwidth does not match the validated manifest."
		[ "$(cake_root_bandwidth_kbps "$dl_if")" = "$expected_dl" ] ||
			die "The active download CAKE bandwidth does not match the validated manifest."
		"$tc_bin" qdisc show dev "$resolved" 2>/dev/null | grep -Eq '^qdisc ingress | qdisc ingress ' ||
			die "The validated ingress qdisc is not active after restart."
		"$tc_bin" filter show dev "$resolved" parent ffff: 2>/dev/null |
			grep -Ei "mirred.*redirect.*(dev|device) $dl_if([^A-Za-z0-9_.:@-]|$)" >/dev/null ||
			die "The validated ingress redirect does not target the expected IFB."
		current_daemon_identity="$(daemon_identity "$job")" || die "Unable to identify the validated daemon generation."
		original_daemon_identity="$(meta_get original_daemon_identity "$token_dir")"
		[ "$current_daemon_identity" != none ] || die "The validated autorate daemon generation is missing."
		[ "$(daemon_identity_count "$current_daemon_identity")" -eq 1 ] ||
			die "The validated autorate instance has multiple daemon generations."
		! daemon_identities_intersect "$current_daemon_identity" "$original_daemon_identity" ||
			die "The postcheck observed a stale pre-apply daemon generation."
	else
		[ "$action" = disable_sqm ] || die "A disabled Full Auto-Tune transaction has no typed disable action."
		[ -n "$tc_bin" ] && [ -x "$tc_bin" ] || die "tc is unavailable for the disabled SQM runtime check."
		resolved="$(json_get "$result_copy" '@.resolved_interface')"
		dl_if="$(uci -q get "cake-autorate.$job.dl_if" 2>/dev/null)"
		safe_interface "$resolved" && safe_interface "$dl_if" || die "The disabled SQM runtime interfaces are invalid."
		runtime_attempt=0
		while ! disabled_runtime_is_clean "$resolved" "$dl_if"; do
			runtime_attempt=$((runtime_attempt + 1))
			[ "$runtime_attempt" -lt "$postcheck_wait_s" ] || break
			sleep 1
		done
		disabled_runtime_is_clean "$resolved" "$dl_if" ||
			die "Disabling SQM left a daemon, CAKE qdisc, ingress redirect, or managed IFB active."
	fi
	: > "$token_dir/postverified"
	chmod 600 "$token_dir/postverified"
	owned_regular "$token_dir/postverified" || die "Unable to record the post-apply verification."
	printf '{"state":"verified","schema_version":1,"token":"%s"}\n' "$token"
}

prepare_confirm() {
	requested_token="${1:-}"
	load_token "$requested_token"
	owned_regular "$token_dir/postverified" || die "The Full Auto-Tune transaction was not post-verified."
	sqm_guard="$(sqm_guard_section "$job")" || die "The SQM rollback marker identity is unsafe."
	if owned_regular "$token_dir/prepared"; then
		! token_live_referenced "$token" || die "A prepared transaction unexpectedly regained a live token marker."
		snapshot_state_matches "$token_dir/expected-final" || die "The prepared Full Auto-Tune terminal state changed."
		printf '{"state":"prepared","schema_version":1,"token":"%s"}\n' "$token"
		return 0
	fi
	[ "$(uci -q get "cake-autorate.$job._autotune_apply_token" 2>/dev/null)" = "$requested_token" ] ||
		die "The requested prepare-confirm token is not the live CAKE marker token."
	[ "$(uci -q get "sqm.$sqm_guard._autotune_apply_token" 2>/dev/null)" = "$requested_token" ] ||
		die "The requested prepare-confirm token is not the live SQM marker token."
	verify_marker "$job" post 1
	snapshot_state_matches "$token_dir/expected" || die "The post-verified configuration changed before prepare-confirm."

	# Remove the enrollment marker first and the CAKE marker last. Both commits
	# remain covered by rpcd's already armed rollback snapshot.
	live_uci_transaction -q delete "sqm.$sqm_guard" || die "Unable to remove the prepared SQM rollback marker."
	live_uci_transaction -q commit sqm || die "Unable to commit prepared SQM marker cleanup."
	for option in _autotune_apply_guard _autotune_apply_fingerprint _autotune_apply_target \
		_autotune_apply_backend _autotune_apply_route_mode _autotune_apply_mwan3_member \
		_autotune_apply_enabled _autotune_apply_disable_adaptive _autotune_apply_action _autotune_apply_token \
		_autotune_apply_expires _autotune_apply_boot_id; do
		if uci -q get "cake-autorate.$job.$option" >/dev/null 2>&1; then
			live_uci_transaction -q delete "cake-autorate.$job.$option" ||
				die "Unable to remove a prepared Full Auto-Tune marker option."
		fi
	done
	live_uci_transaction -q commit cake-autorate || die "Unable to commit prepared CAKE marker cleanup."
	! token_live_referenced "$token" || die "A live token reference survived prepare-confirm."
	snapshot_state_matches "$token_dir/expected-final" || die "The marker-free Full Auto-Tune terminal manifest was not materialized exactly."
	: > "$token_dir/prepared"
	chmod 600 "$token_dir/prepared"
	owned_regular "$token_dir/prepared" || die "Unable to record the prepared Full Auto-Tune transaction."
	printf '{"state":"prepared","schema_version":1,"token":"%s"}\n' "$token"
}

reconcile() {
	load_token "${1:-}"
	owned_regular "$token_dir/prepared" || die "The Full Auto-Tune transaction was never prepared for confirmation."
	if snapshot_state_matches "$token_dir/original"; then
		printf '{"state":"rolled-back","schema_version":1,"token":"%s"}\n' "$token"
		return 0
	fi
	if snapshot_state_matches "$token_dir/expected-final"; then
		printf '{"state":"confirmed","schema_version":1,"token":"%s"}\n' "$token"
		return 0
	fi
	die "Neither exact rollback nor exact prepared-final state can be proven."
}

cleanup_token_dir() {
	cleanup_dir="$1"
	case "$cleanup_dir" in "$guard_root"/*) ;; *) return 1 ;; esac
	[ -d "$cleanup_dir" ] && [ ! -L "$cleanup_dir" ] || return 1
	runtime_lock_path_owned_by_euid "$cleanup_dir" || return 1
	find "$cleanup_dir" -type f -exec rm -f {} \; 2>/dev/null || return 1
	find "$cleanup_dir" -depth -type d -exec rmdir {} \; 2>/dev/null || return 1
}

finalize() {
	load_token "${1:-}"
	owned_regular "$token_dir/postverified" && owned_regular "$token_dir/prepared" ||
		die "The Full Auto-Tune transaction was not prepared for confirmation."
	sqm_guard="$(sqm_guard_section "$job")" || die "The SQM rollback marker identity is unsafe."
	! token_live_referenced "$token" || die "A prepared Full Auto-Tune token is still referenced by persistent configuration."
	if uci -q show "cake-autorate.$job" 2>/dev/null | grep -q "^cake-autorate\.$job\._autotune_apply_" ||
	   uci -q get "sqm.$sqm_guard" >/dev/null 2>&1; then
		die "A persistent Full Auto-Tune marker survived prepare-confirm."
	fi
	snapshot_state_matches "$token_dir/expected-final" || die "The confirmed Full Auto-Tune terminal state changed before finalize."
	if [ "$action" = apply_sqm ]; then
		[ -x "$sqm_init" ] || die "The SQM service cannot be enabled persistently after confirmation."
		"$sqm_init" enable >/dev/null 2>&1 || die "Unable to enable the confirmed SQM service persistently."
		"$sqm_init" enabled >/dev/null 2>&1 || die "The confirmed SQM service is not enabled persistently."
	fi
	write_receipt "$token" complete "The Full Auto-Tune configuration was verified and confirmed."
	cleanup_token_dir "$token_dir" || die "Unable to remove the completed Full Auto-Tune apply token."
	printf '{"state":"finalized","schema_version":1}\n'
}

guard_status() {
	local status_token="${1:-}"
	local status_receipt status_token_dir status_state
	safe_token "$status_token" || die "Invalid Full Auto-Tune apply token."
	prepare_receipt_root
	status_receipt="$receipt_root/$status_token.json"
	if [ -e "$status_receipt" ]; then
		bounded_regular_file "$status_receipt" 4096 ||
			die "The Full Auto-Tune apply receipt is unsafe."
		cat "$status_receipt"
		return 0
	fi
	prepare_root
	status_token_dir="$guard_root/$status_token"
	if [ -d "$status_token_dir" ] && [ ! -L "$status_token_dir" ]; then
		runtime_lock_path_owned_by_euid "$status_token_dir" ||
			die "The Full Auto-Tune apply token is foreign-owned."
		if [ -e "$status_token_dir/prepared" ]; then
			status_state=confirming
		elif [ -e "$status_token_dir/postverified" ]; then
			status_state=verified
		elif [ -e "$status_token_dir/apply-started" ]; then
			status_state=applying
		else
			status_state=armed
		fi
		printf '{"state":"%s","schema_version":1,"token":"%s"}\n' "$status_state" "$status_token"
		return 0
	fi
	die "No Full Auto-Tune apply transaction or receipt exists for this token."
}

wait_for_rollback_deadline() {
	supervisor_token_dir="$1"
	supervisor_started="$(sed -n '1p' "$supervisor_token_dir/apply-started" 2>/dev/null)"
	is_uint "$supervisor_started" || return 1
	supervisor_rollback_s="$(meta_get rollback_timeout_s "$supervisor_token_dir" 2>/dev/null || true)"
	is_uint "$supervisor_rollback_s" && [ "$supervisor_rollback_s" -ge 10 ] &&
		[ "$supervisor_rollback_s" -le 120 ] || return 1
	supervisor_deadline=$((supervisor_started + supervisor_rollback_s + 3))
	while :; do
		supervisor_now="$(date +%s)"
		is_uint "$supervisor_now" || return 1
		[ "$supervisor_now" -ge "$supervisor_deadline" ] && return 0
		sleep 1
	done
}

supervisor_rollback() {
	supervisor_token="$1"
	supervisor_error="$2"
	supervisor_token_dir="$guard_root/$supervisor_token"
	if wait_for_rollback_deadline "$supervisor_token_dir" &&
	   supervisor_rollback_output="$("$0" verify-rollback "$supervisor_token" 2>&1)" &&
	   printf '%s\n' "$supervisor_rollback_output" | grep -q '"state":"rolled-back"' &&
	   "$0" abort "$supervisor_token" >/dev/null 2>&1; then
		write_receipt "$supervisor_token" rolled-back "$supervisor_error"
		return 0
	fi
	write_receipt "$supervisor_token" indeterminate \
		"$supervisor_error; exact rpcd rollback could not be proven."
	return 1
}

supervise() {
	supervisor_token="${1:-}"
	safe_token "$supervisor_token" || die "Invalid Full Auto-Tune apply token."
	prepare_root
	supervisor_token_dir="$guard_root/$supervisor_token"
	require_secure_directory "$supervisor_token_dir" ||
		die "The Full Auto-Tune apply token is missing, foreign-owned, or unsafe."
	supervisor_lock="$supervisor_token_dir/supervisor.lock"
	if ! mkdir "$supervisor_lock" 2>/dev/null; then
		[ -d "$supervisor_lock" ] && [ ! -L "$supervisor_lock" ] &&
			runtime_lock_path_owned_by_euid "$supervisor_lock" ||
			die "The Full Auto-Tune supervisor lock is unsafe."
		printf '{"state":"running","schema_version":1,"token":"%s"}\n' "$supervisor_token"
		return 0
	fi
	chmod 700 "$supervisor_lock" || die "Unable to protect the Full Auto-Tune supervisor lock."

	if ! supervisor_output="$("$0" postcheck "$supervisor_token" 2>&1)"; then
		supervisor_rollback "$supervisor_token" "Post-apply verification failed: $supervisor_output" || true
		return 1
	fi
	if ! supervisor_output="$("$0" prepare-confirm "$supervisor_token" 2>&1)"; then
		supervisor_rollback "$supervisor_token" "Marker cleanup before confirmation failed: $supervisor_output" || true
		return 1
	fi
	if [ -z "$ubus_bin" ] || [ ! -x "$ubus_bin" ]; then
		supervisor_rollback "$supervisor_token" "ubus is unavailable for server-side UCI confirmation." || true
		return 1
	fi
	if ! supervisor_confirm_output="$("$ubus_bin" call uci confirm 2>&1)"; then
		if wait_for_rollback_deadline "$supervisor_token_dir"; then
			if supervisor_reconcile="$("$0" reconcile "$supervisor_token" 2>&1)"; then
				case "$supervisor_reconcile" in
					*'"state":"confirmed"'*)
						"$0" finalize "$supervisor_token"
						return $?
						;;
					*'"state":"rolled-back"'*)
						"$0" abort "$supervisor_token" >/dev/null 2>&1 || true
						write_receipt "$supervisor_token" rolled-back \
							"UCI confirmation failed and rpcd restored the previous configuration."
						return 1
						;;
				esac
			fi
		fi
		write_receipt "$supervisor_token" indeterminate \
			"UCI confirmation outcome is unknown: $supervisor_confirm_output"
		return 1
	fi
	"$0" finalize "$supervisor_token"
}

abort_guard() {
	token="${1:-}"
	safe_token "$token" || die "Invalid Full Auto-Tune apply token."
	prepare_root
	token_dir="$guard_root/$token"
	token_live_referenced "$token" && die "Refusing to abort a Full Auto-Tune token referenced by live configuration."
	if [ -d "$token_dir" ] && [ ! -L "$token_dir" ]; then
		runtime_lock_path_owned_by_euid "$token_dir" || die "Refusing to remove a foreign Full Auto-Tune token."
		if owned_regular "$token_dir/postverified" || owned_regular "$token_dir/prepared"; then
			load_token "$token"
			snapshot_state_matches "$token_dir/original" ||
				die "Refusing to abort post-verified state before exact rollback is proven."
		fi
		cleanup_token_dir "$token_dir" || die "Unable to invalidate the Full Auto-Tune token."
	fi
	printf '{"state":"aborted","schema_version":1}\n'
}

case "$mode" in
	arm) arm_guard "$@" ;;
	verify-init) verify_init ;;
	recover-stale) recover_stale ;;
	status) guard_status "$@" ;;
	supervise) supervise "$@" ;;
	verify-rollback) verify_rollback "$@" ;;
	postcheck) postcheck "$@" ;;
	prepare-confirm) prepare_confirm "$@" ;;
	reconcile) reconcile "$@" ;;
	finalize) finalize "$@" ;;
	abort) abort_guard "$@" ;;
	*) die "Unsupported Full Auto-Tune apply-guard operation." ;;
esac
