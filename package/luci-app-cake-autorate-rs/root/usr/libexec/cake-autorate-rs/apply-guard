#!/bin/sh

# Fail-closed bridge between a validated Full Auto-Tune result and the LuCI
# UCI rollback transaction which applies it.  A marker committed without its
# root-owned tmpfs token deliberately prevents the service from touching SQM.

mode="${1:-verify-init}"
shift 2>/dev/null || true

guard_root="${CAKE_AUTORATE_APPLY_GUARD_DIR:-/tmp/cake-autorate-apply-guard}"
receipt_root="${CAKE_AUTORATE_APPLY_RECEIPT_DIR:-/tmp/cake-autorate-apply-receipts}"
config_dir="${CAKE_AUTORATE_CONFIG_DIR:-/etc/config}"
autotune_root="${CAKE_AUTORATE_AUTOTUNE_DIR:-/tmp/cake-autorate-autotune}"
autotune_bin="${CAKE_AUTORATE_AUTOTUNE:-/usr/libexec/cake-autorate-rs/autotune}"
speedtest_bin="${CAKE_AUTORATE_SPEEDTEST:-/usr/libexec/cake-autorate-rs/speedtest}"
runtime_lock_lib="${CAKE_AUTORATE_RUNTIME_LOCK_LIB:-/usr/libexec/cake-autorate-rs/runtime-lock}"
jsonfilter_bin="${CAKE_AUTORATE_JSONFILTER:-$(command -v jsonfilter 2>/dev/null)}"
daemon_bin="${CAKE_AUTORATE_DAEMON:-/usr/sbin/cake-autorated}"
tc_bin="${CAKE_AUTORATE_TC:-$(command -v tc 2>/dev/null)}"
sys_class_net="${CAKE_AUTORATE_SYS_CLASS_NET:-/sys/class/net}"
proc_root="${CAKE_AUTORATE_PROC_ROOT:-/proc}"
sqm_init="${CAKE_AUTORATE_SQM_INIT:-/etc/init.d/sqm}"
ubus_bin="${CAKE_AUTORATE_UBUS:-$(command -v ubus 2>/dev/null)}"
boot_id_file="${CAKE_AUTORATE_BOOT_ID_FILE:-/proc/sys/kernel/random/boot_id}"
token_ttl_s="${CAKE_AUTORATE_APPLY_GUARD_TTL_S:-180}"
rollback_timeout_s="${CAKE_AUTORATE_APPLY_ROLLBACK_TIMEOUT_S:-30}"
postcheck_wait_s="${CAKE_AUTORATE_APPLY_GUARD_POSTCHECK_WAIT_S:-15}"
orphan_age_s="${CAKE_AUTORATE_APPLY_GUARD_ORPHAN_AGE_S:-900}"
autotune_result_producer="cake-autorate-rs-autotune"

[ -r "$runtime_lock_lib" ] && . "$runtime_lock_lib"

json_escape() {
	printf '%s' "$1" | tr '\n\r\t' '   ' | sed 's/\\/\\\\/g; s/"/\\"/g'
}

die() {
	error_message="$1"
	if [ -n "${arm_cleanup_dir:-}" ] && [ -d "$arm_cleanup_dir" ] && [ ! -L "$arm_cleanup_dir" ]; then
		cleanup_token_dir "$arm_cleanup_dir" >/dev/null 2>&1 || true
		arm_cleanup_dir=""
	fi
	if [ -n "${recovery_cleanup_dir:-}" ] && [ -d "$recovery_cleanup_dir" ] && [ ! -L "$recovery_cleanup_dir" ]; then
		find "$recovery_cleanup_dir" -type f -exec rm -f {} \; 2>/dev/null || true
		find "$recovery_cleanup_dir" -depth -type d -exec rmdir {} \; 2>/dev/null || true
		recovery_cleanup_dir=""
	fi
	printf '{"state":"failed","error":"%s"}\n' "$(json_escape "$error_message")"
	exit 1
}

safe_job() {
	case "$1" in ''|*[!A-Za-z0-9_]*) return 1 ;; esac
}

safe_interface() {
	case "$1" in ''|*[!A-Za-z0-9_.:@-]*) return 1 ;; esac
}

safe_backend() {
	case "$1" in auto|speedtest-go) return 0 ;; *) return 1 ;; esac
}

safe_token() {
	case "$1" in
		????????????????????????????????????????????????????????????????)
			case "$1" in *[!0-9a-f]*) return 1 ;; esac
			;;
		*) return 1 ;;
	esac
}

safe_fingerprint() {
	case "$1" in
		sha256:????????????????????????????????????????????????????????????????)
			case "${1#sha256:}" in *[!0-9a-f]*) return 1 ;; esac
			;;
		*) return 1 ;;
	esac
}

safe_boot_id() {
	case "$1" in
		????????-????-????-????-????????????)
			boot_id_hex="$(printf '%s' "$1" | tr -d '-')"
			case "$boot_id_hex" in *[!0-9A-Fa-f]*) return 1 ;; esac
			;;
		*) return 1 ;;
	esac
}

current_boot_id() {
	[ -f "$boot_id_file" ] && [ ! -L "$boot_id_file" ] || return 1
	boot_id="$(sed -n '1p' "$boot_id_file" 2>/dev/null)"
	safe_boot_id "$boot_id" || return 1
	printf '%s\n' "$boot_id" | tr 'A-F' 'a-f'
}

is_uint() {
	case "$1" in ''|*[!0-9]*) return 1 ;; esac
}

is_int() {
	case "$1" in
		-[0-9]*) case "${1#-}" in ''|*[!0-9]*) return 1 ;; esac ;;
		[0-9]*) case "$1" in *[!0-9]*) return 1 ;; esac ;;
		*) return 1 ;;
	esac
}

is_positive_rate() {
	is_uint "$1" && [ "$1" -gt 0 ] 2>/dev/null && [ "$1" -le 100000000 ] 2>/dev/null
}

is_decimal() {
	case "$1" in
		''|*[!0-9.]*|.*|*..*|*.) return 1 ;;
	esac
}

numbers_equal() {
	is_decimal "$1" && is_decimal "$2" || return 1
	awk -v first="$1" -v second="$2" 'BEGIN {
		delta = (first + 0) - (second + 0)
		if (delta < 0) delta = -delta
		exit(delta > 0.000001)
	}'
}

owned_regular() {
	[ -f "$1" ] && [ ! -L "$1" ] || return 1
	command -v runtime_lock_path_owned_by_euid >/dev/null 2>&1 || return 1
	runtime_lock_path_owned_by_euid "$1"
}

secure_directory() {
	dir="$1"
	command -v runtime_lock_ram_path >/dev/null 2>&1 || return 1
	command -v runtime_lock_path_owned_by_euid >/dev/null 2>&1 || return 1
	runtime_lock_ram_path "$dir" || return 1
	[ ! -L "$dir" ] || return 1
	if [ ! -e "$dir" ]; then
		mkdir -p "$dir" 2>/dev/null || return 1
	fi
	[ -d "$dir" ] && [ ! -L "$dir" ] || return 1
	runtime_lock_path_owned_by_euid "$dir" || return 1
	chmod 700 "$dir" 2>/dev/null
}

require_secure_directory() {
	dir="$1"
	command -v runtime_lock_ram_path >/dev/null 2>&1 || return 1
	command -v runtime_lock_path_owned_by_euid >/dev/null 2>&1 || return 1
	runtime_lock_ram_path "$dir" || return 1
	[ -d "$dir" ] && [ ! -L "$dir" ] || return 1
	runtime_lock_path_owned_by_euid "$dir" || return 1
	chmod 700 "$dir" 2>/dev/null
}

prepare_root() {
	secure_directory "$guard_root" || die "The Full Auto-Tune apply guard directory is unsafe or not tmpfs-backed."
}

prepare_receipt_root() {
	local receipt_count receipt_candidate receipt_name receipt_token

	secure_directory "$receipt_root" ||
		die "The Full Auto-Tune apply receipt directory is unsafe or not tmpfs-backed."
	receipt_count=0
	for receipt_candidate in "$receipt_root"/*.json; do
		[ -e "$receipt_candidate" ] || continue
		owned_regular "$receipt_candidate" || die "A Full Auto-Tune apply receipt is unsafe."
		receipt_name="${receipt_candidate##*/}"
		receipt_token="${receipt_name%.json}"
		safe_token "$receipt_token" || die "A Full Auto-Tune apply receipt has an unsafe name."
		if find "$receipt_candidate" -prune -mmin +1440 -print 2>/dev/null | grep -q .; then
			rm -f "$receipt_candidate" || die "Unable to remove an expired Full Auto-Tune apply receipt."
			continue
		fi
		receipt_count=$((receipt_count + 1))
		[ "$receipt_count" -lt 32 ] || die "Too many Full Auto-Tune apply receipts exist."
	done
}

write_receipt() {
	local receipt_token="$1"
	local receipt_state="$2"
	local receipt_message="${3:-}"
	local receipt_tmp receipt_path
	safe_token "$receipt_token" || die "Unable to write a receipt for an unsafe Full Auto-Tune token."
	case "$receipt_state" in complete|rolled-back|failed|indeterminate) ;; *) die "Invalid Full Auto-Tune receipt state." ;; esac
	prepare_receipt_root
	receipt_tmp="$receipt_root/.$receipt_token.$$"
	receipt_path="$receipt_root/$receipt_token.json"
	[ ! -L "$receipt_path" ] || die "The Full Auto-Tune apply receipt destination is unsafe."
	printf '{"state":"%s","schema_version":1,"token":"%s","message":"%s"}\n' \
		"$receipt_state" "$receipt_token" "$(json_escape "$receipt_message")" > "$receipt_tmp" ||
		die "Unable to write the Full Auto-Tune apply receipt."
	chmod 600 "$receipt_tmp" || die "Unable to protect the Full Auto-Tune apply receipt."
	owned_regular "$receipt_tmp" || die "The temporary Full Auto-Tune apply receipt is unsafe."
	mv "$receipt_tmp" "$receipt_path" || die "Unable to publish the Full Auto-Tune apply receipt."
	owned_regular "$receipt_path" || die "The published Full Auto-Tune apply receipt is unsafe."
}

token_live_referenced() {
	reference_token="$1"
	safe_token "$reference_token" || return 1
	uci -q show cake-autorate 2>/dev/null |
		grep -Fq "._autotune_apply_token='$reference_token'" && return 0
	uci -q show sqm 2>/dev/null |
		grep -Fq "._autotune_apply_token='$reference_token'"
}

guard_orphan_old_enough() {
	orphan_dir="$1"
	orphan_minutes=$(((orphan_age_s + 59) / 60))
	find "$orphan_dir" -prune -mmin "+$orphan_minutes" -print 2>/dev/null | grep -q .
}

guard_capacity_check() {
	guard_now="$(date +%s)"
	is_uint "$guard_now" || return 1
	guard_count=0
	for guard_candidate in "$guard_root"/*; do
		[ -e "$guard_candidate" ] || continue
		[ -d "$guard_candidate" ] && [ ! -L "$guard_candidate" ] || return 1
		runtime_lock_path_owned_by_euid "$guard_candidate" || return 1
		guard_name="${guard_candidate##*/}"
		safe_token "$guard_name" || return 1
		guard_expires="$(meta_get expires_epoch "$guard_candidate" 2>/dev/null || true)"
		if is_uint "$guard_expires"; then
			if [ "$guard_expires" -lt "$guard_now" ] &&
			   ! token_live_referenced "$guard_name" &&
			   ! owned_regular "$guard_candidate/postverified" &&
			   ! owned_regular "$guard_candidate/prepared"; then
				cleanup_token_dir "$guard_candidate" || return 1
				continue
			fi
		elif ! token_live_referenced "$guard_name" && guard_orphan_old_enough "$guard_candidate"; then
			cleanup_token_dir "$guard_candidate" || return 1
			continue
		fi
		guard_count=$((guard_count + 1))
		[ "$guard_count" -lt 8 ] || return 1
	done
}

bounded_regular_file() {
	bounded_file="$1"
	bounded_max="$2"
	owned_regular "$bounded_file" || return 1
	bounded_size="$(wc -c < "$bounded_file" 2>/dev/null)"
	is_uint "$bounded_size" && [ "$bounded_size" -le "$bounded_max" ]
}

json_get() {
	file="$1"
	expression="$2"
	[ -n "$jsonfilter_bin" ] || return 1
	"$jsonfilter_bin" -i "$file" -e "$expression" 2>/dev/null
}

meta_get() {
	key="$1"
	file="$2/meta"
	owned_regular "$file" || return 1
	awk -F= -v key="$key" '$1 == key { sub(/^[^=]*=/, ""); print; found++ } END { if (found != 1) exit 1 }' "$file"
}

uci_at() {
	directory="$1"
	shift
	[ -d "$directory" ] && [ ! -L "$directory" ] || return 1
	if [ ! -d "$directory/.uci" ]; then
		[ ! -e "$directory/.uci" ] && mkdir "$directory/.uci" || return 1
	fi
	[ -d "$directory/.uci" ] && [ ! -L "$directory/.uci" ] || return 1
	chmod 700 "$directory/.uci" 2>/dev/null || return 1
	uci -c "$directory" -t "$directory/.uci" -p "$directory/.uci" "$@"
}

live_uci_transaction() {
	[ -n "${token_dir:-}" ] && secure_directory "$token_dir/live-uci" || return 1
	uci -c "$config_dir" -t "$token_dir/live-uci" -p "$token_dir/live-uci" "$@"
}

original_get() {
	job="$1"
	option="$2"
	fallback="$3"
	value="$(uci_at "$token_dir/original" -q get "cake-autorate.$job.$option" 2>/dev/null || true)"
	[ -n "$value" ] || value="$fallback"
	printf '%s\n' "$value"
}

expected_set() {
	job="$1"
	option="$2"
	value="$3"
	uci_at "$token_dir/expected" -q set "cake-autorate.$job.$option=$value"
}

expected_delete() {
	uci_at "$token_dir/expected" -q delete "$1" 2>/dev/null || true
}

canonical_section() {
	directory="$1"
	config="$2"
	section="$3"
	output="$4"
	uci_at "$directory" -q show "$config.$section" 2>/dev/null | LC_ALL=C sort > "$output"
}

canonical_live_section() {
	config="$1"
	section="$2"
	output="$3"
	uci -q show "$config.$section" 2>/dev/null | LC_ALL=C sort > "$output"
}

canonical_package() {
	directory="$1"
	config="$2"
	output="$3"
	uci_at "$directory" -q show "$config" 2>/dev/null | LC_ALL=C sort > "$output"
}

canonical_live_package() {
	config="$1"
	output="$2"
	uci -q show "$config" 2>/dev/null | LC_ALL=C sort > "$output"
}

sqm_guard_section() {
	guard_job="$1"
	safe_job "$guard_job" || return 1
	printf 'cake_autorate_apply_%s\n' "$guard_job"
}

same_files() {
	cmp -s "$1" "$2"
}

snapshot_fingerprint() {
	snapshot_directory="$1"
	snapshot_config="$2"
	snapshot_file="$token_dir/check-snapshot-${snapshot_config}.$$"
	canonical_package "$snapshot_directory" "$snapshot_config" "$snapshot_file" || return 1
	snapshot_digest="$(sha256sum "$snapshot_file" 2>/dev/null | awk 'NR == 1 { print $1; exit }')"
	rm -f "$snapshot_file"
	case "$snapshot_digest" in
		????????????????????????????????????????????????????????????????)
			case "$snapshot_digest" in *[!0-9a-f]*) return 1 ;; esac
			;;
		*) return 1 ;;
	esac
	printf 'sha256:%s\n' "$snapshot_digest"
}

daemon_identity() {
	identity_job="$1"
	identity_pids="$(pgrep -f "^$daemon_bin --instance $identity_job\$" 2>/dev/null | LC_ALL=C sort -n)"
	[ -n "$identity_pids" ] || { printf '%s\n' none; return 0; }
	for identity_pid in $identity_pids; do
		is_uint "$identity_pid" || return 1
		identity_start="$(awk '{ print $22; exit }' "$proc_root/$identity_pid/stat" 2>/dev/null)"
		is_uint "$identity_start" || return 1
		printf '%s:%s,' "$identity_pid" "$identity_start"
	done
	printf '\n'
}

daemon_identity_count() {
	[ "$1" = none ] && { printf '0\n'; return 0; }
	printf '%s\n' "$1" | awk -F, '{ count = 0; for (i = 1; i <= NF; i++) if ($i != "") count++; print count }'
}

daemon_identities_intersect() {
	current_identities="$1"
	original_identities="$2"
	[ "$current_identities" != none ] && [ "$original_identities" != none ] || return 1
	for current_identity_entry in $(printf '%s' "$current_identities" | tr ',' ' '); do
		case ",$original_identities" in
			*",$current_identity_entry,"*) return 0 ;;
		esac
	done
	return 1
}

cake_root_bandwidth_kbps() {
	bandwidth_device="$1"
	"$tc_bin" qdisc show dev "$bandwidth_device" 2>/dev/null | awk '
		/^qdisc cake / {
			is_root = 0
			for (i = 1; i <= NF; i++) if ($i == "root") is_root = 1
			if (!is_root) next
			count++
			for (i = 1; i <= NF; i++) if ($i == "bandwidth") {
				value = $(i + 1)
				if (value ~ /^[0-9]+([.][0-9]+)?Kbit$/) { sub(/Kbit$/, "", value); rate = value + 0 }
				else if (value ~ /^[0-9]+([.][0-9]+)?Mbit$/) { sub(/Mbit$/, "", value); rate = value * 1000 }
				else if (value ~ /^[0-9]+([.][0-9]+)?Gbit$/) { sub(/Gbit$/, "", value); rate = value * 1000000 }
			}
		}
		END { if (count != 1 || rate <= 0) exit 1; printf "%.0f\n", rate }
	'
}

snapshot_configs() {
	bounded_regular_file "$config_dir/cake-autorate" 1048576 || return 1
	bounded_regular_file "$config_dir/sqm" 1048576 || return 1
	for snapshot_dir in "$token_dir/original" "$token_dir/expected-pre" "$token_dir/expected" "$token_dir/expected-final"; do
		mkdir "$snapshot_dir" || return 1
		chmod 700 "$snapshot_dir" || return 1
		cp "$config_dir/cake-autorate" "$snapshot_dir/cake-autorate" || return 1
		cp "$config_dir/sqm" "$snapshot_dir/sqm" || return 1
		chmod 600 "$snapshot_dir/cake-autorate" "$snapshot_dir/sqm" || return 1
	done
}

require_result_flag() {
	[ "$(json_get "$result_copy" "$1")" = "$2" ] || die "$3"
}

require_result_value() {
	result_value="$(json_get "$result_copy" "$1")" || return 1
	[ -n "$result_value" ] || return 1
	printf '%s\n' "$result_value"
}

proposal_rate() {
	proposal_value="$(require_result_value "$1")" || return 1
	is_positive_rate "$proposal_value" || return 1
	printf '%s\n' "$proposal_value"
}

proposal_uint() {
	proposal_value="$(require_result_value "$1")" || return 1
	is_uint "$proposal_value" || return 1
	printf '%s\n' "$proposal_value"
}

max_rate() {
	current="$1"
	minimum="$2"
	fallback="$3"
	awk -v current="$current" -v minimum="$minimum" -v fallback="$fallback" 'BEGIN {
		if (current !~ /^[0-9]+([.][0-9]+)?$/) current = fallback
		value = current + 0
		if (value < minimum + 0) value = minimum + 0
		printf "%.15g\n", value
	}'
}

normalized_number() {
	current="$1"
	fallback="$2"
	awk -v current="$current" -v fallback="$fallback" 'BEGIN {
		if (current !~ /^-?[0-9]+([.][0-9]+)?$/) current = fallback
		if (current !~ /^-?[0-9]+([.][0-9]+)?$/) exit 1
		printf "%.15g\n", current + 0
	}'
}

load_profile_contract() {
	profile="$(require_result_value '@.profile')" ||
		die "The Full Auto-Tune result has no calibration profile."
	proposal_schema="$(require_result_value '@.proposal.schema_version')" ||
		die "The Full Auto-Tune proposal schema is missing."
	proposal_profile="$(require_result_value '@.proposal.profile')" ||
		die "The Full Auto-Tune proposal profile is missing."
	target_grade="$(require_result_value '@.proposal.target_grade')" ||
		die "The Full Auto-Tune target grade is missing."
	quality_target_required="$(require_result_value '@.proposal.quality_target_required')" ||
		die "The Full Auto-Tune quality-target policy is missing."
	throughput_priority="$(require_result_value '@.proposal.throughput_priority')" ||
		die "The Full Auto-Tune throughput-priority policy is missing."
	[ "$proposal_schema" = 3 ] && [ "$proposal_profile" = "$profile" ] ||
		die "The Full Auto-Tune proposal profile contract is invalid."

	validation_realization_min="$(require_result_value '@.proposal.validation.candidate_realization_min_percent')" ||
		die "The Full Auto-Tune realization floor is missing."
	validation_realization_max="$(require_result_value '@.proposal.validation.candidate_realization_max_percent')" ||
		die "The Full Auto-Tune realization ceiling is missing."
	validation_retention="$(require_result_value '@.proposal.validation.capacity_retention_min_percent')" ||
		die "The Full Auto-Tune capacity-retention floor is missing."
	validation_icmp="$(require_result_value '@.proposal.validation.icmp_delta_max_ms')" ||
		die "The Full Auto-Tune ICMP latency target is missing."
	validation_transport="$(require_result_value '@.proposal.validation.transport_delta_max_ms')" ||
		die "The Full Auto-Tune transport latency target is missing."
	validation_loss="$(require_result_value '@.proposal.validation.loss_max_percent')" ||
		die "The Full Auto-Tune loss target is missing."
	validation_cpu="$(require_result_value '@.proposal.validation.cpu_max_percent')" ||
		die "The Full Auto-Tune CPU ceiling is missing."
	for profile_number in "$validation_realization_min" "$validation_realization_max" \
		"$validation_retention" "$validation_icmp" "$validation_transport" \
		"$validation_loss" "$validation_cpu"; do
		is_decimal "$profile_number" ||
			die "The Full Auto-Tune profile contains a malformed numeric policy."
	done
	numbers_equal "$validation_realization_min" 80 &&
		numbers_equal "$validation_realization_max" 110 &&
		numbers_equal "$validation_cpu" 85 &&
		numbers_equal "$validation_icmp" "$validation_transport" ||
		die "The Full Auto-Tune common validation policy is invalid."

	for threshold_pair in \
		"@.validation_thresholds.candidate_realization_min_percent:$validation_realization_min" \
		"@.validation_thresholds.candidate_realization_max_percent:$validation_realization_max" \
		"@.validation_thresholds.capacity_retention_min_percent:$validation_retention" \
		"@.validation_thresholds.delay_max_ms:$validation_transport" \
		"@.validation_thresholds.loss_max_percent:$validation_loss" \
		"@.validation_thresholds.cpu_max_percent:$validation_cpu"; do
		threshold_path="${threshold_pair%%:*}"
		threshold_expected="${threshold_pair#*:}"
		threshold_actual="$(require_result_value "$threshold_path")" ||
			die "The Full Auto-Tune terminal validation policy is incomplete."
		numbers_equal "$threshold_actual" "$threshold_expected" ||
			die "The Full Auto-Tune terminal and proposal validation policies differ."
	done

	sqm_qdisc="$(require_result_value '@.proposal.sqm.qdisc')" ||
		die "The Full Auto-Tune queue discipline is missing."
	sqm_script="$(require_result_value '@.proposal.sqm.script')" ||
		die "The Full Auto-Tune SQM script is missing."
	sqm_classification="$(require_result_value '@.proposal.sqm.classification')" ||
		die "The Full Auto-Tune CAKE classification mode is missing."
	sqm_squash_dscp="$(require_result_value '@.proposal.sqm.squash_dscp')" ||
		die "The Full Auto-Tune DSCP policy is missing."
	sqm_squash_ingress="$(require_result_value '@.proposal.sqm.squash_ingress')" ||
		die "The Full Auto-Tune ingress DSCP policy is missing."
	sqm_ingress_ecn="$(require_result_value '@.proposal.sqm.ingress_ecn')" ||
		die "The Full Auto-Tune ingress ECN policy is missing."
	sqm_egress_ecn="$(require_result_value '@.proposal.sqm.egress_ecn')" ||
		die "The Full Auto-Tune egress ECN policy is missing."
	sqm_iqdisc_opts="$(json_get "$result_copy" '@.proposal.sqm.iqdisc_opts')" ||
		die "The Full Auto-Tune ingress qdisc options are missing."
	sqm_eqdisc_opts="$(json_get "$result_copy" '@.proposal.sqm.eqdisc_opts')" ||
		die "The Full Auto-Tune egress qdisc options are missing."
	[ "$sqm_qdisc" = cake ] && [ "$sqm_ingress_ecn" = ECN ] &&
		[ "$sqm_egress_ecn" = NOECN ] ||
		die "The Full Auto-Tune common CAKE policy is invalid."

	case "$profile" in
		gaming)
			[ "$target_grade" = A+ ] &&
				[ "$quality_target_required" = true ] &&
				[ "$throughput_priority" = false ] &&
				numbers_equal "$validation_retention" 70 &&
				numbers_equal "$validation_transport" 5 &&
				numbers_equal "$validation_loss" 1 &&
				[ "$sqm_script" = layer_cake.qos ] &&
				[ "$sqm_classification" = diffserv4 ] &&
				[ "$sqm_squash_dscp" = false ] &&
				[ "$sqm_squash_ingress" = false ] &&
				[ "$sqm_iqdisc_opts" = diffserv4 ] &&
				[ "$sqm_eqdisc_opts" = diffserv4 ] ||
				die "The Gaming profile policy is invalid."
			sqm_qdisc_advanced=1
			sqm_qdisc_really_really_advanced=1
			;;
		best_overall)
			[ "$target_grade" = A ] &&
				[ "$quality_target_required" = true ] &&
				[ "$throughput_priority" = false ] &&
				numbers_equal "$validation_retention" 80 &&
				numbers_equal "$validation_transport" 30 &&
				numbers_equal "$validation_loss" 3 ||
				die "The Best overall profile policy is invalid."
			sqm_qdisc_advanced=1
			sqm_qdisc_really_really_advanced=1
			;;
		fair)
			[ "$target_grade" = C ] &&
				[ "$quality_target_required" = false ] &&
				[ "$throughput_priority" = true ] &&
				numbers_equal "$validation_retention" 90 &&
				numbers_equal "$validation_transport" 200 &&
				numbers_equal "$validation_loss" 5 ||
				die "The Fair profile policy is invalid."
			sqm_qdisc_advanced=1
			sqm_qdisc_really_really_advanced=1
			;;
		*)
			die "The Full Auto-Tune profile is unsupported."
			;;
	esac
	case "$profile" in
		best_overall|fair)
			[ "$sqm_script" = layer_cake.qos ] &&
				[ "$sqm_classification" = diffserv4 ] &&
				[ "$sqm_squash_dscp" = true ] &&
				[ "$sqm_squash_ingress" = true ] &&
				[ "$sqm_iqdisc_opts" = besteffort ] &&
				[ "$sqm_eqdisc_opts" = diffserv4 ] ||
				die "The outbound diffserv4 CAKE profile policy is invalid."
			;;
	esac
	[ "$sqm_squash_dscp" = true ] && sqm_squash_dscp_value=1 || sqm_squash_dscp_value=0
	[ "$sqm_squash_ingress" = true ] && sqm_squash_ingress_value=1 || sqm_squash_ingress_value=0
}

