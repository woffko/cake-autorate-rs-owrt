#!/bin/sh

section="$1"
requested_mode="${2:-status}"
capture_mode="${3:-client}"
backend="${4:-auto}"

job_root="${CAKE_AUTORATE_QUALITY_DIR:-/tmp/cake-autorate-quality}"
runtime_root="${CAKE_AUTORATE_RUNTIME_DIR:-/var/run/cake-autorate}"
speedtest_bin="${CAKE_AUTORATE_SPEEDTEST:-/usr/libexec/cake-autorate-rs/speedtest}"
runtime_lock_lib="${CAKE_AUTORATE_RUNTIME_LOCK_LIB:-/usr/libexec/cake-autorate-rs/runtime-lock}"
jsonfilter_bin="${CAKE_AUTORATE_JSONFILTER:-$(command -v jsonfilter 2>/dev/null)}"
uci_bin="${CAKE_AUTORATE_UCI:-uci}"
setsid_bin="${CAKE_AUTORATE_SETSID:-$(command -v setsid 2>/dev/null)}"
timeout_s="${CAKE_AUTORATE_QUALITY_TIMEOUT_S:-180}"
max_automatic_runs="${CAKE_AUTORATE_QUALITY_MAX_RUNS:-3}"
capture_phase="AUTO"
background_dl_kbps="0"
background_ul_kbps="0"
quiet_window_s="5"
quiet_timeout_s="30"
quiet_ratio="0.05"
quiet_min_kbps="1000"

if [ -r "$runtime_lock_lib" ]; then
	# shellcheck source=/usr/libexec/cake-autorate-rs/runtime-lock
	. "$runtime_lock_lib"
fi

json_escape() {
	printf '%s' "$1" | tr '\n\r\t' '   ' | sed 's/\\/\\\\/g; s/"/\\"/g'
}

json_error() {
	printf '{"error":"%s"}\n' "$(json_escape "$1")"
	exit 1
}

worker_fail() {
	message="$1"
	atomic_write "$error_file" "{\"state\":\"error\",\"error\":\"$(json_escape "$message")\"}"
	exit 1
}

safe_name() {
	case "$1" in
		''|*[!A-Za-z0-9_]*) return 1 ;;
	esac
}

safe_interface() {
	case "$1" in
		''|*[!A-Za-z0-9_.:@-]*) return 1 ;;
	esac
}

is_pid() {
	case "$1" in ''|*[!0-9]*) return 1 ;; esac
	[ "$1" -gt 1 ] 2>/dev/null
}

now_epoch() {
	date +%s
}

numeric_or_default() {
	value="$1"
	fallback="$2"
	awk -v value="$value" -v fallback="$fallback" 'BEGIN {
		if (value ~ /^[0-9]+([.][0-9]+)?$/) print value; else print fallback
	}'
}

uci_default() {
	name="$1"
	fallback="$2"
	value="$("$uci_bin" -q get "cake-autorate.$section.$name" 2>/dev/null)"
	numeric_or_default "$value" "$fallback"
}

job_paths() {
	job_dir="$job_root/$section"
	pid_file="$job_dir/pid"
	status_file="$job_dir/status.json"
	result_file="$job_dir/result.json"
	error_file="$job_dir/error.json"
	cancel_file="$job_dir/cancelled"
	log_file="$job_dir/job.log"
	runtime_dir="$runtime_root/$section"
	daemon_status="$runtime_dir/status.json"
	capture_file="$runtime_dir/rating-capture"
}

atomic_write() {
	file="$1"
	shift
	tmp="$file.$$"
	printf '%s\n' "$*" > "$tmp" && mv "$tmp" "$file"
}

status_value() {
	[ -n "$jsonfilter_bin" ] && [ -s "$daemon_status" ] || return 0
	"$jsonfilter_bin" -i "$daemon_status" -e "@$1" 2>/dev/null | sed -n '1p'
}

write_running_status() {
	message="$1"
	atomic_write "$status_file" "{\"state\":\"running\",\"mode\":\"$(json_escape "$capture_mode")\",\"message\":\"$(json_escape "$message")\"}"
}

write_capture() {
	mkdir -p "$runtime_dir" || return 1
	chmod 700 "$runtime_dir" 2>/dev/null || true
	atomic_write "$capture_file" "$token|$capture_mode|$deadline|$capture_phase|$background_dl_kbps|$background_ul_kbps"
}

clear_capture() {
	current="$(sed -n '1p' "$capture_file" 2>/dev/null)"
	case "$current" in
		"$token|"*) rm -f "$capture_file" ;;
	esac
}

resolve_target() {
	target_if="$("$uci_bin" -q get "cake-autorate.$section.sqm_interface" 2>/dev/null)"
	[ -n "$target_if" ] || target_if="$("$uci_bin" -q get "cake-autorate.$section.ul_if" 2>/dev/null)"
	[ -n "$target_if" ] || target_if="$(status_value '.route_device')"
	safe_interface "$target_if"
}

preflight() {
	[ "$("$uci_bin" -q get "cake-autorate.$section.enabled" 2>/dev/null)" = 1 ] || {
		failure="Autorate instance is disabled."
		return 1
	}
	[ "$("$uci_bin" -q get "cake-autorate.$section.sqm_enabled" 2>/dev/null)" = 1 ] || {
		failure="Managed SQM must be enabled for a loaded rating."
		return 1
	}
	[ "$("$uci_bin" -q get "cake-autorate.$section.transport_latency_enabled" 2>/dev/null)" = 1 ] || {
		failure="Transport-aware latency must be enabled."
		return 1
	}
	[ -n "$jsonfilter_bin" ] || {
		failure="jsonfilter is required."
		return 1
	}
	[ -s "$daemon_status" ] || {
		failure="Runtime status is unavailable."
		return 1
	}
	[ "$(status_value '.route_active')" = true ] || {
		failure="Selected uplink route is not active."
		return 1
	}
	if [ "$(status_value '.sqm_runtime_managed')" = true ] && \
	   [ "$(status_value '.sqm_runtime_healthy')" != true ]; then
		failure="Managed SQM runtime is unhealthy: $(status_value '.sqm_runtime_reason')"
		return 1
	fi
	[ "$(status_value '.transport_probe_trusted')" = true ] || {
		failure="A trusted native transport backend is required."
		return 1
	}
	[ "$(status_value '.quality_grade_baseline_ready')" = true ] || {
		failure="Idle RTT baseline is not ready yet."
		return 1
	}
	resolve_target || {
		failure="Unable to resolve the target interface."
		return 1
	}
	if [ "$capture_mode" = automatic ] && [ ! -x "$speedtest_bin" ]; then
		failure="Speed test helper is unavailable."
		return 1
	fi
	return 0
}

load_capture_policy() {
	quiet_window_s="$(uci_default rating_capture_quiet_s 5)"
	quiet_timeout_s="$(uci_default rating_capture_quiet_timeout_s 30)"
	quiet_ratio="$(uci_default rating_capture_quiet_ratio 0.05)"
	quiet_min_kbps="$(uci_default rating_capture_quiet_min_kbps 1000)"
}

quiet_limit_for() {
	reference="$1"
	awk -v reference="$reference" -v ratio="$quiet_ratio" -v minimum="$quiet_min_kbps" 'BEGIN {
		limit = reference * ratio
		if (limit < minimum) limit = minimum
		printf "%.3f", limit
	}'
}

measure_quiet_background() {
	load_capture_policy
	reference_dl="$(status_value '.cake_dl_rate_kbps')"
	reference_ul="$(status_value '.cake_ul_rate_kbps')"
	reference_dl="$(numeric_or_default "$reference_dl" 0)"
	reference_ul="$(numeric_or_default "$reference_ul" 0)"
	awk -v dl="$reference_dl" -v ul="$reference_ul" 'BEGIN { exit !(dl > 0 && ul > 0) }' || {
		failure="Current CAKE rate references are unavailable."
		return 1
	}
	limit_dl="$(quiet_limit_for "$reference_dl")"
	limit_ul="$(quiet_limit_for "$reference_ul")"
	quiet_needed="$(awk -v value="$quiet_window_s" 'BEGIN { value = int(value + 0); if (value < 2) value = 2; print value }')"
	wait_limit="$(awk -v value="$quiet_timeout_s" 'BEGIN { value = int(value + 0); if (value < 5) value = 5; print value }')"
	quiet_count=0
	sum_dl="0"
	sum_ul="0"
	start_wait="$(now_epoch)"

	while [ "$(( $(now_epoch) - start_wait ))" -lt "$wait_limit" ]; do
		current_dl="$(numeric_or_default "$(status_value '.dl_achieved_rate_kbps')" 0)"
		current_ul="$(numeric_or_default "$(status_value '.ul_achieved_rate_kbps')" 0)"
		if awk -v dl="$current_dl" -v ul="$current_ul" -v dlmax="$limit_dl" -v ulmax="$limit_ul" \
			'BEGIN { exit !(dl <= dlmax && ul <= ulmax) }'; then
			quiet_count=$((quiet_count + 1))
			sum_dl="$(awk -v sum="$sum_dl" -v value="$current_dl" 'BEGIN { printf "%.3f", sum + value }')"
			sum_ul="$(awk -v sum="$sum_ul" -v value="$current_ul" 'BEGIN { printf "%.3f", sum + value }')"
			if [ "$quiet_count" -ge "$quiet_needed" ]; then
				background_dl_kbps="$(awk -v sum="$sum_dl" -v count="$quiet_count" 'BEGIN { printf "%.3f", sum / count }')"
				background_ul_kbps="$(awk -v sum="$sum_ul" -v count="$quiet_count" 'BEGIN { printf "%.3f", sum / count }')"
				return 0
			fi
		else
			quiet_count=0
			sum_dl="0"
			sum_ul="0"
		fi
		write_running_status "Waiting for a quiet link ($quiet_count/$quiet_needed s; DL ${current_dl}/${limit_dl}, UL ${current_ul}/${limit_ul} kbit/s)."
		sleep 1
	done

	failure="Background traffic stayed above the quiet limits (DL $limit_dl, UL $limit_ul kbit/s). Stop heavy traffic or use passive rating."
	return 1
}

lock_path_for_target() {
	runtime_lock_interface_paths "$target_if" || return 1
	interface_lock="$runtime_interface_lock_record"
}

acquire_interface_lock() {
	command -v runtime_lock_acquire_interface >/dev/null 2>&1 || {
		failure="The shared CAKE/SQM runtime-lock helper is unavailable."
		return 1
	}
	lock_path_for_target || return 1
	runtime_lock_acquire_global_shared || {
		failure="CAKE/SQM service mutation is already in progress."
		return 1
	}
	runtime_lock_acquire_interface "$target_if" rating "" || {
		lock_rc="$?"
		runtime_lock_release_global >/dev/null 2>&1 || true
		case "$lock_rc" in
			75) failure="Another speed test, Auto-Tune, or rating job is using $target_if." ;;
			76) failure="Full Auto-Tune recovery is pending for $target_if." ;;
			*) failure="Unable to establish an atomic rating interface lock." ;;
		esac
		return 1
	}
}

release_interface_lock() {
	[ -n "${interface_lock:-}" ] || return 0
	runtime_lock_release_interface || return 1
	runtime_lock_release_global || return 1
	interface_lock=""
}

emit_live_status() {
	state="idle"
	[ -s "$status_file" ] && state="running"
	job_mode="$("$jsonfilter_bin" -i "$status_file" -e '@.mode' 2>/dev/null | sed -n '1p')"
	[ -n "$job_mode" ] || job_mode="$capture_mode"
	phase="$(status_value '.rating_load_phase')"
	candidate="$(status_value '.rating_load_candidate')"
	baseline="$(status_value '.quality_grade_baseline_samples')"
	baseline_required="$(status_value '.quality_grade_baseline_required_samples')"
	dl="$(status_value '.quality_grade_dl_samples')"
	ul="$(status_value '.quality_grade_ul_samples')"
	required="$(status_value '.quality_grade_required_samples')"
	finalize="$(status_value '.quality_grade_finalize_remaining_s')"
	dl_load="$(status_value '.rating_load_smoothed_dl_percent')"
	ul_load="$(status_value '.rating_load_smoothed_ul_percent')"
	aggregate_dl="$(status_value '.rating_load_aggregate_dl_kbps')"
	aggregate_ul="$(status_value '.rating_load_aggregate_ul_kbps')"
	effective_dl="$(status_value '.rating_load_effective_dl_kbps')"
	effective_ul="$(status_value '.rating_load_effective_ul_kbps')"
	reference_dl="$(status_value '.rating_load_reference_dl_kbps')"
	reference_ul="$(status_value '.rating_load_reference_ul_kbps')"
	enter_dl="$(status_value '.rating_load_enter_dl_kbps')"
	enter_ul="$(status_value '.rating_load_enter_ul_kbps')"
	requested_phase="$(status_value '.rating_capture_requested_phase')"
	background_dl="$(status_value '.rating_capture_background_dl_kbps')"
	background_ul="$(status_value '.rating_capture_background_ul_kbps')"
	contaminated="$(status_value '.rating_capture_contaminated')"
	contamination_reason="$(status_value '.rating_capture_contamination_reason')"
	last_reject="$(status_value '.transport_probe_last_rejected_reason')"
	message="$(status_value '.quality_grade_state')"
	printf '{"state":"%s","mode":"%s","phase":"%s","candidate":"%s","requested_phase":"%s","message":"%s","baseline_samples":%s,"baseline_required":%s,"dl_samples":%s,"ul_samples":%s,"required_samples":%s,"finalize_remaining_s":%s,"smoothed_dl_percent":%s,"smoothed_ul_percent":%s,"aggregate_dl_kbps":%s,"aggregate_ul_kbps":%s,"effective_dl_kbps":%s,"effective_ul_kbps":%s,"reference_dl_kbps":%s,"reference_ul_kbps":%s,"enter_dl_kbps":%s,"enter_ul_kbps":%s,"background_dl_kbps":%s,"background_ul_kbps":%s,"contaminated":%s,"contamination_reason":"%s","last_rejected_reason":"%s"}\n' \
		"$state" "$(json_escape "$job_mode")" "$(json_escape "${phase:-IDLE}")" \
		"$(json_escape "${candidate:-IDLE}")" "$(json_escape "${requested_phase:-AUTO}")" "$(json_escape "${message:-waiting}")" \
		"${baseline:-0}" "${baseline_required:-20}" "${dl:-0}" "${ul:-0}" \
		"${required:-20}" "${finalize:-null}" "${dl_load:-0}" "${ul_load:-0}" \
		"${aggregate_dl:-0}" "${aggregate_ul:-0}" "${effective_dl:-0}" "${effective_ul:-0}" \
		"${reference_dl:-0}" "${reference_ul:-0}" "${enter_dl:-0}" "${enter_ul:-0}" \
		"${background_dl:-0}" "${background_ul:-0}" "${contaminated:-false}" \
		"$(json_escape "$contamination_reason")" \
		"$(json_escape "$last_reject")"
}

result_is_complete() {
	grade="$(status_value '.quality_grade_current.grade')"
	partial="$(status_value '.quality_grade_current.partial')"
	incomplete="$(status_value '.quality_grade_current.incomplete')"
	started="$(status_value '.quality_grade_current.started_at')"
	awk -v started="${started:-0}" -v job="$job_started" 'BEGIN { exit !(started + 0 >= job + 0) }' || return 1
	[ -n "$grade" ] && \
		[ "$grade" != LEARNING ] && [ "$partial" != true ] && [ "$incomplete" != true ]
}

write_final_result() {
	grade="$(status_value '.quality_grade_current.grade')"
	increase="$(status_value '.quality_grade_current.increase_ms')"
	dl_grade="$(status_value '.quality_grade_current.dl.grade')"
	ul_grade="$(status_value '.quality_grade_current.ul.grade')"
	dl_samples="$(status_value '.quality_grade_current.dl_samples')"
	ul_samples="$(status_value '.quality_grade_current.ul_samples')"
	atomic_write "$result_file" "{\"state\":\"complete\",\"mode\":\"$(json_escape "$capture_mode")\",\"grade\":\"$(json_escape "$grade")\",\"increase_ms\":${increase:-0},\"dl_grade\":\"$(json_escape "$dl_grade")\",\"ul_grade\":\"$(json_escape "$ul_grade")\",\"dl_samples\":${dl_samples:-0},\"ul_samples\":${ul_samples:-0},\"message\":\"Rating completed without changing CAKE limits.\"}"
}

worker_cleanup() {
	clear_capture
	release_interface_lock
	rm -f "$pid_file" "$status_file"
}

worker_signal() {
	atomic_write "$error_file" '{"state":"cancelled","error":"Rating capture cancelled."}'
	exit 0
}

direction_samples_ready() {
	direction="$1"
	required="$(status_value '.quality_grade_required_samples')"
	case "$direction" in
		download) samples="$(status_value '.quality_grade_dl_samples')" ;;
		upload) samples="$(status_value '.quality_grade_ul_samples')" ;;
		*) return 1 ;;
	esac
	awk -v samples="${samples:-0}" -v required="${required:-20}" \
		'BEGIN { exit !(samples + 0 >= required + 0) }'
}

capture_is_contaminated() {
	[ "$(status_value '.rating_capture_contaminated')" = true ]
}

set_capture_phase() {
	capture_phase="$1"
	write_capture
}

wait_capture_phase() {
	expected="$1"
	attempt=0
	while [ "$attempt" -lt 10 ]; do
		active="$(status_value '.rating_capture_active')"
		observed="$(status_value '.rating_capture_requested_phase')"
		# Older daemons and the isolated shell fixtures do not expose the
		# handshake fields. Keep one short compatibility delay in that case.
		if [ -z "$active" ]; then
			sleep 1
			return 0
		fi
		if [ "$active" = true ] && [ "${observed:-AUTO}" = "$expected" ]; then
			return 0
		fi
		attempt=$((attempt + 1))
		sleep 1
	done
	return 1
}

run_automatic_direction() {
	direction="$1"
	case "$direction" in
		download) phase_name="DL" ;;
		upload) phase_name="UL" ;;
		*) return 1 ;;
	esac
	run=1
	while [ "$run" -le "$max_automatic_runs" ]; do
		direction_samples_ready "$direction" && return 0
		write_running_status "Generating shaped $direction load (pass $run/$max_automatic_runs)."
		set_capture_phase "$phase_name" || worker_fail "Unable to arm the $direction rating phase."
		wait_capture_phase "$phase_name" || worker_fail "The daemon did not acknowledge the $direction rating phase."
		if ! "$speedtest_bin" "$section" "$target_if" run "$backend" shaped "$route_mode" "$mwan3_member" "$direction" >> "$log_file" 2>&1; then
			set_capture_phase IDLE 2>/dev/null || true
			worker_fail "Automatic $direction load generator failed; SQM and rates were left unchanged."
		fi
		set_capture_phase IDLE || worker_fail "Unable to close the $direction rating phase."
		sleep 3
		if capture_is_contaminated; then
			reason="$(status_value '.rating_capture_contamination_reason')"
			worker_fail "Automatic rating was contaminated by background traffic: ${reason:-opposite direction active}."
		fi
		direction_samples_ready "$direction" && return 0
		run=$((run + 1))
	done
	return 1
}

worker() {
	job_started="$(now_epoch)"
	token="$job_started-$$"
	deadline="$((job_started + timeout_s))"
	trap worker_cleanup EXIT
	trap worker_signal INT TERM
	preflight || worker_fail "$failure"
	acquire_interface_lock || worker_fail "${failure:-Unable to lock the selected interface.}"
	write_running_status "Waiting for a quiet link before measuring background traffic."
	measure_quiet_background || worker_fail "$failure"
	if [ "$capture_mode" = automatic ]; then
		capture_phase="IDLE"
	else
		capture_phase="AUTO"
	fi
	write_capture || worker_fail "Unable to arm rating capture."
	wait_capture_phase "$capture_phase" || worker_fail "The daemon did not acknowledge the rating capture."
	write_running_status "Rating capture armed; background is DL $background_dl_kbps / UL $background_ul_kbps kbit/s."

	if [ "$capture_mode" = automatic ]; then
		route_mode="$("$uci_bin" -q get "cake-autorate.$section.route_mode" 2>/dev/null)"
		mwan3_member="$("$uci_bin" -q get "cake-autorate.$section.mwan3_member" 2>/dev/null)"
		run_automatic_direction download || worker_fail "Automatic download did not collect enough clean samples."
		run_automatic_direction upload || worker_fail "Automatic upload did not collect enough clean samples."
		set_capture_phase IDLE || worker_fail "Unable to close the automatic rating phases."
		write_running_status "Load generation finished; waiting for the rating window to finalize."
	else
		capture_phase="AUTO"
		write_capture || worker_fail "Unable to arm guided direction detection."
		write_running_status "Run a sequential download/upload test from a LAN client."
	fi

	while [ "$(now_epoch)" -lt "$deadline" ]; do
		[ -f "$cancel_file" ] && {
			atomic_write "$error_file" '{"state":"cancelled","error":"Rating capture cancelled."}'
			exit 0
		}
		if result_is_complete; then
			write_final_result
			exit 0
		fi
		sleep 1
	done
	partial="$(status_value '.quality_grade_current.partial')"
	incomplete="$(status_value '.quality_grade_current.incomplete')"
	dl="$(status_value '.quality_grade_dl_samples')"
	ul="$(status_value '.quality_grade_ul_samples')"
	atomic_write "$error_file" "{\"state\":\"incomplete\",\"error\":\"Rating did not collect both directions before timeout.\",\"partial\":${partial:-false},\"incomplete\":${incomplete:-true},\"dl_samples\":${dl:-0},\"ul_samples\":${ul:-0}}"
}

start_job() {
	case "$capture_mode" in automatic|client) ;; *) json_error "Unknown rating mode." ;; esac
	[ -n "$setsid_bin" ] && [ -x "$setsid_bin" ] || json_error "setsid is required."
	mkdir -p "$job_dir" || json_error "Unable to create rating job directory."
	chmod 700 "$job_dir" 2>/dev/null || true
	if [ -s "$pid_file" ]; then
		pid="$(sed -n '1p' "$pid_file")"
		if is_pid "$pid" && kill -0 "$pid" 2>/dev/null; then
			emit_live_status
			return 0
		fi
	fi
	preflight || json_error "$failure"
	rm -f "$pid_file" "$status_file" "$result_file" "$error_file" "$cancel_file" "$log_file"
	"$setsid_bin" "$0" "$section" worker "$capture_mode" "$backend" </dev/null >> "$log_file" 2>&1 &
	pid="$!"
	printf '%s\n' "$pid" > "$pid_file"
	printf '{"state":"running","mode":"%s","message":"Starting rating capture."}\n' "$(json_escape "$capture_mode")"
}

show_status() {
	if [ -s "$result_file" ]; then cat "$result_file"; return 0; fi
	if [ -s "$error_file" ]; then cat "$error_file"; return 0; fi
	if [ -s "$pid_file" ]; then
		pid="$(sed -n '1p' "$pid_file")"
		if is_pid "$pid" && kill -0 "$pid" 2>/dev/null; then emit_live_status; return 0; fi
	fi
	printf '{"state":"idle","message":"No rating job is running."}\n'
}

cancel_job() {
	touch "$cancel_file"
	if [ -s "$pid_file" ]; then
		pid="$(sed -n '1p' "$pid_file")"
		if is_pid "$pid" && kill -0 "$pid" 2>/dev/null; then
			kill -TERM "-$pid" 2>/dev/null || kill -TERM "$pid" 2>/dev/null || true
		fi
	fi
	rm -f "$capture_file"
	printf '{"state":"cancelled","message":"Rating capture cancelled."}\n'
}

safe_name "$section" || json_error "Invalid instance name."
job_paths

case "$requested_mode" in
	start) start_job ;;
	status) show_status ;;
	cancel) cancel_job ;;
	worker) worker ;;
	*) json_error "Unknown quality-test operation." ;;
esac
