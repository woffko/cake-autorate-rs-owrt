	esac
	case "$validation_actual_grade" in A+|A|B|C|D|F) ;; *) fail "The typed validator returned an invalid quality grade." ;; esac
	case "$validation_correction_action" in
		none|increase|decrease|mixed|retry-measurement|infeasible) ;;
		*) fail "The typed validator returned an unknown correction action." ;;
	esac
	[ -n "$validation_score" ] && [ -n "$validation_correction_reason" ] &&
		[ -n "$dl_candidate_realization" ] && [ -n "$ul_candidate_realization" ] &&
		[ -n "$dl_retention" ] && [ -n "$ul_retention" ] &&
