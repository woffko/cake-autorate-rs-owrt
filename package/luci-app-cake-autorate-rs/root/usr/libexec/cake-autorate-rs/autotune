nonnegative_delta() {
	awk -v loaded="${1:-0}" -v idle="${2:-0}" 'BEGIN {
		delta = loaded - idle
		if (delta < 0) delta = 0
		printf "%.1f", delta
	}'
}

maximum_number() {
