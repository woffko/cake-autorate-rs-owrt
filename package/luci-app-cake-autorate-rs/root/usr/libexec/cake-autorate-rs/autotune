capture_sqm_config_file() {
	snapshot_target="$runtime_lock_root/sqm-snapshot.autotune_$worker_token"
	snapshot_tmp="$runtime_lock_root/.sqm-snapshot.autotune_$worker_token.$$"
	case "$snapshot_target" in "$runtime_lock_root"/sqm-snapshot.*) ;; *) return 1 ;; esac
	[ -f "$sqm_config_file" ] && [ ! -L "$sqm_config_file" ] || return 1
	runtime_lock_path_owned_by_euid "$sqm_config_file" || return 1
	[ ! -e "$snapshot_target" ] && [ ! -L "$snapshot_target" ] || return 1
	[ ! -e "$snapshot_tmp" ] && [ ! -L "$snapshot_tmp" ] || return 1
	if ! cp "$sqm_config_file" "$snapshot_tmp" 2>/dev/null ||
	   ! owned_regular_file "$snapshot_tmp" ||
	   ! chmod 600 "$snapshot_tmp" 2>/dev/null ||
	   ! mv "$snapshot_tmp" "$snapshot_target" ||
	   ! owned_regular_file "$snapshot_target"; then
		rm -f "$snapshot_tmp" 2>/dev/null || true
		return 1
	fi
	[ "$(LC_ALL=C ls -ldn "$snapshot_target" 2>/dev/null | awk 'NR == 1 { print substr($1, 1, 10); exit }')" = '-rw-------' ] || {
		rm -f "$snapshot_target" 2>/dev/null || true
		return 1
	}
	# Re-check the source after the copy. A concurrent replacement cannot turn
	# a partially observed file into an authoritative recovery snapshot.
	[ -f "$sqm_config_file" ] && [ ! -L "$sqm_config_file" ] &&
		runtime_lock_path_owned_by_euid "$sqm_config_file" || {
		rm -f "$snapshot_target" 2>/dev/null || true
		return 1
	}
	printf '%s\n' "$snapshot_target"
}

prepare_recovery() {
	[ -x "$recovery_bin" ] || fail "Full Auto-Tune recovery helper is not installed."
	setsid_bin="$(command -v setsid 2>/dev/null)"
	[ -n "$setsid_bin" ] || fail "setsid is required for Full Auto-Tune recovery."
	secure_ram_directory "$recovery_root" || fail "Unsafe or foreign-owned Full Auto-Tune recovery directory."
	[ "$(proc_starttime "$$" 2>/dev/null)" = "$recovery_owner_starttime" ] ||
		fail "Full Auto-Tune owner identity changed before recovery was armed."
	[ "$(proc_group "$$")" = "$$" ] && [ "$(proc_session "$$")" = "$$" ] ||
		fail "Full Auto-Tune worker is not its isolated process-group leader."
	[ ! -e "$recovery_journal" ] && [ ! -e "$recovery_done_marker" ] && [ ! -e "$recovery_heartbeat" ] ||
		fail "A recovery record with this worker token already exists."
	recovery_prepared=1
	write_recovery_journal || fail "Unable to publish the initial recovery journal."
	# The watcher must not inherit either kernel flock.  It is deliberately
	# detached and acquires the journal-bound locks only after the owner dies.
	CAKE_AUTORATE_RUNTIME_GLOBAL_LOCK_FD= \
	CAKE_AUTORATE_INTERFACE_LOCK_FD= \
	CAKE_AUTORATE_INTERFACE_LOCK_OWNER= \
	CAKE_AUTORATE_INTERFACE_LOCK_STARTTIME= \
	CAKE_AUTORATE_INTERFACE_LOCK_TOKEN= \
	CAKE_AUTORATE_INTERFACE_LOCK_RECOVERY_JOURNAL= \
		"$setsid_bin" "$recovery_bin" watch "$recovery_journal" \
		</dev/null >/dev/null 2>&1 8>&- 9>&- &
	recovery_watcher_pid="$!"
	return 0
}

arm_recovery() {
	[ "${recovery_prepared:-0}" = 1 ] && [ -f "$recovery_journal" ] ||
		fail "Full Auto-Tune recovery journal disappeared before arming."
	runtime_lock_load_record "$autotune_interface_lock" &&
		[ "$runtime_record_pid" = "$$" ] &&
		[ "$runtime_record_starttime" = "$recovery_owner_starttime" ] &&
		[ "$runtime_record_token" = "$worker_token" ] &&
		[ "$runtime_record_journal" = "$recovery_journal" ] ||
		fail "Interface lock identity changed before Full Auto-Tune recovery was armed."
	heartbeat_tmp="$recovery_heartbeat.tmp.$$"
	: > "$heartbeat_tmp" && mv "$heartbeat_tmp" "$recovery_heartbeat" ||
		fail "Unable to arm Full Auto-Tune crash recovery."
	recovery_armed=1
}

compute_config_fingerprint() {
	command -v sha256sum >/dev/null 2>&1 || return 1
	safe_job_name "$job_name" || return 1
	fingerprint_cake_raw="$job_dir/config-fingerprint.cake.raw.$$"
	fingerprint_cake_sorted="$job_dir/config-fingerprint.cake.sorted.$$"
	fingerprint_sqm_raw="$job_dir/config-fingerprint.sqm.raw.$$"
	fingerprint_sqm_sorted="$job_dir/config-fingerprint.sqm.sorted.$$"
	fingerprint_input="$job_dir/config-fingerprint.input.$$"
	if uci -q show "cake-autorate.$job_name" > "$fingerprint_cake_raw" 2>/dev/null &&
	   [ -s "$fingerprint_cake_raw" ]; then
		fingerprint_sqm_section="$(uci -q get "cake-autorate.$job_name.sqm_section" 2>/dev/null)"
		[ -n "$fingerprint_sqm_section" ] || fingerprint_sqm_section="cake_$job_name"
		safe_job_name "$fingerprint_sqm_section" || return 1
		[ "$(uci -q get "sqm.$fingerprint_sqm_section._cake_autorate_managed" 2>/dev/null)" = "$job_name" ] || return 1
		uci -q show "sqm.$fingerprint_sqm_section" > "$fingerprint_sqm_raw" 2>/dev/null &&
			[ -s "$fingerprint_sqm_raw" ] || return 1
	else
		# Create wizard: no instance exists yet.  Bind the result to that absence
		# and to the absence of its default SQM name; a foreign/same-name queue is
		# a conflict, not configuration to inherit.
		fingerprint_sqm_section="cake_$job_name"
		safe_job_name "$fingerprint_sqm_section" || return 1
		: > "$fingerprint_cake_raw"
		if uci -q show "sqm.$fingerprint_sqm_section" > "$fingerprint_sqm_raw" 2>/dev/null &&
		   [ -s "$fingerprint_sqm_raw" ]; then
			return 1
		fi
		printf '<absent>\n' > "$fingerprint_cake_raw"
		printf '<absent>\n' > "$fingerprint_sqm_raw"
	fi
	if [ ! -s "$fingerprint_cake_raw" ] || [ ! -s "$fingerprint_sqm_raw" ]; then
		rm -f "$fingerprint_cake_raw" "$fingerprint_cake_sorted" \
			"$fingerprint_sqm_raw" "$fingerprint_sqm_sorted" "$fingerprint_input"
		return 1
	fi
	LC_ALL=C sort "$fingerprint_cake_raw" > "$fingerprint_cake_sorted" || return 1
	LC_ALL=C sort "$fingerprint_sqm_raw" > "$fingerprint_sqm_sorted" || return 1
	{
		printf 'cake-autorate:%s\n' "$job_name"
		cat "$fingerprint_cake_sorted"
		printf 'sqm:%s\n' "$fingerprint_sqm_section"
		cat "$fingerprint_sqm_sorted"
	} > "$fingerprint_input" || return 1
	fingerprint_digest="$(sha256sum "$fingerprint_input" 2>/dev/null | awk '{ print $1; exit }')"
	rm -f "$fingerprint_cake_raw" "$fingerprint_cake_sorted" \
		"$fingerprint_sqm_raw" "$fingerprint_sqm_sorted" "$fingerprint_input"
	case "$fingerprint_digest" in
		????????????????????????????????????????????????????????????????)
			case "$fingerprint_digest" in *[!0-9a-f]*) return 1 ;; esac
			printf 'sha256:%s\n' "$fingerprint_digest"
			;;
		*) return 1 ;;
	esac
}

capture_config_fingerprint() {
	config_fingerprint="$(compute_config_fingerprint)" ||
		fail "Unable to capture the managed UCI configuration fingerprint under the calibration lock."
	config_fingerprint_captured=true
}

config_fingerprint_matches() {
	[ "${config_fingerprint_captured:-false}" = true ] || return 1
