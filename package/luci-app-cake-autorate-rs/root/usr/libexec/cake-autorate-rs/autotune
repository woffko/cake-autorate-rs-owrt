		--ul-candidate-kbps "$ul_base" \
		--dl-achieved-kbps "$shaped_dl" \
		--ul-achieved-kbps "$shaped_ul" \
		--dl-min-kbps "$dl_minimum" \
		--ul-min-kbps "$ul_minimum" \
