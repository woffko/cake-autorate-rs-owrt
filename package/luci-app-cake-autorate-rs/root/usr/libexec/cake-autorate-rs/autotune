	validation_pass="$(extract_json "$typed_validation_decision" '@.pass')"
	validation_hard_pass="$(extract_json "$typed_validation_decision" '@.hard_pass')"
	validation_quality_target_met="$(extract_json "$typed_validation_decision" '@.quality_target_met')"
	validation_actual_grade="$(extract_json "$typed_validation_decision" '@.actual_grade')"
	validation_score="$(extract_json "$typed_validation_decision" '@.score')"
	validation_correction_action="$(extract_json "$typed_validation_decision" '@.correction.action')"
	validation_correction_feasible="$(extract_json "$typed_validation_decision" '@.correction.feasible')"
	validation_correction_reason="$(extract_json "$typed_validation_decision" '@.correction.reason')"
	dl_correction_action="$(extract_json "$typed_validation_decision" '@.correction.download.action')"
