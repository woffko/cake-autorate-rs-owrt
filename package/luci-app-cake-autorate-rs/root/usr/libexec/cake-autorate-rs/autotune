config_changed_inconclusive() {
	stage_terminal_json error "{\"state\":\"inconclusive\",\"schema_version\":5,\"stage\":\"config-changed\",\"error\":\"Managed CAKE Autorate/SQM configuration changed during calibration; all measurements are stale.\",\"reason\":\"config-changed\",\"retryable\":true,\"auto_apply_eligible\":false,\"manual_apply_eligible\":false,\"phase_evidence_complete\":false,\"configuration_written\":false}"
	exit 1
}

terminal_json_shape_valid() {
	terminal_candidate="$1"
	strict_single_json_object "$terminal_candidate" || return 1
	terminal_candidate_state="$(extract_json "$terminal_candidate" '@.state')" || return 1
	terminal_candidate_schema="$(extract_json "$terminal_candidate" '@.schema_version')" || return 1
	[ -n "$terminal_candidate_state" ] &&
		[ "$terminal_candidate_schema" = "$autotune_result_schema" ]
}

terminal_json_valid() {
	terminal_candidate="$1"
	terminal_json_shape_valid "$terminal_candidate" || return 1
	terminal_candidate_producer="$(extract_json "$terminal_candidate" '@.producer')" || return 1
	[ "$terminal_candidate_producer" = "$autotune_result_producer" ]
}

stage_terminal_json() {
	terminal_kind="$1"
	payload="$2"
	if [ "${config_fingerprint_captured:-false}" = true ] &&
	   ! config_fingerprint_matches; then
		payload="{\"state\":\"inconclusive\",\"schema_version\":5,\"stage\":\"config-changed\",\"error\":\"Managed CAKE Autorate/SQM configuration changed during calibration; all measurements are stale.\",\"reason\":\"config-changed\",\"retryable\":true,\"auto_apply_eligible\":false,\"manual_apply_eligible\":false,\"phase_evidence_complete\":false,\"configuration_written\":false}"
		terminal_kind=error
	fi
	terminal_json_shape_valid "$payload" || return 1
	case "$payload" in
		*'}') payload="${payload%?},\"producer\":\"$autotune_result_producer\",\"profile\":\"$autotune_profile\",\"run_id\":\"$(json_escape "${worker_token:-unknown}")\",\"config_fingerprint\":\"$(json_escape "${config_fingerprint:-}")\",\"runtime_restored\":false,\"recovery_pending\":true}" ;;
		*) return 1 ;;
	esac
	terminal_json_valid "$payload" || return 1
	terminal_state="$(extract_json "$payload" '@.state')" || return 1
	case "$terminal_kind" in
		result)
			[ "$terminal_state" = complete ] || return 1
			rm -f "$pending_error_file"
			atomic_write "$pending_result_file" "$payload"
			;;
		error)
			[ "$terminal_state" != complete ] || return 1
			rm -f "$pending_result_file"
			atomic_write "$pending_error_file" "$payload"
			;;
		*) return 1 ;;
	esac
}

publish_staged_terminal() {
	if [ -s "$pending_result_file" ]; then
		pending_source="$pending_result_file"
		public_target="$result_file"
	elif [ -s "$pending_error_file" ]; then
		pending_source="$pending_error_file"
		public_target="$error_file"
	else
		return 1
	fi
	pending_payload="$(cat "$pending_source" 2>/dev/null)" || return 1
	terminal_json_valid "$pending_payload" || return 1
	case "$pending_payload" in *'"runtime_restored":false,"recovery_pending":true}') ;; *) return 1 ;; esac
	terminal_payload="$(printf '%s\n' "$pending_payload" |
		sed 's/,\"runtime_restored\":false,\"recovery_pending\":true}$/,"runtime_restored":true,"recovery_pending":false}/')"
	case "$terminal_payload" in
		*'"runtime_restored":true,"recovery_pending":false}') ;;
		*) return 1 ;;
	esac
	terminal_json_valid "$terminal_payload" || return 1
	atomic_write "$public_target" "$terminal_payload" || return 1
	if [ "$public_target" = "$result_file" ]; then
		rm -f "$error_file"
	else
		rm -f "$result_file"
	fi
	rm -f "$pending_result_file" "$pending_error_file" "$status_file"
	return 0
}

emit_saved_terminal() {
	saved_terminal_file="$1"
	owned_regular_file "$saved_terminal_file" || {
		printf '{"state":"failed","schema_version":%s,"producer":"%s","error":"Saved Full Auto-Tune state is unsafe or unreadable; run calibration again.","auto_apply_eligible":false,"manual_apply_eligible":false,"configuration_written":false,"runtime_restored":true,"recovery_pending":false}\n' \
			"$autotune_result_schema" "$autotune_result_producer"
		return 0
	}
	saved_terminal="$(cat "$saved_terminal_file" 2>/dev/null)" || saved_terminal=""
	if terminal_json_valid "$saved_terminal"; then
		printf '%s\n' "$saved_terminal"
		return 0
	fi
	if strict_single_json_object "$saved_terminal"; then
		saved_schema="$(extract_json "$saved_terminal" '@.schema_version' 2>/dev/null || true)"
		saved_state="$(extract_json "$saved_terminal" '@.state' 2>/dev/null || true)"
		printf '{"state":"legacy","schema_version":%s,"producer":"%s","legacy_schema_version":"%s","legacy_state":"%s","error":"Saved Full Auto-Tune diagnostics were created by an older result schema. They cannot be applied; run Full Auto-Tune again.","auto_apply_eligible":false,"manual_apply_eligible":false,"configuration_written":false,"runtime_restored":true,"recovery_pending":false,"legacy_result":%s}\n' \
			"$autotune_result_schema" "$autotune_result_producer" \
			"$(json_escape "${saved_schema:-unknown}")" \
			"$(json_escape "${saved_state:-unknown}")" "$saved_terminal"
		return 0
	fi
	printf '{"state":"failed","schema_version":%s,"producer":"%s","error":"Saved Full Auto-Tune diagnostics are malformed and were ignored; run calibration again.","auto_apply_eligible":false,"manual_apply_eligible":false,"configuration_written":false,"runtime_restored":true,"recovery_pending":false}\n' \
		"$autotune_result_schema" "$autotune_result_producer"
}

