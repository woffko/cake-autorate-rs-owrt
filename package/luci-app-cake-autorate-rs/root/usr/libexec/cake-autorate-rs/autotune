	ul_candidate_realization="$(extract_json "$typed_validation_decision" '@.metrics.upload.candidate_realization_percent')"
	dl_retention="$(extract_json "$typed_validation_decision" '@.metrics.download.capacity_retention_percent')"
	ul_retention="$(extract_json "$typed_validation_decision" '@.metrics.upload.capacity_retention_percent')"
	effective_loaded_delta_ms="$(extract_json "$typed_validation_decision" '@.metrics.effective_delta_ms')"
	case "$validation_pass:$validation_correction_feasible" in
		true:true|false:true|false:false) ;;
