#!/bin/sh

umask 077

job_name="${1:-}"
target_if_input="${2:-}"
mode="${3:-status}"
backend="${4:-auto}"
backend_input="$backend"
route_mode_override="${5:-}"
mwan3_member_override="${6:-}"
profile_argument="${7:-}"
case "$profile_argument" in
	gaming|best_overall|best-overall|balanced|fair)
		profile_override="$profile_argument"
		conservative_override="${8:-0}"
		worker_token="${9:-}"
		;;
	0|1|'')
		# Compatibility with RC17 callers where argument seven was the
		# conservative flag and argument eight was the worker token.
		profile_override=""
		conservative_override="${profile_argument:-0}"
		worker_token="${8:-}"
		;;
	*)
		profile_override="$profile_argument"
		conservative_override="${8:-0}"
		worker_token="${9:-}"
		;;
esac
reflector_scan_cooldown_s="${CAKE_AUTORATE_REFLECTOR_SCAN_COOLDOWN_S:-5}"
baseline_retry_backoff_s="${CAKE_AUTORATE_BASELINE_RETRY_BACKOFF_S:-20}"
autotune_result_schema=5
autotune_result_producer="cake-autorate-rs-autotune"

job_root="${CAKE_AUTORATE_AUTOTUNE_DIR:-/tmp/cake-autorate-autotune}"
speedtest_bin="${CAKE_AUTORATE_SPEEDTEST:-/usr/libexec/cake-autorate-rs/speedtest}"
pinger_plan_bin="${CAKE_AUTORATE_PINGER_PLAN:-/usr/libexec/cake-autorate-rs/pinger-plan}"
daemon_bin="${CAKE_AUTORATE_DAEMON:-/usr/sbin/cake-autorated}"
transport_probe_bin="${CAKE_AUTORATE_TRANSPORT_PROBE:-$daemon_bin}"
recovery_bin="${CAKE_AUTORATE_AUTOTUNE_RECOVER:-/usr/libexec/cake-autorate-rs/autotune-recover}"
runtime_lock_lib="${CAKE_AUTORATE_RUNTIME_LOCK_LIB:-/usr/libexec/cake-autorate-rs/runtime-lock}"
sqm_config_file="${CAKE_AUTORATE_SQM_CONFIG_FILE:-/etc/config/sqm}"
jsonfilter_bin="${CAKE_AUTORATE_JSONFILTER:-$(command -v jsonfilter 2>/dev/null)}"
fping_bin="${CAKE_AUTORATE_FPING:-$(command -v fping 2>/dev/null)}"

if [ -r "$runtime_lock_lib" ]; then
	# shellcheck source=/usr/libexec/cake-autorate-rs/runtime-lock
	. "$runtime_lock_lib"
fi

json_escape() {
	printf '%s' "$1" | tr '\n\r\t' '   ' | sed 's/\\/\\\\/g; s/"/\\"/g'
}

strict_single_json_object() {
	json_candidate="$1"
	[ -n "$json_candidate" ] || return 1
	[ "${#json_candidate}" -le 262144 ] 2>/dev/null || return 1
	printf '%s\n' "$json_candidate" | awk '
		NR > 1 { bad = 1; next }
		NR == 1 {
			for (i = 1; i <= length($0); i++) {
				ch = substr($0, i, 1)
				if (!started) {
					if (ch ~ /[[:space:]]/) continue
					if (ch != "{") { bad = 1; break }
					started = 1; stack[++depth] = ch; continue
				}
				if (ended) {
					if (ch !~ /[[:space:]]/) { bad = 1; break }
					continue
				}
				if (in_string) {
					if (escaped) { escaped = 0; continue }
					if (ch == "\\") { escaped = 1; continue }
					if (ch == "\"") in_string = 0
					continue
				}
				if (ch == "\"") { in_string = 1; continue }
				if (ch == "{" || ch == "[") { stack[++depth] = ch; continue }
				if (ch == "}" || ch == "]") {
					expected = (ch == "}" ? "{" : "[")
					if (depth < 1 || stack[depth] != expected) { bad = 1; break }
					delete stack[depth--]
					if (depth == 0) ended = 1
				}
			}
		}
		END { exit(bad || !started || !ended || depth != 0 || in_string || escaped ? 1 : 0) }
	'
}

json_error() {
	printf '{"error":"%s"}\n' "$(json_escape "$1")"
	exit 1
}

safe_job_name() {
	case "$1" in
		''|*[!A-Za-z0-9_]*) return 1 ;;
	esac
}

safe_interface_name() {
	case "$1" in
		''|*[!A-Za-z0-9_.:@-]*) return 1 ;;
	esac
}

canonical_autotune_profile() {
	case "$1" in
		gaming) printf '%s\n' gaming ;;
		best_overall|best-overall|balanced) printf '%s\n' best_overall ;;
		fair) printf '%s\n' fair ;;
		*) return 1 ;;
	esac
}

resolve_autotune_profile() {
	profile_candidate="$profile_override"
	if [ -z "$profile_candidate" ]; then
		profile_candidate="$(uci -q get "cake-autorate.$job_name.autotune_profile" 2>/dev/null)"
	fi
	[ -n "$profile_candidate" ] || profile_candidate=best_overall
	autotune_profile="$(canonical_autotune_profile "$profile_candidate")" || return 1
}

is_positive_uint() {
	case "$1" in
		''|*[!0-9]*) return 1 ;;
	esac
	[ "$1" -gt 0 ] 2>/dev/null
}

is_uint_between() {
	case "$1" in
		''|*[!0-9]*) return 1 ;;
	esac
	[ "$1" -ge "$2" ] 2>/dev/null && [ "$1" -le "$3" ] 2>/dev/null
}

is_decimal_between() {
	case "$1" in
		''|*[!0-9.]*) return 1 ;;
	esac
	awk -v value="$1" -v minimum="$2" -v maximum="$3" 'BEGIN {
		if (value !~ /^[0-9]+([.][0-9]+)?$/) exit 1
		exit(value + 0 < minimum + 0 || value + 0 > maximum + 0)
	}'
}

numbers_equal() {
	is_decimal_between "$1" 0 100000000 || return 1
	is_decimal_between "$2" 0 100000000 || return 1
	awk -v first="$1" -v second="$2" 'BEGIN {
		delta = (first + 0) - (second + 0)
		if (delta < 0) delta = -delta
		exit(delta > 0.000001)
	}'
}

valid_reflector() {
	# Keep this in sync with pinger-plan: reflector text is later expanded into
	# individual fping argv entries, so option-like and glob-like tokens are not
	# merely "bad hosts"; they are unsafe command arguments.
	case "$1" in ''|-*|*[!0-9A-Za-z:.-]*) return 1 ;; esac
	printf '%s\n' "$1" | awk '
		function ipv4(value, parts, n, i) {
			n = split(value, parts, ".")
			if (n != 4) return 0
			for (i = 1; i <= 4; i++)
				if (parts[i] !~ /^[0-9]+$/ || parts[i] + 0 > 255 ||
				    (length(parts[i]) > 1 && substr(parts[i], 1, 1) == "0")) return 0
			return 1
		}
		function hostname(value, labels, n, i) {
			if (length(value) > 253 || value ~ /^-/ || value ~ /-$/ || value ~ /\.\./) return 0
			n = split(value, labels, ".")
			for (i = 1; i <= n; i++)
				if (length(labels[i]) < 1 || length(labels[i]) > 63 ||
				    labels[i] !~ /^[A-Za-z0-9]([A-Za-z0-9-]*[A-Za-z0-9])?$/) return 0
			return 1
		}
		function ipv6(value, groups, n, i, compressed, count, scan, pos, compressions) {
			if (value !~ /^[0-9A-Fa-f:.]+$/ || value ~ /:::/) return 0
			scan = value
			while ((pos = index(scan, "::")) > 0) { compressions++; scan = substr(scan, pos + 2) }
			if (compressions > 1) return 0
			compressed = compressions == 1
			n = split(value, groups, ":")
			count = 0
			for (i = 1; i <= n; i++) {
				if (groups[i] == "") continue
				if (index(groups[i], ".") > 0) {
					if (i != n || !ipv4(groups[i])) return 0
					count += 2
				} else {
					if (groups[i] !~ /^[0-9A-Fa-f]+$/ || length(groups[i]) > 4) return 0
					count++
				}
			}
			return compressed ? count < 8 : count == 8
		}
		{
			value = $0
			# The shell allow-list above already excludes whitespace, glob and
			# pathname metacharacters.  A repeated bracket expression containing
			# literal braces is not portable to BusyBox awk on OpenWrt.
			if (value == "" || substr(value, 1, 1) == "-") exit 1
			if (index(value, ":") > 0) exit(ipv6(value) ? 0 : 1)
			if (value ~ /^[0-9.]+$/) exit(ipv4(value) ? 0 : 1)
			exit(hostname(value) ? 0 : 1)
		}
	'
}

reflector_family() {
	case "$1" in
		1.1.1.1|1.0.0.1) printf '%s' cloudflare ;;
		8.8.8.8|8.8.4.4) printf '%s' google ;;
		9.9.9.*) printf '%s' quad9 ;;
		94.140.*) printf '%s' adguard ;;
		64.6.*) printf '%s' verisign ;;
		156.154.*) printf '%s' ultradns ;;
		208.67.*) printf '%s' opendns ;;
		185.228.*) printf '%s' cleanbrowsing ;;
		*.*.*.*)
			printf '%s\n' "$1" | awk -F . '{ print "ipv4-" $1 "." $2 "." $3 }'
			;;
		*) printf '%s' "$1" ;;
	esac
}

select_diverse_reflectors() {
	selected=""
	families=""
	reflector_family_count=0
	for candidate in "$@"; do
		[ -n "$candidate" ] || continue
		valid_reflector "$candidate" || continue
		family="$(reflector_family "$candidate")"
		case " $families " in
			*" $family "*) continue ;;
		esac
		selected="${selected}${selected:+ }$candidate"
		families="${families}${families:+ }$family"
		reflector_family_count=$((reflector_family_count + 1))
		[ "$reflector_family_count" -ge 3 ] && break
	done
	printf '%s\n' "$selected"
}

reflectors_json_array() {
	reflector_json_first=1
	printf '['
	for reflector_json_value in "$@"; do
		valid_reflector "$reflector_json_value" || return 1
		[ "$reflector_json_first" = 1 ] || printf ','
		printf '"%s"' "$(json_escape "$reflector_json_value")"
		reflector_json_first=0
	done
	printf ']'
}

valid_irtt_target() {
	valid_reflector "$1" && return 0
	case "$1" in ''|*://*) return 1 ;; esac
	printf '%s' "$1" | grep -Eq '^\[[0-9A-Fa-f:.]+\](:[0-9]+)?$'
}

pinger_targets_json_array() {
	pinger_json_method="$1"
	shift
	pinger_json_first=1
	pinger_json_count=0
	printf '['
	for pinger_json_value in "$@"; do
		case "$pinger_json_method" in
			irtt) valid_irtt_target "$pinger_json_value" || return 1 ;;
			fping|fping-ts|tsping|ping) valid_reflector "$pinger_json_value" || return 1 ;;
			*) return 1 ;;
		esac
		pinger_json_count=$((pinger_json_count + 1))
		[ "$pinger_json_count" -le 64 ] || return 1
		[ "$pinger_json_first" = 1 ] || printf ','
		printf '"%s"' "$(json_escape "$pinger_json_value")"
		pinger_json_first=0
	done
	printf ']'
}

job_paths() {
	job_dir="$job_root/$job_name"
	pid_file="$job_dir/pid"
	status_file="$job_dir/status.json"
	result_file="$job_dir/result.json"
	error_file="$job_dir/error.json"
	pending_result_file="$job_dir/result.pending.json"
	pending_error_file="$job_dir/error.pending.json"
	cancel_file="$job_dir/cancelled"
	log_file="$job_dir/job.log"
	history_dir="$job_dir/history"
}

secure_ram_directory() {
	secure_dir="$1"
	command -v runtime_lock_ram_path >/dev/null 2>&1 &&
		command -v runtime_lock_path_owned_by_euid >/dev/null 2>&1 || return 1
	runtime_lock_ram_path "$secure_dir" || return 1
	[ ! -L "$secure_dir" ] || return 1
	if [ ! -e "$secure_dir" ]; then
		mkdir "$secure_dir" 2>/dev/null || return 1
	fi
	[ -d "$secure_dir" ] && [ ! -L "$secure_dir" ] || return 1
	runtime_lock_path_owned_by_euid "$secure_dir" || return 1
	chmod 700 "$secure_dir" 2>/dev/null || return 1
}

prepare_job_storage() {
	secure_ram_directory "$job_root" || return 1
	secure_ram_directory "$job_dir"
}

remove_history_run() {
	history_remove_dir="$1"
	case "$history_remove_dir" in "$history_dir"/*) ;; *) return 1 ;; esac
	[ -d "$history_remove_dir" ] && [ ! -L "$history_remove_dir" ] || return 1
	runtime_lock_path_owned_by_euid "$history_remove_dir" || return 1
	[ -z "$(find "$history_remove_dir" -type l -print -quit 2>/dev/null)" ] || return 1
	find "$history_remove_dir" -type f -exec rm -f {} \; 2>/dev/null || return 1
	find "$history_remove_dir" -depth -type d -exec rmdir {} \; 2>/dev/null || return 1
}

prune_history() {
	history_max_runs="${CAKE_AUTORATE_AUTOTUNE_HISTORY_RUNS:-5}"
	history_max_kib="${CAKE_AUTORATE_AUTOTUNE_HISTORY_KIB:-2048}"
	is_uint_between "$history_max_runs" 1 20 || history_max_runs=5
	is_uint_between "$history_max_kib" 128 16384 || history_max_kib=2048
	history_count=0
	for history_candidate in $(find "$history_dir" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | LC_ALL=C sort -r); do
		history_count=$((history_count + 1))
		[ "$history_count" -le "$history_max_runs" ] ||
			remove_history_run "$history_candidate" || return 1
	done
	while :; do
		history_used_kib="$(du -sk "$history_dir" 2>/dev/null | awk 'NR == 1 { print $1; exit }')"
		case "$history_used_kib" in ''|*[!0-9]*) return 1 ;; esac
		[ "$history_used_kib" -le "$history_max_kib" ] && break
		history_oldest="$(find "$history_dir" -mindepth 1 -maxdepth 1 -type d 2>/dev/null |
			LC_ALL=C sort | sed -n '1p')"
		[ -n "$history_oldest" ] || break
		remove_history_run "$history_oldest" || return 1
	done
}

archive_previous_terminal() {
	history_terminal=""
	if [ -s "$result_file" ]; then
		history_terminal="$result_file"
	elif [ -s "$error_file" ]; then
		history_terminal="$error_file"
	else
		return 0
	fi
	owned_regular_file "$history_terminal" || return 1
	history_size="$(wc -c < "$history_terminal" 2>/dev/null)"
	case "$history_size" in ''|*[!0-9]*) return 1 ;; esac
	[ "$history_size" -ge 2 ] && [ "$history_size" -le 1048576 ] || return 1
	history_payload="$(cat "$history_terminal" 2>/dev/null)" || return 1
	strict_single_json_object "$history_payload" || return 1
	history_epoch="$(date +%s)"
	is_positive_uint "$history_epoch" || return 1
	history_run_id="$(extract_json "$history_payload" '@.run_id' 2>/dev/null || true)"
	case "$history_run_id" in
		''|*[!A-Za-z0-9_-]*) history_run_id="legacy-$history_epoch-$$" ;;
	esac
	history_state="$(extract_json "$history_payload" '@.state' 2>/dev/null || true)"
	case "$history_state" in
		complete|failed|inconclusive|background-blocked|cancelled|legacy) ;;
		*) history_state=unknown ;;
	esac
	secure_ram_directory "$history_dir" || return 1
	history_target="$history_dir/$history_epoch-$history_run_id"
	[ ! -e "$history_target" ] && [ ! -L "$history_target" ] || return 1
	mkdir "$history_target" 2>/dev/null || return 1
	chmod 700 "$history_target" 2>/dev/null || return 1
	runtime_lock_path_owned_by_euid "$history_target" || return 1
	if ! cp "$history_terminal" "$history_target/terminal.json" 2>/dev/null ||
	   ! chmod 600 "$history_target/terminal.json" 2>/dev/null ||
	   ! owned_regular_file "$history_target/terminal.json"; then
		remove_history_run "$history_target" >/dev/null 2>&1 || true
		return 1
	fi
	if owned_regular_file "$log_file"; then
		history_log_size="$(wc -c < "$log_file" 2>/dev/null)"
		case "$history_log_size" in
			''|*[!0-9]*) history_log_size=0 ;;
		esac
		if [ "$history_log_size" -gt 0 ] && [ "$history_log_size" -le 524288 ]; then
			cp "$log_file" "$history_target/job.log" 2>/dev/null &&
				chmod 600 "$history_target/job.log" 2>/dev/null &&
				owned_regular_file "$history_target/job.log" || {
					remove_history_run "$history_target" >/dev/null 2>&1 || true
					return 1
				}
		fi
	fi
	atomic_write "$history_target/meta" \
		"run_id=$history_run_id
state=$history_state
completed_epoch=$history_epoch" || {
		remove_history_run "$history_target" >/dev/null 2>&1 || true
		return 1
	}
	prune_history
}

owned_regular_file() {
	[ -f "$1" ] && [ ! -L "$1" ] || return 1
	runtime_lock_path_owned_by_euid "$1"
}

proc_stat_field() {
	proc_pid="$1"
	proc_field="$2"
	[ -r "/proc/$proc_pid/stat" ] || return 1
	# Fields after the final ") " start at the kernel's field 3.  Parsing the
	# tail avoids breaking on a command name containing spaces or parentheses.
	sed -n '1{s/^[0-9][0-9]* (.*) //;p;}' "/proc/$proc_pid/stat" 2>/dev/null |
		awk -v field="$proc_field" '{ print $field; exit }'
}

proc_starttime() {
	# Kernel field 22 is tail field 20 after stripping pid/comm.
	proc_stat_field "$1" 20
}

proc_state() {
	# Kernel field 3 is tail field 1.
	proc_stat_field "$1" 1
}

proc_group() {
	# Kernel field 5 is tail field 3.
	proc_stat_field "$1" 3
}

proc_session() {
	# Kernel field 6 is tail field 4.
	proc_stat_field "$1" 4
}

proc_cmdline_has_arg() {
	proc_pid="$1"
	expected_arg="$2"
	[ -r "/proc/$proc_pid/cmdline" ] || return 1
	cmdline_args="$(cat "/proc/$proc_pid/cmdline" 2>/dev/null | tr '\000' '\n')"
	[ -n "$cmdline_args" ] || return 1
	printf '%s\n' "$cmdline_args" | grep -F -x -- "$expected_arg" >/dev/null 2>&1
}

read_worker_identity() {
	identity_pid=""
	identity_starttime=""
	identity_token=""
	identity_target=""
	identity_backend=""
	identity_route_mode=""
	identity_mwan3_member=""
	identity_profile=""
	identity_conservative=""
	owned_regular_file "$pid_file" || return 1
	identity_pid="$(sed -n '1p' "$pid_file" 2>/dev/null)"
	identity_starttime="$(sed -n '2p' "$pid_file" 2>/dev/null)"
	identity_token="$(sed -n '3p' "$pid_file" 2>/dev/null)"
	identity_target="$(sed -n '4p' "$pid_file" 2>/dev/null)"
	identity_backend="$(sed -n '5p' "$pid_file" 2>/dev/null)"
	identity_route_mode="$(sed -n '6p' "$pid_file" 2>/dev/null)"
	identity_mwan3_member="$(sed -n '7p' "$pid_file" 2>/dev/null)"
	identity_profile="$(sed -n '8p' "$pid_file" 2>/dev/null)"
	identity_conservative="$(sed -n '9p' "$pid_file" 2>/dev/null)"
}

worker_identity_matches() {
	read_worker_identity
	is_positive_uint "$identity_pid" || return 1
	is_positive_uint "$identity_starttime" || return 1
	case "$identity_token" in ''|*[!A-Za-z0-9_-]*) return 1 ;; esac
	[ "$(proc_starttime "$identity_pid")" = "$identity_starttime" ] || return 1
	[ "$(proc_group "$identity_pid")" = "$identity_pid" ] || return 1
	[ "$(proc_session "$identity_pid")" = "$identity_pid" ] || return 1
	proc_cmdline_has_arg "$identity_pid" job-run || return 1
	proc_cmdline_has_arg "$identity_pid" "$identity_token" || return 1
	return 0
}

worker_request_matches() {
	expected_conservative="${1:-0}"
	# worker_identity_matches() has already read and authenticated one complete
	# identity snapshot at both call sites.  Re-reading pid_file here creates a
	# completion race: the verified owner may remove its identity between the
	# two reads, turning an ordinary terminal transition into a false request
	# mismatch.  Compare the authenticated snapshot instead.
	[ "$identity_target" = "$target_if_input" ] &&
		[ "$identity_backend" = "$backend_input" ] &&
		[ "$identity_route_mode" = "$route_mode_override" ] &&
		[ "$identity_mwan3_member" = "$mwan3_member_override" ] &&
		[ "$identity_profile" = "$autotune_profile" ] || return 1
	[ "$expected_conservative" = any ] || [ "$identity_conservative" = "$expected_conservative" ]
}

remove_own_worker_identity() {
	[ -s "$pid_file" ] || return 0
	read_worker_identity
	if [ "$identity_pid" = "$$" ] && [ -n "${worker_token:-}" ] &&
	   [ "$identity_token" = "$worker_token" ]; then
		rm -f "$pid_file"
	fi
}

new_worker_token() {
	token="$(od -An -N16 -tx1 /dev/urandom 2>/dev/null | tr -d ' \n')"
	case "$token" in
		''|*[!A-Fa-f0-9]*) token="$(awk '{ gsub(/[.]/, "", $1); print $1 }' /proc/uptime 2>/dev/null)-$$" ;;
	esac
	printf '%s\n' "$token"
}

atomic_write() {
	file="$1"
	tmp="$file.$$"
	shift
	[ ! -L "$file" ] || return 1
	[ ! -e "$tmp" ] && [ ! -L "$tmp" ] || return 1
	printf '%s\n' "$*" > "$tmp" &&
		owned_regular_file "$tmp" && chmod 600 "$tmp" 2>/dev/null &&
		mv "$tmp" "$file" && owned_regular_file "$file"
}

configure_recovery_paths() {
	case "$worker_token" in ''|*[!A-Za-z0-9_-]*) return 1 ;; esac
	recovery_owner_starttime="$(proc_starttime "$$" 2>/dev/null)"
	is_positive_uint "$recovery_owner_starttime" || return 1
	recovery_root="$job_root/recovery"
	recovery_stem="${job_name}_${worker_token}"
	recovery_journal="$recovery_root/$recovery_stem.journal"
	recovery_done_marker="$recovery_root/$recovery_stem.done"
	recovery_heartbeat="$recovery_root/$recovery_stem.armed"
}

write_recovery_journal() {
	[ "${recovery_prepared:-0}" = 1 ] || return 0
	tmp="$recovery_journal.tmp.$$"
	{
		printf 'journal_version=4\n'
		printf 'job=%s\n' "$job_name"
		printf 'section=%s\n' "$job_name"
		printf 'owner_pid=%s\n' "$$"
		printf 'owner_pgid=%s\n' "$$"
		printf 'proc_starttime=%s\n' "$recovery_owner_starttime"
		printf 'target_if=%s\n' "$target_if"
		printf 'temp_ifb=%s\n' "${recovery_temp_ifb:-}"
		printf 'temp_ifb_alias=%s\n' "${recovery_temp_ifb_alias:-}"
		printf 'temp_ifb_ifindex=%s\n' "${recovery_temp_ifb_ifindex:-}"
		printf 'temp_target_handle=%s\n' "${recovery_temp_target_handle:-}"
		printf 'temp_ifb_handle=%s\n' "${recovery_temp_ifb_handle:-}"
		printf 'temp_ingress_handle=%s\n' "${recovery_temp_ingress_handle:-}"
		printf 'temp_redirect_pref=%s\n' "${recovery_temp_redirect_pref:-}"
		printf 'shaper_started=%s\n' "${recovery_shaper_started:-0}"
		printf 'sqm_was_active=%s\n' "${recovery_sqm_was_active:-0}"
		printf 'sqm_restore_mode=%s\n' "${recovery_sqm_restore_mode:-none}"
		printf 'sqm_section=%s\n' "${recovery_sqm_section:-}"
		printf 'sqm_target_if=%s\n' "${recovery_sqm_target_if:-}"
		printf 'sqm_ul_if=%s\n' "${recovery_sqm_ul_if:-}"
