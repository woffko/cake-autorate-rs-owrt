		"$(json_escape "${route_if:-}")" "$(json_escape "${route_mark:-}")" \
		"$(json_escape "${route_table:-}")" "$(json_escape "${route_identity:-}")" \
		"$(json_escape "${selected_external_ip:-}")"
}

check_background_traffic() {
	write_status quiet-check 27 "Checking background traffic before throughput calibration"
	measure_background_traffic
	if [ "$background_blocked" = true ] && [ "${conservative_mode:-0}" != 1 ]; then
		stage_terminal_json error "{\"state\":\"background-blocked\",\"schema_version\":5,\"error\":\"Background traffic is above the strict calibration limit. Retry when quiet or explicitly continue conservatively.\",\"background_blocked\":true,\"retryable\":true,\"stage\":\"quiet-check\",\"auto_apply_eligible\":false,\"manual_apply_eligible\":false,\"phase_evidence_complete\":false,\"phase_contamination_seen\":false,\"route\":$(route_diagnostics_json),\"background\":$(background_json),\"baseline\":$(baseline_diagnostics_json),\"pinger_plan\":${pinger_plan:-null},\"configuration_written\":false}"
		exit 1
	fi
	if [ "${conservative_mode:-0}" = 1 ]; then
		current_dl_min="$(uci -q get "cake-autorate.$job_name.min_dl_shaper_rate_kbps" 2>/dev/null)"
		current_dl_base="$(uci -q get "cake-autorate.$job_name.base_dl_shaper_rate_kbps" 2>/dev/null)"
		current_dl_max="$(uci -q get "cake-autorate.$job_name.max_dl_shaper_rate_kbps" 2>/dev/null)"
		current_dl_cap="$(uci -q get "cake-autorate.$job_name.adaptive_ceiling_dl_cap_kbps" 2>/dev/null)"
		current_ul_min="$(uci -q get "cake-autorate.$job_name.min_ul_shaper_rate_kbps" 2>/dev/null)"
		current_ul_base="$(uci -q get "cake-autorate.$job_name.base_ul_shaper_rate_kbps" 2>/dev/null)"
		current_ul_max="$(uci -q get "cake-autorate.$job_name.max_ul_shaper_rate_kbps" 2>/dev/null)"
		current_ul_cap="$(uci -q get "cake-autorate.$job_name.adaptive_ceiling_ul_cap_kbps" 2>/dev/null)"
		if { [ "$background_dl_usable" != true ] || [ "$background_ul_usable" != true ]; } &&
		   { ! is_positive_uint "$current_dl_base" || ! is_positive_uint "$current_ul_base"; }; then
			stage_terminal_json error "{\"state\":\"failed\",\"schema_version\":5,\"error\":\"Background traffic leaves an unusable direction and this new instance has no confirmed limits to retain.\",\"background_blocked\":true,\"retryable\":true,\"stage\":\"quiet-check\",\"auto_apply_eligible\":false,\"manual_apply_eligible\":false,\"phase_evidence_complete\":false,\"phase_contamination_seen\":false,\"route\":$(route_diagnostics_json),\"background\":$(background_json),\"baseline\":$(baseline_diagnostics_json),\"pinger_plan\":${pinger_plan:-null},\"configuration_written\":false}"
			exit 1
		fi
	fi
}

cleanup_phase_background_counter() {
	if [ "${phase_counter_created:-0}" = 1 ] && [ -n "${nft_bin:-}" ]; then
		"$nft_bin" delete table inet "$phase_counter_table" >/dev/null 2>&1 || true
	fi
	phase_counter_created=0
}

active_nft_flowtable() {
	ruleset="$1"
	printf '%s\n' "$ruleset" | awk '
		$1 == "flowtable" && index($0, "{") { in_flowtable = 1 }
		in_flowtable && /hook[[:space:]]+ingress([[:space:]]|;)/ { found = 1 }
		in_flowtable && $1 == "}" { in_flowtable = 0 }
		END { exit(found ? 0 : 1) }
	'
}

preflight_phase_accounting() {
	nft_bin="$(command -v nft 2>/dev/null)"
	[ -n "$nft_bin" ] || fail "nft is required to prove that calibration phases are free of forwarded client traffic."
	phase_ruleset="$($nft_bin list ruleset 2>/dev/null)" ||
		fail "Unable to inspect nftables before calibration; forwarded-traffic evidence cannot be trusted."
	if active_nft_flowtable "$phase_ruleset"; then
		fail "Active nftables flowtable/offload bypasses the calibration forward counters. Disable software and hardware flow offloading before Full Auto-Tune."
	fi
}

cleanup_stale_phase_background_tables() {
	[ -n "${nft_bin:-}" ] || return 1
	table_listing="$($nft_bin list tables 2>/dev/null)" || return 1
	stale_tables="$(printf '%s\n' "$table_listing" | awk '$1 == "table" && $2 == "inet" { print $3 }')"
	for stale_table in $stale_tables; do
		case "$stale_table" in
			"cake_autotune_${job_name}_"*)
				stale_suffix="${stale_table#cake_autotune_${job_name}_}"
				case "$stale_suffix" in ''|*[!0-9]*) continue ;; esac
				"$nft_bin" delete table inet "$stale_table" >/dev/null 2>&1 || return 1
				;;
		esac
	done
	return 0
}

start_phase_background_counter() {
	phase_reference_dl_kbps="${1:-0}"
	phase_reference_ul_kbps="${2:-0}"
	phase_background_available=false
	phase_background_contaminated=false
	phase_background_dl_kbps=0
	phase_background_ul_kbps=0
	phase_counter_started="$(cut -d ' ' -f 1 /proc/uptime 2>/dev/null)"

	if [ "${CAKE_AUTORATE_AUTOTUNE_TEST_PREFLIGHT:-0}" = 1 ]; then
		phase_background_available=true
		return 0
	fi

	nft_bin="$(command -v nft 2>/dev/null)"
	[ -n "$nft_bin" ] || return 0
	# A PID suffix makes a stale table from a prior SIGKILL harmless.  The
	# current worker still removes only its own table during normal cleanup.
	phase_counter_table="cake_autotune_${job_name}_$$"
	cleanup_phase_background_counter
	recovery_nft_table="$phase_counter_table"
	write_recovery_journal || fail "Unable to journal the nftables counter before creating it."
	"$nft_bin" add table inet "$phase_counter_table" >/dev/null 2>&1 || return 0
	phase_counter_created=1
	"$nft_bin" add chain inet "$phase_counter_table" forward \
		'{ type filter hook forward priority -1; policy accept; }' >/dev/null 2>&1 || {
		cleanup_phase_background_counter
		return 0
	}
	"$nft_bin" add rule inet "$phase_counter_table" forward iifname "$target_if" counter \
		comment cake-autotune-dl >/dev/null 2>&1 || {
		cleanup_phase_background_counter
		return 0
	}
	"$nft_bin" add rule inet "$phase_counter_table" forward oifname "$target_if" counter \
		comment cake-autotune-ul >/dev/null 2>&1 || {
		cleanup_phase_background_counter
		return 0
	}
	phase_background_available=true
}

stop_phase_background_counter() {
	phase_counter_stopped="$(cut -d ' ' -f 1 /proc/uptime 2>/dev/null)"
	phase_duration_s="$(awk -v start="${phase_counter_started:-0}" -v stop="${phase_counter_stopped:-0}" 'BEGIN {
		d = stop - start; if (d < 0.01) d = 0.01; printf "%.2f", d
	}')"

	if [ "${CAKE_AUTORATE_AUTOTUNE_TEST_PREFLIGHT:-0}" = 1 ]; then
		if [ "${phase_background_kind:-}" = baseline ]; then
			test_phase_unavailable="${CAKE_AUTORATE_AUTOTUNE_TEST_BASELINE_BACKGROUND_UNAVAILABLE:-0}"
			if [ "${baseline_phase_attempt:-0}" = 1 ]; then
				test_phase_dl="${CAKE_AUTORATE_AUTOTUNE_TEST_BASELINE_BACKGROUND_FIRST_DL_KBPS:-${CAKE_AUTORATE_AUTOTUNE_TEST_BASELINE_BACKGROUND_DL_KBPS:-0}}"
				test_phase_ul="${CAKE_AUTORATE_AUTOTUNE_TEST_BASELINE_BACKGROUND_FIRST_UL_KBPS:-${CAKE_AUTORATE_AUTOTUNE_TEST_BASELINE_BACKGROUND_UL_KBPS:-0}}"
			else
				test_phase_dl="${CAKE_AUTORATE_AUTOTUNE_TEST_BASELINE_BACKGROUND_DL_KBPS:-0}"
				test_phase_ul="${CAKE_AUTORATE_AUTOTUNE_TEST_BASELINE_BACKGROUND_UL_KBPS:-0}"
			fi
		else
			test_phase_unavailable="${CAKE_AUTORATE_AUTOTUNE_TEST_PHASE_BACKGROUND_UNAVAILABLE:-0}"
			test_phase_dl="${CAKE_AUTORATE_AUTOTUNE_TEST_PHASE_BACKGROUND_DL_KBPS:-0}"
			test_phase_ul="${CAKE_AUTORATE_AUTOTUNE_TEST_PHASE_BACKGROUND_UL_KBPS:-0}"
		fi
		if [ "$test_phase_unavailable" = 1 ]; then
			phase_background_available=false
		else
			phase_background_dl_kbps="$test_phase_dl"
			phase_background_ul_kbps="$test_phase_ul"
		fi
	elif [ "${phase_background_available:-false}" = true ] && [ "${phase_counter_created:-0}" = 1 ]; then
		if phase_counter_dump="$($nft_bin list chain inet "$phase_counter_table" forward 2>/dev/null)"; then
			phase_background_dl_bytes="$(printf '%s\n' "$phase_counter_dump" | awk '
				/comment "?cake-autotune-dl"?/ { for (i = 1; i <= NF; i++) if ($i == "bytes") { print $(i + 1); exit } }')"
			phase_background_ul_bytes="$(printf '%s\n' "$phase_counter_dump" | awk '
				/comment "?cake-autotune-ul"?/ { for (i = 1; i <= NF; i++) if ($i == "bytes") { print $(i + 1); exit } }')"
			case "$phase_background_dl_bytes:$phase_background_ul_bytes" in
				*[!0-9:]*|:*|*:) phase_background_available=false ;;
				*)
					phase_background_dl_kbps="$(awk -v b="$phase_background_dl_bytes" -v s="$phase_duration_s" 'BEGIN { printf "%.0f", b * 8 / s / 1000 }')"
					phase_background_ul_kbps="$(awk -v b="$phase_background_ul_bytes" -v s="$phase_duration_s" 'BEGIN { printf "%.0f", b * 8 / s / 1000 }')"
					;;
			esac
		else
			phase_background_available=false
		fi
	fi
	cleanup_phase_background_counter

	phase_background_dl_limit="$(awk -v r="${phase_reference_dl_kbps:-0}" 'BEGIN { v=r*0.02; if(v<1000)v=1000; printf "%.0f",v }')"
	phase_background_ul_limit="$(awk -v r="${phase_reference_ul_kbps:-0}" 'BEGIN { v=r*0.02; if(v<1000)v=1000; printf "%.0f",v }')"
	phase_background_contaminated=false
	if [ "${phase_background_available:-false}" != true ]; then
		phase_background_contaminated=true
		phase_evidence_complete=false
	fi
	[ "${phase_background_dl_kbps:-0}" -le "$phase_background_dl_limit" ] 2>/dev/null || phase_background_contaminated=true
	[ "${phase_background_ul_kbps:-0}" -le "$phase_background_ul_limit" ] 2>/dev/null || phase_background_contaminated=true
}

phase_background_json() {
	printf '{"available":%s,"contaminated":%s,"duration_s":%s,"download_kbps":%s,"upload_kbps":%s,"download_limit_kbps":%s,"upload_limit_kbps":%s}' \
		"${phase_background_available:-false}" "${phase_background_contaminated:-false}" \
		"${phase_duration_s:-0}" "${phase_background_dl_kbps:-0}" "${phase_background_ul_kbps:-0}" \
		"${phase_background_dl_limit:-0}" "${phase_background_ul_limit:-0}"
}

resolve_interface_device() {
	name="$1"
	status=""
	device=""

	if [ -e "/sys/class/net/$name" ]; then
		printf '%s\n' "$name"
		return 0
	fi

	if [ -n "$jsonfilter_bin" ]; then
		status="$(ubus call "network.interface.$name" status 2>/dev/null)"
		device="$(printf '%s\n' "$status" | "$jsonfilter_bin" -e '@.l3_device' 2>/dev/null)"
		[ -n "$device" ] || device="$(printf '%s\n' "$status" | "$jsonfilter_bin" -e '@.device' 2>/dev/null)"
	fi

	[ -n "$device" ] && [ -e "/sys/class/net/$device" ] || return 1
	printf '%s\n' "$device"
}

source_ip_for() {
	ip -4 -o addr show dev "$1" scope global 2>/dev/null |
		awk '{ split($4, address, "/"); print address[1]; exit }'
}

route_device_for() {
	source_ip="$1"
	if [ -n "$source_ip" ]; then
		ip route get 1.1.1.1 from "$source_ip" 2>/dev/null |
			sed -n 's/.* dev \([^ ]*\).*/\1/p' | head -n 1
	else
		ip route get 1.1.1.1 2>/dev/null |
			sed -n 's/.* dev \([^ ]*\).*/\1/p' | head -n 1
	fi
}

route_exec() {
	if [ "${route_mode:-main}" = "mwan3" ]; then
		mwan3 use "$mwan3_member" exec "$@"
	else
		"$@"
	fi
}

route_rule_for_device() {
	device="$1"
	wrapper_mark="${2:-}"
	rules="$(ip -4 rule show 2>/dev/null)"
	discovered_table="$(printf '%s\n' "$rules" | awk -v device="$device" '
		{ for (i = 1; i <= NF; i++) if ($i == "iif" && $(i + 1) == device)
			for (j = 1; j <= NF; j++) if ($j == "lookup") { print $(j + 1); exit } }')"
	if [ -z "$discovered_table" ] && [ -n "$wrapper_mark" ]; then
		discovered_table="$(printf '%s\n' "$rules" | awk -v mark="$wrapper_mark" '
			{
				matched = 0
				for (i = 1; i <= NF; i++) if ($i == "fwmark") {
					split($(i + 1), value, "/")
					if (value[1] == mark) matched = 1
				}
				if (matched) for (i = 1; i <= NF; i++) if ($i == "lookup") { print $(i + 1); exit }
			}')"
	fi
	discovered_mark=""
	if [ -n "$discovered_table" ]; then
		discovered_mark="$(printf '%s\n' "$rules" | awk -v table="$discovered_table" '
			{ found = 0; for (i = 1; i <= NF; i++) if ($i == "lookup" && $(i + 1) == table) found = 1;
			  if (found) for (i = 1; i <= NF; i++) if ($i == "fwmark") { split($(i + 1), value, "/"); print value[1]; exit } }')"
	fi
	[ -n "$discovered_table" ] || return 1
	printf '%s|%s\n' "$discovered_mark" "$discovered_table"
}

valid_route_mark() {
	mark="$1"
	case "$mark" in
		0x*) digits="${mark#0x}"; case "$digits" in ''|*[!A-Fa-f0-9]*) return 1 ;; esac ;;
		*) case "$mark" in ''|*[!0-9]*) return 1 ;; esac ;;
	esac
}

valid_route_table() {
	table="$1"
	case "$table" in
		''|main|default|local|*[!A-Za-z0-9_.-]*) return 1 ;;
	esac
}

inspect_autotune_route() {
	route_mode_configured="$(uci -q get "cake-autorate.$job_name.route_mode" 2>/dev/null)"
	mwan3_member="$(uci -q get "cake-autorate.$job_name.mwan3_member" 2>/dev/null)"
	[ -n "$route_mode_override" ] && route_mode_configured="$route_mode_override"
	[ -n "$mwan3_member_override" ] && mwan3_member="$mwan3_member_override"
	[ -n "$route_mode_configured" ] || route_mode_configured=auto
	case "$route_mode_configured" in
		main) route_mode=main ;;
		mwan3) route_mode=mwan3 ;;
		auto) [ -n "$mwan3_member" ] && route_mode=mwan3 || route_mode=main ;;
		*) return 1 ;;
	esac

	if [ "$route_mode" = mwan3 ]; then
		case "$mwan3_member" in ''|*[!A-Za-z0-9_.:@-]*) return 1 ;; esac
		command -v mwan3 >/dev/null 2>&1 || return 1
		command -v nft >/dev/null 2>&1 && nft list table inet mwan3 >/dev/null 2>&1 || return 1
		member_status="$(ubus call mwan3 status "{\"interface\":\"$mwan3_member\"}" 2>/dev/null)" || return 1
		[ "$(printf '%s\n' "$member_status" | "$jsonfilter_bin" -e '@.interfaces.*.status' 2>/dev/null | sed -n '1p')" = online ] || return 1
		[ "$(printf '%s\n' "$member_status" | "$jsonfilter_bin" -e '@.interfaces.*.enabled' 2>/dev/null | sed -n '1p')" = true ] || return 1
		[ "$(printf '%s\n' "$member_status" | "$jsonfilter_bin" -e '@.interfaces.*.running' 2>/dev/null | sed -n '1p')" = true ] || return 1
		[ "$(printf '%s\n' "$member_status" | "$jsonfilter_bin" -e '@.interfaces.*.up' 2>/dev/null | sed -n '1p')" = true ] || return 1
		network_status="$(ubus call "network.interface.$mwan3_member" status 2>/dev/null)" || return 1
		[ "$(printf '%s\n' "$network_status" | "$jsonfilter_bin" -e '@.up' 2>/dev/null)" = true ] || return 1
		network_device="$(printf '%s\n' "$network_status" | "$jsonfilter_bin" -e '@.l3_device' 2>/dev/null)"
		[ -n "$network_device" ] || network_device="$(printf '%s\n' "$network_status" | "$jsonfilter_bin" -e '@.device' 2>/dev/null)"
		route_environment="$(mwan3 use "$mwan3_member" exec env 2>/dev/null)" || return 1
		route_if="$(printf '%s\n' "$route_environment" | sed -n 's/^DEVICE=//p' | sed -n '1p')"
		[ -n "$route_if" ] || route_if="$network_device"
		source_ip="$(printf '%s\n' "$route_environment" | sed -n 's/^SRCIP=//p' | sed -n '1p')"
		[ "$route_if" = "$target_if" ] && [ -n "$source_ip" ] || return 1
		route_mark="$(printf '%s\n' "$route_environment" | sed -n 's/^FWMARK=//p' | sed -n '1p')"
		route_mark="${route_mark%%/*}"
		route_rule="$(route_rule_for_device "$route_if" "$route_mark" 2>/dev/null)" || return 1
		discovered_mark="${route_rule%%|*}"
		route_table="${route_rule#*|}"
		[ -n "$discovered_mark" ] && route_mark="$discovered_mark"
		valid_route_mark "$route_mark" || return 1
		valid_route_table "$route_table" || return 1
		forced_route="$(mwan3 use "$mwan3_member" exec ip -4 route get 1.1.1.1 from "$source_ip" 2>/dev/null)" || return 1
		forced_route_if="$(printf '%s\n' "$forced_route" | sed -n 's/.* dev \([^ ]*\).*/\1/p' | sed -n '1p')"
		[ "$forced_route_if" = "$target_if" ] || return 1
		table_default="$(ip -4 route show table "$route_table" default 2>/dev/null)" || return 1
		printf '%s\n' "$table_default" | awk -v device="$target_if" '
			{ for (i = 1; i <= NF; i++) if ($i == "dev" && $(i + 1) == device) found = 1 }
			END { exit(found ? 0 : 1) }
		' || return 1
	else
		source_ip="$(source_ip_for "$target_if")"
		[ -n "$source_ip" ] || return 1
		route_if="$(route_device_for "$source_ip")"
		[ "$route_if" = "$target_if" ] || return 1
		default_route_if="$(ip -4 route show default 2>/dev/null | sed -n '1{s/.* dev \([^ ]*\).*/\1/p}')"
		[ "$default_route_if" = "$target_if" ] || return 1
		route_mark=""
		route_table="main"
	fi
	route_identity="$route_mode|$mwan3_member|$route_if|$source_ip|$route_mark|$route_table"
	return 0
}

autorate_cmdline_matches() {
	candidate_pid="$1"
	[ -r "/proc/$candidate_pid/cmdline" ] || return 1
	cmdline="$(tr '\000' '\n' < "/proc/$candidate_pid/cmdline")"
	[ "$(printf '%s\n' "$cmdline" | sed -n '1p')" = /usr/sbin/cake-autorated ] || return 1
	[ "$(printf '%s\n' "$cmdline" | sed -n '2p')" = --instance ] || return 1
	[ "$(printf '%s\n' "$cmdline" | sed -n '3p')" = "$job_name" ] || return 1
	[ -z "$(printf '%s\n' "$cmdline" | sed -n '4p')" ]
}

pause_job_autorate() {
	autorate_candidates="$(pgrep -f "^/usr/sbin/cake-autorated --instance $job_name\$" 2>/dev/null || true)"
	set -- $autorate_candidates
	[ "$#" -le 1 ] || fail "Multiple autorate processes exist for $job_name; refusing ambiguous calibration."
	[ "$#" -eq 1 ] || return 0
	autorate_pid="$1"
	autorate_starttime="$(proc_starttime "$autorate_pid" 2>/dev/null)"
	is_positive_uint "$autorate_starttime" && autorate_cmdline_matches "$autorate_pid" ||
		fail "Unable to verify the autorate process identity before calibration."
	case "$(proc_state "$autorate_pid" 2>/dev/null)" in
		T|t) fail "Autorate instance $job_name was already stopped before calibration." ;;
		Z|z|'') fail "Autorate instance $job_name is not a live controllable process." ;;
	esac
	recovery_autorate_pid="$autorate_pid"
	recovery_autorate_starttime="$autorate_starttime"
	write_recovery_journal || fail "Unable to journal the autorate identity before stopping it."
	[ "$(proc_starttime "$autorate_pid" 2>/dev/null)" = "$autorate_starttime" ] &&
		autorate_cmdline_matches "$autorate_pid" || fail "Autorate process identity changed before STOP."
	kill -STOP "$autorate_pid" 2>/dev/null || fail "Unable to stop autorate for deterministic calibration."
	stop_attempt=0
	while [ "$stop_attempt" -lt 3 ]; do
		[ "$(proc_starttime "$autorate_pid" 2>/dev/null)" = "$autorate_starttime" ] ||
			fail "Autorate process identity changed while waiting for STOP."
		[ "$(proc_state "$autorate_pid" 2>/dev/null)" = T ] && {
			autorate_paused=1
			return 0
		}
		stop_attempt=$((stop_attempt + 1))
		sleep 1
	done
	fail "Autorate instance did not enter the stopped state."
}

resume_job_autorate() {
	if [ "${autorate_paused:-0}" = 1 ] && is_positive_uint "${autorate_pid:-}"; then
		kill -CONT "$autorate_pid" >/dev/null 2>&1 || true
	fi
	autorate_paused=0
	autorate_pid=""
}

configure_autotune_interface_lock_path() {
	command -v runtime_lock_interface_paths >/dev/null 2>&1 || return 1
	runtime_lock_interface_paths "$target_if" || return 1
	autotune_interface_lock="$runtime_interface_lock_record"
}

acquire_autotune_interface_lock() {
	[ -n "${autotune_interface_lock:-}" ] ||
		configure_autotune_interface_lock_path || fail "Unable to derive a safe interface lock for $target_if."
	runtime_lock_acquire_global_shared || {
		lock_rc="$?"
		[ "$lock_rc" -eq 75 ] && fail "CAKE/SQM service mutation is already in progress."
		fail "Unable to acquire the global CAKE/SQM runtime lock."
	}
	runtime_lock_acquire_interface "$target_if" autotune "$recovery_journal" "$worker_token" || {
		lock_rc="$?"
		runtime_lock_release_global >/dev/null 2>&1 || true
		case "$lock_rc" in
			75) fail "Another speed test or Full Auto-Tune job is already using $target_if." ;;
			76) fail "Full Auto-Tune recovery is still pending for $target_if." ;;
			*) fail "Unable to establish an atomic interface lock for $target_if." ;;
		esac
	}
	[ "$runtime_interface_lock_starttime" = "$recovery_owner_starttime" ] ||
		fail "Interface-lock owner identity does not match the recovery journal."
}

release_autotune_interface_lock() {
	[ "${runtime_interface_lock_held:-0}" = 1 ] || return 0
	runtime_lock_release_interface || return 1
	runtime_lock_release_global || return 1
	autotune_interface_lock=""
	return 0
}

detect_link_kind() {
	device="$1"
	logical="$2"
	type="$(sed -n '1p' "/sys/class/net/$device/type" 2>/dev/null)"
	proto=""

	if [ -n "$jsonfilter_bin" ]; then
		proto="$(ubus call "network.interface.$logical" status 2>/dev/null |
			"$jsonfilter_bin" -e '@.proto' 2>/dev/null)"
	fi

	case "$proto:$device" in
		pppoe:*|*:pppoe-*) printf '%s' pppoe ;;
		qmi:*|mbim:*|ncm:*|3g:*|modemmanager:*|*:wwan*|*:rmnet*|*:lte*|*:modem*)
			printf '%s' cellular
			;;
		*)
			case "$type" in
				512) printf '%s' pppoe ;;
				1) printf '%s' ethernet ;;
				*) printf '%s' unknown ;;
			esac
			;;
	esac
}

autorate_conflict_for_target() {
	command -v uci >/dev/null 2>&1 || return 1
	sections="$(uci -q show cake-autorate 2>/dev/null |
		sed -n 's/^cake-autorate\.\([^.=]*\)=cake_autorate$/\1/p')"
	for section in $sections; do
		[ "$section" = "$job_name" ] && continue
		[ "$(uci -q get "cake-autorate.$section.enabled" 2>/dev/null)" = 1 ] || continue
		candidate="$(uci -q get "cake-autorate.$section.wan_if" 2>/dev/null)"
		[ -n "$candidate" ] || candidate="$(uci -q get "cake-autorate.$section.sqm_interface" 2>/dev/null)"
		candidate="$(resolve_interface_device "$candidate" 2>/dev/null)"
		if [ "$candidate" = "$target_if" ]; then
			printf '%s\n' "$section"
			return 0
		fi
	done
	return 1
}

sqm_state_dir() {
	(
		[ ! -r /etc/sqm/sqm.conf ] || . /etc/sqm/sqm.conf 2>/dev/null
		printf '%s' "${SQM_STATE_DIR:-/var/run/sqm}"
	)
}

inspect_sqm_ownership() {
	sqm_ownership_error=""
	preflight_managed_sqm_active=0
	command -v tc >/dev/null 2>&1 || {
		sqm_ownership_error="tc is required to inspect existing qdisc ownership."
		return 1
	}
	qdisc_state="$(tc qdisc show dev "$target_if" 2>/dev/null)" || {
		sqm_ownership_error="Unable to inspect qdisc state on $target_if; Full Auto-Tune will not assume the target is clean."
		return 1
	}
	root_kind="$(printf '%s\n' "$qdisc_state" | awk '$4 == "root" { print $2; exit }')"
	has_ingress=false
	printf '%s\n' "$qdisc_state" | grep -Eq ' ingress | clsact ' && has_ingress=true
	state_dir="$(sqm_state_dir)"
	state_present=false
	[ -f "$state_dir/$target_if.state" ] && state_present=true
	existing_instance="$(uci -q get "cake-autorate.$job_name" 2>/dev/null || true)"

	qdisc_clean=false
	case "$root_kind" in ''|noqueue|mq) [ "$has_ingress" = false ] && [ "$state_present" = false ] && qdisc_clean=true ;; esac
	if [ -z "$existing_instance" ]; then
		[ "$qdisc_clean" = true ] && return 0
		sqm_ownership_error="Target $target_if already has root qdisc ${root_kind:-unknown}, ingress/clsact state, or an SQM state file that is not owned by this new instance."
		return 1
	fi

	[ "$(uci -q get "cake-autorate.$job_name.manage_sqm" 2>/dev/null)" = 1 ] || {
		sqm_ownership_error="Existing instance $job_name does not manage SQM; Full Auto-Tune will not replace or snapshot an arbitrary qdisc."
		return 1
	}
	[ "$(uci -q get "cake-autorate.$job_name.sqm_enabled" 2>/dev/null)" = 1 ] || {
		sqm_ownership_error="Existing instance $job_name has managed SQM disabled; enable its matching queue before Full Auto-Tune."
		return 1
	}
	configured_sqm_if="$(uci -q get "cake-autorate.$job_name.sqm_interface" 2>/dev/null || true)"
	[ -n "$configured_sqm_if" ] || configured_sqm_if="$(uci -q get "cake-autorate.$job_name.ul_if" 2>/dev/null || true)"
	resolved_sqm_if="$(resolve_interface_device "$configured_sqm_if" 2>/dev/null)"
	[ "$resolved_sqm_if" = "$target_if" ] || {
		sqm_ownership_error="Existing instance $job_name manages ${resolved_sqm_if:-no resolved SQM interface}, not $target_if."
		return 1
	}
	sqm_section="$(uci -q get "cake-autorate.$job_name.sqm_section" 2>/dev/null || true)"
	[ -n "$sqm_section" ] || sqm_section="cake_$job_name"
	[ "$(uci -q get "sqm.$sqm_section._cake_autorate_managed" 2>/dev/null)" = "$job_name" ] || {
		sqm_ownership_error="SQM section $sqm_section is not marked as owned by instance $job_name."
		return 1
	}
	[ "$(uci -q get "sqm.$sqm_section.enabled" 2>/dev/null)" = 1 ] || {
		sqm_ownership_error="Managed SQM section $sqm_section is disabled."
		return 1
	}
	[ "$(uci -q get "sqm.$sqm_section.interface" 2>/dev/null)" = "$target_if" ] || {
		sqm_ownership_error="Managed SQM section $sqm_section does not target $target_if."
		return 1
	}
	[ "$state_present" = true ] && [ "$root_kind" = cake ] && [ "$has_ingress" = true ] || {
		sqm_ownership_error="Managed SQM for $job_name is not active as CAKE plus ingress on $target_if."
		return 1
	}
	dl_if="$(uci -q get "cake-autorate.$job_name.dl_if" 2>/dev/null || true)"
	[ -n "$dl_if" ] || dl_if="ifb4$target_if"
	safe_interface_name "$dl_if" || {
		sqm_ownership_error="Managed download IFB for $job_name is invalid."
		return 1
	}
	[ -e "/sys/class/net/$dl_if" ] &&
		[ "$(tc qdisc show dev "$dl_if" 2>/dev/null | awk '$4 == "root" { print $2; exit }')" = cake ] || {
		sqm_ownership_error="Managed download IFB $dl_if is missing or does not have CAKE."
		return 1
	}
	managed_redirect_state="$(tc filter show dev "$target_if" ingress 2>/dev/null)" || {
		sqm_ownership_error="Unable to inspect the managed ingress redirect on $target_if."
		return 1
	}
	printf '%s\n' "$managed_redirect_state" | grep -Fq "redirect dev $dl_if" ||
		printf '%s\n' "$managed_redirect_state" | grep -Fq "Redirect to device $dl_if)" || {
		sqm_ownership_error="Managed SQM ingress on $target_if does not redirect to the expected IFB $dl_if."
		return 1
	}
	preflight_managed_sqm_active=1
	return 0
}

preflight_sqm_ownership() {
	if [ "${CAKE_AUTORATE_AUTOTUNE_TEST_PREFLIGHT:-0}" = 1 ] &&
	   [ "${CAKE_AUTORATE_AUTOTUNE_TEST_SQM_OWNERSHIP:-0}" != 1 ]; then
		return 0
	fi
	inspect_sqm_ownership || fail "$sqm_ownership_error"
}

capture_recovery_sqm_snapshot() {
	recovery_sqm_was_active=0
	recovery_sqm_restore_mode=none
	recovery_sqm_section=""
	recovery_sqm_target_if=""
	recovery_sqm_ul_if=""
	recovery_sqm_dl_if=""
	recovery_sqm_config_fingerprint=""
	recovery_sqm_config_snapshot=""
	recovery_sqm_restore_required=0

	state_dir="$(sqm_state_dir)"
	if [ "${preflight_managed_sqm_active:-0}" != 1 ]; then
		[ ! -f "$state_dir/$target_if.state" ] || return 1
		return 0
	fi
	inspect_sqm_ownership || return 1
	[ "${preflight_managed_sqm_active:-0}" = 1 ] || return 1
	[ -f "$state_dir/$target_if.state" ] || return 1
	# Production preflight has already proved that this state file, target CAKE,
	# ingress redirect, and IFB are owned by this exact instance.  Persist the
	# immutable identity before the first unshaped speedtest is allowed to stop
	# SQM, so SIGKILL during that child cannot strand the link unshaped.
	[ -n "${sqm_section:-}" ] || return 1
	recovery_sqm_section="$sqm_section"
	recovery_sqm_target_if="$target_if"
	recovery_sqm_ul_if="$(uci -q get "cake-autorate.$job_name.ul_if" 2>/dev/null)"
	[ -n "$recovery_sqm_ul_if" ] || recovery_sqm_ul_if="$target_if"
	recovery_sqm_dl_if="${dl_if:-$(uci -q get "cake-autorate.$job_name.dl_if" 2>/dev/null)}"
	[ -n "$recovery_sqm_dl_if" ] || recovery_sqm_dl_if="ifb4$target_if"
	safe_job_name "$recovery_sqm_section" &&
		safe_interface_name "$recovery_sqm_target_if" &&
		safe_interface_name "$recovery_sqm_ul_if" &&
		safe_interface_name "$recovery_sqm_dl_if" || return 1
	fingerprint_before="$(managed_sqm_config_fingerprint "$recovery_sqm_section")" || return 1
	snapshot_candidate="$(capture_sqm_config_file)" || return 1
	snapshot_fingerprint="$(managed_sqm_snapshot_fingerprint "$snapshot_candidate" "$recovery_sqm_section")" || {
		rm -f "$snapshot_candidate" 2>/dev/null || true
		return 1
	}
	fingerprint_after="$(managed_sqm_config_fingerprint "$recovery_sqm_section")" || {
		rm -f "$snapshot_candidate" 2>/dev/null || true
		return 1
	}
	[ "$fingerprint_before" = "$snapshot_fingerprint" ] &&
		[ "$fingerprint_before" = "$fingerprint_after" ] || {
		rm -f "$snapshot_candidate" 2>/dev/null || true
		return 1
	}
	recovery_sqm_config_fingerprint="$fingerprint_before"
	recovery_sqm_config_snapshot="$snapshot_candidate"
	recovery_sqm_restore_required=1
	recovery_sqm_was_active=1
	recovery_sqm_restore_mode=managed
	return 0
}

replace_temporary_cake_qdisc() {
	qdisc_device="$1"
	qdisc_handle="$2"
	qdisc_rate_kbps="$3"
	qdisc_direction="$4"
	safe_interface_name "$qdisc_device" &&
		is_positive_uint "$qdisc_rate_kbps" || return 1
	case "$qdisc_direction" in download|upload) ;; *) return 1 ;; esac

	# Construct argv one token at a time.  The profile, direction, and link
	# compensation values are all selected from closed allowlists, so shaped
	# validation cannot drift from the exact SQM policy that will be proposed
	# later or turn a UCI value into shell syntax.
	set -- qdisc replace dev "$qdisc_device" root handle "$qdisc_handle" \
		cake bandwidth "${qdisc_rate_kbps}kbit"
	case "$autotune_profile" in
		gaming) set -- "$@" diffserv4 nat ;;
		best_overall|fair)
			set -- "$@" besteffort nat
			# piece_of_cake.qos washes only the ingress/IFB path when
			# squash_dscp=1. Its egress path remains besteffort+nat.
			[ "$qdisc_direction" != download ] || set -- "$@" wash
			;;
		*) return 1 ;;
	esac
	case "$link_kind" in
		pppoe) set -- "$@" ethernet overhead 44 mpu 84 ;;
		ethernet) set -- "$@" ethernet overhead 18 mpu 64 ;;
		*) set -- "$@" raw ;;
	esac
	tc "$@" >/dev/null 2>&1
}

configure_temp_shaper_identity() {
	identity_seed="$(printf '%s' "$worker_token" | cut -c1-8)"
	case "$identity_seed" in
		????????) ;;
		*) identity_seed="" ;;
	esac
	case "$identity_seed" in
		''|*[!A-Fa-f0-9]*)
			identity_seed="$(printf '%s' "$worker_token" | cksum 2>/dev/null |
				awk 'NF >= 1 { printf "%08x", $1; exit }')"
			;;
	esac
	case "$identity_seed" in ????????) ;; *) return 1 ;; esac
	handle_seed="$(printf '%s' "$identity_seed" | cut -c1-3 | tr 'A-F' 'a-f')"
	temp_ifb="catf$identity_seed"
	temp_ifb_alias="cake-autotune-$worker_token"
	temp_target_handle="a${handle_seed}:"
	temp_ifb_handle="b${handle_seed}:"
	temp_ingress_handle="ffff:"
	temp_redirect_pref="$((49152 + ($$ % 1024)))"
	[ "${#temp_ifb}" -le 15 ] && safe_interface_name "$temp_ifb" || return 1
	case "$temp_ifb_alias" in ''|*[!A-Za-z0-9_-]*) return 1 ;; esac
	recovery_temp_ifb="$temp_ifb"
	recovery_temp_ifb_alias="$temp_ifb_alias"
	recovery_temp_ifb_ifindex=""
	recovery_temp_target_handle="$temp_target_handle"
	recovery_temp_ifb_handle="$temp_ifb_handle"
	recovery_temp_ingress_handle="$temp_ingress_handle"
	recovery_temp_redirect_pref="$temp_redirect_pref"
}

exact_root_qdisc() {
	qdisc_device="$1"
	qdisc_handle="$2"
	qdisc_expected_kbps="$3"
	qdisc_direction="$4"
	is_positive_uint "$qdisc_expected_kbps" || return 1
	case "$qdisc_direction" in download|upload) ;; *) return 1 ;; esac
	qdisc_output="$(tc qdisc show dev "$qdisc_device" 2>/dev/null)" || return 1
	printf '%s\n' "$qdisc_output" | awk -v handle="$qdisc_handle" -v expected="$qdisc_expected_kbps" '
		function rate_kbps(token, value, multiplier) {
			value = token
			if (value ~ /[Kk]bit$/) { sub(/[Kk]bit$/, "", value); multiplier = 1 }
			else if (value ~ /[Mm]bit$/) { sub(/[Mm]bit$/, "", value); multiplier = 1000 }
			else if (value ~ /[Gg]bit$/) { sub(/[Gg]bit$/, "", value); multiplier = 1000000 }
			else if (value ~ /[Tt]bit$/) { sub(/[Tt]bit$/, "", value); multiplier = 1000000000 }
			else if (value ~ /bit$/) { sub(/bit$/, "", value); multiplier = 0.001 }
			else return -1
			if (value !~ /^[0-9]+([.][0-9]+)?$/) return -1
			return value * multiplier
		}
		$1 == "qdisc" && $2 == "cake" && $3 == handle && $4 == "root" {
			found++
			for (i = 5; i < NF; i++) if ($i == "bandwidth") {
				actual = rate_kbps($(i + 1))
				delta = actual - expected
				if (delta < 0) delta = -delta
				if (actual >= 0 && delta < 0.5) rate_matches++
				break
			}
		}
		END { exit(found == 1 && rate_matches == 1 ? 0 : 1) }
	' || return 1
	qdisc_line="$(printf '%s\n' "$qdisc_output" |
		awk -v handle="$qdisc_handle" '
			$1 == "qdisc" && $2 == "cake" && $3 == handle && $4 == "root" {
				print
				found++
			}
			END { exit(found == 1 ? 0 : 1) }
		')" || return 1
	case "$autotune_profile" in
		gaming)
			printf '%s\n' "$qdisc_line" | grep -Eq '(^|[[:space:]])diffserv4([[:space:]]|$)' || return 1
			! printf '%s\n' "$qdisc_line" | grep -Eq '(^|[[:space:]])wash([[:space:]]|$)' || return 1
			;;
		best_overall|fair)
			printf '%s\n' "$qdisc_line" | grep -Eq '(^|[[:space:]])besteffort([[:space:]]|$)' || return 1
			if [ "$qdisc_direction" = download ]; then
				printf '%s\n' "$qdisc_line" | grep -Eq '(^|[[:space:]])wash([[:space:]]|$)' || return 1
			else
				! printf '%s\n' "$qdisc_line" | grep -Eq '(^|[[:space:]])wash([[:space:]]|$)' || return 1
			fi
			;;
		*) return 1 ;;
	esac
	printf '%s\n' "$qdisc_line" | grep -Eq '(^|[[:space:]])nat([[:space:]]|$)' || return 1
	# layer_cake.qos and piece_of_cake.qos attach CAKE to an IFB but do not
	# pass CAKE's separate `ingress` keyword. Validate that exact effective
	# qdisc rather than a superficially similar custom shaper.
	! printf '%s\n' "$qdisc_line" | grep -Eq '(^|[[:space:]])ingress([[:space:]]|$)' || return 1
}

exact_ingress_redirect() {
	qdisc_output="$(tc qdisc show dev "$target_if" 2>/dev/null)" || return 1
	printf '%s\n' "$qdisc_output" | awk -v handle="$temp_ingress_handle" '
		$1 == "qdisc" && $2 == "ingress" && $3 == handle { found++ }
		END { exit(found == 1 ? 0 : 1) }
	' || return 1
	filter_output="$(tc filter show dev "$target_if" ingress 2>/dev/null)" || return 1
	printf '%s\n' "$filter_output" | grep -Eq "(^|[[:space:]])pref[[:space:]]+$temp_redirect_pref([[:space:]]|$)" || return 1
	printf '%s\n' "$filter_output" | grep -Fq "redirect dev $temp_ifb" ||
		printf '%s\n' "$filter_output" | grep -Fq "Redirect to device $temp_ifb)" || return 1
}

exact_temp_ifb() {
	[ -e "/sys/class/net/$temp_ifb" ] || return 1
	[ "$(cat "/sys/class/net/$temp_ifb/ifalias" 2>/dev/null)" = "$temp_ifb_alias" ] || return 1
	is_positive_uint "${recovery_temp_ifb_ifindex:-}" || return 1
	[ "$(cat "/sys/class/net/$temp_ifb/ifindex" 2>/dev/null)" = "$recovery_temp_ifb_ifindex" ] || return 1
}

temporary_shaper_owned() {
	if [ "${CAKE_AUTORATE_AUTOTUNE_TEST_SHAPER:-0}" = 1 ]; then
		[ "${temp_shaper_active:-0}" = 1 ] || return 1
		is_positive_uint "${temp_download_kbps:-}" || return 1
		is_positive_uint "${temp_upload_kbps:-}" || return 1
		if [ -n "${AUTOTUNE_MOCK_SHAPER_OWNERSHIP_LOST_MARKER:-}" ] &&
		   [ -e "$AUTOTUNE_MOCK_SHAPER_OWNERSHIP_LOST_MARKER" ]; then
			return 1
		fi
		if [ -n "${AUTOTUNE_MOCK_SHAPER_OWNERSHIP_CHECK_COUNTER:-}" ]; then
			ownership_check_count="$(sed -n '1p' "$AUTOTUNE_MOCK_SHAPER_OWNERSHIP_CHECK_COUNTER" 2>/dev/null)"
			case "$ownership_check_count" in ''|*[!0-9]*) ownership_check_count=0 ;; esac
			ownership_check_count=$((ownership_check_count + 1))
			printf '%s\n' "$ownership_check_count" > "$AUTOTUNE_MOCK_SHAPER_OWNERSHIP_CHECK_COUNTER" || return 1
			if is_positive_uint "${AUTOTUNE_MOCK_SHAPER_INVALIDATE_AFTER_CHECK:-}" &&
			   [ "$ownership_check_count" -eq "$AUTOTUNE_MOCK_SHAPER_INVALIDATE_AFTER_CHECK" ]; then
				[ -n "${AUTOTUNE_MOCK_SHAPER_OWNERSHIP_LOST_MARKER:-}" ] || return 1
				: > "$AUTOTUNE_MOCK_SHAPER_OWNERSHIP_LOST_MARKER" || return 1
			fi
		fi
		return 0
	fi
	[ "${recovery_shaper_started:-0}" = 1 ] || return 1
	is_positive_uint "${temp_download_kbps:-}" || return 1
	is_positive_uint "${temp_upload_kbps:-}" || return 1
	exact_temp_ifb &&
		exact_root_qdisc "$target_if" "$temp_target_handle" "$temp_upload_kbps" upload &&
		exact_root_qdisc "$temp_ifb" "$temp_ifb_handle" "$temp_download_kbps" download &&
		exact_ingress_redirect
}

restore_temp_shaper() {
	if [ "${CAKE_AUTORATE_AUTOTUNE_TEST_SHAPER:-0}" = 1 ]; then
		[ -n "${AUTOTUNE_MOCK_SHAPER_RESTORE_MARKER:-}" ] &&
			touch "$AUTOTUNE_MOCK_SHAPER_RESTORE_MARKER"
		temp_shaper_active=0
		return 0
	fi

	if [ "${temp_shaper_active:-0}" = 1 ]; then
		temporary_shaper_owned || return 1
		tc qdisc del dev "$target_if" ingress >/dev/null 2>&1 || return 1
		tc qdisc del dev "$target_if" root >/dev/null 2>&1 || return 1
		tc qdisc del dev "$temp_ifb" root >/dev/null 2>&1 || return 1
		if [ "${temp_ifb_created:-0}" = 1 ]; then
			ip link set dev "$temp_ifb" down >/dev/null 2>&1 || return 1
			ip link delete dev "$temp_ifb" type ifb >/dev/null 2>&1 || return 1
		fi
		[ ! -e "/sys/class/net/$temp_ifb" ] || return 1
		temp_shaper_active=0
	fi

	# Managed SQM is intentionally not restarted here. The recovery helper owns
	# that operation and verifies the immutable SQM/IFB/redirect postconditions
	# before it resumes autorate and releases the interface lock.
}

discard_unpublished_temp_ifb() {
	# This path is only for a synchronous failure before shaper_started=1 is
	# durably published.  Delete nothing unless the just-created link still has
	# both the locally captured ifindex and our random ownership alias.  Crash
	# recovery deliberately ignores an uncommitted IFB and restores managed SQM.
	[ "${temp_ifb_created:-0}" = 1 ] || return 0
	is_positive_uint "${created_temp_ifb_ifindex:-}" || return 1
	[ "$(cat "/sys/class/net/$temp_ifb/ifindex" 2>/dev/null)" = "$created_temp_ifb_ifindex" ] || return 1
	[ "$(cat "/sys/class/net/$temp_ifb/ifalias" 2>/dev/null)" = "$temp_ifb_alias" ] || return 1
	ip link set dev "$temp_ifb" down >/dev/null 2>&1 || return 1
	ip link delete dev "$temp_ifb" type ifb >/dev/null 2>&1 || return 1
	[ ! -e "/sys/class/net/$temp_ifb" ] || return 1
	temp_ifb_created=0
	return 0
}

prepare_temp_shaper() {
	download_kbps="$1"
	upload_kbps="$2"

	if [ "${CAKE_AUTORATE_AUTOTUNE_TEST_SHAPER:-0}" = 1 ]; then
		temp_shaper_active=1
		temp_download_kbps="$download_kbps"
		temp_upload_kbps="$upload_kbps"
		return 0
	fi

	command -v tc >/dev/null 2>&1 || fail "tc is required for shaped validation."
	command -v ip >/dev/null 2>&1 || fail "ip is required for shaped validation."
	[ -x /usr/lib/sqm/run.sh ] || fail "sqm-scripts is required for shaped validation."
	[ -n "${temp_ifb:-}" ] && [ -n "${temp_ifb_alias:-}" ] ||
		fail "Temporary shaper ownership identity is unavailable."
	if [ "${temp_shaper_active:-0}" = 1 ]; then
		[ "${recovery_shaper_started:-0}" = 1 ] && [ "$recovery_temp_ifb" = "$temp_ifb" ] ||
			fail "Temporary shaper identity changed between validation attempts."
		temporary_shaper_owned || fail "Temporary shaper ownership changed between validation attempts."
		# Retain the same journal-owned shaper across a bounded correction/retry;
		# only its rates change. Restarting managed SQM between attempts creates a
		# larger crash window and used to make attempt two impossible.
		replace_temporary_cake_qdisc "$target_if" "$temp_target_handle" "$upload_kbps" upload ||
			fail "Unable to update the temporary upload CAKE rate."
		replace_temporary_cake_qdisc "$temp_ifb" "$temp_ifb_handle" "$download_kbps" download ||
			fail "Unable to update the temporary download CAKE rate."
		temp_download_kbps="$download_kbps"
		temp_upload_kbps="$upload_kbps"
		temporary_shaper_owned || fail "Temporary shaper ownership changed while updating candidate rates."
		return 0
	fi

	state_dir="$(sqm_state_dir)"
	if [ "${recovery_sqm_was_active:-0}" = 1 ]; then
		[ -f "$state_dir/$target_if.state" ] ||
			fail "Managed SQM disappeared before shaped validation; recovery remains armed."
		current_sqm_section="$(uci -q get "cake-autorate.$job_name.sqm_section" 2>/dev/null)"
		[ -n "$current_sqm_section" ] || current_sqm_section="cake_$job_name"
		current_ul_if="$(uci -q get "cake-autorate.$job_name.ul_if" 2>/dev/null)"
		[ -n "$current_ul_if" ] || current_ul_if="$target_if"
		current_dl_if="$(uci -q get "cake-autorate.$job_name.dl_if" 2>/dev/null)"
		[ -n "$current_dl_if" ] || current_dl_if="ifb4$target_if"
		[ "$current_sqm_section" = "$recovery_sqm_section" ] &&
			[ "$target_if" = "$recovery_sqm_target_if" ] &&
			[ "$current_ul_if" = "$recovery_sqm_ul_if" ] &&
			[ "$current_dl_if" = "$recovery_sqm_dl_if" ] ||
			fail "Managed SQM identity changed during Full Auto-Tune."
		sqm_was_active=1
		write_recovery_journal || fail "Unable to refresh the managed SQM journal before stopping it."
		/usr/lib/sqm/run.sh stop "$target_if" >/dev/null 2>&1 ||
			fail "Unable to pause existing SQM before shaped validation."
	elif [ -f "$state_dir/$target_if.state" ]; then
		fail "Unexpected SQM state appeared after the recovery snapshot was armed."
	fi

	post_stop_qdisc_state="$(tc qdisc show dev "$target_if" 2>/dev/null)" ||
		fail "Unable to inspect qdisc state after stopping managed SQM."
	root_kind="$(printf '%s\n' "$post_stop_qdisc_state" | awk '$4 == "root" { print $2; exit }')"
	case "$root_kind" in
		''|noqueue|mq|fq_codel|pfifo_fast) ;;
		*) fail "Refusing to replace unmanaged root qdisc $root_kind on $target_if." ;;
	esac
	if printf '%s\n' "$post_stop_qdisc_state" | grep -Eq ' ingress | clsact '; then
		fail "Refusing to replace unmanaged ingress/clsact state on $target_if."
	fi
	[ ! -e "/sys/class/net/$temp_ifb" ] || fail "Refusing to reuse existing IFB $temp_ifb."

	recovery_temp_ifb="$temp_ifb"
	recovery_temp_ifb_alias="$temp_ifb_alias"
	recovery_temp_ifb_ifindex=""
	recovery_shaper_started=0
	write_recovery_journal || fail "Unable to journal the temporary shaper before creating it."
	ip link add name "$temp_ifb" type ifb >/dev/null 2>&1 || fail "Unable to create temporary IFB $temp_ifb."
	temp_ifb_created=1
	created_temp_ifb_ifindex="$(cat "/sys/class/net/$temp_ifb/ifindex" 2>/dev/null)"
	is_positive_uint "$created_temp_ifb_ifindex" || fail "Unable to capture newly-created temporary IFB identity."
	ip link set dev "$temp_ifb" alias "$temp_ifb_alias" >/dev/null 2>&1 ||
		fail "Unable to mark temporary IFB ownership."
	ip link set dev "$temp_ifb" up >/dev/null 2>&1 || {
		discard_unpublished_temp_ifb || true
		fail "Unable to bring up temporary IFB $temp_ifb."
	}
	recovery_temp_ifb_ifindex="$created_temp_ifb_ifindex"
	recovery_shaper_started=1
	write_recovery_journal || {
		recovery_shaper_started=0
		recovery_temp_ifb_ifindex=""
		discard_unpublished_temp_ifb || true
		fail "Unable to atomically journal the created temporary IFB identity."
	}
	# Only a complete name+alias+ifindex tuple published in one atomic journal
	# transition authorizes qdisc attachment or recovery-side deletion.
	temp_shaper_active=1
	replace_temporary_cake_qdisc "$target_if" "$temp_target_handle" "$upload_kbps" upload ||
		fail "Unable to attach temporary upload CAKE qdisc."
	replace_temporary_cake_qdisc "$temp_ifb" "$temp_ifb_handle" "$download_kbps" download ||
		fail "Unable to attach temporary download CAKE qdisc."
	temp_download_kbps="$download_kbps"
	temp_upload_kbps="$upload_kbps"
	tc qdisc add dev "$target_if" handle ffff: ingress >/dev/null 2>&1 ||
		fail "Unable to attach temporary ingress qdisc."
	tc filter add dev "$target_if" parent ffff: protocol all pref "$temp_redirect_pref" u32 match u32 0 0 \
		action mirred egress redirect dev "$temp_ifb" >/dev/null 2>&1 ||
		fail "Unable to redirect ingress traffic into temporary IFB."
	temporary_shaper_owned || fail "Temporary CAKE/IFB ownership postconditions failed."
}

cpu_monitor() {
	output="$1"
	marker="$2"
	previous=""
	while [ -e "$marker" ]; do
		current="$(awk '/^cpu / { total=0; for (i=2; i<=NF; i++) total += $i; print total, $5 + $6; exit }' /proc/stat)"
		if [ -n "$previous" ]; then
			awk -v previous="$previous" -v current="$current" 'BEGIN {
				split(previous, p, " "); split(current, c, " ");
				total = c[1] - p[1]; idle = c[2] - p[2];
				if (total > 0) printf "%.1f\n", (total - idle) * 100 / total;
			}' >> "$output"
		fi
		previous="$current"
		sleep 1
	done
}

numeric_latency_stats() {
	input="$1"
	sorted="$2"
	[ -s "$input" ] || return 1
	sort -n "$input" > "$sorted"
	awk '
		{ value[NR] = $1 }
		END {
			if (NR < 1) exit 1
			if (NR % 2) median = value[(NR + 1) / 2]
			else median = (value[NR / 2] + value[NR / 2 + 1]) / 2
			p95_index = int((NR * 95 + 99) / 100)
			if (p95_index < 1) p95_index = 1
			printf "%.3f %.3f %.3f %d", median, value[p95_index], value[NR], NR
		}
	' "$sorted"
}

configure_transport_probe() {
	transport_probe_backend="$(uci -q get "cake-autorate.$job_name.transport_probe_backend" 2>/dev/null || true)"
	transport_probe_endpoint="$(uci -q get "cake-autorate.$job_name.transport_probe_endpoint" 2>/dev/null || true)"
	transport_probe_configuration_error=""
	transport_probe_timeout_s="$(uci -q get "cake-autorate.$job_name.transport_probe_timeout_s" 2>/dev/null || true)"
	case "$transport_probe_timeout_s" in
		''|*[!0-9]*) transport_probe_timeout_s=5 ;;
	esac
	[ "$transport_probe_timeout_s" -ge 1 ] 2>/dev/null || transport_probe_timeout_s=5
	[ "$transport_probe_timeout_s" -le 30 ] 2>/dev/null || transport_probe_timeout_s=30

	case "$transport_probe_backend:$transport_probe_endpoint" in
		:) transport_probe_backend=websocket; transport_probe_endpoint=wss://ping-bufferbloat.libreqos.com/ws ;;
		websocket:ws://*|websocket:wss://*) ;;
		tcp:tcp://*)
			transport_probe_configuration_error="Full Auto-Tune requires persistent WebSocket or HTTPS transport evidence; TCP connect probes are diagnostic-only."
			return 1
			;;
		http:https://*) ;;
		legacy-http:http://*|legacy-http:https://*)
			transport_probe_configuration_error="Full Auto-Tune requires persistent WebSocket or HTTPS transport evidence; Legacy HTTP is diagnostic-only."
			return 1
			;;
		*)
			transport_probe_configuration_error="The configured transport probe backend and endpoint do not match."
			return 1
			;;
	esac
	case "$transport_probe_backend" in
		websocket) transport_probe_reported_backend=websocket ;;
		http) transport_probe_reported_backend=persistent-http ;;
		tcp) transport_probe_reported_backend=tcp-connect ;;
	esac
	return 0
}

run_transport_probe_cli() {
	count="$1"
	interval_ms="$2"
	set -- "$transport_probe_bin" --transport-probe \
		--backend "$transport_probe_backend" \
		--endpoint "$transport_probe_endpoint" \
		--device "$target_if" \
		--source-ip "$source_ip" \
		--count "$count" \
		--timeout "$transport_probe_timeout_s" \
		--interval-ms "$interval_ms"
	[ -n "${route_mark:-}" ] && set -- "$@" --fwmark "$route_mark"
	"$@"
}

extract_transport_values() {
	input="$1"
	output="$2"
	awk '
		match($0, /"raw_ms":\[[^]]*\]/) {
			raw = substr($0, RSTART, RLENGTH)
			sub(/^"raw_ms":\[/, "", raw)
			sub(/\]$/, "", raw)
			n = split(raw, values, ",")
			for (i = 1; i <= n; i++)
				if (values[i] ~ /^[0-9]+([.][0-9]+)?$/)
					print values[i]
		}
	' "$input" > "$output"
}

validate_transport_evidence() {
	input="$1"
	output="$2"
	minimum_rows="$3"
	minimum_samples="$4"
	report="$output.report"
	transport_evidence_valid=false
	transport_evidence_reason=transport-output-invalid
	transport_evidence_rows=0
	transport_evidence_samples=0
	: > "$output"

	# TCP connect timings are useful diagnostics but do not have persistent
	# session semantics.  Full Auto-Tune compares loaded and idle application
	# latency, so a handshake-only backend is intentionally inconclusive.
	if [ "$transport_probe_reported_backend" = tcp-connect ]; then
		transport_evidence_reason=transport-backend-not-persistent
		return 1
	fi

	awk -v expected_backend="$transport_probe_reported_backend" \
	    -v expected_endpoint="$transport_probe_endpoint" '
		function string_field(line, key, pattern, value) {
			pattern = "\\\"" key "\\\":\\\"[^\\\"]*\\\""
			if (!match(line, pattern)) return ""
			value = substr(line, RSTART + length(key) + 4, RLENGTH - length(key) - 5)
			return value
		}
		NF {
			rows++
			backend = string_field($0, "backend")
			endpoint = string_field($0, "endpoint")
			if (backend != expected_backend) bad_backend++
			if (endpoint != expected_endpoint) bad_endpoint++
			if ($0 !~ /"trusted":true([,}])/) bad_trust++
			if ($0 ~ /"connection_reused":true([,}])/) reused++
			else if ($0 !~ /"connection_reused":false([,}])/) bad_reuse_field++
			else if (rows > 1) nonpersistent_after_warmup++
			if (match($0, /"raw_ms":\[[^]]*\]/)) {
				raw = substr($0, RSTART, RLENGTH)
				sub(/^"raw_ms":\[/, "", raw)
				sub(/\]$/, "", raw)
				n = split(raw, values, ",")
				for (i = 1; i <= n; i++) {
					gsub(/^[[:space:]]+|[[:space:]]+$/, "", values[i])
					if (values[i] ~ /^[0-9]+([.][0-9]+)?$/) {
						print "V " values[i]
						samples++
					} else if (values[i] != "") bad_sample++
				}
			} else bad_raw++
		}
		END {
			reason = "ok"
			if (rows < 1) reason = "transport-output-empty"
			else if (bad_backend) reason = "transport-backend-mismatch"
			else if (bad_endpoint) reason = "transport-endpoint-mismatch"
			else if (bad_trust) reason = "transport-untrusted"
			else if (bad_reuse_field || nonpersistent_after_warmup || reused < rows - 1)
				reason = "transport-not-persistent"
			else if (bad_raw || bad_sample) reason = "transport-samples-malformed"
			print "M " reason " " rows " " samples
		}
	' "$input" > "$report" 2>/dev/null || {
		rm -f "$report"
		return 1
	}
	awk '$1 == "V" { print $2 }' "$report" > "$output"
	set -- $(awk '$1 == "M" { print $2, $3, $4; exit }' "$report")
	rm -f "$report"
	transport_evidence_reason="${1:-transport-output-invalid}"
	transport_evidence_rows="${2:-0}"
	transport_evidence_samples="${3:-0}"
	[ "$transport_evidence_reason" = ok ] || return 1
	[ "$transport_evidence_rows" -ge "$minimum_rows" ] 2>/dev/null || {
		transport_evidence_reason=transport-too-few-probes
		return 1
	}
	[ "$transport_evidence_samples" -ge "$minimum_samples" ] 2>/dev/null || {
		transport_evidence_reason=transport-too-few-samples
		return 1
	}
	transport_evidence_valid=true
	return 0
}

baseline_transport_latency() {
	raw="$job_dir/transport-baseline.raw"
	values="$job_dir/transport-baseline.values"
	sorted="$job_dir/transport-baseline.sorted"
	errors="$job_dir/transport-baseline.errors"
	: > "$raw"
	if ! run_transport_probe_cli 5 250 > "$raw" 2> "$errors"; then
		[ -s "$raw" ] || return 1
	fi
	validate_transport_evidence "$raw" "$values" 5 15 || {
		printf '%s\n' "$transport_evidence_reason" > "$job_dir/transport-baseline.evidence-error"
		return 1
	}
	numeric_latency_stats "$values" "$sorted"
}

wait_for_baseline_retry() {
	case "$baseline_retry_backoff_s" in
		''|*[!0-9]*) baseline_retry_backoff_s=20 ;;
		*) [ "$baseline_retry_backoff_s" -le 60 ] 2>/dev/null || baseline_retry_backoff_s=20 ;;
	esac
	if [ "$baseline_retry_backoff_s" -gt 0 ] 2>/dev/null; then
		write_status quiet-check 19 "Waiting for ICMP policers and background traffic to settle before baseline retry"
		sleep "$baseline_retry_backoff_s"
	fi
}

capture_idle_baseline() {
	baseline_phase_attempt=1
	while [ "$baseline_phase_attempt" -le 2 ]; do
		write_status quiet-check 19 "Checking that the selected uplink is idle before baseline attempt $baseline_phase_attempt"
		measure_background_traffic
		baseline_prequiet=true
		[ "$background_blocked" = true ] && baseline_prequiet=false
		if [ "$baseline_prequiet" != true ]; then
			baseline_entry="{\"phase\":\"baseline\",\"attempt\":$baseline_phase_attempt,\"skipped\":true,\"prequiet\":false,\"postquiet\":false,\"icmp_valid\":false,\"transport_valid\":false,\"forwarded_background\":null}"
			if [ -n "${phase_background_runs_json:-}" ]; then
				phase_background_runs_json="$phase_background_runs_json,$baseline_entry"
			else
				phase_background_runs_json="$baseline_entry"
			fi
			phase_contamination_seen=true
			if [ "$baseline_phase_attempt" -lt 2 ]; then
				baseline_phase_attempt=$((baseline_phase_attempt + 1))
				continue
			fi
			stage_terminal_json error "{\"state\":\"background-blocked\",\"schema_version\":5,\"stage\":\"baseline\",\"error\":\"The uplink was busy before both idle baseline attempts. Retry when quiet; conservative mode cannot invent an idle p95.\",\"background_blocked\":true,\"retryable\":true,\"auto_apply_eligible\":false,\"manual_apply_eligible\":false,\"phase_evidence_complete\":${phase_evidence_complete:-false},\"phase_contamination_seen\":true,\"route\":$(route_diagnostics_json),\"background\":$(background_json),\"baseline\":$(baseline_diagnostics_json),\"runs\":[${runs_json:-}],\"phase_background\":[$phase_background_runs_json],\"pinger_plan\":${pinger_plan:-null},\"configuration_written\":false}"
			exit 1
		fi

		write_status baseline 22 "Measuring clean idle latency baseline (attempt $baseline_phase_attempt)"
		phase_background_kind=baseline
		start_phase_background_counter "$(configured_rate dl)" "$(configured_rate ul)"
		baseline_valid=true
		candidate_baseline="$(baseline_latency "$reflectors")" || baseline_valid=false
		transport_baseline_valid=true
		candidate_transport_baseline="$(baseline_transport_latency)" || transport_baseline_valid=false
		stop_phase_background_counter

		write_status quiet-check 25 "Checking that the uplink stayed idle through baseline attempt $baseline_phase_attempt"
		measure_background_traffic
		baseline_postquiet=true
		[ "$background_blocked" = true ] && baseline_postquiet=false
		baseline_traffic_contaminated="$phase_background_contaminated"
		[ "$baseline_prequiet" = true ] || baseline_traffic_contaminated=true
		[ "$baseline_postquiet" = true ] || baseline_traffic_contaminated=true
		baseline_contaminated="$baseline_traffic_contaminated"
		[ "$baseline_valid" = true ] || baseline_contaminated=true
		[ "$transport_baseline_valid" = true ] || baseline_contaminated=true
		baseline_entry="{\"phase\":\"baseline\",\"attempt\":$baseline_phase_attempt,\"prequiet\":$baseline_prequiet,\"postquiet\":$baseline_postquiet,\"icmp_valid\":$baseline_valid,\"transport_valid\":$transport_baseline_valid,\"forwarded_background\":$(phase_background_json)}"
		if [ -n "${phase_background_runs_json:-}" ]; then
			phase_background_runs_json="$phase_background_runs_json,$baseline_entry"
		else
			phase_background_runs_json="$baseline_entry"
		fi

		if [ "$baseline_contaminated" != true ]; then
			set -- $candidate_baseline
			idle_median_ms="$1"
			idle_p95_ms="$2"
			baseline_samples="$3"
			set -- $candidate_transport_baseline
			transport_idle_median_ms="$1"
			transport_idle_p95_ms="$2"
			transport_idle_max_ms="$3"
			transport_idle_samples="$4"
			[ "$baseline_samples" -ge 9 ] 2>/dev/null || baseline_valid=false
			[ "$transport_idle_samples" -ge 15 ] 2>/dev/null || transport_baseline_valid=false
			if [ "$baseline_valid" = true ] && [ "$transport_baseline_valid" = true ]; then
				phase_background_kind=""
				return 0
			fi
			baseline_contaminated=true
		fi

		# A probe parser/rate-limit retry is measurement instability, not proof
		# of forwarded client traffic.  Preserve auto-apply eligibility when a
		# second baseline is fully clean; real pre/post/counter contamination
		# remains sticky and fail-closed.
		[ "$baseline_traffic_contaminated" = true ] && phase_contamination_seen=true
		if [ "$baseline_phase_attempt" -lt 2 ]; then
			wait_for_baseline_retry
			baseline_phase_attempt=$((baseline_phase_attempt + 1))
			continue
		fi
		if [ "$phase_background_available" != true ]; then
			fail "Forwarded-traffic evidence was unavailable for both idle baseline attempts; an idle p95 cannot be proven."
		fi
		if [ "$baseline_valid" != true ]; then
			phase_evidence_complete=false
			measurement_inconclusive baseline icmp-insufficient-per-reflector-baseline
		fi
		if [ "$transport_baseline_valid" != true ]; then
			phase_evidence_complete=false
			baseline_transport_reason="$(sed -n '1p' "$job_dir/transport-baseline.evidence-error" 2>/dev/null)"
			measurement_inconclusive baseline "${baseline_transport_reason:-transport-baseline-invalid}"
		fi
		fail "Background traffic contaminated both idle baseline attempts. Conservative mode cannot reuse a contaminated idle p95."
	done
	return 1
}

start_transport_latency_monitor() {
	output="$1"
	errors="$2"
	: > "$output"
	run_transport_probe_cli 100 1000 > "$output" 2> "$errors" &
	transport_pid="$!"
	transport_starttime="$(proc_starttime "$transport_pid" 2>/dev/null)"
	is_positive_uint "$transport_starttime" || {
		kill -KILL "$transport_pid" 2>/dev/null || true
		wait "$transport_pid" 2>/dev/null || true
		transport_pid=""
		return 1
	}
}

owned_monitor_gone() {
	monitor_pid="$1"
	monitor_start="$2"
	actual_monitor_start="$(proc_starttime "$monitor_pid" 2>/dev/null)" || return 0
	[ "$actual_monitor_start" = "$monitor_start" ] || return 1
	case "$(proc_state "$monitor_pid" 2>/dev/null)" in ''|Z|z) return 0 ;; esac
	return 1
}

stop_owned_monitor() {
	monitor_pid="$1"
	monitor_start="$2"
	[ -n "$monitor_pid" ] || return 0
	is_positive_uint "$monitor_start" || return 1
	owned_monitor_gone "$monitor_pid" "$monitor_start" && {
		wait "$monitor_pid" 2>/dev/null || true
		return 0
	}
	[ "$(proc_starttime "$monitor_pid" 2>/dev/null)" = "$monitor_start" ] || return 1
	kill -TERM "$monitor_pid" 2>/dev/null || true
	monitor_wait=0
	while [ "$monitor_wait" -lt 3 ]; do
		owned_monitor_gone "$monitor_pid" "$monitor_start" && {
			wait "$monitor_pid" 2>/dev/null || true
			return 0
		}
		monitor_wait=$((monitor_wait + 1))
		sleep 1
	done
	[ "$(proc_starttime "$monitor_pid" 2>/dev/null)" = "$monitor_start" ] || return 1
	kill -KILL "$monitor_pid" 2>/dev/null || true
	monitor_wait=0
	while [ "$monitor_wait" -lt 3 ]; do
		owned_monitor_gone "$monitor_pid" "$monitor_start" && {
			wait "$monitor_pid" 2>/dev/null || true
			return 0
		}
		monitor_wait=$((monitor_wait + 1))
		sleep 1
	done
	return 1

}

stop_transport_latency_monitor() {
	[ -n "${transport_pid:-}" ] || return 0
	stop_owned_monitor "$transport_pid" "${transport_starttime:-}" || return 1
	transport_pid=""
	transport_starttime=""
	return 0
}

icmp_latency_monitor() {
	output="$1"
	marker="$2"
	while [ -e "$marker" ]; do
		case $- in *f*) monitor_had_noglob=1 ;; *) monitor_had_noglob=0; set -f ;; esac
		# fping accepts --; every following token has also passed
		# valid_reflector, preventing target text from becoming an option.
		set -- $reflectors
		[ "$monitor_had_noglob" = 1 ] || set +f
		route_exec "$fping_bin" -I "$target_if" -D -c 1 -p 1000 -- "$@" >> "$output" 2>&1 || true
		[ -e "$marker" ] && sleep 1
	done
}

latency_stats() {
	input="$1"
	values="$job_dir/loaded.values"
	sorted="$job_dir/loaded.sorted"
	awk '
		{
			for (i = 2; i <= NF; i++)
				if ($i == "ms" && $(i - 1) ~ /^[0-9]+([.][0-9]+)?$/)
					print $(i - 1)
		}
	' "$input" > "$values"
	[ -s "$values" ] || return 1
	sort -n "$values" > "$sorted"
	awk '
		{ value[NR] = $1 }
		END {
			if (NR < 1) exit 1
			if (NR % 2) median = value[(NR + 1) / 2]
			else median = (value[NR / 2] + value[NR / 2 + 1]) / 2
			p95_index = int((NR * 95 + 99) / 100)
			printf "%.3f %.3f %.3f %d", median, value[p95_index], value[NR], NR
		}
	' "$sorted"
}

build_icmp_evidence() {
	icmp_build_input="$1"
	icmp_build_expected="$2"
	icmp_build_output="$3"
	icmp_build_format="$4"
	icmp_build_minimum_attempts="$5"
	icmp_build_minimum_successes="$6"
	awk -v expected="$icmp_build_expected" -v format="$icmp_build_format" \
	    -v minimum_attempts="$icmp_build_minimum_attempts" -v minimum_successes="$icmp_build_minimum_successes" '
		function remember(host, value) {
			success[host]++
			values[host SUBSEP success[host]] = value + 0
		}
		format == "baseline" {
			# fping right-aligns the separator, so short IPv4 addresses have
			# several spaces before the colon.  Match the whitespace-delimited
			# separator rather than the exact three-byte string " : ".
			if (!match($0, /[[:space:]]+:[[:space:]]+/)) next
			host = substr($0, 1, RSTART - 1)
			gsub(/[[:space:]]+$/, "", host)
			rest = substr($0, RSTART + RLENGTH)
			n = split(rest, fields, /[[:space:]]+/)
			for (i = 1; i <= n; i++) {
				if (fields[i] == "-") attempts[host]++
				else if (fields[i] ~ /^[0-9]+([.][0-9]+)?$/) {
					attempts[host]++
					remember(host, fields[i])
				}
			}
			next
		}
		format == "loaded" {
			host = $2
			if (host == "") next
			if (index($0, "timed out")) {
				attempts[host]++
				next
			}
			if (index($0, " bytes,") && index($0, " ms")) {
				attempts[host]++
				for (i = 2; i <= NF; i++)
					if ($i == "ms" && $(i - 1) ~ /^[0-9]+([.][0-9]+)?$/) {
						remember(host, $(i - 1))
						break
					}
			}
		}
		END {
			nhosts = split(expected, hosts, /[[:space:]]+/)
			if (nhosts < 3) invalid = 1
			for (h = 1; h <= nhosts; h++) {
				host = hosts[h]
				if (host == "") { invalid = 1; continue }
				if (attempts[host] < minimum_attempts || success[host] < minimum_successes) invalid = 1
				for (i = 1; i <= success[host]; i++) sorted[i] = values[host SUBSEP i]
				for (i = 1; i <= success[host]; i++)
					for (j = i + 1; j <= success[host]; j++)
						if (sorted[j] < sorted[i]) { tmp = sorted[i]; sorted[i] = sorted[j]; sorted[j] = tmp }
				p95index = int((success[host] * 95 + 99) / 100)
				if (p95index < 1) p95index = 1
				p95 = success[host] ? sorted[p95index] : 0
				loss = attempts[host] ? 100 * (attempts[host] - success[host]) / attempts[host] : 100
				printf "%s\t%d\t%d\t%.2f\t%.3f\n", host, attempts[host], success[host], loss, p95
				for (i = 1; i <= success[host]; i++) delete sorted[i]
			}
			exit(invalid ? 1 : 0)
		}
	' "$icmp_build_input" > "$icmp_build_output"
}

classify_loaded_icmp_evidence() {
	loaded_stats="$1"
	baseline_stats="$2"
	classification="$(awk '
		FNR == NR { baseline[$1] = $5; next }
		{
			n++
			host[n] = $1
			loss[n] = $4 + 0
			delta[n] = $5 - baseline[$1]
			if (delta[n] < 0) delta[n] = 0
		}
		END {
			if (n < 3) { print "incomplete|fewer-than-three-reflector-families"; exit }
			for (i = 1; i <= n; i++) {
				sorted_loss[i] = loss[i]
				sorted_delta[i] = delta[i]
			}
			for (i = 1; i <= n; i++) for (j = i + 1; j <= n; j++) {
				if (sorted_loss[j] < sorted_loss[i]) { tmp=sorted_loss[i]; sorted_loss[i]=sorted_loss[j]; sorted_loss[j]=tmp }
				if (sorted_delta[j] < sorted_delta[i]) { tmp=sorted_delta[i]; sorted_delta[i]=sorted_delta[j]; sorted_delta[j]=tmp }
			}
			max_loss = sorted_loss[n]
			second_loss = sorted_loss[n - 1]
			if (max_loss >= 20 && second_loss <= 5) {
				for (i = 1; i <= n; i++) if (loss[i] == max_loss) { print "rate-limit|" host[i]; exit }
			}
			median_delta = sorted_delta[int((n + 1) / 2)]
			spread_limit = median_delta * 3 + 10
			if (spread_limit < 30) spread_limit = 30
			if (sorted_delta[n] - sorted_delta[1] > spread_limit) {
				print "disagreement|reflector-family-p95-disagreement"
				exit
			}
			print "ok|ok"
		}
	' "$baseline_stats" "$loaded_stats" 2>/dev/null)"
	icmp_evidence_class="${classification%%|*}"
	icmp_evidence_detail="${classification#*|}"
	[ "$icmp_evidence_class" = ok ]
}

packet_loss_percent() {
	input="$1"
	probe_loss="$(awk '
		index($0, "timed out") {
			host = $2; sent[host]++; next
		}
		index($0, " bytes,") && index($0, " ms") {
			host = $2; sent[host]++; received[host]++
		}
		END {
			for (host in sent) {
				if (host == "") continue
				n++
				loss[n] = 100 * (sent[host] - received[host]) / sent[host]
			}
			if (n < 1) exit 1
			for (i = 1; i <= n; i++)
				for (j = i + 1; j <= n; j++)
					if (loss[j] < loss[i]) {
						tmp = loss[i]; loss[i] = loss[j]; loss[j] = tmp
					}
			if (n % 2) median = loss[(n + 1) / 2]
			else median = (loss[n / 2] + loss[n / 2 + 1]) / 2
			printf "%.2f\n", median
		}
	' "$input" 2>/dev/null)" || probe_loss=""
	if [ -n "$probe_loss" ]; then
		printf '%s\n' "$probe_loss"
		return 0
	fi

	# Some fping variants only expose per-host summaries.  Use their median so
	# one public reflector's ICMP rate limiting does not masquerade as link loss.
	sed -n 's/.*%loss = [0-9][0-9]*\/[0-9][0-9]*\/\([0-9.][0-9.]*\)%.*/\1/p' "$input" |
		sort -n |
	awk '
		{ value[NR] = $1 }
		END {
			if (NR < 1) exit 1
			if (NR % 2) median = value[(NR + 1) / 2]
			else median = (value[NR / 2] + value[NR / 2 + 1]) / 2
			printf "%.2f\n", median
		}
	'
}

typed_json_fragment() {
	typed_json="$1"
	typed_field="$2"
	case "$typed_field" in
		metrics) printf '%s\n' "$typed_json" | sed -n 's/^.*"metrics":\(.*\),"signals":.*$/\1/p' ;;
		signals) printf '%s\n' "$typed_json" | sed -n 's/^.*"signals":\(.*\),"gates":.*$/\1/p' ;;
		gates) printf '%s\n' "$typed_json" | sed -n 's/^.*"gates":\(\[.*\]\),"reasons":.*$/\1/p' ;;
		reasons) printf '%s\n' "$typed_json" | sed -n 's/^.*"reasons":\(\[.*\]\),"correction":.*$/\1/p' ;;
		correction) printf '%s\n' "$typed_json" | sed -n 's/^.*"correction":\(.*\)}$/\1/p' ;;
		*) return 1 ;;
	esac
}

scale_for_reference_base() {
	desired_kbps="$1"
	reference_kbps="$2"
	awk -v desired="$desired_kbps" -v reference="$reference_kbps" 'BEGIN {
		if (desired <= 0 || reference <= 0) exit 1
		printf "%.9f", desired / reference
	}'
}

extract_json() {
	json="$1"
	expression="$2"
	[ -n "$jsonfilter_bin" ] || return 1
	printf '%s\n' "$json" | "$jsonfilter_bin" -e "$expression" 2>/dev/null
}

proposal_json_valid() {
	proposal_candidate="$1"
	[ -n "$proposal_candidate" ] || return 1
	strict_single_json_object "$proposal_candidate" || return 1
	proposal_schema="$(extract_json "$proposal_candidate" '@.schema_version')" || return 1
	proposal_profile="$(extract_json "$proposal_candidate" '@.profile')" || return 1
	proposal_target_grade="$(extract_json "$proposal_candidate" '@.target_grade')" || return 1
	proposal_quality_required="$(extract_json "$proposal_candidate" '@.quality_target_required')" || return 1
	proposal_throughput_priority="$(extract_json "$proposal_candidate" '@.throughput_priority')" || return 1
	[ "$proposal_schema" = 3 ] && [ "$proposal_profile" = "$autotune_profile" ] || return 1

	proposal_dl_min="$(extract_json "$proposal_candidate" '@.download.minimum_kbps')" || return 1
	proposal_dl_base="$(extract_json "$proposal_candidate" '@.download.base_kbps')" || return 1
	proposal_dl_max="$(extract_json "$proposal_candidate" '@.download.maximum_kbps')" || return 1
	proposal_dl_cap="$(extract_json "$proposal_candidate" '@.download.absolute_cap_kbps')" || return 1
	proposal_dl_low="$(extract_json "$proposal_candidate" '@.download.observed_low_kbps')" || return 1
	proposal_dl_median="$(extract_json "$proposal_candidate" '@.download.observed_median_kbps')" || return 1
	proposal_dl_high="$(extract_json "$proposal_candidate" '@.download.observed_high_kbps')" || return 1
	proposal_ul_min="$(extract_json "$proposal_candidate" '@.upload.minimum_kbps')" || return 1
	proposal_ul_base="$(extract_json "$proposal_candidate" '@.upload.base_kbps')" || return 1
	proposal_ul_max="$(extract_json "$proposal_candidate" '@.upload.maximum_kbps')" || return 1
	proposal_ul_cap="$(extract_json "$proposal_candidate" '@.upload.absolute_cap_kbps')" || return 1
	proposal_ul_low="$(extract_json "$proposal_candidate" '@.upload.observed_low_kbps')" || return 1
	proposal_ul_median="$(extract_json "$proposal_candidate" '@.upload.observed_median_kbps')" || return 1
	proposal_ul_high="$(extract_json "$proposal_candidate" '@.upload.observed_high_kbps')" || return 1
	for proposal_rate in \
		"$proposal_dl_min" "$proposal_dl_base" "$proposal_dl_max" "$proposal_dl_cap" \
		"$proposal_dl_low" "$proposal_dl_median" "$proposal_dl_high" \
		"$proposal_ul_min" "$proposal_ul_base" "$proposal_ul_max" "$proposal_ul_cap" \
		"$proposal_ul_low" "$proposal_ul_median" "$proposal_ul_high"; do
		is_uint_between "$proposal_rate" 100 100000000 || return 1
	done
	[ "$proposal_dl_min" -le "$proposal_dl_base" ] &&
		[ "$proposal_dl_base" -le "$proposal_dl_max" ] &&
		[ "$proposal_dl_max" -le "$proposal_dl_cap" ] &&
		[ "$proposal_dl_low" -le "$proposal_dl_median" ] &&
		[ "$proposal_dl_median" -le "$proposal_dl_high" ] || return 1
	[ "$proposal_ul_min" -le "$proposal_ul_base" ] &&
		[ "$proposal_ul_base" -le "$proposal_ul_max" ] &&
		[ "$proposal_ul_max" -le "$proposal_ul_cap" ] &&
		[ "$proposal_ul_low" -le "$proposal_ul_median" ] &&
		[ "$proposal_ul_median" -le "$proposal_ul_high" ] || return 1

	proposal_active="$(extract_json "$proposal_candidate" '@.active_threshold_kbps')" || return 1
	proposal_adjust_up="$(extract_json "$proposal_candidate" '@.thresholds_ms.adjust_up')" || return 1
	proposal_delay="$(extract_json "$proposal_candidate" '@.thresholds_ms.delay')" || return 1
	proposal_adjust_down="$(extract_json "$proposal_candidate" '@.thresholds_ms.adjust_down')" || return 1
	is_uint_between "$proposal_active" 1 20000 || return 1
	[ "$proposal_active" -le "$proposal_dl_min" ] &&
		[ "$proposal_active" -le "$proposal_ul_min" ] || return 1
	is_uint_between "$proposal_adjust_up" 1 200 || return 1
	is_uint_between "$proposal_delay" 1 1000 || return 1
	is_uint_between "$proposal_adjust_down" 1 5000 || return 1
	[ "$proposal_adjust_up" -le "$proposal_delay" ] &&
		[ "$proposal_delay" -le "$proposal_adjust_down" ] || return 1

	proposal_adaptive_enabled="$(extract_json "$proposal_candidate" '@.adaptive_ceiling.enabled')" || return 1
	proposal_adaptive_hold="$(extract_json "$proposal_candidate" '@.adaptive_ceiling.hold_s')" || return 1
	proposal_adaptive_growth="$(extract_json "$proposal_candidate" '@.adaptive_ceiling.growth_percent')" || return 1
	proposal_adaptive_probe="$(extract_json "$proposal_candidate" '@.adaptive_ceiling.probe_s')" || return 1
	proposal_adaptive_cooldown="$(extract_json "$proposal_candidate" '@.adaptive_ceiling.cooldown_s')" || return 1
	proposal_adaptive_ttl="$(extract_json "$proposal_candidate" '@.adaptive_ceiling.failed_bound_ttl_s')" || return 1
	case "$proposal_adaptive_enabled" in true|false) ;; *) return 1 ;; esac
	is_uint_between "$proposal_adaptive_hold" 1 86400 || return 1
	is_decimal_between "$proposal_adaptive_growth" 0.1 10 || return 1
	is_uint_between "$proposal_adaptive_probe" 1 3600 || return 1
	is_uint_between "$proposal_adaptive_cooldown" 0 86400 || return 1
	is_uint_between "$proposal_adaptive_ttl" 1 604800 || return 1

	proposal_validation_realization_min="$(extract_json "$proposal_candidate" '@.validation.candidate_realization_min_percent')" || return 1
	proposal_validation_realization_max="$(extract_json "$proposal_candidate" '@.validation.candidate_realization_max_percent')" || return 1
	proposal_validation_retention="$(extract_json "$proposal_candidate" '@.validation.capacity_retention_min_percent')" || return 1
	proposal_validation_icmp="$(extract_json "$proposal_candidate" '@.validation.icmp_delta_max_ms')" || return 1
	proposal_validation_transport="$(extract_json "$proposal_candidate" '@.validation.transport_delta_max_ms')" || return 1
	proposal_validation_loss="$(extract_json "$proposal_candidate" '@.validation.loss_max_percent')" || return 1
	proposal_validation_cpu="$(extract_json "$proposal_candidate" '@.validation.cpu_max_percent')" || return 1
	numbers_equal "$proposal_validation_realization_min" 80 || return 1
	numbers_equal "$proposal_validation_realization_max" 110 || return 1
	numbers_equal "$proposal_validation_cpu" 85 || return 1

	proposal_sqm_qdisc="$(extract_json "$proposal_candidate" '@.sqm.qdisc')" || return 1
	proposal_sqm_script="$(extract_json "$proposal_candidate" '@.sqm.script')" || return 1
	proposal_sqm_classification="$(extract_json "$proposal_candidate" '@.sqm.classification')" || return 1
	proposal_sqm_squash_dscp="$(extract_json "$proposal_candidate" '@.sqm.squash_dscp')" || return 1
	proposal_sqm_squash_ingress="$(extract_json "$proposal_candidate" '@.sqm.squash_ingress')" || return 1
	proposal_sqm_ingress_ecn="$(extract_json "$proposal_candidate" '@.sqm.ingress_ecn')" || return 1
	proposal_sqm_egress_ecn="$(extract_json "$proposal_candidate" '@.sqm.egress_ecn')" || return 1
	proposal_sqm_iqdisc_opts="$(extract_json "$proposal_candidate" '@.sqm.iqdisc_opts')" || return 1
	proposal_sqm_eqdisc_opts="$(extract_json "$proposal_candidate" '@.sqm.eqdisc_opts')" || return 1
	[ "$proposal_sqm_qdisc" = cake ] &&
		[ "$proposal_sqm_ingress_ecn" = ECN ] &&
		[ "$proposal_sqm_egress_ecn" = NOECN ] || return 1

	case "$autotune_profile" in
		gaming)
			[ "$proposal_target_grade" = A+ ] &&
				[ "$proposal_quality_required" = true ] &&
				[ "$proposal_throughput_priority" = false ] &&
				numbers_equal "$proposal_validation_retention" 70 &&
				numbers_equal "$proposal_validation_icmp" 5 &&
				numbers_equal "$proposal_validation_transport" 5 &&
				numbers_equal "$proposal_validation_loss" 1 &&
				[ "$proposal_sqm_script" = layer_cake.qos ] &&
				[ "$proposal_sqm_classification" = diffserv4 ] &&
				[ "$proposal_sqm_squash_dscp" = false ] &&
				[ "$proposal_sqm_squash_ingress" = false ] &&
				[ "$proposal_sqm_iqdisc_opts" = diffserv4 ] &&
				[ "$proposal_sqm_eqdisc_opts" = diffserv4 ] || return 1
			;;
		best_overall)
			[ "$proposal_target_grade" = A ] &&
				[ "$proposal_quality_required" = true ] &&
				[ "$proposal_throughput_priority" = false ] &&
				numbers_equal "$proposal_validation_retention" 80 &&
				numbers_equal "$proposal_validation_icmp" 30 &&
				numbers_equal "$proposal_validation_transport" 30 &&
				numbers_equal "$proposal_validation_loss" 3 || return 1
			;;
		fair)
			[ "$proposal_target_grade" = C ] &&
				[ "$proposal_quality_required" = false ] &&
				[ "$proposal_throughput_priority" = true ] &&
				numbers_equal "$proposal_validation_retention" 90 &&
				numbers_equal "$proposal_validation_icmp" 200 &&
				numbers_equal "$proposal_validation_transport" 200 &&
				numbers_equal "$proposal_validation_loss" 5 || return 1
			;;
		*) return 1 ;;
	esac
	case "$autotune_profile" in
		best_overall|fair)
			[ "$proposal_sqm_script" = piece_of_cake.qos ] &&
				[ "$proposal_sqm_classification" = besteffort ] &&
				[ "$proposal_sqm_squash_dscp" = true ] &&
				[ "$proposal_sqm_squash_ingress" = true ] &&
				[ -z "$proposal_sqm_iqdisc_opts" ] &&
				[ -z "$proposal_sqm_eqdisc_opts" ] || return 1
			;;
	esac

	proposal_link_layer="$(extract_json "$proposal_candidate" '@.link.layer')" || return 1
	proposal_link_overhead="$(extract_json "$proposal_candidate" '@.link.overhead')" || return 1
	proposal_link_mpu="$(extract_json "$proposal_candidate" '@.link.mpu')" || return 1
	case "$proposal_link_layer" in none|ethernet|atm) ;; *) return 1 ;; esac
	is_uint_between "$proposal_link_overhead" 0 1500 || return 1
	is_uint_between "$proposal_link_mpu" 0 65535 || return 1
	return 0
}

process_group_contains_session() {
	group_id="$1"
	for proc_dir in /proc/[0-9]*; do
		[ -r "$proc_dir/stat" ] || continue
		member_pid="${proc_dir#/proc/}"
		case "$(proc_state "$member_pid" 2>/dev/null)" in
			''|Z|z) continue ;;
		esac
		[ "$(proc_group "$member_pid")" = "$group_id" ] || continue
		[ "$(proc_session "$member_pid")" = "$group_id" ] || continue
		return 0
	done
	return 1
}

speedtest_identity_matches() {
	candidate_pid="$1"
	expected_starttime="$2"
	[ "$(proc_starttime "$candidate_pid" 2>/dev/null)" = "$expected_starttime" ] || return 1
	proc_cmdline_has_arg "$candidate_pid" "$speedtest_bin" || return 1
	proc_cmdline_has_arg "$candidate_pid" "$job_name" || return 1
	proc_cmdline_has_arg "$candidate_pid" "$target_if" || return 1
}

signal_test_group_until_gone() {
	group_id="$1"
	group_starttime="$2"
	process_group_contains_session "$group_id" || return 0
	if [ -d "/proc/$group_id" ]; then
		[ "$(proc_starttime "$group_id" 2>/dev/null)" = "$group_starttime" ] || return 1
		case "$(proc_state "$group_id" 2>/dev/null)" in
			Z|z) ;;
			*) speedtest_identity_matches "$group_id" "$group_starttime" || return 1 ;;
		esac
	fi
	kill -TERM -- "-$group_id" >/dev/null 2>&1 || kill -TERM "-$group_id" >/dev/null 2>&1 || true
	grace_second=0
	while [ "$grace_second" -lt "$test_termination_grace_s" ]; do
		process_group_contains_session "$group_id" || return 0
		if [ -d "/proc/$group_id" ]; then
			[ "$(proc_starttime "$group_id" 2>/dev/null)" = "$group_starttime" ] || return 1
			case "$(proc_state "$group_id" 2>/dev/null)" in
				Z|z) ;;
				*) speedtest_identity_matches "$group_id" "$group_starttime" || return 1 ;;
			esac
		fi
		grace_second=$((grace_second + 1))
		sleep 1
	done
	if [ -d "/proc/$group_id" ]; then
		[ "$(proc_starttime "$group_id" 2>/dev/null)" = "$group_starttime" ] || return 1
		case "$(proc_state "$group_id" 2>/dev/null)" in
			Z|z) ;;
			*) speedtest_identity_matches "$group_id" "$group_starttime" || return 1 ;;
		esac
	fi
	kill -KILL -- "-$group_id" >/dev/null 2>&1 || kill -KILL "-$group_id" >/dev/null 2>&1 || true
	grace_second=0
	while [ "$grace_second" -lt 3 ]; do
		process_group_contains_session "$group_id" || return 0
		grace_second=$((grace_second + 1))
		sleep 1
	done
	return 1
}

clear_active_test_journal() {
	old_active_test_pgid="${recovery_active_test_pgid:-}"
	old_active_test_starttime="${recovery_active_test_starttime:-}"
	recovery_active_test_pgid=""
	recovery_active_test_starttime=""
	if ! write_recovery_journal; then
		recovery_active_test_pgid="$old_active_test_pgid"
		recovery_active_test_starttime="$old_active_test_starttime"
		return 1
	fi
	return 0
}

speedtest_supervisor_fail() {
	speedtest_supervisor_reason="$1"
	speedtest_supervisor_rc="${2:-1}"
	return "$speedtest_supervisor_rc"
}

finalize_speedtest_result() {
	final_destination="$1"
	final_test_rc="$2"
	final_timed_out="$3"

	if process_group_contains_session "$test_pid"; then
		speedtest_supervisor_fail descendant-remained 1
		return
	fi
	if ! clear_active_test_journal; then
		speedtest_supervisor_fail journal-clear 1
		return
	fi
	if [ "$final_timed_out" = 1 ]; then
		speedtest_supervisor_fail timeout 124
		return
	fi
	if [ "$final_test_rc" -ne 0 ] 2>/dev/null; then
		speedtest_supervisor_fail "helper-exit:$final_test_rc" "$final_test_rc"
		return
	fi
	if ! owned_regular_file "$test_output"; then
		speedtest_supervisor_fail result-unsafe 1
		return
	fi
	final_size="$(wc -c < "$test_output" 2>/dev/null)"
	case "$final_size" in
		''|*[!0-9]*)
			speedtest_supervisor_fail result-size-unavailable 1
			return
			;;
	esac
	if [ "$final_size" -lt 2 ] || [ "$final_size" -gt 262144 ]; then
		speedtest_supervisor_fail result-size-invalid 1
		return
	fi
	final_payload="$(cat "$test_output" 2>/dev/null)" || {
		speedtest_supervisor_fail result-read 1
		return
	}
	if ! strict_single_json_object "$final_payload"; then
		speedtest_supervisor_fail result-malformed 1
		return
	fi
	[ ! -L "$final_destination" ] || {
		speedtest_supervisor_fail destination-unsafe 1
		return
	}
	rm -f "$final_destination"
	if ! mv "$test_output" "$final_destination" || ! owned_regular_file "$final_destination"; then
		speedtest_supervisor_fail result-publish 1
		return
	fi
	speedtest_supervisor_reason=ok
	speedtest_supervisor_rc=0
	return 0
}

run_speedtest_with_timeout() {
	# Keep every speedtest-go phase on the server selected by the first
	# unshaped sample.  The helper's automatic validation may otherwise pick a
	# different server under a deliberately shaped low-rate validation run,
	# making the throughput and latency comparison invalid.
	speedtest_destination="$1"
	shift
	speedtest_supervisor_reason=precondition
	speedtest_supervisor_rc=1
	[ "${recovery_prepared:-0}" = 1 ] && [ "${recovery_armed:-0}" = 1 ] &&
		[ -f "$recovery_journal" ] && [ -e "$recovery_heartbeat" ] || {
			speedtest_supervisor_fail recovery-not-armed 1
			return
		}
	setsid_bin="$(command -v setsid 2>/dev/null)"
	[ -n "$setsid_bin" ] || {
		speedtest_supervisor_fail setsid-unavailable 1
		return
	}
	test_timeout_s="${CAKE_AUTORATE_AUTOTUNE_SPEEDTEST_TIMEOUT_S:-90}"
	test_termination_grace_s="${CAKE_AUTORATE_AUTOTUNE_SPEEDTEST_TERM_GRACE_S:-3}"
	case "$test_timeout_s" in ''|*[!0-9]*) test_timeout_s=90 ;; esac
	case "$test_termination_grace_s" in ''|*[!0-9]*) test_termination_grace_s=3 ;; esac
	[ "$test_timeout_s" -ge 1 ] 2>/dev/null || test_timeout_s=90
	[ "$test_timeout_s" -le 300 ] 2>/dev/null || test_timeout_s=300
	[ "$test_termination_grace_s" -ge 1 ] 2>/dev/null || test_termination_grace_s=3
	[ "$test_termination_grace_s" -le 10 ] 2>/dev/null || test_termination_grace_s=10
	test_output="$job_dir/speedtest-phase.raw"
	rm -f "$test_output" "$speedtest_destination"
	launch_parent_group="$(proc_group "$$" 2>/dev/null)"
	launch_parent_session="$(proc_session "$$" 2>/dev/null)"
	if [ "$backend" = "speedtest-go" ] && is_positive_uint "${selected_server_id:-}"; then
		CAKE_AUTORATE_SPEEDTEST_GO_SERVER_ID="$selected_server_id" \
		CAKE_AUTORATE_SPEEDTEST_START_STOPPED=1 CAKE_AUTORATE_SPEEDTEST_SETSID="$setsid_bin" \
			"$speedtest_bin" "$@" > "$test_output" &
	else
		CAKE_AUTORATE_SPEEDTEST_START_STOPPED=1 CAKE_AUTORATE_SPEEDTEST_SETSID="$setsid_bin" \
			"$speedtest_bin" "$@" > "$test_output" &
	fi
	test_pid="$!"
	test_starttime="$(proc_starttime "$test_pid" 2>/dev/null)"
	is_positive_uint "$test_starttime" || {
		kill -KILL "$test_pid" 2>/dev/null || true
		wait "$test_pid" 2>/dev/null || true
		speedtest_supervisor_fail launch-identity 1
		return
	}
	test_stopped=0
	identity_attempt=0
	while [ "$identity_attempt" -lt 5 ]; do
		if [ "$(proc_starttime "$test_pid" 2>/dev/null)" = "$test_starttime" ] &&
		   [ "$(proc_state "$test_pid" 2>/dev/null)" = T ] &&
		   [ "$(proc_group "$test_pid" 2>/dev/null)" = "$launch_parent_group" ] &&
		   [ "$(proc_session "$test_pid" 2>/dev/null)" = "$launch_parent_session" ] &&
		   speedtest_identity_matches "$test_pid" "$test_starttime"; then
			test_stopped=1
			break
		fi
		[ "$(proc_state "$test_pid" 2>/dev/null)" = Z ] && break
		kill -0 "$test_pid" 2>/dev/null || break
		identity_attempt=$((identity_attempt + 1))
		sleep 1
	done
	if [ "$test_stopped" != 1 ]; then
		[ "$(proc_starttime "$test_pid" 2>/dev/null)" = "$test_starttime" ] &&
			kill -KILL "$test_pid" 2>/dev/null || true
		wait "$test_pid" 2>/dev/null || true
		speedtest_supervisor_fail launch-stopped-handshake 1
		return
	fi
	recovery_active_test_pgid="$test_pid"
	recovery_active_test_starttime="$test_starttime"
	if ! write_recovery_journal; then
		kill -KILL "$test_pid" 2>/dev/null || true
		wait "$test_pid" 2>/dev/null || true
		speedtest_supervisor_fail journal-publish 1
		return
	fi
	[ "$(proc_starttime "$test_pid" 2>/dev/null)" = "$test_starttime" ] &&
		[ "$(proc_state "$test_pid" 2>/dev/null)" = T ] &&
		[ "$(proc_group "$test_pid" 2>/dev/null)" = "$launch_parent_group" ] &&
		[ "$(proc_session "$test_pid" 2>/dev/null)" = "$launch_parent_session" ] &&
		speedtest_identity_matches "$test_pid" "$test_starttime" || {
			[ "$(proc_starttime "$test_pid" 2>/dev/null)" = "$test_starttime" ] &&
				kill -KILL "$test_pid" 2>/dev/null || true
			wait "$test_pid" 2>/dev/null || true
			if process_group_contains_session "$test_pid"; then
				speedtest_supervisor_fail descendant-remained 1
				return
			fi
			if ! clear_active_test_journal; then
				speedtest_supervisor_fail journal-clear 1
				return
			fi
			speedtest_supervisor_fail identity-before-resume 1
			return
		}
	kill -CONT "$test_pid" 2>/dev/null || {
			[ "$(proc_starttime "$test_pid" 2>/dev/null)" = "$test_starttime" ] &&
			kill -KILL "$test_pid" 2>/dev/null || true
		wait "$test_pid" 2>/dev/null || true
		if process_group_contains_session "$test_pid"; then
			speedtest_supervisor_fail descendant-remained 1
			return
		fi
		if ! clear_active_test_journal; then
			speedtest_supervisor_fail journal-clear 1
			return
		fi
		speedtest_supervisor_fail resume 1
		return
	}
	test_group_verified=0
	transition_attempt=0
	while [ "$transition_attempt" -lt 5 ]; do
		test_state="$(proc_state "$test_pid" 2>/dev/null)"
		case "$test_state" in ''|Z|z) break ;; esac
		if speedtest_identity_matches "$test_pid" "$test_starttime" &&
		   [ "$(proc_group "$test_pid" 2>/dev/null)" = "$test_pid" ] &&
		   [ "$(proc_session "$test_pid" 2>/dev/null)" = "$test_pid" ]; then
			test_group_verified=1
			break
		fi
		transition_attempt=$((transition_attempt + 1))
		sleep 1
	done
	if [ "$test_group_verified" != 1 ]; then
		test_state="$(proc_state "$test_pid" 2>/dev/null)"
		case "$test_state" in
			''|Z|z)
				if wait "$test_pid" 2>/dev/null; then test_rc=0; else test_rc="$?"; fi
				finalize_speedtest_result "$speedtest_destination" "$test_rc" 0
				return
				;;
			*)
				# The child never completed its verified setsid transition.  It is
				# still an exact child in the owner group, so kill only that PID;
				# never enter an unbounded wait and never clear the journal until
				# absence of a separately created group has been proved.
				if [ "$(proc_starttime "$test_pid" 2>/dev/null)" = "$test_starttime" ]; then
					kill -KILL "$test_pid" 2>/dev/null || true
				fi
				wait "$test_pid" 2>/dev/null || true
				if process_group_contains_session "$test_pid"; then
					speedtest_supervisor_fail descendant-remained 1
					return
				fi
				if ! clear_active_test_journal; then
					speedtest_supervisor_fail journal-clear 1
					return
				fi
				speedtest_supervisor_fail setsid-transition 1
				return
				;;
		esac
	fi

	timed_out=0
	elapsed_seconds=0
	while process_group_contains_session "$test_pid"; do
		if [ "$elapsed_seconds" -ge "$test_timeout_s" ]; then
			timed_out=1
			signal_test_group_until_gone "$test_pid" "$test_starttime" || {
				speedtest_supervisor_fail termination-failed 1
				return
			}
			break
		fi
		if [ -d "/proc/$test_pid" ] &&
		   [ "$(proc_starttime "$test_pid" 2>/dev/null)" = "$test_starttime" ] &&
		   ! speedtest_identity_matches "$test_pid" "$test_starttime"; then
			signal_test_group_until_gone "$test_pid" "$test_starttime" || true
			speedtest_supervisor_fail identity-mismatch 1
			return
		fi
		elapsed_seconds=$((elapsed_seconds + 1))
		sleep 1
	done
	if wait "$test_pid"; then test_rc=0; else test_rc="$?"; fi
	finalize_speedtest_result "$speedtest_destination" "$test_rc" "$timed_out"
}

baseline_latency() {
	reflectors="$1"
	values="$job_dir/baseline.values"
	sorted="$job_dir/baseline.sorted"
	output="$job_dir/baseline.raw"
	: > "$values"

	[ -n "$fping_bin" ] || return 1
	[ -n "$reflectors" ] || reflectors="1.1.1.1 9.9.9.9"
	# fping writes summary output to stderr.  -C gives each individual RTT,
	# which is preferable to estimating p95 from only min/avg/max.
	case $- in *f*) baseline_had_noglob=1 ;; *) baseline_had_noglob=0; set -f ;; esac
	set -- $reflectors
	[ "$baseline_had_noglob" = 1 ] || set +f
	route_exec "$fping_bin" -I "$target_if" -C 5 -p 1000 -q -- "$@" > /dev/null 2> "$output" || true
	# A large total is not enough: one fast reflector could otherwise hide two
	# dead or heavily lossy families.  Require an independently useful baseline
	# (at least three successful RTTs) from every selected reflector.
	build_icmp_evidence "$output" "$reflectors" \
		"$job_dir/icmp-baseline-reflectors.tsv" baseline 5 3 || return 1
	awk '
		{
			if (!match($0, /[[:space:]]+:[[:space:]]+/)) next
			rest = substr($0, RSTART + RLENGTH)
			n = split(rest, fields, /[[:space:]]+/)
			for (i = 1; i <= n; i++)
				if (fields[i] ~ /^[0-9]+([.][0-9]+)?$/) print fields[i]
		}
	' "$output" > "$values"
	[ -s "$values" ] || return 1
	sort -n "$values" > "$sorted"
	awk '
		{ value[NR] = $1 }
		END {
			if (NR < 1) exit 1
			if (NR % 2) median = value[(NR + 1) / 2]
			else median = (value[NR / 2] + value[NR / 2 + 1]) / 2
			p95_index = int((NR * 95 + 99) / 100)
			if (p95_index < 1) p95_index = 1
			printf "%.3f %.3f %d", median, value[p95_index], NR
		}
	' "$sorted"
}

preflight() {
	write_status preflight 5 "Checking interface, route, test backend, and helper availability"
	[ -r "$runtime_lock_lib" ] && command -v runtime_lock_acquire_interface >/dev/null 2>&1 ||
		fail "The shared CAKE/SQM runtime-lock helper is unavailable."
	[ -x "$speedtest_bin" ] || fail "Speed test helper is not installed."
	[ -x "$pinger_plan_bin" ] || fail "Reflector planner is not installed."
	[ -x "$daemon_bin" ] || fail "cake-autorated is not installed."
	[ -n "$jsonfilter_bin" ] || fail "jsonfilter is required for Full Auto-Tune."
	[ -n "$fping_bin" ] || fail "fping is required for Full Auto-Tune latency validation."
	[ -x "$transport_probe_bin" ] || fail "The native transport probe helper is required for Full Auto-Tune latency validation."
	configure_transport_probe || fail "$transport_probe_configuration_error"

	if [ "${CAKE_AUTORATE_AUTOTUNE_TEST_PREFLIGHT:-0}" = 1 ]; then
		# Test-only injection: LuCI/rpcd does not pass caller-controlled
		# environment variables, so production cannot bypass these gates.
		target_if="$target_if_input"
		source_ip="192.0.2.1"
		route_if="$target_if"
		route_mode=main
		mwan3_member=""
		route_mark=""
		route_table="main"
		route_identity="main||$route_if|$source_ip||main"
		calibration_route_identity="$route_identity"
		link_kind="${CAKE_AUTORATE_AUTOTUNE_TEST_LINK_KIND:-cellular}"
	else
		target_if="$(resolve_interface_device "$target_if_input")" ||
			fail "Target interface $target_if_input does not resolve to an active device."
		operstate="$(sed -n '1p' "/sys/class/net/$target_if/operstate" 2>/dev/null)"
		case "$operstate" in
			up|unknown) ;;
			*) fail "Target interface $target_if is not up (state: ${operstate:-missing})." ;;
		esac
		inspect_autotune_route ||
			fail "Selected route is offline, mismatched, or cannot be forced through $target_if."
		calibration_route_identity="$route_identity"
		link_kind="$(detect_link_kind "$target_if" "$target_if_input")"
	fi
	preflight_sqm_ownership

	requested_backend="$backend"
	status_backend="$requested_backend"
	# Full Auto-Tune needs one server that can be pinned across unshaped and
	# directional shaped phases. Generic speedtest `auto` may prefer
	# librespeed-cli first, so deliberately resolve the supported pinnable
	# backend instead of selecting one and rejecting it afterwards.
	[ "$requested_backend" = auto ] && status_backend=speedtest-go
	backend_status="$($speedtest_bin "$job_name" "$target_if" status "$status_backend" 2>/dev/null)"
	backend_available="$(extract_json "$backend_status" '@.available')"
	[ "$backend_available" = true ] || fail "No usable speed test backend is available."
	resolved_backend="$(extract_json "$backend_status" '@.selected_backend')"
	case "$resolved_backend" in
		speedtest-go) ;;
		'') fail "The speed test helper did not resolve $status_backend to a concrete backend." ;;
		*) fail "Full Auto-Tune requires a backend with a pinnable, verifiable server identity; $resolved_backend cannot currently prove comparable multi-phase samples." ;;
	esac
	backend="$resolved_backend"
	preflight_phase_accounting
	conflicting_instance="$(autorate_conflict_for_target 2>/dev/null || true)"
	[ -z "$conflicting_instance" ] ||
		fail "Enabled autorate instance $conflicting_instance already owns $target_if. Tune that instance instead of creating a duplicate."
}

speedtest_supervisor_json() {
	if [ -z "${speedtest_supervisor_reason:-}" ] || [ "$speedtest_supervisor_reason" = ok ]; then
		printf 'null'
		return
	fi
	supervisor_raw_available=false
	supervisor_raw_bytes=0
	if [ -n "${test_output:-}" ] && owned_regular_file "$test_output"; then
		supervisor_raw_available=true
		supervisor_raw_bytes="$(wc -c < "$test_output" 2>/dev/null)"
		case "$supervisor_raw_bytes" in ''|*[!0-9]*) supervisor_raw_bytes=0 ;; esac
	fi
	printf '{"reason":"%s","exit_code":%s,"raw_available":%s,"raw_bytes":%s}' \
		"$(json_escape "$speedtest_supervisor_reason")" \
		"${speedtest_supervisor_rc:-1}" "$supervisor_raw_available" "$supervisor_raw_bytes"
}

fail() {
	message="$1"
	if [ -e "$cancel_file" ]; then
		exit 130
	fi
	stage_terminal_json error "{\"state\":\"failed\",\"schema_version\":5,\"stage\":\"$(json_escape "${current_phase:-unknown}")\",\"error\":\"$(json_escape "$message")\",\"speedtest_supervisor\":$(speedtest_supervisor_json),\"auto_apply_eligible\":false,\"manual_apply_eligible\":false,\"phase_evidence_complete\":${phase_evidence_complete:-false},\"phase_contamination_seen\":${phase_contamination_seen:-false},\"route\":$(route_diagnostics_json),\"background\":$(background_json),\"baseline\":$(baseline_diagnostics_json),\"runs\":[${runs_json:-}],\"phase_background\":[${phase_background_runs_json:-}],\"validation_attempts\":[${validation_attempts_json:-}],\"validation\":${validation_json:-null},\"pinger_plan\":${pinger_plan:-null},\"proposal\":${proposal:-null},\"configuration_written\":false}"
	exit 1
}

measurement_inconclusive() {
	measurement_stage="$1"
	measurement_reason="$2"
	stage_terminal_json error "{\"state\":\"inconclusive\",\"schema_version\":5,\"stage\":\"$(json_escape "$measurement_stage")\",\"error\":\"Measurement evidence remained invalid after a bounded retry; no candidate was accepted.\",\"reason\":\"$(json_escape "$measurement_reason")\",\"retryable\":true,\"auto_apply_eligible\":false,\"manual_apply_eligible\":false,\"phase_evidence_complete\":false,\"phase_contamination_seen\":${phase_contamination_seen:-false},\"route\":$(route_diagnostics_json),\"background\":$(background_json),\"baseline\":$(baseline_diagnostics_json),\"runs\":[${runs_json:-}],\"phase_background\":[${phase_background_runs_json:-}],\"validation_attempts\":[${validation_attempts_json:-}],\"pinger_plan\":${pinger_plan:-null},\"proposal\":${proposal:-null},\"configuration_written\":false}"
	exit 1
}

run_measurement() {
	index="$1"
	measurement_attempt=1
	while [ "$measurement_attempt" -le 2 ]; do
		write_status throughput "$((30 + index * 20))" "Running unshaped throughput sample $index of 2 (attempt $measurement_attempt)"
		phase_background_kind=unshaped
		start_phase_background_counter "$(configured_rate dl)" "$(configured_rate ul)"
		fair_control_this_attempt=0
		if [ "$autotune_profile" = fair ] && [ "$index" -eq 2 ]; then
			if start_fair_control_monitors "$measurement_attempt"; then
				fair_control_this_attempt=1
			else
				fair_control_json='{"available":false,"measurement_evidence":{"valid":false,"reason":"control-monitor-start-failed"}}'
			fi
		fi
		measurement_result_file="$job_dir/unshaped-$index-$measurement_attempt.result"
		if ! run_speedtest_with_timeout "$measurement_result_file" \
			"$job_name" "$target_if" run "$backend" "" "$route_mode" "$mwan3_member"; then
			[ "$fair_control_this_attempt" -eq 0 ] ||
				stop_fair_control_monitors >/dev/null 2>&1 || true
			stop_phase_background_counter
			fail "Throughput sample $index failed in the speed-test supervisor (${speedtest_supervisor_reason:-unknown})."
		fi
		result="$(cat "$measurement_result_file" 2>/dev/null)"
		rm -f "$measurement_result_file"
		if [ "$fair_control_this_attempt" -eq 1 ] &&
		   ! stop_fair_control_monitors; then
			fair_control_json='{"available":false,"measurement_evidence":{"valid":false,"reason":"control-monitor-stop-failed"}}'
			fair_control_this_attempt=0
		fi
		stop_phase_background_counter
		if [ "$fair_control_this_attempt" -eq 1 ]; then
			evaluate_fair_control "$result"
		fi
		result_backend="$(extract_json "$result" '@.backend')"
		[ "$result_backend" = "$backend" ] ||
			fail "Speed test backend changed from $backend to ${result_backend:-unknown} during unshaped sample $index."
		download="$(extract_json "$result" '@.download_kbps')"
		upload="$(extract_json "$result" '@.upload_kbps')"
		phase_entry="{\"phase\":\"unshaped\",\"sample\":$index,\"attempt\":$measurement_attempt,\"measured\":{\"download_kbps\":${download:-0},\"upload_kbps\":${upload:-0}},\"forwarded_background\":$(phase_background_json)}"
		if [ -n "${phase_background_runs_json:-}" ]; then
			phase_background_runs_json="$phase_background_runs_json,$phase_entry"
		else
			phase_background_runs_json="$phase_entry"
		fi
		if [ "$phase_background_contaminated" != true ]; then
			break
		fi
		phase_contamination_seen=true
		if [ "$measurement_attempt" -ge 2 ]; then
			if [ "$phase_background_available" != true ]; then
				fail "Forwarded-traffic evidence was unavailable for both attempts of unshaped sample $index."
			fi
			if [ "${conservative_mode:-0}" = 1 ]; then
				break
			fi
			stage_terminal_json error "{\"state\":\"background-blocked\",\"schema_version\":5,\"error\":\"Forwarded WAN traffic contaminated both attempts of unshaped sample $index. Retry when quiet or explicitly continue conservatively.\",\"background_blocked\":true,\"retryable\":true,\"stage\":\"throughput\",\"auto_apply_eligible\":false,\"manual_apply_eligible\":false,\"phase_evidence_complete\":${phase_evidence_complete:-false},\"phase_contamination_seen\":true,\"route\":$(route_diagnostics_json),\"background\":$(background_json),\"baseline\":$(baseline_diagnostics_json),\"runs\":[${runs_json:-}],\"phase_background\":[$phase_background_runs_json],\"pinger_plan\":${pinger_plan:-null},\"configuration_written\":false}"
			exit 1
		fi
		measurement_attempt=$((measurement_attempt + 1))
	done
	download="$(extract_json "$result" '@.download_kbps')"
	upload="$(extract_json "$result" '@.upload_kbps')"
	is_positive_uint "$download" || fail "Throughput sample $index returned no download rate."
	is_positive_uint "$upload" || fail "Throughput sample $index returned no upload rate."
	server_id="$(extract_json "$result" '@.server_id')"
	is_positive_uint "$server_id" || fail "The pinned speedtest-go server identity was missing from throughput sample $index."
	result_route_identity="$(extract_json "$result" '@.route_mode')|$(extract_json "$result" '@.mwan3_member')|$(extract_json "$result" '@.route_interface')|$(extract_json "$result" '@.route_source_ip')|$(extract_json "$result" '@.route_fwmark')|$(extract_json "$result" '@.route_table')"
	[ "$result_route_identity" = "$calibration_route_identity" ] ||
		fail "WAN route identity changed between Full Auto-Tune phases."
	result_external_ip="$(extract_json "$result" '@.external_ip_after')"
	[ -n "$result_external_ip" ] || fail "Throughput sample $index returned no routed external IP."
	if [ "$index" -eq 1 ]; then
		selected_server_id="$server_id"
		selected_external_ip="$result_external_ip"
	elif [ -n "$selected_server_id" ] && [ "$server_id" != "$selected_server_id" ]; then
		fail "Speed test server changed during raw calibration; retry for comparable samples."
	fi
	[ "$result_external_ip" = "$selected_external_ip" ] ||
		fail "External IP changed between Full Auto-Tune throughput samples."
	if [ -n "$download_samples" ]; then
		download_samples="$download_samples,$download"
		upload_samples="$upload_samples,$upload"
		runs_json="$runs_json,$result"
	else
		download_samples="$download"
		upload_samples="$upload"
		runs_json="$result"
	fi
}

calculate_proposal() {
	dl_base_scale="${1:-1.0}"
	ul_base_scale="${2:-$dl_base_scale}"
	if [ "${conservative_mode:-0}" = 1 ]; then
		"$daemon_bin" --autotune-proposal \
			--dl-samples "$download_samples" \
			--ul-samples "$upload_samples" \
			--idle-median-ms "$idle_median_ms" \
			--idle-p95-ms "$idle_p95_ms" \
			--idle-samples "$baseline_samples" \
			--link-kind "$link_kind" \
			--profile "$autotune_profile" \
			--dl-base-scale "$dl_base_scale" \
			--ul-base-scale "$ul_base_scale" \
			--conservative-background-dl-kbps "${background_dl_kbps:-0}" \
			--conservative-background-ul-kbps "${background_ul_kbps:-0}" \
			--retain-dl "$([ "$background_dl_usable" = true ] && printf 0 || printf 1)" \
			--retain-ul "$([ "$background_ul_usable" = true ] && printf 0 || printf 1)" \
			--current-dl-min-kbps "${current_dl_min:-0}" \
			--current-dl-base-kbps "${current_dl_base:-0}" \
			--current-dl-max-kbps "${current_dl_max:-0}" \
			--current-dl-cap-kbps "${current_dl_cap:-0}" \
			--current-ul-min-kbps "${current_ul_min:-0}" \
			--current-ul-base-kbps "${current_ul_base:-0}" \
			--current-ul-max-kbps "${current_ul_max:-0}" \
			--current-ul-cap-kbps "${current_ul_cap:-0}"
	else
		"$daemon_bin" --autotune-proposal \
			--dl-samples "$download_samples" \
			--ul-samples "$upload_samples" \
			--idle-median-ms "$idle_median_ms" \
			--idle-p95-ms "$idle_p95_ms" \
			--idle-samples "$baseline_samples" \
			--link-kind "$link_kind" \
			--profile "$autotune_profile" \
			--dl-base-scale "$dl_base_scale" \
			--ul-base-scale "$ul_base_scale"
	fi
}

stop_validation_monitors() {
	rm -f "${cpu_marker:-}" "${latency_marker:-}"
	monitors_stopped=1
	stop_transport_latency_monitor || monitors_stopped=0
	[ -z "${latency_pid:-}" ] ||
		stop_owned_monitor "$latency_pid" "${latency_starttime:-}" || monitors_stopped=0
	[ -z "${cpu_pid:-}" ] ||
		stop_owned_monitor "$cpu_pid" "${cpu_starttime:-}" || monitors_stopped=0
	latency_pid=""
	latency_starttime=""
	cpu_pid=""
	cpu_starttime=""
	[ "$monitors_stopped" = 1 ]
}

quality_grade_for_delta() {
	awk -v delta="$1" 'BEGIN {
		if (delta < 5) print "A+"
		else if (delta < 30) print "A"
		else if (delta < 60) print "B"
		else if (delta < 200) print "C"
		else if (delta < 400) print "D"
		else print "F"
	}'
}

quality_grade_rank() {
	case "$1" in
		A+) printf '0\n' ;;
		A) printf '1\n' ;;
		B) printf '2\n' ;;
		C) printf '3\n' ;;
		D) printf '4\n' ;;
		F) printf '5\n' ;;
		*) return 1 ;;
	esac
}

build_fair_outcome() {
	fair_outcome_mode="$1"
	fair_recommended_action=apply_sqm
	fair_disable_available=false
	fair_comparison_reason=quality-target-met
	fair_control_available="$(extract_json "$fair_control_json" '@.available' 2>/dev/null || true)"
	fair_control_dl_gain_percent=0
	fair_control_ul_gain_percent=0

	if [ "$fair_outcome_mode" = throughput-fallback ]; then
		fair_comparison_reason=quality-target-unreachable-above-throughput-floor
		if [ "$fair_control_available" = true ]; then
			fair_control_grade_value="$(extract_json "$fair_control_json" '@.grade')"
			fair_control_delta_value="$(extract_json "$fair_control_json" '@.effective_delta_ms')"
			fair_control_dl="$(extract_json "$fair_control_json" '@.throughput.download_kbps')"
			fair_control_ul="$(extract_json "$fair_control_json" '@.throughput.upload_kbps')"
			fair_control_background_available="$(extract_json "$fair_control_json" '@.forwarded_background.available')"
			fair_control_background_contaminated="$(extract_json "$fair_control_json" '@.forwarded_background.contaminated')"
			fair_control_background_dl="$(extract_json "$fair_control_json" '@.forwarded_background.download_kbps')"
			fair_control_background_ul="$(extract_json "$fair_control_json" '@.forwarded_background.upload_kbps')"
			fair_control_background_dl_limit="$(extract_json "$fair_control_json" '@.forwarded_background.download_limit_kbps')"
			fair_control_background_ul_limit="$(extract_json "$fair_control_json" '@.forwarded_background.upload_limit_kbps')"
			fair_shaped_rank="$(quality_grade_rank "$validation_actual_grade")" || fair_shaped_rank=99
			fair_control_rank="$(quality_grade_rank "$fair_control_grade_value")" || fair_control_rank=99
			fair_control_dl_gain_percent="$(awk -v control="$fair_control_dl" -v shaped="$shaped_dl" 'BEGIN {
				if (control <= 0 || shaped <= 0) { print 0; exit }
				printf "%.3f", (control / shaped - 1) * 100
			}')"
			fair_control_ul_gain_percent="$(awk -v control="$fair_control_ul" -v shaped="$shaped_ul" 'BEGIN {
				if (control <= 0 || shaped <= 0) { print 0; exit }
				printf "%.3f", (control / shaped - 1) * 100
			}')"
			if awk -v control_rank="$fair_control_rank" -v shaped_rank="$fair_shaped_rank" \
				-v control_delta="$fair_control_delta_value" -v shaped_delta="$effective_loaded_delta_ms" \
				-v dl_gain="$fair_control_dl_gain_percent" -v ul_gain="$fair_control_ul_gain_percent" \
				-v background_available="$fair_control_background_available" \
				-v background_contaminated="$fair_control_background_contaminated" \
				-v background_dl="$fair_control_background_dl" -v background_ul="$fair_control_background_ul" \
				-v background_dl_limit="$fair_control_background_dl_limit" \
				-v background_ul_limit="$fair_control_background_ul_limit" 'BEGIN {
					exit(!(background_available == "true" && background_contaminated == "false" &&
						background_dl ~ /^[0-9]+([.][0-9]+)?$/ &&
						background_ul ~ /^[0-9]+([.][0-9]+)?$/ &&
						background_dl_limit ~ /^[0-9]+([.][0-9]+)?$/ &&
						background_ul_limit ~ /^[0-9]+([.][0-9]+)?$/ &&
						background_dl <= background_dl_limit &&
						background_ul <= background_ul_limit &&
						control_rank <= shaped_rank &&
						control_delta <= shaped_delta + 10 &&
						dl_gain >= 2 && ul_gain >= 2))
				}'; then
				fair_outcome_mode=sqm-disable-recommended
				fair_recommended_action=disable_sqm
				fair_disable_available=true
				fair_comparison_reason=no-material-latency-benefit-with-throughput-cost
			fi
		fi
	fi

	fair_allowed_actions='"apply_sqm","keep_current"'
	[ "$fair_disable_available" = true ] &&
		fair_allowed_actions="$fair_allowed_actions,\"disable_sqm\""
	fair_outcome_json="{\"mode\":\"$(json_escape "$fair_outcome_mode")\",\"target_grade\":\"C\",\"target_delta_ms\":200,\"capacity_floor_percent\":90,\"actual_grade\":\"$(json_escape "$validation_actual_grade")\",\"actual_effective_delta_ms\":$effective_loaded_delta_ms,\"recommended_action\":\"$fair_recommended_action\",\"allowed_actions\":[$fair_allowed_actions],\"disable_sqm_available\":$fair_disable_available,\"comparison_reason\":\"$(json_escape "$fair_comparison_reason")\",\"no_sqm_control\":$fair_control_json,\"throughput_gain_without_sqm\":{\"download_percent\":$fair_control_dl_gain_percent,\"upload_percent\":$fair_control_ul_gain_percent}}"
}

start_fair_control_monitors() {
	fair_control_attempt="$1"
	fair_control_active=1
	cpu_pid=""
	latency_pid=""
	transport_pid=""
	loaded_raw="$job_dir/fair-control-icmp-$fair_control_attempt.raw"
	latency_marker="$job_dir/fair-control-latency.running"
	transport_raw="$job_dir/fair-control-transport-$fair_control_attempt.raw"
	transport_values="$job_dir/fair-control-transport-$fair_control_attempt.values"
	transport_sorted="$job_dir/fair-control-transport-$fair_control_attempt.sorted"
	transport_errors="$job_dir/fair-control-transport-$fair_control_attempt.errors"
	cpu_values="$job_dir/fair-control-cpu-$fair_control_attempt.values"
	cpu_marker="$job_dir/fair-control-cpu.running"
	: > "$loaded_raw"
	: > "$transport_raw"
	: > "$transport_values"
	: > "$cpu_values"
	: > "$cpu_marker"
	: > "$latency_marker"

	if [ "${CAKE_AUTORATE_AUTOTUNE_TEST_SHAPER:-0}" = 1 ]; then
		if [ "${AUTOTUNE_MOCK_FAIR_CONTROL_BAD:-0}" = 1 ]; then
			fair_control_icmp_base=310
			fair_control_transport_raw='[310.0,320.0,330.0,340.0]'
		else
			fair_control_icmp_base=20
			fair_control_transport_raw='[20.0,22.0,23.0,24.0]'
		fi
		printf '%s\n' \
			"[1.00000] 1.1.1.1 : [0], 64 bytes, ${fair_control_icmp_base}.0 ms (${fair_control_icmp_base}.0 avg, 0% loss)" \
			"[1.10000] 9.9.9.9 : [0], 64 bytes, $((fair_control_icmp_base + 1)).0 ms ($((fair_control_icmp_base + 1)).0 avg, 0% loss)" \
			"[1.20000] 8.8.8.8 : [0], 64 bytes, $((fair_control_icmp_base + 2)).0 ms ($((fair_control_icmp_base + 2)).0 avg, 0% loss)" \
			"[2.00000] 1.1.1.1 : [1], 64 bytes, $((fair_control_icmp_base + 2)).0 ms ($((fair_control_icmp_base + 1)).0 avg, 0% loss)" \
			"[2.10000] 9.9.9.9 : [1], 64 bytes, $((fair_control_icmp_base + 3)).0 ms ($((fair_control_icmp_base + 2)).0 avg, 0% loss)" \
			"[2.20000] 8.8.8.8 : [1], 64 bytes, $((fair_control_icmp_base + 4)).0 ms ($((fair_control_icmp_base + 3)).0 avg, 0% loss)" \
			"[3.00000] 1.1.1.1 : [2], 64 bytes, $((fair_control_icmp_base + 4)).0 ms ($((fair_control_icmp_base + 2)).0 avg, 0% loss)" \
			"[3.10000] 9.9.9.9 : [2], 64 bytes, $((fair_control_icmp_base + 5)).0 ms ($((fair_control_icmp_base + 3)).0 avg, 0% loss)" \
			"[3.20000] 8.8.8.8 : [2], 64 bytes, $((fair_control_icmp_base + 6)).0 ms ($((fair_control_icmp_base + 4)).0 avg, 0% loss)" \
			"[4.00000] 1.1.1.1 : [3], 64 bytes, $((fair_control_icmp_base + 6)).0 ms ($((fair_control_icmp_base + 3)).0 avg, 0% loss)" \
			"[4.10000] 9.9.9.9 : [3], 64 bytes, $((fair_control_icmp_base + 7)).0 ms ($((fair_control_icmp_base + 4)).0 avg, 0% loss)" \
			"[4.20000] 8.8.8.8 : [3], 64 bytes, $((fair_control_icmp_base + 8)).0 ms ($((fair_control_icmp_base + 5)).0 avg, 0% loss)" > "$loaded_raw"
		printf '%s\n' 12.0 > "$cpu_values"
		printf '%s\n' \
			"{\"index\":1,\"backend\":\"$transport_probe_reported_backend\",\"endpoint\":\"$transport_probe_endpoint\",\"raw_ms\":$fair_control_transport_raw,\"trusted\":true,\"connection_reused\":true}" \
			"{\"index\":2,\"backend\":\"$transport_probe_reported_backend\",\"endpoint\":\"$transport_probe_endpoint\",\"raw_ms\":$fair_control_transport_raw,\"trusted\":true,\"connection_reused\":true}" \
			"{\"index\":3,\"backend\":\"$transport_probe_reported_backend\",\"endpoint\":\"$transport_probe_endpoint\",\"raw_ms\":$fair_control_transport_raw,\"trusted\":true,\"connection_reused\":true}" \
			"{\"index\":4,\"backend\":\"$transport_probe_reported_backend\",\"endpoint\":\"$transport_probe_endpoint\",\"raw_ms\":$fair_control_transport_raw,\"trusted\":true,\"connection_reused\":true}" > "$transport_raw"
	else
		cpu_monitor "$cpu_values" "$cpu_marker" &
		cpu_pid="$!"
		cpu_starttime="$(proc_starttime "$cpu_pid" 2>/dev/null)"
		is_positive_uint "$cpu_starttime" || {
			stop_validation_monitors >/dev/null 2>&1 || true
			fair_control_active=0
			return 1
		}
		start_transport_latency_monitor "$transport_raw" "$transport_errors" || {
			stop_validation_monitors >/dev/null 2>&1 || true
			fair_control_active=0
			return 1
		}
		icmp_latency_monitor "$loaded_raw" "$latency_marker" &
		latency_pid="$!"
		latency_starttime="$(proc_starttime "$latency_pid" 2>/dev/null)"
		is_positive_uint "$latency_starttime" || {
			stop_validation_monitors >/dev/null 2>&1 || true
			fair_control_active=0
			return 1
		}
	fi
	return 0
}

stop_fair_control_monitors() {
	[ "${fair_control_active:-0}" = 1 ] || return 0
	stop_validation_monitors || return 1
	fair_control_active=0
	return 0
}

evaluate_fair_control() {
	fair_control_result="$1"
	fair_control_valid=true
	fair_control_reason=ok
	fair_control_direction="$(extract_json "$fair_control_result" '@.test_direction')"
	fair_control_bypassed="$(extract_json "$fair_control_result" '@.shaper_bypassed')"
	fair_control_sqm_paused="$(extract_json "$fair_control_result" '@.sqm_paused')"
	if [ "$fair_control_direction" != both ]; then
		fair_control_valid=false
		fair_control_reason=control-direction-invalid
	elif [ "$fair_control_bypassed" != true ]; then
		fair_control_valid=false
		fair_control_reason=control-shaper-proof-invalid
	elif [ "$fair_control_sqm_paused" != true ] || [ "${temp_shaper_active:-0}" != 0 ]; then
		fair_control_valid=false
		fair_control_reason=control-sqm-proof-invalid
	fi
	fair_control_icmp_stats="$job_dir/fair-control-icmp-$fair_control_attempt.tsv"
	if [ "$fair_control_valid" = true ] &&
	   ! build_icmp_evidence "$loaded_raw" "$reflectors" "$fair_control_icmp_stats" loaded 3 3; then
		fair_control_valid=false
		fair_control_reason=control-icmp-insufficient
	elif [ "$fair_control_valid" = true ] &&
	     ! classify_loaded_icmp_evidence "$fair_control_icmp_stats" "$job_dir/icmp-baseline-reflectors.tsv"; then
		fair_control_valid=false
		fair_control_reason=control-icmp-inconsistent
	fi
	if [ "$fair_control_valid" = true ]; then
		fair_control_loaded="$(latency_stats "$loaded_raw")" || {
			fair_control_valid=false
			fair_control_reason=control-icmp-statistics
		}
	fi
	if [ "$fair_control_valid" = true ]; then
		set -- $fair_control_loaded
		fair_control_icmp_median_ms="$1"
		fair_control_icmp_p95_ms="$2"
		fair_control_icmp_max_ms="$3"
		fair_control_icmp_samples="$4"
		fair_control_loss_percent="$(packet_loss_percent "$loaded_raw")"
		[ -n "$fair_control_loss_percent" ] || {
			fair_control_valid=false
			fair_control_reason=control-loss-unavailable
		}
	fi
	if [ "$fair_control_valid" = true ] &&
	   ! validate_transport_evidence "$transport_raw" "$transport_values" 4 12; then
		fair_control_valid=false
		fair_control_reason="$transport_evidence_reason"
	fi
	if [ "$fair_control_valid" = true ]; then
		fair_control_transport="$(numeric_latency_stats "$transport_values" "$transport_sorted")" || {
			fair_control_valid=false
			fair_control_reason=control-transport-statistics
		}
	fi
	fair_control_cpu_peak="$(sort -n "$cpu_values" 2>/dev/null | tail -n 1)"
	if [ -z "$fair_control_cpu_peak" ]; then
		fair_control_valid=false
		fair_control_reason=control-cpu-unavailable
	fi
	if [ "$fair_control_valid" != true ]; then
		fair_control_json="{\"available\":false,\"measurement_evidence\":{\"valid\":false,\"reason\":\"$(json_escape "$fair_control_reason")\"}}"
		return 0
	fi
	set -- $fair_control_transport
	fair_control_transport_median_ms="$1"
	fair_control_transport_p95_ms="$2"
	fair_control_transport_max_ms="$3"
	fair_control_transport_samples="$4"
	fair_control_icmp_delta_ms="$(nonnegative_delta "$fair_control_icmp_p95_ms" "$idle_p95_ms")"
	fair_control_transport_delta_ms="$(nonnegative_delta "$fair_control_transport_p95_ms" "$transport_idle_p95_ms")"
	fair_control_effective_delta_ms="$(maximum_number "$fair_control_icmp_delta_ms" "$fair_control_transport_delta_ms")"
	fair_control_grade="$(quality_grade_for_delta "$fair_control_effective_delta_ms")"
	fair_control_json="{\"available\":true,\"measurement_evidence\":{\"valid\":true,\"reason\":\"ok\",\"test_direction\":\"both\",\"shaper_bypassed\":true,\"sqm_paused\":true},\"grade\":\"$(json_escape "$fair_control_grade")\",\"effective_delta_ms\":$fair_control_effective_delta_ms,\"throughput\":{\"download_kbps\":$(extract_json "$fair_control_result" '@.download_kbps'),\"upload_kbps\":$(extract_json "$fair_control_result" '@.upload_kbps')},\"icmp_latency\":{\"median_ms\":$fair_control_icmp_median_ms,\"p95_ms\":$fair_control_icmp_p95_ms,\"max_ms\":$fair_control_icmp_max_ms,\"idle_p95_ms\":$idle_p95_ms,\"delta_p95_ms\":$fair_control_icmp_delta_ms,\"samples\":$fair_control_icmp_samples,\"loss_percent\":$fair_control_loss_percent},\"transport_latency\":{\"backend\":\"$(json_escape "$transport_probe_backend")\",\"endpoint\":\"$(json_escape "$transport_probe_endpoint")\",\"median_ms\":$fair_control_transport_median_ms,\"p95_ms\":$fair_control_transport_p95_ms,\"max_ms\":$fair_control_transport_max_ms,\"idle_p95_ms\":$transport_idle_p95_ms,\"delta_p95_ms\":$fair_control_transport_delta_ms,\"samples\":$fair_control_transport_samples},\"cpu_peak_percent\":$fair_control_cpu_peak,\"forwarded_background\":$(phase_background_json)}"
}

run_validation_direction_phase() {
	phase_direction="$1"
	phase_validation_attempt="$2"
	phase_background_attempt=1
	while [ "$phase_background_attempt" -le 2 ]; do
		cpu_pid=""
		latency_pid=""
		transport_pid=""
		loaded_raw="$job_dir/loaded-$phase_direction-$phase_validation_attempt-$phase_background_attempt.raw"
		latency_marker="$job_dir/latency-$phase_direction.running"
		transport_raw="$job_dir/transport-loaded-$phase_direction-$phase_validation_attempt-$phase_background_attempt.raw"
		transport_values="$job_dir/transport-loaded-$phase_direction-$phase_validation_attempt-$phase_background_attempt.values"
		transport_sorted="$job_dir/transport-loaded-$phase_direction-$phase_validation_attempt-$phase_background_attempt.sorted"
		transport_errors="$job_dir/transport-loaded-$phase_direction-$phase_validation_attempt-$phase_background_attempt.errors"
		cpu_values="$job_dir/cpu-$phase_direction-$phase_validation_attempt-$phase_background_attempt.values"
		cpu_marker="$job_dir/cpu-$phase_direction.running"
		: > "$loaded_raw"
		: > "$transport_raw"
		: > "$transport_values"
		: > "$cpu_values"
		: > "$cpu_marker"
		: > "$latency_marker"

		if [ "${CAKE_AUTORATE_AUTOTUNE_TEST_SHAPER:-0}" = 1 ]; then
			printf '%s\n' \
				'[1.00000] 1.1.1.1 : [0], 64 bytes, 20.0 ms (20.0 avg, 0% loss)' \
				'[1.10000] 9.9.9.9 : [0], 64 bytes, 21.0 ms (21.0 avg, 0% loss)' \
				'[1.20000] 8.8.8.8 : [0], 64 bytes, 22.0 ms (22.0 avg, 0% loss)' \
				'[2.00000] 1.1.1.1 : [1], 64 bytes, 22.0 ms (21.0 avg, 0% loss)' \
				'[2.10000] 9.9.9.9 : [1], 64 bytes, 23.0 ms (22.0 avg, 0% loss)' \
				'[2.20000] 8.8.8.8 : [1], 64 bytes, 24.0 ms (23.0 avg, 0% loss)' \
				'[3.00000] 1.1.1.1 : [2], 64 bytes, 24.0 ms (22.0 avg, 0% loss)' \
				'[3.10000] 9.9.9.9 : [2], 64 bytes, 25.0 ms (23.0 avg, 0% loss)' \
				'[3.20000] 8.8.8.8 : [2], 64 bytes, 26.0 ms (24.0 avg, 0% loss)' \
				'[4.00000] 1.1.1.1 : [3], 64 bytes, 26.0 ms (23.0 avg, 0% loss)' \
				'[4.10000] 9.9.9.9 : [3], 64 bytes, 27.0 ms (24.0 avg, 0% loss)' \
				'[4.20000] 8.8.8.8 : [3], 64 bytes, 28.0 ms (25.0 avg, 0% loss)' > "$loaded_raw"
			if [ "${AUTOTUNE_MOCK_ICMP_RATE_LIMIT:-0}" = 1 ]; then
				printf '%s\n' '[5.00000] 1.1.1.1 : [4], timed out (NaN avg, 20% loss)' >> "$loaded_raw"
			fi
			if [ "${AUTOTUNE_MOCK_RC16:-0}" = 1 ] ||
			   [ "${AUTOTUNE_MOCK_FAIR_SHAPED_BAD:-0}" = 1 ]; then
				printf '%s\n' 53.2 > "$cpu_values"
				phase_test_transport_raw='[230.0,240.0,250.0,480.0]'
			else
				printf '%s\n' 12.0 > "$cpu_values"
				phase_test_transport_raw='[20.0,22.0,23.0,24.0]'
			fi
			printf '%s\n' \
				"{\"index\":1,\"backend\":\"$transport_probe_reported_backend\",\"endpoint\":\"$transport_probe_endpoint\",\"raw_ms\":$phase_test_transport_raw,\"trusted\":true,\"connection_reused\":true}" \
				"{\"index\":2,\"backend\":\"$transport_probe_reported_backend\",\"endpoint\":\"$transport_probe_endpoint\",\"raw_ms\":$phase_test_transport_raw,\"trusted\":true,\"connection_reused\":true}" \
				"{\"index\":3,\"backend\":\"$transport_probe_reported_backend\",\"endpoint\":\"$transport_probe_endpoint\",\"raw_ms\":$phase_test_transport_raw,\"trusted\":true,\"connection_reused\":true}" \
				"{\"index\":4,\"backend\":\"$transport_probe_reported_backend\",\"endpoint\":\"$transport_probe_endpoint\",\"raw_ms\":$phase_test_transport_raw,\"trusted\":true,\"connection_reused\":true}" > "$transport_raw"
		else
			cpu_monitor "$cpu_values" "$cpu_marker" &
			cpu_pid="$!"
			cpu_starttime="$(proc_starttime "$cpu_pid" 2>/dev/null)"
			is_positive_uint "$cpu_starttime" || fail "Unable to register the CPU monitor process."
			start_transport_latency_monitor "$transport_raw" "$transport_errors" ||
				fail "Unable to register the transport-latency monitor process."
			icmp_latency_monitor "$loaded_raw" "$latency_marker" &
			latency_pid="$!"
			latency_starttime="$(proc_starttime "$latency_pid" 2>/dev/null)"
			is_positive_uint "$latency_starttime" || fail "Unable to register the ICMP monitor process."
		fi

		write_status shaped 87 "Running $phase_direction-only validation phase $phase_validation_attempt on the pinned server (traffic check $phase_background_attempt)"
		phase_background_kind=shaped
		if ! temporary_shaper_owned; then
			stop_validation_monitors ||
				fail "A validation monitor could not be terminated; crash recovery remains armed."
			phase_evidence_complete=false
			measurement_inconclusive "shaped-$phase_direction" temporary-shaper-precondition-failed
		fi
		start_phase_background_counter "$dl_base" "$ul_base"
		phase_result_file="$job_dir/shaped-$phase_direction-$phase_validation_attempt-$phase_background_attempt.result"
		if ! run_speedtest_with_timeout "$phase_result_file" \
			"$job_name" "$target_if" run "$backend" shaped "$route_mode" "$mwan3_member" "$phase_direction"; then
			stop_phase_background_counter
			stop_validation_monitors ||
				fail "A validation monitor could not be terminated; crash recovery remains armed."
			fail "The $phase_direction-only shaped validation speed test failed in the supervisor (${speedtest_supervisor_reason:-unknown})."
		fi
		if ! temporary_shaper_owned; then
			stop_phase_background_counter
			stop_validation_monitors ||
				fail "A validation monitor could not be terminated; crash recovery remains armed."
			rm -f "$phase_result_file"
			phase_evidence_complete=false
			measurement_inconclusive "shaped-$phase_direction" temporary-shaper-postcondition-failed
		fi
		phase_result="$(cat "$phase_result_file" 2>/dev/null)"
		rm -f "$phase_result_file"
		stop_phase_background_counter
		stop_validation_monitors ||
			fail "A validation monitor could not be terminated; crash recovery remains armed."
		phase_backend="$(extract_json "$phase_result" '@.backend')"
		[ "$phase_backend" = "$backend" ] ||
			fail "Speed test backend changed from $backend to ${phase_backend:-unknown} during $phase_direction-only validation."
		phase_reported_direction="$(extract_json "$phase_result" '@.test_direction')"
		[ "$phase_reported_direction" = "$phase_direction" ] ||
			fail "Speed test helper reported ${phase_reported_direction:-no direction} for the requested $phase_direction-only validation phase."
		phase_shaper_bypassed="$(extract_json "$phase_result" '@.shaper_bypassed')"
		phase_sqm_paused="$(extract_json "$phase_result" '@.sqm_paused')"

		case "$phase_direction" in
			download) phase_achieved_kbps="$(extract_json "$phase_result" '@.download_kbps')" ;;
			upload) phase_achieved_kbps="$(extract_json "$phase_result" '@.upload_kbps')" ;;
		esac
		is_positive_uint "$phase_achieved_kbps" || fail "The $phase_direction-only validation returned no rate."

		phase_measurement_valid=true
		phase_measurement_reason=ok
		if [ "$phase_shaper_bypassed" != false ] || [ "$phase_sqm_paused" != false ]; then
			phase_measurement_valid=false
			phase_measurement_reason=shaped-shaper-proof-invalid
		fi
		phase_icmp_stats="$job_dir/icmp-loaded-$phase_direction-$phase_validation_attempt-$phase_background_attempt.tsv"
		if [ "$phase_measurement_valid" = true ] &&
		   ! build_icmp_evidence "$loaded_raw" "$reflectors" "$phase_icmp_stats" loaded 3 3; then
			phase_measurement_valid=false
			phase_measurement_reason=icmp-insufficient-per-reflector-samples
		elif [ "$phase_measurement_valid" = true ] &&
		     ! classify_loaded_icmp_evidence "$phase_icmp_stats" "$job_dir/icmp-baseline-reflectors.tsv"; then
			phase_measurement_valid=false
			case "$icmp_evidence_class" in
				rate-limit) phase_measurement_reason="icmp-rate-limit-suspected:$icmp_evidence_detail" ;;
				disagreement) phase_measurement_reason=icmp-reflector-family-disagreement ;;
				*) phase_measurement_reason=icmp-evidence-incomplete ;;
			esac
		fi
		if [ "$phase_measurement_valid" = true ]; then
			phase_loaded="$(latency_stats "$loaded_raw")" || {
				phase_measurement_valid=false
				phase_measurement_reason=icmp-no-aggregate-samples
			}
		fi
		if [ "$phase_measurement_valid" = true ]; then
			set -- $phase_loaded
			phase_loaded_median_ms="$1"
			phase_loaded_p95_ms="$2"
			phase_loaded_max_ms="$3"
			phase_loaded_samples="$4"
			phase_loss_percent="$(packet_loss_percent "$loaded_raw")"
			[ -n "$phase_loss_percent" ] || {
				phase_measurement_valid=false
				phase_measurement_reason=icmp-loss-unavailable
			}
		fi
		if [ "$phase_measurement_valid" = true ] &&
		   ! validate_transport_evidence "$transport_raw" "$transport_values" 4 12; then
			phase_measurement_valid=false
			phase_measurement_reason="$transport_evidence_reason"
		fi
		if [ "$phase_measurement_valid" = true ]; then
			phase_transport_loaded="$(numeric_latency_stats "$transport_values" "$transport_sorted")" || {
				phase_measurement_valid=false
				phase_measurement_reason=transport-statistics-unavailable
			}
		fi
		phase_cpu_peak="$(sort -n "$cpu_values" 2>/dev/null | tail -n 1)"
		if [ -z "$phase_cpu_peak" ]; then
			phase_measurement_valid=false
			phase_measurement_reason=cpu-samples-unavailable
		fi

		phase_entry="{\"phase\":\"shaped\",\"direction\":\"$phase_direction\",\"validation_attempt\":$phase_validation_attempt,\"attempt\":$phase_background_attempt,\"measured_kbps\":$phase_achieved_kbps,\"measurement_evidence\":{\"valid\":$phase_measurement_valid,\"reason\":\"$(json_escape "$phase_measurement_reason")\"},\"forwarded_background\":$(phase_background_json)}"
		if [ -n "${phase_background_runs_json:-}" ]; then
			phase_background_runs_json="$phase_background_runs_json,$phase_entry"
		else
			phase_background_runs_json="$phase_entry"
		fi
		if [ "$phase_measurement_valid" != true ]; then
			if [ "$phase_background_attempt" -lt 2 ]; then
				case "$phase_measurement_reason" in
					icmp-rate-limit-suspected:*)
						# Replacing a reflector here used to overwrite the accepted idle
						# baseline while the temporary shaper and loaded phase were active.
						# That can only reduce loaded-minus-idle delay and create a false
						# pass. A different reflector set requires a brand-new clean run.
						phase_evidence_complete=false
						measurement_inconclusive "shaped-$phase_direction" \
							"$phase_measurement_reason-restart-required"
						;;
				esac
				phase_background_attempt=$((phase_background_attempt + 1))
				continue
			fi
			phase_evidence_complete=false
			measurement_inconclusive "shaped-$phase_direction" "$phase_measurement_reason"
		fi

		set -- $phase_transport_loaded
		phase_transport_median_ms="$1"
		phase_transport_p95_ms="$2"
		phase_transport_max_ms="$3"
		phase_transport_samples="$4"
		phase_icmp_delta_ms="$(nonnegative_delta "$phase_loaded_p95_ms" "$idle_p95_ms")"
		phase_transport_delta_ms="$(nonnegative_delta "$phase_transport_p95_ms" "$transport_idle_p95_ms")"
		if [ "${AUTOTUNE_MOCK_RC16:-0}" = 1 ]; then
			phase_icmp_delta_ms=0.19
			phase_loss_percent=7.59
		fi
		phase_observation_json="{\"direction\":\"$phase_direction\",\"throughput_kbps\":$phase_achieved_kbps,\"measurement_evidence\":{\"valid\":true,\"reason\":\"ok\",\"transport_rows\":$transport_evidence_rows},\"icmp_latency\":{\"median_ms\":$phase_loaded_median_ms,\"p95_ms\":$phase_loaded_p95_ms,\"max_ms\":$phase_loaded_max_ms,\"idle_p95_ms\":$idle_p95_ms,\"delta_p95_ms\":$phase_icmp_delta_ms,\"samples\":$phase_loaded_samples,\"loss_percent\":$phase_loss_percent},\"transport_latency\":{\"backend\":\"$(json_escape "$transport_probe_backend")\",\"endpoint\":\"$(json_escape "$transport_probe_endpoint")\",\"median_ms\":$phase_transport_median_ms,\"p95_ms\":$phase_transport_p95_ms,\"max_ms\":$phase_transport_max_ms,\"idle_p95_ms\":$transport_idle_p95_ms,\"delta_p95_ms\":$phase_transport_delta_ms,\"samples\":$phase_transport_samples},\"cpu_peak_percent\":$phase_cpu_peak,\"forwarded_background\":$(phase_background_json),\"server_id\":\"$(json_escape "$(extract_json "$phase_result" '@.server_id')")\"}"
		if [ "$phase_background_contaminated" != true ]; then
			break
		fi
		phase_contamination_seen=true
		if [ "$phase_background_attempt" -lt 2 ]; then
			phase_background_attempt=$((phase_background_attempt + 1))
			continue
		fi
		if [ "${conservative_mode:-0}" != 1 ]; then
			stage_terminal_json error "{\"state\":\"background-blocked\",\"schema_version\":5,\"error\":\"Forwarded WAN traffic contaminated both $phase_direction-only shaped validation attempts. Retry when quiet or explicitly continue conservatively.\",\"background_blocked\":true,\"retryable\":true,\"stage\":\"shaped-$phase_direction\",\"auto_apply_eligible\":false,\"manual_apply_eligible\":false,\"phase_evidence_complete\":${phase_evidence_complete:-false},\"phase_contamination_seen\":true,\"route\":$(route_diagnostics_json),\"background\":$(background_json),\"baseline\":$(baseline_diagnostics_json),\"runs\":[${runs_json:-}],\"phase_background\":[$phase_background_runs_json],\"pinger_plan\":${pinger_plan:-null},\"proposal\":$proposal,\"configuration_written\":false}"
			exit 1
		fi
		if [ "$phase_background_available" != true ]; then
			fail "Forwarded-traffic evidence was unavailable for both $phase_direction-only validation attempts."
		fi
		validation_contaminated=true
		break
	done

	phase_server_id="$(extract_json "$phase_result" '@.server_id')"
	is_positive_uint "$phase_server_id" ||
		fail "The pinned speedtest-go server identity was missing during $phase_direction-only validation."
	if [ "$phase_server_id" != "$selected_server_id" ]; then
		fail "Speed test server changed during $phase_direction-only shaped validation."
	fi
	phase_route_identity="$(extract_json "$phase_result" '@.route_mode')|$(extract_json "$phase_result" '@.mwan3_member')|$(extract_json "$phase_result" '@.route_interface')|$(extract_json "$phase_result" '@.route_source_ip')|$(extract_json "$phase_result" '@.route_fwmark')|$(extract_json "$phase_result" '@.route_table')"
	[ "$phase_route_identity" = "$calibration_route_identity" ] ||
		fail "WAN route identity changed during $phase_direction-only shaped validation."
	[ "$(extract_json "$phase_result" '@.external_ip_after')" = "$selected_external_ip" ] ||
		fail "External IP changed during $phase_direction-only shaped validation."
}

run_shaped_validation() {
	validation_attempt="${1:-1}"
	config_fingerprint_matches || config_changed_inconclusive
	dl_base="$(extract_json "$proposal" '@.download.base_kbps')"
	ul_base="$(extract_json "$proposal" '@.upload.base_kbps')"
