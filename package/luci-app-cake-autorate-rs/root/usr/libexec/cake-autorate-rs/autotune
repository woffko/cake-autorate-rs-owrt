	recovery_active_test_pgid=""
	recovery_active_test_starttime=""
	recovery_nft_table=""
	cleanup_started=0
	phase_counter_created=0
	phase_background_runs_json=""
	phase_evidence_complete=false
	phase_contamination_seen=false
	config_fingerprint=""
	config_fingerprint_captured=false
	speedtest_supervisor_reason=""
	speedtest_supervisor_rc=0
	test_output=""
	current_phase=starting
	trap 'cancelled=1; exit 130' INT TERM
	trap 'worker_cleanup "$?"' EXIT
	[ -n "${autotune_profile:-}" ] || fail "Full Auto-Tune profile is missing."
	case "$worker_token" in ''|*[!A-Za-z0-9_-]*) fail "Full Auto-Tune worker identity token is missing or invalid." ;; esac
	registration_attempt=0
	worker_registered=false
	while [ "$registration_attempt" -lt 5 ]; do
		if [ -s "$pid_file" ]; then
			read_worker_identity
			if [ "$identity_pid" = "$$" ] && [ "$identity_token" = "$worker_token" ] &&
			   [ "$identity_starttime" = "$(proc_starttime "$$" 2>/dev/null)" ] &&
			   [ "$identity_target" = "$target_if_input" ] && [ "$identity_backend" = "$backend_input" ] &&
			   [ "$identity_route_mode" = "$route_mode_override" ] &&
			   [ "$identity_mwan3_member" = "$mwan3_member_override" ] &&
			   [ "$identity_profile" = "$autotune_profile" ] &&
			   [ "$identity_conservative" = "$conservative_mode" ]; then
				worker_registered=true
				break
			fi
		fi
		sleep 1
		registration_attempt=$((registration_attempt + 1))
	done
	[ "$worker_registered" = true ] || fail "Full Auto-Tune worker identity could not be registered safely."

	preflight
	configure_recovery_paths || fail "Unable to derive safe Full Auto-Tune recovery paths."
	configure_temp_shaper_identity || fail "Unable to derive a unique temporary shaper identity."
	configure_autotune_interface_lock_path || fail "Unable to derive a safe interface lock for $target_if."
	acquire_autotune_interface_lock
	capture_config_fingerprint
	prepare_recovery
	capture_recovery_sqm_snapshot || fail "Managed SQM changed before the exclusive calibration lock was acquired."
	write_recovery_journal || fail "Unable to publish the locked managed-SQM recovery snapshot."
	arm_recovery
	cleanup_stale_phase_background_tables || fail "Unable to remove stale Full Auto-Tune nftables counters for this job."
	pause_job_autorate
	write_status reflectors 15 "Selecting healthy latency reflectors"
	pinger_plan_candidate="$($pinger_plan_bin "$job_name" scan "" "$route_mode" "$mwan3_member" 2>/dev/null)" ||
		fail "Reflector scan failed."
	strict_single_json_object "$pinger_plan_candidate" || fail "Reflector planner returned malformed or empty JSON."
	rtt_candidates="$(extract_json "$pinger_plan_candidate" '@.rtt_reflectors[*]')"
	[ -n "$rtt_candidates" ] || rtt_candidates="$(extract_json "$pinger_plan_candidate" '@.recommended_reflectors[*]')"
	[ -n "$rtt_candidates" ] || fail "Reflector planner returned malformed or empty JSON."
	case $- in *f*) reflector_had_noglob=1 ;; *) reflector_had_noglob=0; set -f ;; esac
	reflectors="$(select_diverse_reflectors $rtt_candidates)"
	[ "$reflector_had_noglob" = 1 ] || set +f
	set -- $reflectors
	[ "$#" -ge 3 ] || fail "Fewer than three independent reflector families are reachable on the selected uplink."
	pinger_rtt_reflectors_json="$(reflectors_json_array "$@")" ||
		fail "Reflector planner returned an unsafe RTT reflector."
	pinger_method="$(extract_json "$pinger_plan_candidate" '@.recommended_method')" ||
		fail "Reflector planner returned no recommended method."
	case "$pinger_method" in fping|fping-ts|tsping|ping|irtt) ;; *) fail "Reflector planner returned an unsupported method." ;; esac
	pinger_count="$(extract_json "$pinger_plan_candidate" '@.recommended_no_pingers')" ||
		fail "Reflector planner returned no active-pinger count."
	is_positive_uint "$pinger_count" && [ "$pinger_count" -le 16 ] 2>/dev/null ||
		fail "Reflector planner returned an invalid active-pinger count."
	recommended_candidates="$(extract_json "$pinger_plan_candidate" '@.recommended_reflectors[*]')" ||
		fail "Reflector planner returned no recommended targets."
	[ -n "$recommended_candidates" ] || fail "Reflector planner returned no recommended targets."
	case $- in *f*) recommended_had_noglob=1 ;; *) recommended_had_noglob=0; set -f ;; esac
	set -- $recommended_candidates
	[ "$recommended_had_noglob" = 1 ] || set +f
	[ "$#" -ge "$pinger_count" ] 2>/dev/null || fail "Reflector planner returned fewer targets than active pingers."
	pinger_reflectors_json="$(pinger_targets_json_array "$pinger_method" "$@")" ||
		fail "Reflector planner returned an unsafe recommended target."
	# Reconstruct a bounded allowlisted object. Raw helper JSON, warnings, and
	# unrecognised fields are never spliced into a terminal result.
	pinger_plan="{\"recommended_method\":\"$(json_escape "$pinger_method")\",\"recommended_no_pingers\":$pinger_count,\"recommended_reflectors\":$pinger_reflectors_json,\"rtt_reflectors\":$pinger_rtt_reflectors_json,\"warnings\":[]}"
	case "$reflector_scan_cooldown_s" in
		''|*[!0-9]*) reflector_scan_cooldown_s=5 ;;
		*) [ "$reflector_scan_cooldown_s" -le 30 ] 2>/dev/null || reflector_scan_cooldown_s=5 ;;
	esac
	if [ "$reflector_scan_cooldown_s" -gt 0 ] 2>/dev/null; then
		write_status reflectors 17 "Allowing ICMP policers to recover after the paced reflector scan"
		sleep "$reflector_scan_cooldown_s"
	fi
	# Baseline and every following heavy phase must append an available nftables
	# observation. A missing/list/parse failure flips this false permanently.
	phase_evidence_complete=true
	capture_idle_baseline
	check_background_traffic

	download_samples=""
	upload_samples=""
	runs_json=""
	selected_server_id=""
	selected_external_ip=""
	fair_control_json=null
	fair_control_active=0
	run_measurement 1
	run_measurement 2

	write_status proposal 80 "Calculating safe initial limits and adaptive ceiling bounds"
	reference_proposal_candidate="$(calculate_proposal 1.0 1.0)" || fail "Autotune reference proposal calculation failed."
	proposal_json_valid "$reference_proposal_candidate" || fail "Autotune reference proposal returned malformed JSON."
	reference_proposal="$reference_proposal_candidate"
	reference_dl_base="$(extract_json "$reference_proposal" '@.download.base_kbps')"
	reference_ul_base="$(extract_json "$reference_proposal" '@.upload.base_kbps')"
	is_positive_uint "$reference_dl_base" || fail "Reference proposal returned no download base."
	is_positive_uint "$reference_ul_base" || fail "Reference proposal returned no upload base."
	if [ "$conservative_mode" = 1 ]; then
		proposal_candidate="$(calculate_proposal 0.85 0.85)" || fail "Conservative autotune proposal calculation failed."
		proposal_json_valid "$proposal_candidate" || fail "Conservative autotune proposal returned malformed JSON."
		proposal="$proposal_candidate"
	else
		proposal="$reference_proposal"
	fi
	configure_validation_thresholds ||
		fail "Autotune proposal returned an invalid or mismatched profile policy."

	validation_attempt_number=1
	validation_attempts_json=""
	measurement_retry_used=0
	rate_correction_used=0
	max_rate_corrections=1
	[ "$autotune_profile" = fair ] && max_rate_corrections=2
	fair_best_total=0
	fair_best_proposal=""
	fair_best_validation_json=""
	fair_outcome_json=null
	while [ "$validation_attempt_number" -le 3 ]; do
		run_shaped_validation "$validation_attempt_number"
		if [ -n "$validation_attempts_json" ]; then
			validation_attempts_json="$validation_attempts_json,$validation_json"
		else
			validation_attempts_json="$validation_json"
		fi
		if [ "$autotune_profile" = fair ] && [ "$validation_hard_pass" = true ]; then
			fair_candidate_total=$((shaped_dl + shaped_ul))
			if [ "$fair_candidate_total" -gt "$fair_best_total" ]; then
				fair_best_total="$fair_candidate_total"
				fair_best_proposal="$proposal"
				fair_best_validation_json="$validation_json"
				fair_best_shaped_dl="$shaped_dl"
				fair_best_shaped_ul="$shaped_ul"
				fair_best_loaded_delta_ms="$loaded_delta_ms"
				fair_best_transport_loaded_delta_ms="$transport_loaded_delta_ms"
				fair_best_effective_loaded_delta_ms="$effective_loaded_delta_ms"
				fair_best_loss_percent="$loss_percent"
				fair_best_cpu_peak="$cpu_peak"
				fair_best_actual_grade="$validation_actual_grade"
				fair_best_validation_contaminated="$validation_contaminated"
			fi
		fi
		[ "$validation_pass" = true ] && break

		case "$validation_correction_action" in
			retry-measurement)
				[ "$measurement_retry_used" -eq 0 ] || break
				measurement_retry_used=1
				write_status correction 90 "Repeating the same directional candidate because its achieved rate was not reliable"
				;;
			increase|decrease|mixed)
				[ "$validation_correction_feasible" = true ] || break
				[ "$rate_correction_used" -lt "$max_rate_corrections" ] || break
				rate_correction_used=$((rate_correction_used + 1))
				dl_revision_scale="$(scale_for_reference_base "$dl_correction_proposed_kbps" "$reference_dl_base")" ||
					fail "Unable to calculate the exact download correction scale."
				ul_revision_scale="$(scale_for_reference_base "$ul_correction_proposed_kbps" "$reference_ul_base")" ||
					fail "Unable to calculate the exact upload correction scale."
				write_status correction 91 "Applying one typed, direction-specific bounded correction"
				proposal_candidate="$(calculate_proposal "$dl_revision_scale" "$ul_revision_scale")" ||
					fail "Autotune direction-specific correction calculation failed."
				proposal_json_valid "$proposal_candidate" ||
					fail "Autotune direction-specific correction returned malformed JSON."
				proposal="$proposal_candidate"
				realized_dl_correction="$(extract_json "$proposal" '@.download.base_kbps')"
				realized_ul_correction="$(extract_json "$proposal" '@.upload.base_kbps')"
				[ "$realized_dl_correction" = "$dl_correction_proposed_kbps" ] &&
					[ "$realized_ul_correction" = "$ul_correction_proposed_kbps" ] ||
					fail "Proposal constraints could not realize the typed direction-specific correction exactly."
				;;
			infeasible|none|*) break ;;
		esac
		validation_attempt_number=$((validation_attempt_number + 1))
	done
	if [ "$validation_pass" != true ] && [ "$autotune_profile" = fair ] &&
	   [ -n "$fair_best_proposal" ]; then
		proposal="$fair_best_proposal"
		validation_json="$fair_best_validation_json"
		validation_hard_pass=true
		validation_quality_target_met=false
		validation_actual_grade="$fair_best_actual_grade"
		shaped_dl="$fair_best_shaped_dl"
		shaped_ul="$fair_best_shaped_ul"
		loaded_delta_ms="$fair_best_loaded_delta_ms"
		transport_loaded_delta_ms="$fair_best_transport_loaded_delta_ms"
		effective_loaded_delta_ms="$fair_best_effective_loaded_delta_ms"
		loss_percent="$fair_best_loss_percent"
		cpu_peak="$fair_best_cpu_peak"
		validation_contaminated="$fair_best_validation_contaminated"
		build_fair_outcome throughput-fallback
	elif [ "$validation_pass" = true ] && [ "$autotune_profile" = fair ]; then
		build_fair_outcome quality-target-met
	fi
	if [ "$validation_pass" != true ]; then
		if [ "$autotune_profile" = fair ] && [ "$validation_hard_pass" = true ]; then
			:
		elif [ "$validation_correction_action" = retry-measurement ]; then
			phase_evidence_complete=false
			measurement_inconclusive validation \
				"${validation_correction_reason:-candidate-realization-unreliable}-after-bounded-retry"
		else
			validation_error="Directional candidate validation failed (${validation_correction_action}: ${validation_correction_reason}; DL realization ${dl_candidate_realization}%, capacity ${dl_retention}%; UL realization ${ul_candidate_realization}%, capacity ${ul_retention}%; max ICMP +${loaded_delta_ms} ms, transport +${transport_loaded_delta_ms} ms, loss ${loss_percent}%, CPU ${cpu_peak}%); no configuration was written."
			stage_terminal_json error "{\"state\":\"failed\",\"schema_version\":5,\"stage\":\"validation\",\"error\":\"$(json_escape "$validation_error")\",\"auto_apply_eligible\":false,\"manual_apply_eligible\":false,\"phase_evidence_complete\":$phase_evidence_complete,\"phase_contamination_seen\":$phase_contamination_seen,\"route_mode\":\"$(json_escape "$route_mode")\",\"route_interface\":\"$(json_escape "$route_if")\",\"route_identity\":\"$(json_escape "$route_identity")\",\"external_ip\":\"$(json_escape "$selected_external_ip")\",\"background\":$(background_json),\"baseline\":{\"median_ms\":$idle_median_ms,\"p95_ms\":$idle_p95_ms,\"samples\":$baseline_samples,\"transport_median_ms\":$transport_idle_median_ms,\"transport_p95_ms\":$transport_idle_p95_ms,\"transport_samples\":$transport_idle_samples,\"transport_backend\":\"$(json_escape "$transport_probe_backend")\",\"transport_endpoint\":\"$(json_escape "$transport_probe_endpoint")\"},\"runs\":[$runs_json],\"phase_background\":[$phase_background_runs_json],\"validation_attempts\":[$validation_attempts_json],\"validation\":$validation_json,\"fair_outcome\":$fair_outcome_json,\"pinger_plan\":$pinger_plan,\"proposal\":$proposal,\"configuration_written\":false}"
			exit 1
		fi
	fi

	write_status review 96 "Preparing validated review; no configuration has been written"
	confidence_mode=normal
	[ "$conservative_mode" = 1 ] && confidence_mode=low
	auto_apply_eligible=false
	manual_apply_eligible=false
	if [ "$confidence_mode" = normal ] && [ "$phase_evidence_complete" = true ] &&
		[ "$phase_contamination_seen" = false ] && [ "$validation_contaminated" = false ]; then
		if [ "$autotune_profile" = fair ]; then
			[ "$validation_hard_pass" = true ] && manual_apply_eligible=true
			[ "$validation_pass" = true ] && [ "$validation_quality_target_met" = true ] &&
				auto_apply_eligible=true
		elif [ "$validation_pass" = true ]; then
			manual_apply_eligible=true
			auto_apply_eligible=true
		fi
	fi
	stage_terminal_json result "{\"state\":\"complete\",\"schema_version\":5,\"auto_apply_eligible\":$auto_apply_eligible,\"manual_apply_eligible\":$manual_apply_eligible,\"phase_evidence_complete\":$phase_evidence_complete,\"phase_contamination_seen\":$phase_contamination_seen,\"job_id\":\"$(json_escape "$job_name")\",\"target_interface\":\"$(json_escape "$target_if_input")\",\"resolved_interface\":\"$(json_escape "$target_if")\",\"source_ip\":\"$(json_escape "$source_ip")\",\"external_ip\":\"$(json_escape "$selected_external_ip")\",\"route_interface\":\"$(json_escape "$route_if")\",\"route_mode\":\"$(json_escape "$route_mode")\",\"mwan3_member\":\"$(json_escape "$mwan3_member")\",\"route_identity\":\"$(json_escape "$route_identity")\",\"link_kind\":\"$(json_escape "$link_kind")\",\"conservative\":$([ "$conservative_mode" = 1 ] && printf true || printf false),\"confidence_mode\":\"$confidence_mode\",\"background\":$(background_json),\"phase_background\":[$phase_background_runs_json],\"usable_directions\":{\"download\":${background_dl_usable:-true},\"upload\":${background_ul_usable:-true}},\"validation_thresholds\":{\"candidate_realization_min_percent\":$validation_candidate_realization_min_percent,\"candidate_realization_max_percent\":$validation_candidate_realization_max_percent,\"capacity_retention_min_percent\":$validation_capacity_retention_min_percent,\"delay_max_ms\":$validation_delay_max_ms,\"loss_max_percent\":$validation_loss_max_percent,\"cpu_max_percent\":$validation_cpu_max_percent},\"baseline\":{\"median_ms\":$idle_median_ms,\"p95_ms\":$idle_p95_ms,\"samples\":$baseline_samples,\"transport_median_ms\":$transport_idle_median_ms,\"transport_p95_ms\":$transport_idle_p95_ms,\"transport_samples\":$transport_idle_samples,\"transport_backend\":\"$(json_escape "$transport_probe_backend")\",\"transport_endpoint\":\"$(json_escape "$transport_probe_endpoint")\"},\"runs\":[$runs_json],\"validation_attempts\":[$validation_attempts_json],\"validation\":$validation_json,\"fair_outcome\":$fair_outcome_json,\"pinger_plan\":$pinger_plan,\"proposal\":$proposal,\"configuration_written\":false}"
}

job_recovery_pending() {
	recovery_scan_root="$job_root/recovery"
	for recovery_candidate in "$recovery_scan_root/${job_name}_"*.journal; do
		[ -f "$recovery_candidate" ] || continue
		return 0
	done
	return 1
}

start_job() {
	start_conservative="${1:-0}"
	setsid_bin="$(command -v setsid 2>/dev/null)"
	[ -n "$setsid_bin" ] || json_error "setsid is required for Full Auto-Tune."
	prepare_job_storage || json_error "Unsafe or foreign-owned Full Auto-Tune job directory."
	start_guard="$job_dir/start.guard"
	[ ! -L "$start_guard" ] || json_error "Unsafe Full Auto-Tune start lock."
	exec 6>>"$start_guard" || json_error "Unable to open the Full Auto-Tune start lock."
	start_flock_bin="${runtime_lock_flock_bin:-flock}"
	command -v "$start_flock_bin" >/dev/null 2>&1 || json_error "flock is required for Full Auto-Tune."
	"$start_flock_bin" 6 || json_error "Unable to serialize Full Auto-Tune startup."

	# A live registered worker owns its recovery journal by design.  Check it
	# before scanning journals so an idempotent second RPC returns current state
	# rather than misreporting the normal armed run as recovery-pending.
	if [ -s "$pid_file" ]; then
		if worker_identity_matches; then
			if worker_request_matches "$start_conservative"; then
				cat "$status_file" 2>/dev/null || printf '{"state":"running","phase":"starting","progress":0}\n'
				return 0
			fi
			json_error "A different Full Auto-Tune request is already running for this instance. Cancel it or wait for completion."
		fi
	fi
	job_recovery_pending && json_error "Full Auto-Tune recovery is still pending for $job_name; wait for runtime restoration before starting another test."

	archive_previous_terminal ||
		json_error "Unable to archive and bound the previous Full Auto-Tune diagnostics in RAM."
	new_token="$(new_worker_token)"
	active_run_id="$new_token"
	rm -f "$pid_file" "$status_file" "$result_file" "$error_file" "$pending_result_file" \
		"$pending_error_file" "$cancel_file" "$log_file"
	write_status starting 0 "Starting Full Auto-Tune"
	"$setsid_bin" "$0" "$job_name" "$target_if_input" job-run "$backend" "$route_mode_override" "$mwan3_member_override" "$autotune_profile" "$start_conservative" "$new_token" \
		</dev/null > "$log_file" 2>&1 6>&- &
	pid="$!"
	launch_attempt=0
	launch_starttime=""
	while [ "$launch_attempt" -lt 5 ]; do
		launch_starttime="$(proc_starttime "$pid" 2>/dev/null)"
		if is_positive_uint "$launch_starttime" &&
		   [ "$(proc_group "$pid")" = "$pid" ] &&
		   [ "$(proc_session "$pid")" = "$pid" ] &&
		   proc_cmdline_has_arg "$pid" job-run && proc_cmdline_has_arg "$pid" "$new_token"; then
			break
		fi
		kill -0 "$pid" 2>/dev/null || break
		sleep 1
		launch_attempt=$((launch_attempt + 1))
	done
	if ! is_positive_uint "$launch_starttime" ||
	   [ "$(proc_group "$pid" 2>/dev/null)" != "$pid" ] ||
	   [ "$(proc_session "$pid" 2>/dev/null)" != "$pid" ] ||
	   ! proc_cmdline_has_arg "$pid" "$new_token"; then
		[ -n "$launch_starttime" ] && [ "$(proc_starttime "$pid" 2>/dev/null)" = "$launch_starttime" ] &&
			kill -TERM "$pid" 2>/dev/null || true
		json_error "Unable to establish an isolated Full Auto-Tune worker process group."
	fi
	worker_identity="$(printf '%s\n%s\n%s\n%s\n%s\n%s\n%s\n%s\n%s' \
		"$pid" "$launch_starttime" "$new_token" "$target_if_input" "$backend_input" \
		"$route_mode_override" "$mwan3_member_override" "$autotune_profile" "$start_conservative")"
	atomic_write "$pid_file" "$worker_identity" || {
		[ "$(proc_starttime "$pid" 2>/dev/null)" = "$launch_starttime" ] &&
			kill -TERM "$pid" 2>/dev/null || true
		json_error "Unable to publish the Full Auto-Tune worker identity."
	}
	cat "$status_file"
}

status_job() {
	# A verified live owner is authoritative.  Otherwise an armed recovery
	# journal outranks every settled-looking result/error: accepting that result
	# before runtime restoration is exactly how stale calibration escaped.
	if [ -s "$pid_file" ] && worker_identity_matches; then
		if worker_request_matches any; then
			cat "$status_file" 2>/dev/null || printf '{"state":"running","phase":"starting","progress":0}\n'
			return 0
		fi
		json_error "A different Full Auto-Tune request is running for this instance; its status was not attached to this uplink."
	fi
	if job_recovery_pending; then
		printf '{"state":"recovery-pending","recovery_pending":true,"auto_apply_eligible":false,"manual_apply_eligible":false,"error":"Full Auto-Tune runtime restoration is still pending; any settled result is withheld."}\n'
		return 0
	fi
	if [ -s "$result_file" ]; then
		emit_saved_terminal "$result_file"
	elif [ -s "$error_file" ]; then
		emit_saved_terminal "$error_file"
	elif [ -s "$pid_file" ]; then
		printf '{"state":"failed","error":"Autotune worker identity is stale or the worker exited without a result."}\n'
	else
		printf '{"state":"idle"}\n'
	fi
}

history_job() {
	printf '{"state":"ready","schema_version":1,"runs":['
	history_first=1
	if [ -d "$history_dir" ] && [ ! -L "$history_dir" ] &&
	   runtime_lock_path_owned_by_euid "$history_dir"; then
		for history_candidate in $(find "$history_dir" -mindepth 1 -maxdepth 1 -type d 2>/dev/null |
			LC_ALL=C sort -r); do
			history_meta="$history_candidate/meta"
			owned_regular_file "$history_meta" || continue
			history_run_id="$(sed -n 's/^run_id=//p' "$history_meta")"
			history_state="$(sed -n 's/^state=//p' "$history_meta")"
			history_epoch="$(sed -n 's/^completed_epoch=//p' "$history_meta")"
			case "$history_run_id" in ''|*[!A-Za-z0-9_-]*) continue ;; esac
			case "$history_state" in
				complete|failed|inconclusive|background-blocked|cancelled|legacy|unknown) ;;
				*) continue ;;
			esac
			is_positive_uint "$history_epoch" || continue
			[ "$history_first" = 1 ] || printf ','
			printf '{"run_id":"%s","state":"%s","completed_epoch":%s}' \
				"$(json_escape "$history_run_id")" "$(json_escape "$history_state")" "$history_epoch"
			history_first=0
		done
	fi
	printf ']}\n'
}

attest_job() {
	# Unlike status, this path never replays result.json. It recomputes both the
	# complete managed UCI fingerprint and the selected route/external address
	# immediately before LuCI stages a reviewed proposal.
	if [ -s "$pid_file" ]; then
		json_error "Full Auto-Tune state is not settled; live attestation is unavailable."
	fi
	job_recovery_pending &&
		json_error "Full Auto-Tune recovery is pending; live attestation is unavailable."
	mkdir -p "$job_dir" || json_error "Unable to create the Full Auto-Tune attestation directory."
	[ -d "$job_dir" ] && [ ! -L "$job_dir" ] || json_error "Unsafe Full Auto-Tune attestation directory."
	chmod 700 "$job_dir" 2>/dev/null || true

	attest_fingerprint_before="$(compute_config_fingerprint)" ||
		json_error "Unable to recompute the managed UCI configuration fingerprint."
	attest_route="$(CAKE_AUTORATE_ROUTE_STATUS_TIMEOUT_S=5 \
		"$speedtest_bin" "$job_name" "$target_if_input" route-status "${backend:-auto}" "" \
		"${route_mode_override:-}" "${mwan3_member_override:-}" 2>/dev/null)" ||
		json_error "Unable to attest the currently selected uplink route."
	attest_fingerprint_after="$(compute_config_fingerprint)" ||
		json_error "Unable to confirm the managed UCI configuration fingerprint."
	[ "$attest_fingerprint_before" = "$attest_fingerprint_after" ] ||
		json_error "Managed UCI configuration changed during live attestation."
	[ "$(extract_json "$attest_route" '@.state')" = ready ] &&
		[ "$(extract_json "$attest_route" '@.schema_version')" = 1 ] ||
		json_error "The route helper returned an invalid attestation."

	attest_target="$(extract_json "$attest_route" '@.target_interface')"
	attest_resolved="$(extract_json "$attest_route" '@.resolved_interface')"
	attest_route_if="$(extract_json "$attest_route" '@.route_interface')"
	attest_mode="$(extract_json "$attest_route" '@.route_mode')"
	attest_member="$(extract_json "$attest_route" '@.mwan3_member')"
	attest_source_ip="$(extract_json "$attest_route" '@.source_ip')"
	attest_external_ip="$(extract_json "$attest_route" '@.external_ip')"
	attest_identity="$(extract_json "$attest_route" '@.route_identity')"
	[ -n "$attest_target" ] && [ -n "$attest_resolved" ] && [ -n "$attest_route_if" ] &&
		[ -n "$attest_source_ip" ] && [ -n "$attest_external_ip" ] && [ -n "$attest_identity" ] ||
		json_error "The route helper returned incomplete identity fields."
	case "$attest_mode" in main) [ -z "$attest_member" ] || json_error "Main-route attestation unexpectedly names an mwan3 member." ;;
		mwan3) [ -n "$attest_member" ] || json_error "mwan3 attestation returned no member." ;;
		*) json_error "The route helper returned an invalid route mode." ;;
	esac

	printf '{"state":"ready","schema_version":1,"config_fingerprint":"%s","target_interface":"%s","resolved_interface":"%s","route_interface":"%s","route_mode":"%s","mwan3_member":"%s","source_ip":"%s","external_ip":"%s","route_identity":"%s"}\n' \
		"$(json_escape "$attest_fingerprint_before")" "$(json_escape "$attest_target")" \
		"$(json_escape "$attest_resolved")" "$(json_escape "$attest_route_if")" \
		"$(json_escape "$attest_mode")" "$(json_escape "$attest_member")" \
		"$(json_escape "$attest_source_ip")" "$(json_escape "$attest_external_ip")" \
		"$(json_escape "$attest_identity")"
}

cancel_job() {
	if [ -s "$pid_file" ]; then
		if worker_identity_matches; then
			pid="$identity_pid"
			: > "$cancel_file"
			write_status cancelling 0 "Cancelling Full Auto-Tune and restoring temporary speed-test/SQM state"
			kill -TERM "$pid" 2>/dev/null || true
			cat "$status_file"
			return 0
		fi
	fi
	printf '{"state":"idle"}\n'
}

if [ "${CAKE_AUTORATE_AUTOTUNE_SOURCE_ONLY:-0}" = 1 ]; then
	return 0 2>/dev/null || exit 0
fi

safe_job_name "$job_name" || json_error "Invalid autotune job name."
safe_interface_name "$target_if_input" || json_error "Invalid target interface."
resolve_autotune_profile || json_error "Unsupported Full Auto-Tune profile."
case "$conservative_override" in 0|1) ;; *) json_error "Invalid conservative Full Auto-Tune flag." ;; esac
job_paths
prepare_job_storage || json_error "Unsafe or foreign-owned Full Auto-Tune state directory."

case "$mode" in
	start) start_job 0 ;;
	start-conservative) start_job 1 ;;
	status) status_job ;;
	history) history_job ;;
	attest) attest_job ;;
	cancel) cancel_job ;;
	job-run) run_job ;;
	*) json_error "Unsupported autotune mode." ;;
esac
