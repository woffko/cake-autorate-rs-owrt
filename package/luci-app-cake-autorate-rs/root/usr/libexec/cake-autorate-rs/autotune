	validation_reasons_json="$(typed_json_fragment "$typed_validation_decision" reasons)"
	validation_correction_json="$(typed_json_fragment "$typed_validation_decision" correction)"
	[ -n "$validation_metrics_json" ] && [ -n "$validation_signals_json" ] &&
		[ -n "$validation_gates_json" ] && [ -n "$validation_reasons_json" ] &&
		[ -n "$validation_correction_json" ] || fail "Unable to preserve structured typed validation diagnostics."

	loaded_delta_ms="$(maximum_number "$dl_icmp_delta_ms" "$ul_icmp_delta_ms")"
	transport_loaded_delta_ms="$(maximum_number "$dl_transport_delta_ms" "$ul_transport_delta_ms")"
	loss_percent="$(maximum_number "$dl_loss_percent" "$ul_loss_percent")"
	cpu_peak="$(maximum_number "$dl_cpu_peak" "$ul_cpu_peak")"
	loaded_median_ms="$(maximum_number "$dl_loaded_median_ms" "$ul_loaded_median_ms")"
	loaded_p95_ms="$(maximum_number "$dl_loaded_p95_ms" "$ul_loaded_p95_ms")"
	loaded_max_ms="$(maximum_number "$dl_loaded_max_ms" "$ul_loaded_max_ms")"
	loaded_samples=$((dl_loaded_samples + ul_loaded_samples))
	transport_loaded_median_ms="$(maximum_number "$dl_transport_median_ms" "$ul_transport_median_ms")"
	transport_loaded_p95_ms="$(maximum_number "$dl_transport_p95_ms" "$ul_transport_p95_ms")"
	transport_loaded_max_ms="$(maximum_number "$dl_transport_max_ms" "$ul_transport_max_ms")"
	transport_loaded_samples=$((dl_transport_samples + ul_transport_samples))
	validation_json="{\"profile\":\"$(json_escape "$autotune_profile")\",\"pass\":$validation_pass,\"hard_pass\":$validation_hard_pass,\"quality_target_met\":$validation_quality_target_met,\"actual_grade\":\"$(json_escape "$validation_actual_grade")\",\"contaminated\":$validation_contaminated,\"score\":$validation_score,\"metrics\":$validation_metrics_json,\"signals\":$validation_signals_json,\"gates\":$validation_gates_json,\"reasons\":$validation_reasons_json,\"correction\":$validation_correction_json,\"candidate_base\":{\"download_kbps\":$dl_base,\"upload_kbps\":$ul_base},\"throughput\":{\"download_kbps\":$shaped_dl,\"upload_kbps\":$shaped_ul,\"download_candidate_realization_percent\":$dl_candidate_realization,\"upload_candidate_realization_percent\":$ul_candidate_realization,\"download_capacity_retention_percent\":$dl_retention,\"upload_capacity_retention_percent\":$ul_retention,\"comparison\":\"observed-low\"},\"direction_phases\":{\"download\":$download_phase_observation_json,\"upload\":$upload_phase_observation_json},\"latency\":{\"median_ms\":$loaded_median_ms,\"p95_ms\":$loaded_p95_ms,\"max_ms\":$loaded_max_ms,\"delta_p95_ms\":$loaded_delta_ms,\"samples\":$loaded_samples,\"loss_percent\":$loss_percent},\"transport_latency\":{\"backend\":\"$(json_escape "$transport_probe_backend")\",\"endpoint\":\"$(json_escape "$transport_probe_endpoint")\",\"median_ms\":$transport_loaded_median_ms,\"p95_ms\":$transport_loaded_p95_ms,\"max_ms\":$transport_loaded_max_ms,\"delta_p95_ms\":$transport_loaded_delta_ms,\"samples\":$transport_loaded_samples},\"effective_delta_ms\":$effective_loaded_delta_ms,\"cpu_peak_percent\":$cpu_peak,\"server_id\":\"$(json_escape "$selected_server_id")\",\"decision\":$typed_validation_decision}"
}

journal_value() {
	journal_key="$1"
	[ -f "${recovery_journal:-}" ] && [ ! -L "$recovery_journal" ] || return 1
	awk -v key="$journal_key" '
		index($0, key "=") == 1 {
			count++
			value = substr($0, length(key) + 2)
		}
		END {
			if (count != 1) exit 1
			print value
		}
	' "$recovery_journal"
}

read_journalled_active_test() {
	journal_test_pgid="$(journal_value active_test_pgid 2>/dev/null)" || return 1
	journal_test_starttime="$(journal_value active_test_starttime 2>/dev/null)" || return 1
	case "$journal_test_pgid:$journal_test_starttime" in
		:) return 0 ;;
		*:*)
			is_positive_uint "$journal_test_pgid" && is_positive_uint "$journal_test_starttime" || return 1
			[ "$journal_test_pgid" != "$$" ] || return 1
			return 0
			;;
		*) return 1 ;;
	esac
}

terminate_journalled_active_test() {
	read_journalled_active_test || return 1
	[ -n "$journal_test_pgid" ] || return 0
	recovery_active_test_pgid="$journal_test_pgid"
	recovery_active_test_starttime="$journal_test_starttime"
	test_termination_grace_s="${CAKE_AUTORATE_AUTOTUNE_SPEEDTEST_TERM_GRACE_S:-3}"
	case "$test_termination_grace_s" in ''|*[!0-9]*) test_termination_grace_s=3 ;; esac
	[ "$test_termination_grace_s" -ge 1 ] 2>/dev/null || test_termination_grace_s=3
	[ "$test_termination_grace_s" -le 10 ] 2>/dev/null || test_termination_grace_s=10

	if process_group_contains_session "$journal_test_pgid"; then
		signal_test_group_until_gone "$journal_test_pgid" "$journal_test_starttime" || return 1
	fi
	# Cancellation can interrupt the child before exec(setsid).  In that narrow
	# state it is still a member of the owner's isolated group, so signal only
	# the exact PID/starttime recorded before CONT.
	if [ "$(proc_starttime "$journal_test_pgid" 2>/dev/null)" = "$journal_test_starttime" ]; then
		case "$(proc_state "$journal_test_pgid" 2>/dev/null)" in
			''|Z|z) ;;
			*)
				kill -TERM "$journal_test_pgid" 2>/dev/null || true
				cleanup_wait=0
				while [ "$cleanup_wait" -lt "$test_termination_grace_s" ] &&
				      [ "$(proc_starttime "$journal_test_pgid" 2>/dev/null)" = "$journal_test_starttime" ] &&
				      ! { case "$(proc_state "$journal_test_pgid" 2>/dev/null)" in ''|Z|z) true ;; *) false ;; esac; }; do
					cleanup_wait=$((cleanup_wait + 1))
					sleep 1
				done
				if [ "$(proc_starttime "$journal_test_pgid" 2>/dev/null)" = "$journal_test_starttime" ]; then
					case "$(proc_state "$journal_test_pgid" 2>/dev/null)" in
						''|Z|z) ;;
						*) kill -KILL "$journal_test_pgid" 2>/dev/null || true ;;
					esac
				fi
				cleanup_wait=0
				while [ "$cleanup_wait" -lt 3 ] &&
				      [ "$(proc_starttime "$journal_test_pgid" 2>/dev/null)" = "$journal_test_starttime" ]; do
					case "$(proc_state "$journal_test_pgid" 2>/dev/null)" in
						''|Z|z) break ;;
					esac
					cleanup_wait=$((cleanup_wait + 1))
					sleep 1
				done
				;;
		esac
	fi
	process_group_contains_session "$journal_test_pgid" && return 1
	if [ "$(proc_starttime "$journal_test_pgid" 2>/dev/null)" = "$journal_test_starttime" ]; then
		case "$(proc_state "$journal_test_pgid" 2>/dev/null)" in ''|Z|z) ;; *) return 1 ;; esac
	fi
	return 0
}

owner_session_has_live_children() {
	for proc_dir in /proc/[0-9]*; do
		[ -r "$proc_dir/stat" ] || continue
		member_pid="${proc_dir#/proc/}"
		[ "$member_pid" != "$$" ] || continue
		case "$(proc_state "$member_pid" 2>/dev/null)" in ''|Z|z) continue ;; esac
		[ "$(proc_group "$member_pid" 2>/dev/null)" = "$$" ] || continue
		[ "$(proc_session "$member_pid" 2>/dev/null)" = "$$" ] || continue
		return 0
	done
	return 1
}

signal_owner_session_children() {
	owner_signal="$1"
	for proc_dir in /proc/[0-9]*; do
		[ -r "$proc_dir/stat" ] || continue
		member_pid="${proc_dir#/proc/}"
		[ "$member_pid" != "$$" ] || continue
		case "$(proc_state "$member_pid" 2>/dev/null)" in ''|Z|z) continue ;; esac
		[ "$(proc_group "$member_pid" 2>/dev/null)" = "$$" ] || continue
		[ "$(proc_session "$member_pid" 2>/dev/null)" = "$$" ] || continue
		kill "-$owner_signal" "$member_pid" 2>/dev/null || true
	done
}

terminate_owner_session_children() {
	owner_session_has_live_children || return 0
	signal_owner_session_children TERM
	sleep 1
	owner_session_has_live_children || return 0
	signal_owner_session_children KILL
	sleep 1
	! owner_session_has_live_children
}

clear_terminated_active_test_journal() {
	read_journalled_active_test || return 1
	[ -n "$journal_test_pgid" ] || return 0
	process_group_contains_session "$journal_test_pgid" && return 1
	if [ "$(proc_starttime "$journal_test_pgid" 2>/dev/null)" = "$journal_test_starttime" ]; then
		case "$(proc_state "$journal_test_pgid" 2>/dev/null)" in ''|Z|z) ;; *) return 1 ;; esac
	fi
	recovery_active_test_pgid="$journal_test_pgid"
	recovery_active_test_starttime="$journal_test_starttime"
	clear_active_test_journal
}

worker_cleanup() {
	worker_rc="$1"
	[ "${cleanup_started:-0}" = 0 ] || return 0
	cleanup_started=1
	trap - 0
	trap '' INT TERM HUP
	[ -n "${recovery_heartbeat:-}" ] && [ -e "$recovery_heartbeat" ] && recovery_armed=1
	[ "${recovery_armed:-0}" = 1 ] &&
		write_status restoring 98 "Restoring and verifying SQM, autorate, and temporary calibration state" || true

	# No qdisc, nftables, SQM, or autorate mutation is allowed until every
	# journalled test and every monitor in the owner's session is proved gone.
	cleanup_runtime_ok=1
	if [ "${recovery_armed:-0}" = 1 ] && ! terminate_journalled_active_test; then
		cleanup_runtime_ok=0
	fi
	rm -f "${cpu_marker:-}" "${latency_marker:-}"
	stop_transport_latency_monitor || cleanup_runtime_ok=0
	terminate_owner_session_children || cleanup_runtime_ok=0
	if [ "${recovery_armed:-0}" = 1 ] && ! clear_terminated_active_test_journal; then
		cleanup_runtime_ok=0
	fi
	if [ "$cleanup_runtime_ok" = 1 ]; then
		cleanup_phase_background_counter
		cleanup_stale_phase_background_tables >/dev/null 2>&1 || true
		restore_temp_shaper || cleanup_runtime_ok=0
	fi

	if [ ! -s "$pending_result_file" ] && [ ! -s "$pending_error_file" ]; then
		if [ "$worker_rc" -eq 130 ] || [ -e "$cancel_file" ]; then
			stage_terminal_json error "{\"state\":\"cancelled\",\"schema_version\":5,\"stage\":\"$(json_escape "${current_phase:-unknown}")\",\"error\":\"Full Auto-Tune was cancelled; no configuration was written.\",\"auto_apply_eligible\":false,\"manual_apply_eligible\":false,\"configuration_written\":false}" || true
		else
			stage_terminal_json error "{\"state\":\"failed\",\"schema_version\":5,\"stage\":\"$(json_escape "${current_phase:-unknown}")\",\"error\":\"Full Auto-Tune worker exited without a complete diagnostic result.\",\"auto_apply_eligible\":false,\"manual_apply_eligible\":false,\"configuration_written\":false}" || true
		fi
	fi

	if [ "${recovery_armed:-0}" = 1 ]; then
		if [ "$cleanup_runtime_ok" = 1 ] && "$recovery_bin" finalize "$recovery_journal"; then
			recovery_armed=0
			publish_staged_terminal || true
		else
			# Keep pending diagnostics private.  The helper's recovery-failed
			# result, armed journal, and interface lock remain authoritative for
			# the detached watcher/procd retry after this owner exits.
			rm -f "$status_file"
		fi
	else
		# No network mutation is allowed before the heartbeat is armed.
		if release_autotune_interface_lock; then
			[ -z "${recovery_sqm_config_snapshot:-}" ] || rm -f "$recovery_sqm_config_snapshot" 2>/dev/null || true
			[ -n "${recovery_journal:-}" ] && rm -f "$recovery_journal" "${recovery_journal}.cleanup-done" 2>/dev/null || true
			publish_staged_terminal || true
		else
			# Keep the prepared journal for dead-owner garbage collection if a
			# partial lock reservation could not be removed synchronously.
			rm -f "$status_file"
		fi
	fi
	remove_own_worker_identity
	return 0
}

