#!/bin/sh /etc/rc.common

START=96
STOP=10
USE_PROCD=1

start_service() {
	procd_open_instance scheduler
	procd_set_param command /usr/libexec/cake-autorate-rs/autotune-scheduler run
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance

	# procd keeps this process outside every Full Auto-Tune worker process
	# group.  It is the durable fallback when both a worker and its optional
	# detached fast-path watcher are killed without running EXIT traps.
	procd_open_instance recovery
	procd_set_param command /usr/libexec/cake-autorate-rs/autotune-recover monitor /tmp/cake-autorate-autotune/recovery
	procd_set_param respawn 60 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}
