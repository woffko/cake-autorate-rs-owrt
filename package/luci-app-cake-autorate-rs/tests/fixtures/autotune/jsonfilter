		printf '%s\n' "$input" | awk -F '"state":"' '
			NF > 1 {
				value = $2
				sub(/".*/, "", value)
				print value
				exit
			}
		'
		;;
	'@.error')
		printf '%s\n' "$input" | sed -n 's/.*"error":"\([^"]*\)".*/\1/p'
		;;
