#!/bin/sh /etc/rc.common

START=98
STOP=10
USE_PROCD=1

CONFIG="cake-autorate"
PUBLISHER="/usr/libexec/cake-autorate-rs/mqtt-publisher"

start_mqtt_instance() {
	local section="$1"
	local enabled

	config_get_bool enabled "$section" mqtt_enabled 0
	[ "$enabled" -eq 1 ] || return 0

	procd_open_instance "$section"
	procd_set_param command "$PUBLISHER" "$section"
	procd_set_param respawn
	procd_close_instance
}

start_service() {
	[ -x "$PUBLISHER" ] || return 1

	config_load "$CONFIG"
	config_foreach start_mqtt_instance cake_autorate
}

service_triggers() {
	procd_add_reload_trigger "$CONFIG"
}
