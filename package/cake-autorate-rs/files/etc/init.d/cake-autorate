#!/bin/sh /etc/rc.common

START=97
STOP=4
USE_PROCD=1
EXTRA_COMMANDS="recover_interface"
EXTRA_HELP="\trecover_interface <mwan3-member>\tStart a member instance that was unavailable at boot"

CONFIG="cake-autorate"
SQM_CONFIG="sqm"
DAEMON="/usr/sbin/cake-autorated"
SQM_MANAGED=0
CAKE_CONFIG_CHANGED=0
SQM_INTERFACES=""
SQM_CONFLICT_FILE="${CAKE_AUTORATE_SQM_CONFLICT_FILE:-/var/run/cake-autorate/sqm-conflicts}"
BRIDGER_CONFIG_CHANGED=0

set_cake_option_if_changed() {
	local section="$1"
	local option="$2"
	local value="$3"
	local current

	config_get current "$section" "$option"
	[ "$current" = "$value" ] && return 0

	uci set "$CONFIG.$section.$option=$value"
	CAKE_CONFIG_CHANGED=1
}

set_cake_option_if_empty() {
	local section="$1"
	local option="$2"
	local value="$3"
	local current

	[ -n "$value" ] || return 0

	config_get current "$section" "$option"
	[ -n "$current" ] && return 0

	uci set "$CONFIG.$section.$option=$value"
	CAKE_CONFIG_CHANGED=1
}

half_rate_kbps() {
	local value="$1"

	case "$value" in
		''|*[!0-9]*)
			printf '%s\n' "$value"
			;;
		*)
			printf '%s\n' $(( (value + 1) / 2 ))
			;;
	esac
}

resolve_interface_device() {
	local name="$1"
	local status dev

	[ -n "$name" ] || return 1

	if [ -e "/sys/class/net/$name" ]; then
		printf '%s\n' "$name"
		return 0
	fi

	status="$(ubus call network.interface."$name" status 2>/dev/null)"
	if [ -n "$status" ] && command -v jsonfilter >/dev/null 2>&1; then
		dev="$(printf '%s\n' "$status" | jsonfilter -e '@.l3_device' 2>/dev/null)"
		[ -n "$dev" ] || dev="$(printf '%s\n' "$status" | jsonfilter -e '@.device' 2>/dev/null)"

		if [ -n "$dev" ] && [ -e "/sys/class/net/$dev" ]; then
			printf '%s\n' "$dev"
			return 0
		fi
	fi

	printf '%s\n' "$name"
}

sync_interface_preset_instance() {
	local section="$1"
	local auto wan

	config_get_bool auto "$section" auto_interface_preset 1
	[ "$auto" -eq 1 ] || return 0

	config_get wan "$section" wan_if
	[ -n "$wan" ] || config_get wan "$section" sqm_interface
	[ -n "$wan" ] || config_get wan "$section" ul_if
	[ -n "$wan" ] || return 0
	wan="$(resolve_interface_device "$wan")"

	set_cake_option_if_changed "$section" wan_if "$wan"
	set_cake_option_if_changed "$section" sqm_interface "$wan"
	set_cake_option_if_changed "$section" ul_if "$wan"
	set_cake_option_if_changed "$section" dl_if "ifb4$wan"
}

sync_rate_preset_instance() {
	local section="$1"
	local manual dl ul

	config_get_bool manual "$section" manual_rate_limits 0
	[ "$manual" -eq 0 ] || return 0

	config_get dl "$section" sqm_download
	[ -n "$dl" ] || config_get dl "$section" base_dl_shaper_rate_kbps
	if [ -n "$dl" ]; then
		set_cake_option_if_empty "$section" base_dl_shaper_rate_kbps "$dl"
		set_cake_option_if_empty "$section" max_dl_shaper_rate_kbps "$dl"
		set_cake_option_if_empty "$section" min_dl_shaper_rate_kbps "$(half_rate_kbps "$dl")"
	fi

	config_get ul "$section" sqm_upload
	[ -n "$ul" ] || config_get ul "$section" base_ul_shaper_rate_kbps
	if [ -n "$ul" ]; then
		set_cake_option_if_empty "$section" base_ul_shaper_rate_kbps "$ul"
		set_cake_option_if_empty "$section" max_ul_shaper_rate_kbps "$ul"
		set_cake_option_if_empty "$section" min_ul_shaper_rate_kbps "$(half_rate_kbps "$ul")"
	fi
}

migrate_legacy_route_instance() {
	local section="$1"
	local mode member prefix parsed

	config_get mode "$section" route_mode auto
	config_get member "$section" mwan3_member
	config_get prefix "$section" ping_prefix_string
	[ -n "$prefix" ] || return 0

	parsed="$(printf '%s\n' "$prefix" | awk '
		NF == 4 && $1 == "mwan3" && $2 == "use" && $4 == "exec" &&
		$3 ~ /^[A-Za-z0-9_.:@-]+$/ { print $3 }')"
	[ -n "$parsed" ] || return 0

	if [ "$mode" = auto ] && [ -z "$member" ]; then
		set_cake_option_if_changed "$section" route_mode mwan3
		set_cake_option_if_changed "$section" mwan3_member "$parsed"
		uci -q delete "$CONFIG.$section.ping_prefix_string"
		CAKE_CONFIG_CHANGED=1
		logger -t cake-autorate "migrated legacy mwan3 ping prefix for instance '$section' to structured member '$parsed'"
	elif [ "$mode" = mwan3 ] && [ "$member" = "$parsed" ]; then
		uci -q delete "$CONFIG.$section.ping_prefix_string"
		CAKE_CONFIG_CHANGED=1
	fi
}

sync_interface_presets() {
	CAKE_CONFIG_CHANGED=0
	config_foreach migrate_legacy_route_instance cake_autorate
	config_foreach sync_interface_preset_instance cake_autorate
	config_foreach sync_rate_preset_instance cake_autorate
	[ "$CAKE_CONFIG_CHANGED" -eq 1 ] || return 0

	uci commit "$CONFIG"
	config_load "$CONFIG"
}

append_sqm_conflict() {
	local section="$1"

	grep -Fxq "$section" "$SQM_CONFLICT_FILE" 2>/dev/null || printf '%s\n' "$section" >> "$SQM_CONFLICT_FILE"
}

detect_managed_sqm_conflicts() {
	local section enabled manage_sqm sqm_enabled target pair previous_target previous_section seen=""

	mkdir -p "$(dirname "$SQM_CONFLICT_FILE")"
	: > "$SQM_CONFLICT_FILE"
	for section in $(uci -q show "$CONFIG" | sed -n "s/^$CONFIG\.\([^.]*\)=cake_autorate$/\1/p"); do
		config_get_bool enabled "$section" enabled 0
		config_get_bool manage_sqm "$section" manage_sqm 1
		config_get_bool sqm_enabled "$section" sqm_enabled "$enabled"
		[ "$enabled" -eq 1 ] && [ "$manage_sqm" -eq 1 ] && [ "$sqm_enabled" -eq 1 ] || continue

		config_get target "$section" sqm_interface
		[ -n "$target" ] || config_get target "$section" ul_if
		[ -n "$target" ] || config_get target "$section" wan_if
		[ -n "$target" ] || continue
		target="$(resolve_interface_device "$target")"

		for pair in $seen; do
			previous_target="${pair%%|*}"
			previous_section="${pair#*|}"
			[ "$previous_target" = "$target" ] || continue
			append_sqm_conflict "$previous_section"
			append_sqm_conflict "$section"
			logger -t cake-autorate "refusing duplicate managed shapers: instances '$previous_section' and '$section' both target '$target'"
		done
		seen="${seen:+$seen }$target|$section"
	done
}

section_has_sqm_conflict() {
	grep -Fxq "$1" "$SQM_CONFLICT_FILE" 2>/dev/null
}

set_sqm_option() {
	local section="$1"
	local option="$2"
	local value="$3"

	uci set "$SQM_CONFIG.$section.$option=$value"
}

set_sqm_optional_option() {
	local section="$1"
	local option="$2"
	local value="$3"

	if [ -n "$value" ]; then
		set_sqm_option "$section" "$option" "$value"
	else
		uci -q delete "$SQM_CONFIG.$section.$option"
	fi
}

append_sqm_interface() {
	local iface="$1"

	[ -n "$iface" ] || return 0
	case " $SQM_INTERFACES " in
		*" $iface "*) return 0 ;;
	esac

	SQM_INTERFACES="${SQM_INTERFACES:+$SQM_INTERFACES }$iface"
}

disable_unmanaged_sqm_conflicts() {
	local keep="$1"
	local target="$2"
	local candidate enabled iface owner

	for candidate in $(uci -q show "$SQM_CONFIG" | sed -n "s/^$SQM_CONFIG\.\([^.]*\)=queue$/\1/p"); do
		[ "$candidate" != "$keep" ] || continue

		enabled="$(uci -q get "$SQM_CONFIG.$candidate.enabled" 2>/dev/null)"
		[ "$enabled" = "1" ] || continue
		iface="$(uci -q get "$SQM_CONFIG.$candidate.interface" 2>/dev/null)"
		[ -n "$iface" ] || continue
		iface="$(resolve_interface_device "$iface")"
		[ "$iface" = "$target" ] || continue

		owner="$(uci -q get "$SQM_CONFIG.$candidate._cake_autorate_managed" 2>/dev/null)"
		if [ -n "$owner" ]; then
			logger -t cake-autorate "SQM conflict on '$target': managed queues '$keep' and '$candidate' cannot run on the same interface"
			continue
		fi

		uci set "$SQM_CONFIG.$candidate.enabled=0"
		logger -t cake-autorate "disabled conflicting unmanaged SQM queue '$candidate' on '$target'; CAKE Autorate manages '$keep'"
		SQM_MANAGED=1
	done
}

bridger_blacklist_contains() {
	local iface="$1"
	local current

	current="$(uci -q get bridger.@defaults[0].blacklist 2>/dev/null)"
	case " $current " in
		*" $iface "*) return 0 ;;
	esac

	return 1
}

sync_bridger_blacklist() {
	local iface

	BRIDGER_CONFIG_CHANGED=0
	[ -n "$SQM_INTERFACES" ] || return 0
	[ -x /etc/init.d/bridger ] || return 0
	uci -q get bridger.@defaults[0] >/dev/null || return 0

	for iface in $SQM_INTERFACES; do
		bridger_blacklist_contains "$iface" && continue
		uci add_list "bridger.@defaults[0].blacklist=$iface"
		logger -t cake-autorate "added SQM interface '$iface' to bridger blacklist"
		BRIDGER_CONFIG_CHANGED=1
	done

	[ "$BRIDGER_CONFIG_CHANGED" -eq 1 ] || return 0
	uci commit bridger
	/etc/init.d/bridger reload >/dev/null 2>&1 || true
}

remove_empty_clsact() {
	local iface="$1"
	local ingress_filters egress_filters

	command -v tc >/dev/null 2>&1 || return 0
	tc qdisc show dev "$iface" 2>/dev/null | grep -q '^qdisc clsact ' || return 0

	ingress_filters="$(tc filter show dev "$iface" ingress 2>/dev/null)"
	egress_filters="$(tc filter show dev "$iface" egress 2>/dev/null)"
	if [ -n "$ingress_filters$egress_filters" ]; then
		logger -t cake-autorate "cannot replace clsact on SQM interface '$iface': non-SQM tc filters are still attached"
		return 1
	fi

	if tc qdisc del dev "$iface" clsact >/dev/null 2>&1; then
		logger -t cake-autorate "removed empty clsact from SQM interface '$iface' before ingress setup"
		return 0
	fi

	logger -t cake-autorate "failed to remove empty clsact from SQM interface '$iface'"
	return 1
}

prepare_sqm_ingress_interfaces() {
	local iface

	sync_bridger_blacklist
	for iface in $SQM_INTERFACES; do
		remove_empty_clsact "$iface" || true
	done
}

cleanup_stale_sqm_sections() {
	local owner="$1"
	local keep="$2"
	local managed_section="cake_$owner"
	local changed=0 section

	for section in $(uci -q show "$SQM_CONFIG" | sed -n "s/^$SQM_CONFIG\\.\\([^.]*\\)\\._cake_autorate_managed='$owner'$/\\1/p"); do
		[ -n "$section" ] || continue
		[ "$section" = "$keep" ] && continue

		if [ "$section" = "$managed_section" ]; then
			uci -q delete "$SQM_CONFIG.$section"
		else
			uci -q delete "$SQM_CONFIG.$section._cake_autorate_managed"
		fi

		changed=1
	done

	[ "$changed" -eq 1 ]
}

sync_sqm_instance() {
	local section="$1"
	local manage_sqm enabled sqm_enabled sqm_section value

	config_get_bool manage_sqm "$section" manage_sqm 1
	if [ "$manage_sqm" -ne 1 ]; then
		if cleanup_stale_sqm_sections "$section" ""; then
			SQM_MANAGED=1
		fi

		return 0
	fi

	config_get_bool enabled "$section" enabled 0
	config_get_bool sqm_enabled "$section" sqm_enabled "$enabled"
	if section_has_sqm_conflict "$section"; then
		config_get sqm_section "$section" sqm_section "cake_$section"
		if uci -q get "$SQM_CONFIG.$sqm_section" >/dev/null; then
			set_sqm_option "$sqm_section" enabled 0
			SQM_MANAGED=1
		fi
		cleanup_stale_sqm_sections "$section" ""
		return 0
	fi
	if [ "$enabled" -ne 1 ] || [ "$sqm_enabled" -ne 1 ]; then
		config_get sqm_section "$section" sqm_section "cake_$section"
		if uci -q get "$SQM_CONFIG.$sqm_section" >/dev/null; then
			set_sqm_option "$sqm_section" enabled 0
			SQM_MANAGED=1
		fi

		if cleanup_stale_sqm_sections "$section" ""; then
			SQM_MANAGED=1
		fi

		return 0
	fi

	config_get sqm_section "$section" sqm_section "cake_$section"
	cleanup_stale_sqm_sections "$section" "$sqm_section"
	uci -q get "$SQM_CONFIG.$sqm_section" >/dev/null || uci set "$SQM_CONFIG.$sqm_section=queue"
	set_sqm_option "$sqm_section" "_cake_autorate_managed" "$section"
	set_sqm_option "$sqm_section" enabled "$sqm_enabled"

	config_get value "$section" sqm_interface
	[ -n "$value" ] || config_get value "$section" ul_if
	value="$(resolve_interface_device "$value")"
	set_sqm_option "$sqm_section" interface "$value"
	append_sqm_interface "$value"
	disable_unmanaged_sqm_conflicts "$sqm_section" "$value"

	config_get value "$section" sqm_download
	[ -n "$value" ] || config_get value "$section" base_dl_shaper_rate_kbps
	set_sqm_option "$sqm_section" download "$value"

	config_get value "$section" sqm_upload
	[ -n "$value" ] || config_get value "$section" base_ul_shaper_rate_kbps
	set_sqm_option "$sqm_section" upload "$value"

	config_get value "$section" sqm_debug_logging 0
	set_sqm_option "$sqm_section" debug_logging "$value"
	config_get value "$section" sqm_verbosity 5
	set_sqm_option "$sqm_section" verbosity "$value"
	config_get value "$section" sqm_qdisc cake
	set_sqm_option "$sqm_section" qdisc "$value"
	config_get value "$section" sqm_script piece_of_cake.qos
	set_sqm_option "$sqm_section" script "$value"
	config_get value "$section" sqm_qdisc_advanced 0
	set_sqm_option "$sqm_section" qdisc_advanced "$value"
	config_get value "$section" sqm_squash_dscp 1
	set_sqm_option "$sqm_section" squash_dscp "$value"
	config_get value "$section" sqm_squash_ingress 1
	set_sqm_option "$sqm_section" squash_ingress "$value"
	config_get value "$section" sqm_ingress_ecn ECN
	set_sqm_option "$sqm_section" ingress_ecn "$value"
	config_get value "$section" sqm_egress_ecn NOECN
	set_sqm_option "$sqm_section" egress_ecn "$value"
	config_get value "$section" sqm_qdisc_really_really_advanced 0
	set_sqm_option "$sqm_section" qdisc_really_really_advanced "$value"

	config_get value "$section" sqm_ilimit
	set_sqm_optional_option "$sqm_section" ilimit "$value"
	config_get value "$section" sqm_elimit
	set_sqm_optional_option "$sqm_section" elimit "$value"
	config_get value "$section" sqm_itarget
	set_sqm_optional_option "$sqm_section" itarget "$value"
	config_get value "$section" sqm_etarget
	set_sqm_optional_option "$sqm_section" etarget "$value"
	config_get value "$section" sqm_iqdisc_opts
	set_sqm_optional_option "$sqm_section" iqdisc_opts "$value"
	config_get value "$section" sqm_eqdisc_opts
	set_sqm_optional_option "$sqm_section" eqdisc_opts "$value"

	config_get value "$section" sqm_linklayer none
	set_sqm_option "$sqm_section" linklayer "$value"
	config_get value "$section" sqm_overhead 0
	set_sqm_option "$sqm_section" overhead "$value"
	config_get value "$section" sqm_linklayer_advanced 0
	set_sqm_option "$sqm_section" linklayer_advanced "$value"
	config_get value "$section" sqm_tcMTU 2047
	set_sqm_option "$sqm_section" tcMTU "$value"
	config_get value "$section" sqm_tcTSIZE 128
	set_sqm_option "$sqm_section" tcTSIZE "$value"
	config_get value "$section" sqm_tcMPU 0
	set_sqm_option "$sqm_section" tcMPU "$value"
	config_get value "$section" sqm_linklayer_adaptation_mechanism default
	set_sqm_option "$sqm_section" linklayer_adaptation_mechanism "$value"

	SQM_MANAGED=1
}

sync_sqm_config() {
	SQM_MANAGED=0
	SQM_INTERFACES=""
	config_foreach sync_sqm_instance cake_autorate
	[ "$SQM_MANAGED" -eq 1 ] || return 0
	uci commit "$SQM_CONFIG"
}

start_sqm_backend() {
	[ "$SQM_MANAGED" -eq 1 ] || return 0
	[ -x /etc/init.d/sqm ] || return 0

	/etc/init.d/sqm enable >/dev/null 2>&1 || true
	/etc/init.d/sqm restart >/dev/null 2>&1 || /etc/init.d/sqm start >/dev/null 2>&1 || true
}

managed_sqm_sections() {
	uci -q show "$SQM_CONFIG" | sed -n "s/^$SQM_CONFIG\\.\\([^.]*\\)\\._cake_autorate_managed=.*$/\\1/p" | sort -u
}

stop_managed_sqm_backend() {
	local sqm_section iface

	[ -x /usr/lib/sqm/run.sh ] || return 0

	for sqm_section in $(managed_sqm_sections); do
		iface="$(uci -q get "$SQM_CONFIG.$sqm_section.interface" 2>/dev/null)"
		[ -n "$iface" ] || continue
		iface="$(resolve_interface_device "$iface")"
		/usr/lib/sqm/run.sh stop "$iface" >/dev/null 2>&1 || true
	done
}

sqm_section_enabled_for_device() {
	local sqm_section="$1"
	local expected_if="$2"
	local enabled iface

	[ -n "$sqm_section" ] || return 1
	[ -n "$expected_if" ] || return 1

	enabled="$(uci -q get "$SQM_CONFIG.$sqm_section.enabled" 2>/dev/null)"
	[ "$enabled" = "1" ] || return 1

	iface="$(uci -q get "$SQM_CONFIG.$sqm_section.interface" 2>/dev/null)"
	[ -n "$iface" ] || return 1
	iface="$(resolve_interface_device "$iface")"

	[ "$iface" = "$expected_if" ]
}

instance_has_enabled_sqm_backing() {
	local section="$1"
	local target sqm_section candidate

	config_get target "$section" sqm_interface
	[ -n "$target" ] || config_get target "$section" ul_if
	[ -n "$target" ] || config_get target "$section" wan_if
	[ -n "$target" ] || return 1
	target="$(resolve_interface_device "$target")"

	config_get sqm_section "$section" sqm_section
	if [ -n "$sqm_section" ]; then
		sqm_section_enabled_for_device "$sqm_section" "$target"
		return $?
	fi

	for candidate in $(uci -q show "$SQM_CONFIG" | sed -n "s/^$SQM_CONFIG\\.\\([^.]*\\)=queue$/\\1/p"); do
		sqm_section_enabled_for_device "$candidate" "$target" && return 0
	done

	return 1
}

instance_has_interface_backing() {
	local section="$1"
	local dl rx enabled auto manage_sqm sqm_enabled target

	config_get rx "$section" rx_bytes_path
	[ -n "$rx" ] && return 0

	config_get dl "$section" dl_if
	case "$dl" in
		ifb*) ;;
		*) return 0 ;;
	esac

	config_get_bool auto "$section" auto_interface_preset 1
	[ "$auto" -eq 1 ] || return 0

	config_get_bool enabled "$section" enabled 0
	config_get_bool manage_sqm "$section" manage_sqm 1
	config_get_bool sqm_enabled "$section" sqm_enabled "$enabled"

	if [ "$manage_sqm" -eq 1 ] && [ "$sqm_enabled" -ne 1 ]; then
		logger -t cake-autorate "not starting instance '$section': auto_interface_preset selected dl_if '$dl', but SQM is disabled for this managed instance"
		return 1
	fi

	if ! instance_has_enabled_sqm_backing "$section"; then
		logger -t cake-autorate "not starting instance '$section': auto_interface_preset selected dl_if '$dl', but no enabled SQM backing queue is configured for this instance"
		return 1
	fi

	if [ ! -e "/sys/class/net/$dl" ]; then
		logger -t cake-autorate "not starting instance '$section': auto_interface_preset selected dl_if '$dl', but that IFB is not present after SQM startup"
		return 1
	fi

	config_get target "$section" sqm_interface
	[ -n "$target" ] || config_get target "$section" ul_if
	[ -n "$target" ] || config_get target "$section" wan_if
	target="$(resolve_interface_device "$target")"
	if command -v tc >/dev/null 2>&1 &&
	   ! tc filter show dev "$target" ingress 2>/dev/null | grep -Fq "$dl"; then
		logger -t cake-autorate "not starting instance '$section': IFB '$dl' exists but '$target' has no active ingress redirect to it (check duplicate SQM queues or bridger clsact)"
		return 1
	fi

	return 0
}

start_instance() {
	local section="$1"
	local enabled

	config_get_bool enabled "$section" enabled 0
	[ "$enabled" -eq 1 ] || return 0
	if section_has_sqm_conflict "$section"; then
		logger -t cake-autorate "not starting instance '$section': duplicate managed CAKE queue target"
		return 0
	fi
	instance_has_interface_backing "$section" || return 0

	procd_open_instance "$section"
	procd_set_param command "$DAEMON" --instance "$section"
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

start_service() {
	config_load "$CONFIG"
	sync_interface_presets
	detect_managed_sqm_conflicts
	sync_sqm_config
	prepare_sqm_ingress_interfaces
	start_sqm_backend
	config_foreach start_instance cake_autorate
	[ -x /etc/init.d/cake-autorate-mqtt ] && /etc/init.d/cake-autorate-mqtt restart >/dev/null 2>&1 || true
}

recover_interface() {
	local member="$1"
	local section configured enabled

	[ -n "$member" ] || return 0
	config_load "$CONFIG"
	for section in $(uci -q show "$CONFIG" | sed -n "s/^$CONFIG\.\([^.]*\)=cake_autorate$/\1/p"); do
		config_get configured "$section" mwan3_member
		[ "$configured" = "$member" ] || continue
		config_get_bool enabled "$section" enabled 0
		[ "$enabled" -eq 1 ] || continue
		pgrep -f "^$DAEMON --instance $section\$" >/dev/null 2>&1 && continue
		logger -t cake-autorate "mwan3 member '$member' recovered while instance '$section' was absent; reloading managed SQM and instances"
		reload_service
		return 0
	done
}

reload_service() {
	stop
	start
}

cleanup_runtime_files() {
	# Runtime status and graph history live only in tmpfs. Remove them whenever
	# the service is explicitly stopped so LuCI cannot show inactive instances.
	rm -f /var/run/cake-autorate/*/status.json \
		/var/run/cake-autorate/*/history.csv \
		/var/run/cake-autorate/*/history.csv.tmp 2>/dev/null || true
}

stop_service() {
	stop_managed_sqm_backend
}

service_stopped() {
	# procd_kill() returns before the terminated process is fully reaped. Give
	# the daemon a moment to stop so it cannot recreate status.json after the
	# cleanup, then remove all volatile runtime files synchronously.
	sleep 1
	cleanup_runtime_files
}

service_triggers() {
	local section member seen=""

	procd_add_reload_trigger "$CONFIG"
	procd_add_reload_trigger "$SQM_CONFIG"
	config_load "$CONFIG"
	for section in $(uci -q show "$CONFIG" | sed -n "s/^$CONFIG\.\([^.]*\)=cake_autorate$/\1/p"); do
		config_get member "$section" mwan3_member
		[ -n "$member" ] || continue
		case " $seen " in
			*" $member "*) continue ;;
		esac
		seen="${seen:+$seen }$member"
		procd_add_interface_trigger "interface.*.up" "$member" /etc/init.d/cake-autorate recover_interface "$member"
	done
}
