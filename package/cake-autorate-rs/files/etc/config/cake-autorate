config globals 'globals'
	# Fresh installations intentionally contain no autorate instance. Create the
	# first instance with the LuCI wizard; package upgrades preserve every
	# existing user-defined cake_autorate section.
	# Total RAM budget shared by every enabled graph-history instance. Use auto
	# to select a conservative value from MemAvailable, or one of the LuCI
	# presets from 256 KiB through 102400 KiB (100 MiB).
	option graph_history_ram_budget_kib 'auto'
