config cake_autorate 'primary'
	option enabled '0'

	# Interfaces and shaper control
	option wan_if 'wan'
	option auto_interface_preset '1'
	option dl_if 'ifb4wan'
	option ul_if 'wan'
	option adjust_dl_shaper_rate '1'
	option adjust_ul_shaper_rate '1'
	option min_dl_shaper_rate_kbps '5000'
	option base_dl_shaper_rate_kbps '20000'
	option max_dl_shaper_rate_kbps '80000'
	option min_ul_shaper_rate_kbps '5000'
	option base_ul_shaper_rate_kbps '20000'
	option max_ul_shaper_rate_kbps '35000'

	# SQM backend managed by this package. The LuCI package depends on
	# sqm-scripts and the init script mirrors these values to /etc/config/sqm.
	option manage_sqm '1'
	option sqm_section 'cake_primary'
	option sqm_enabled '0'
	option sqm_interface 'wan'
	option sqm_download '20000'
	option sqm_upload '20000'
	option sqm_debug_logging '0'
	option sqm_verbosity '5'
	option sqm_qdisc 'cake'
	option sqm_script 'piece_of_cake.qos'
	option sqm_qdisc_advanced '0'
	option sqm_squash_dscp '1'
	option sqm_squash_ingress '1'
	option sqm_ingress_ecn 'ECN'
	option sqm_egress_ecn 'NOECN'
	option sqm_qdisc_really_really_advanced '0'
	option sqm_ilimit ''
	option sqm_elimit ''
	option sqm_itarget ''
	option sqm_etarget ''
	option sqm_iqdisc_opts ''
	option sqm_eqdisc_opts ''
	option sqm_linklayer 'none'
	option sqm_overhead '0'
	option sqm_linklayer_advanced '0'
	option sqm_tcMTU '2047'
	option sqm_tcTSIZE '128'
	option sqm_tcMPU '0'
	option sqm_linklayer_adaptation_mechanism 'default'

	# Pinger backend. fping-ts/tsping use ICMP timestamp probes when reflectors support them.
	option pinger_method 'fping'
	list reflector '1.1.1.1'
	list reflector '1.0.0.1'
	list reflector '8.8.8.8'
	list reflector '8.8.4.4'
	list reflector '9.9.9.9'
	list reflector '9.9.9.10'
	option reflectors_url ''
	option reflectors_url_skip_lines '1'
	option randomize_reflectors '1'
	option retain_reflector_stats '1'
	option no_pingers '6'
	option reflector_ping_interval_s '0.3'

	# Delay thresholds
	option dl_avg_owd_delta_max_adjust_up_thr_ms '10.0'
	option ul_avg_owd_delta_max_adjust_up_thr_ms '10.0'
	option dl_owd_delta_delay_thr_ms '30.0'
	option ul_owd_delta_delay_thr_ms '30.0'
	option dl_avg_owd_delta_max_adjust_down_thr_ms '60.0'
	option ul_avg_owd_delta_max_adjust_down_thr_ms '60.0'

	# Idle, stall, and startup behavior
	option enable_sleep_function '1'
	option connection_active_thr_kbps '2000'
	option sustained_idle_sleep_thr_s '60.0'
	option min_shaper_rates_enforcement '0'
	option startup_wait_s '0.0'
	option global_ping_response_timeout_s '10.0'
	option if_up_check_interval_s '10.0'

	# Logging
	option output_processing_stats '0'
	option output_load_stats '0'
	option output_reflector_stats '0'
	option output_summary_stats '1'
	option output_cake_changes '0'
	option output_cpu_stats '0'
	option output_cpu_raw_stats '0'
	option debug '1'
	option log_DEBUG_messages_to_syslog '0'
	option log_to_file '1'
	option log_file_max_time_mins '10'
	option log_file_max_size_KB '2000'
	option log_file_path_override ''
	option log_file_buffer_size_B '512'
	option log_file_buffer_timeout_ms '500'
	option log_file_export_compress '1'

	# Advanced pinger options
	option ping_extra_args ''
	option ping_prefix_string ''
	option irtt_session_duration_m '10'

	# Monitoring intervals and detector windows
	option monitor_achieved_rates_interval_ms '200'
	option monitor_cpu_usage_interval_ms '2000'
	option bufferbloat_detection_window '6'
	option bufferbloat_detection_thr '3'
	option alpha_baseline_increase '0.001'
	option alpha_baseline_decrease '0.9'
	option alpha_delta_ewma '0.095'
	option shaper_rate_min_adjust_down_bufferbloat '0.99'
	option shaper_rate_max_adjust_down_bufferbloat '0.75'
	option shaper_rate_min_adjust_up_load_high '1.0'
	option shaper_rate_max_adjust_up_load_high '1.04'
	option shaper_rate_adjust_down_load_low '0.99'
	option shaper_rate_adjust_up_load_low '1.01'
	option high_load_thr '0.75'
	option bufferbloat_refractory_period_ms '300'
	option decay_refractory_period_ms '1000'
	option reflector_health_check_interval_s '1.0'
	option reflector_response_deadline_s '1.0'
	option reflector_misbehaving_detection_window '60'
	option reflector_misbehaving_detection_thr '3'
	option reflector_replacement_interval_mins '60'
	option reflector_comparison_interval_mins '1'
	option reflector_sum_owd_baselines_delta_thr_ms '20.0'
	option reflector_owd_delta_ewma_delta_thr_ms '10.0'
	option stall_detection_thr '5'
	option connection_stall_thr_kbps '10'

	# Optional direct counter paths. Leave empty for interface-derived defaults.
	option rx_bytes_path ''
	option tx_bytes_path ''
